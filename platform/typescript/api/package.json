{
  "name": "@ghatana/api",
  "version": "0.1.0",
  "description": "Fetch-based API client with middleware and retries for the Ghatana platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "api",
    "fetch",
    "http",
    "middleware"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
