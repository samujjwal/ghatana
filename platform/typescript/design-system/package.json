{
  "name": "@ghatana/design-system",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Design System components for Ghatana platform - WCAG AA compliant, Atomic Design",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./atoms/*": {
      "types": "./dist/atoms/*.d.ts",
      "import": "./dist/atoms/*.js"
    },
    "./molecules/*": {
      "types": "./dist/molecules/*.d.ts",
      "import": "./dist/molecules/*.js"
    },
    "./organisms/*": {
      "types": "./dist/organisms/*.d.ts",
      "import": "./dist/organisms/*.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    },
    "./privacy": {
      "types": "./dist/privacy/index.d.ts",
      "import": "./dist/privacy/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js"
    },
    "./voice": {
      "types": "./dist/voice/index.d.ts",
      "import": "./dist/voice/index.js"
    },
    "./nlp": {
      "types": "./dist/nlp/index.d.ts",
      "import": "./dist/nlp/index.js"
    },
    "./selection": {
      "types": "./dist/selection/index.d.ts",
      "import": "./dist/selection/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "@ghatana/accessibility": "workspace:*",
    "@ghatana/ds-schema": "workspace:*",
    "@ghatana/domain-components": "workspace:*",
    "@ghatana/platform-events": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "typedoc": "^0.28.18",
    "vitest": "catalog:"
  },
  "keywords": [
    "ghatana",
    "design-system",
    "components",
    "react",
    "wcag",
    "accessible",
    "atomic-design"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
