{
  "name": "@ghatana/data-grid",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Data grid with pagination, sorting, and filtering for Ghatana platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ghatana/platform-utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": ["ghatana", "data-grid", "table", "pagination"],
  "author": "Ghatana Platform Team",
  "license": "UNLICENSED",
  "private": true
}
