{
  "name": "@ghatana/platform-testing",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Shared testing utilities for Ghatana platform \u2014 accessibility helpers, performance matchers, and WCAG compliance test fixtures.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./accessibility": {
      "types": "./src/accessibility-testing.ts",
      "import": "./src/accessibility-testing.ts"
    },
    "./vitest-browser": {
      "types": "./src/vitest-browser.ts",
      "import": "./src/vitest-browser.ts"
    },
    "./builder-preview": {
      "types": "./src/builder-preview.ts",
      "import": "./src/builder-preview.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@testing-library/jest-dom": ">=6.0.0",
    "@testing-library/react": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
