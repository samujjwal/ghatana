{
  "name": "@ghatana/platform-testing",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Shared testing utilities for Ghatana platform \u2014 accessibility helpers, performance matchers, and WCAG compliance test fixtures.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./accessibility": {
      "types": "./src/accessibility-testing.ts",
      "import": "./src/accessibility-testing.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "@testing-library/react": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vitest": ">=2.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
