{
  "name": "@ghatana/realtime",
  "version": "0.1.0",
  "description": "WebSocket and SSE helpers for Ghatana realtime clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "realtime",
    "websocket",
    "sse"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
