{
  "name": "@ghatana/platform-typescript",
  "version": "1.0.0",
  "description": "Platform TypeScript packages for Ghatana",
  "private": true,
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "test": "pnpm --filter \"./packages/**\" test",
    "test:coverage": "pnpm --filter \"./packages/**\" test:coverage",
    "lint": "pnpm --filter \"./packages/**\" lint",
    "type-check": "pnpm --filter \"./packages/**\" type-check",
    "clean": "pnpm --filter \"./packages/**\" clean",
    "depcruise": "depcruise --config .dependency-cruiser.cjs --output-type text */src"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
