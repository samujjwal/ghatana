{
  "name": "@ghatana/state",
  "version": "1.0.0",
  "description": "Platform-level state management abstractions for Ghatana applications",
  "keywords": ["ghatana", "state", "jotai", "atoms", "platform"],
  "license": "UNLICENSED",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./atoms": {
      "types": "./dist/atoms.d.ts",
      "import": "./dist/atoms.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
    },
    "./machine": {
      "types": "./dist/machine.d.ts",
      "import": "./dist/machine.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jotai": "^2.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
