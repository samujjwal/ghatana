{
  "name": "@ghatana/kernel-product-contracts",
  "version": "1.0.0",
  "description": "Shared kernel product lifecycle contracts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./route": {
      "types": "./dist/route/index.d.ts",
      "import": "./dist/route/index.js"
    },
    "./policy": {
      "types": "./dist/policy/MobilePhiPolicyContract.d.ts",
      "import": "./dist/policy/MobilePhiPolicyContract.js"
    },
    "./mobile-privacy": {
      "types": "./dist/privacy/index.d.ts",
      "import": "./dist/privacy/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ]
}
