{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir":    "src",
    "outDir":     "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap":  true,
    "strict":     true,
    "target":     "ES2022",
    "module":     "ESNext",
    "moduleResolution": "bundler",
    "lib":        ["ES2022", "DOM"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
