{
  "name": "@ghatana/sso-client",
  "sideEffects": false,
  "version": "1.0.0",
  "description": "Cross-product SSO client for the Ghatana platform \u2014 reads platform JWT from OIDC redirect, provides isAuthenticated(), getUser(), login() and logout() helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ghatana",
    "sso",
    "auth",
    "jwt",
    "oidc",
    "platform"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
