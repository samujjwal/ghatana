{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES6"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@ghatana/privacy-ui": ["./privacy-ui/src"],
      "@ghatana/security-ui": ["./security-ui/src"],
      "@ghatana/voice-ui": ["./voice-ui/src"],
      "@ghatana/nlp-ui": ["./nlp-ui/src"],
      "@ghatana/audit-ui": ["./audit-ui/src"],
      "@ghatana/selection-ui": ["./selection-ui/src"]
    }
  },
  "include": [
    "*/src/**/*"
  ],
  "exclude": [
    "*/node_modules",
    "*/dist",
    "*/__tests__"
  ]
}
