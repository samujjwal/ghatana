{
  "name": "@ghatana/code-editor",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Monaco-based code editor component with lazy loading for YAPPC",
  "private": false,
  "license": "Proprietary",
  "types": "./dist/src/index.d.ts",
  "main": "./dist/src/index.js",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "monaco-editor": "^0.30.0"
  },
  "keywords": [
    "code-editor",
    "monaco",
    "lazy-loading",
    "react"
  ]
}
