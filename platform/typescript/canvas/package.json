{
  "name": "@ghatana/canvas",
  "version": "0.1.0",
  "description": "Ghatana Platform Canvas - Hybrid renderer (custom + ReactFlow) for all Ghatana products",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react/index.tsx",
    "./types": "./src/types/index.ts",
    "./core/canvas-renderer": "./src/core/canvas-renderer.ts",
    "./ui-builder": "./src/ui-builder/index.ts",
    "./plugins": "./src/plugins/index.ts",
    "./hybrid": "./src/hybrid/index.ts",
    "./topology": "./src/topology/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@preact/signals-core": "^1.12.2",
    "@xyflow/react": "^12.10.0",
    "dagre": "^0.8.5",
    "jotai": "^2.17.0",
    "lit": "^3.3.2",
    "nanoid": "^5.1.6",
    "rxjs": "^7.8.2",
    "yjs": "^13.6.29",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.53",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "canvas",
    "drawing",
    "diagram",
    "ghatana",
    "edgeless",
    "hybrid",
    "reactflow"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
