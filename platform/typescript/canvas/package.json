{
  "name": "@ghatana/canvas",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Ghatana Platform Canvas - Hybrid renderer (custom + ReactFlow) for all Ghatana products",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./core/canvas-renderer": {
      "types": "./dist/core/canvas-renderer.d.ts",
      "import": "./dist/core/canvas-renderer.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./hybrid": {
      "types": "./dist/hybrid/index.d.ts",
      "import": "./dist/hybrid/index.js"
    },
    "./topology": {
      "types": "./dist/topology/index.d.ts",
      "import": "./dist/topology/index.js"
    },
    "./core": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./coordinates": {
      "types": "./dist/coordinates/index.d.ts",
      "import": "./dist/coordinates/index.js"
    },
    "./chrome": {
      "types": "./dist/chrome.d.ts",
      "import": "./dist/chrome.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export/index.js"
    },
    "./collaboration": {
      "types": "./dist/collaboration/index.d.ts",
      "import": "./dist/collaboration/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./flow": {
      "types": "./dist/flow/index.d.ts",
      "import": "./dist/flow/index.js"
    },
    "./public": {
      "types": "./dist/public/index.d.ts",
      "import": "./dist/public/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/platform-events": "workspace:*",
    "@preact/signals-core": "^1.14.1",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "jotai": "^2.19.1",
    "lit": "^3.3.2",
    "nanoid": "^5.1.7",
    "rxjs": "^7.8.2",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.4",
    "jsdom": "^29.0.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "canvas",
    "drawing",
    "diagram",
    "ghatana",
    "edgeless",
    "hybrid",
    "reactflow"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
