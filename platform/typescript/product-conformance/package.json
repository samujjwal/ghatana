{
  "name": "@ghatana/product-conformance",
  "version": "1.0.0",
  "description": "Kernel-owned product conformance validation tools - schema, AST, and runtime checks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./ast": {
      "types": "./dist/ast/index.d.ts",
      "import": "./dist/ast/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js"
    },
    "./suite": {
      "types": "./dist/suite/index.d.ts",
      "import": "./dist/suite/index.js"
    },
    "./route-entitlements": {
      "types": "./dist/route-entitlements/index.d.ts",
      "import": "./dist/route-entitlements/index.js"
    },
    "./data-access": {
      "types": "./dist/data-access/index.d.ts",
      "import": "./dist/data-access/index.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency/index.d.ts",
      "import": "./dist/idempotency/index.js"
    },
    "./observability-flows": {
      "types": "./dist/observability-flows/index.d.ts",
      "import": "./dist/observability-flows/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
