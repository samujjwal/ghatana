{
  "name": "@ghatana/audio-video-client",
  "version": "0.1.0",
  "description": "HTTP clients for the Ghatana Audio-Video platform (STT, TTS, Vision)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/audio-video-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
