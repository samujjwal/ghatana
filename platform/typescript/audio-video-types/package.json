{
  "name": "@ghatana/audio-video-types",
  "version": "0.1.0",
  "description": "Shared TypeScript type definitions for Ghatana STT, TTS, and Vision services",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "audio-video",
    "stt",
    "tts",
    "vision",
    "types"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
