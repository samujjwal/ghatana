{
  "name": "@ghatana/ghatana-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Unified Ghatana Studio experience for ideation, blueprinting, development, lifecycle execution, deployment, health, learning, and evolution.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
