    "@ghatana/ds-registry": "workspace:*",
    "@ghatana/kernel-artifacts": "workspace:*",
    "@ghatana/kernel-deployment": "workspace:*",
    "@ghatana/kernel-product-contracts": "workspace:*",
    "@ghatana/kernel-release": "workspace:*",
    "@ghatana/i18n": "workspace:*",
    "@ghatana/platform-events": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "zod": "^3.23.8"
