    "@ghatana/tokens": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.14.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
