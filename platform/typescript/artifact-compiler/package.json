{
  "name": "@ghatana/artifact-compiler",
  "version": "0.1.0",
  "description": "Ghatana Artifact Compiler - Bidirectional product model extraction, synthesis, and round-trip code generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./inventory": {
      "types": "./dist/inventory/index.d.ts",
      "import": "./dist/inventory/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model/index.js"
    },
    "./provenance": {
      "types": "./dist/provenance/index.d.ts",
      "import": "./dist/provenance/index.js"
    },
    "./residual": {
      "types": "./dist/residual/index.d.ts",
      "import": "./dist/residual/index.js"
    },
    "./extractors": {
      "types": "./dist/extractors/index.d.ts",
      "import": "./dist/extractors/index.js"
    },
    "./synthesis": {
      "types": "./dist/synthesis/index.d.ts",
      "import": "./dist/synthesis/index.js"
    },
    "./merge": {
      "types": "./dist/merge/index.d.ts",
      "import": "./dist/merge/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ghatana/ds-registry": "workspace:*",
    "@ghatana/ds-schema": "workspace:*",
    "@ghatana/platform-events": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "ghatana",
    "artifact-compiler",
    "decompilation",
    "reverse-engineering",
    "code-extraction",
    "semantic-model"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
