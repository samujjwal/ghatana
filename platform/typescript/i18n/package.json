{
  "name": "@ghatana/i18n",
  "sideEffects": false,
  "version": "1.0.0",
  "description": "Shared internationalization framework for Ghatana React applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./locales/*": "./src/locales/*"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^26.0.3",
    "react-i18next": "^17.0.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
