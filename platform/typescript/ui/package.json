{
  "name": "@ghatana/ui",
  "version": "0.1.0",
  "description": "[DEPRECATED] Compatibility layer for Ghatana platform UI - Use @ghatana/design-system and @ghatana/ui-integration instead",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ghatana/design-system": "workspace:*",
    "@ghatana/ui-integration": "workspace:*",
    "@mui/material": "^7.3.7"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "ui",
    "compatibility",
    "deprecated",
    "react"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}
