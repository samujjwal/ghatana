{
  "name": "@ghatana/ui",
  "version": "0.1.0",
  "description": "Global UI component library for Ghatana platform - WCAG AA compliant, Atomic Design",
  "type": "module",
  "main": "./dist/ui/src/index.js",
  "types": "./dist/ui/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ui/src/index.d.ts",
      "import": "./dist/ui/src/index.js"
    },
    "./icons": {
      "types": "./dist/ui/src/icons/index.d.ts",
      "import": "./dist/ui/src/icons/index.js"
    },
    "./atoms/*": {
      "types": "./dist/ui/src/atoms/*.d.ts",
      "import": "./dist/ui/src/atoms/*.js"
    },
    "./molecules/*": {
      "types": "./dist/ui/src/molecules/*.d.ts",
      "import": "./dist/ui/src/molecules/*.js"
    },
    "./organisms/*": {
      "types": "./dist/ui/src/organisms/*.d.ts",
      "import": "./dist/ui/src/organisms/*.js"
    },
    "./hooks": {
      "types": "./dist/ui/src/hooks/index.d.ts",
      "import": "./dist/ui/src/hooks/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@ghatana/utils": "workspace:*",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-router-dom": "^6.20.0 || ^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "react-router-dom": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "ui",
    "components",
    "react",
    "design-system",
    "wcag",
    "accessible",
    "atomic-design"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}