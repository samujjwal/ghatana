{
  "name": "@ghatana/utils",
  "version": "0.1.0",
  "description": "Shared utility functions for Ghatana platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./formatters": {
      "types": "./dist/formatters.d.ts",
      "import": "./dist/formatters.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "import": "./dist/platform.js"
    },
    "./responsive": {
      "types": "./dist/responsive.d.ts",
      "import": "./dist/responsive.js"
    },
    "./accessibility": {
      "types": "./dist/accessibility.d.ts",
      "import": "./dist/accessibility.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ghatana",
    "utilities",
    "formatters",
    "helpers",
    "utils"
  ],
  "author": "Ghatana Team",
  "license": "MIT"
}