{
  "name": "@ghatana/canvas-core",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Ghatana Canvas Core — base types, element base classes, and bounds utilities",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "deprecated": "Use @ghatana/canvas directly. This package is a thin re-export facade.",
  "dependencies": {
    "@ghatana/canvas": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": ["ghatana", "canvas", "core"],
  "license": "MIT"
}
