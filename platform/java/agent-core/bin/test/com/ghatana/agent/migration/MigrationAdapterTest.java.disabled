    // ═════════════════════════════════════════════════════════════════════════
    // Stub / helper factories
    // ═════════════════════════════════════════════════════════════════════════

    /**
     * Lightweight in-test registry used to keep migration tests independent from
     * concrete runtime implementations now owned by aep-agent-runtime.
     */
    static final class TestAgentFrameworkRegistry implements AgentRegistry {

        private final Map<String, TypedAgent<?, ?>> agents = new HashMap<>();

        @Override
        public @NotNull Promise<Void> register(@NotNull TypedAgent<?, ?> agent, @NotNull AgentConfig config) {
            agents.put(agent.descriptor().getAgentId(), agent);
            return Promise.complete();
        }

        @Override
        public @NotNull Promise<Void> deregister(@NotNull String agentId) {
            agents.remove(agentId);
            return Promise.complete();
        }

        @Override
        @SuppressWarnings("unchecked")
        public @NotNull <I, O> Promise<Optional<TypedAgent<I, O>>> resolve(@NotNull String agentId) {
            TypedAgent<I, O> agent = (TypedAgent<I, O>) agents.get(agentId);
            return Promise.of(Optional.ofNullable(agent));
        }

        @Override
        public @NotNull Promise<Set<String>> listAgentIds() {
            return Promise.of(Set.copyOf(agents.keySet()));
        }

        @Override
        public @NotNull Promise<List<String>> findByCapability(@NotNull String capability) {
            List<String> matched = agents.entrySet().stream()
                    .filter(e -> e.getValue().descriptor().hasCapability(capability))
                    .map(Map.Entry::getKey)
                    .collect(Collectors.toList());
            return Promise.of(matched);
        }

        @Override
        public @NotNull Promise<Map<String, Object>> getStats() {
            Map<String, Object> stats = new LinkedHashMap<>();
            stats.put("registeredAgents", agents.size());
            return Promise.of(Collections.unmodifiableMap(stats));
        }
    }

    private TypedAgent<String, String> createStubTypedAgent(String id, String prefix) {
        return new TypedAgent<String, String>() {
            @Override
            public AgentDescriptor descriptor() {
                return new AgentDescriptor(id, AgentType.DETERMINISTIC, "1.0.0", prefix + ":");
            }

            @Override
            public Promise<AgentResult<String>> process(AgentContext ctx, String input) {
                return Promise.of(AgentResult.success(prefix + ":" + input));
            }

            @Override
            public Promise<Void> initialize(AgentConfig config) {
                return Promise.complete();
            }

            @Override
            public Promise<Void> shutdown() {
                return Promise.complete();
            }

            @Override
            public Promise<HealthStatus> healthCheck() {
                return Promise.of(HealthStatus.HEALTHY);
            }
        };
    }

    private BaseAgent<String, String> createBaseAgent(String id) {
        return new BaseAgent<>(id, (ctx, input) -> Promise.of(AgentResult.success("base:" + input))) {
            @Override
            protected Promise<AgentResult<String>> doProcess(AgentContext ctx, String input) {
                return Promise.of(AgentResult.success("base:" + input));
            }
        };
    }

    @SuppressWarnings("unused")
    private OrchestrationStrategy.Agent<String, String> createOrchestrationAgent(String id) {
        return null;
    }

    @SuppressWarnings("unused")
