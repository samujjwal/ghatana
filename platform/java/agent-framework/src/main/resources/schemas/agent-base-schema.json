{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghatana.com/schemas/agent/v2/agent-base.json",
  "title": "Ghatana Agent Base Specification",
  "description": "Base schema shared by all agent spec configurations (agent-spec.md v1.0.0, schema v2.0.0)",
  "type": "object",
  "properties": {
    "agentSpecVersion": {
      "type": "string",
      "description": "Version of the agent-spec.md schema being used",
      "default": "1.0.0"
    },
    "metadata": {
      "$ref": "#/$defs/SpecMetadata"
    },
    "identity": {
      "$ref": "#/$defs/SpecIdentity"
    },
    "purposeModel": {
      "$ref": "#/$defs/PurposeModel"
    },
    "scope": {
      "$ref": "#/$defs/SpecScope"
    },
    "capabilities": {
      "$ref": "#/$defs/SpecCapabilities"
    },
    "reasoningProfile": {
      "$ref": "#/$defs/ReasoningProfile"
    },
    "executionModel": {
      "$ref": "#/$defs/ExecutionModel"
    },
    "interfaces": {
      "$ref": "#/$defs/SpecInterfaces"
    },
    "memoryModel": {
      "$ref": "#/$defs/MemoryModel"
    },
    "toolsAndResources": {
      "$ref": "#/$defs/ToolsAndResources"
    },
    "governance": {
      "$ref": "#/$defs/GovernanceSpec"
    },
    "learningModel": {
      "$ref": "#/$defs/LearningModel"
    },
    "evaluation": {
      "$ref": "#/$defs/EvaluationModel"
    },
    "observability": {
      "$ref": "#/$defs/ObservabilitySpec"
    },
    "interoperability": {
      "$ref": "#/$defs/InteroperabilitySpec"
    },
    "security": {
      "$ref": "#/$defs/SecuritySpec"
    },
    "deployment": {
      "$ref": "#/$defs/DeploymentSpec"
    }
  },
  "required": ["metadata", "identity"],
  "additionalProperties": false,

  "$defs": {

    "SpecMetadata": {
      "type": "object",
      "description": "Agent metadata: identity, ownership, lifecycle state",
      "properties": {
        "id": {
          "type": "string",
          "description": "Globally unique stable agent identifier (e.g., agent.fraud-detector)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name"
        },
        "namespace": {
          "type": "string",
          "description": "Logical ownership boundary (e.g., yappc.core.knowledge)"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this spec"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated", "retired", "suspended"],
          "default": "active"
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "team": { "type": "string" },
              "role": { "type": "string" }
            }
          },
          "description": "Responsible teams/individuals"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Searchable classification labels"
        },
        "summary": {
          "type": "string",
          "description": "One-paragraph agent purpose description"
        },
        "description": {
          "type": "string",
          "description": "Longer-form functional narrative"
        }
      },
      "required": ["id", "name", "namespace", "version", "status", "summary"],
      "additionalProperties": false
    },

    "SpecIdentity": {
      "type": "object",
      "description": "Agent type classification and behavioral guarantees",
      "properties": {
        "agentType": {
          "type": "string",
          "enum": [
            "deterministic", "probabilistic", "stream-processor", "planning",
            "hybrid", "adaptive", "composite", "reactive", "custom"
          ],
          "description": "Primary processing paradigm (one canonical type per agent)"
        },
        "agentSubtype": {
          "type": "string",
          "description": "Refined subtype classification (e.g., rule-engine, llm, workflow)"
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Functional roles in the wider ecosystem"
        },
        "personas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Optional behavior profiles for different operating modes"
        },
        "criticality": {
          "type": "string",
          "enum": ["low", "medium", "high", "mission-critical"],
          "description": "Operational criticality driving validation depth and incident response"
        },
        "autonomyLevel": {
          "type": "string",
          "enum": ["advisory", "assisted", "semi-autonomous", "autonomous"],
          "description": "How much independent action the agent may take"
        },
        "determinismGuarantee": {
          "type": "string",
          "enum": ["full", "config-scoped", "none", "eventual"],
          "description": "Output reproducibility guarantee"
        },
        "stateMutability": {
          "type": "string",
          "enum": ["stateless", "local-state", "external-state", "hybrid-state"],
          "description": "How the agent manages mutable state across invocations"
        },
        "failureMode": {
          "type": "string",
          "enum": ["fail-fast", "retry", "fallback", "skip", "dead-letter", "circuit-breaker"],
          "description": "Default failure handling strategy"
        }
      },
      "required": ["agentType", "roles", "criticality", "autonomyLevel",
                   "determinismGuarantee", "stateMutability", "failureMode"],
      "additionalProperties": false
    },

    "PurposeModel": {
      "type": "object",
      "description": "Agent mission, goals, non-goals, and success criteria",
      "properties": {
        "mission": { "type": "string" },
        "goals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nonGoals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "successCriteria": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": { "type": "string" },
              "target": { "type": "string" }
            }
          }
        }
      },
      "required": ["mission", "goals", "successCriteria"],
      "additionalProperties": false
    },

    "SpecScope": {
      "type": "object",
      "description": "Operational scope: domains, entities, explicit boundaries",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supportedEntities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundaries": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["domains", "boundaries"],
      "additionalProperties": false
    },

    "SpecCapabilities": {
      "type": "object",
      "description": "Rich capability declarations",
      "properties": {
        "declaredCapabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "inputTypes": { "type": "array", "items": { "type": "string" } },
              "outputTypes": { "type": "array", "items": { "type": "string" } },
              "determinismLevel": { "type": "string" },
              "requiresHumanApproval": { "type": "boolean", "default": false }
            },
            "required": ["id", "name"]
          }
        },
        "capabilityDependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prohibitedCapabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["declaredCapabilities"],
      "additionalProperties": false
    },

    "ReasoningProfile": {
      "type": "object",
      "description": "Reasoning engines, strategy, determinism zones, confidence model",
      "properties": {
        "primaryReasoner": { "type": "string" },
        "reasonerPortfolio": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["rule-engine", "llm", "pattern", "template", "ml-model",
                         "bayesian", "classifier", "script", "service-call"]
              },
              "purpose": { "type": "string" },
              "engine": { "type": "string" },
              "invocationWhen": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id", "type"]
          }
        },
        "reasoningStrategy": { "type": "string" },
        "determinismProfile": {
          "type": "object",
          "properties": {
            "fullyDeterministicZones": { "type": "array", "items": { "type": "string" } },
            "boundedSpeculativeZones": { "type": "array", "items": { "type": "string" } },
            "nonDeterministicZones":   { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "confidenceModel": {
          "type": "object",
          "properties": {
            "scoreRange":              { "type": "string" },
            "sources":                 { "type": "array", "items": { "type": "string" } },
            "autoApproveThreshold":    { "type": "number", "minimum": 0, "maximum": 1 },
            "humanReviewThreshold":    { "type": "number", "minimum": 0, "maximum": 1 },
            "rejectBelowThreshold":    { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "required": ["primaryReasoner", "reasonerPortfolio"],
      "additionalProperties": false
    },

    "ExecutionModel": {
      "type": "object",
      "description": "Invocation modes, lifecycle states, concurrency, retry, timeout, compensation",
      "properties": {
        "invocationModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["request", "event", "schedule", "handoff", "resume", "stream"]
          }
        },
        "lifecycleStates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concurrencyModel": {
          "type": "object",
          "additionalProperties": true
        },
        "retryPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxAttempts": { "type": "integer", "minimum": 1 },
            "backoffStrategy": { "type": "string", "enum": ["fixed", "linear", "exponential"] },
            "retryableErrors": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "timeoutPolicy": {
          "type": "object",
          "properties": {
            "softTimeoutMs": { "type": "integer" },
            "hardTimeoutMs": { "type": "integer" },
            "onSoftTimeout": { "type": "string" },
            "onHardTimeout": { "type": "string" }
          },
          "additionalProperties": false
        },
        "compensationPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "actions": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "required": ["invocationModes", "lifecycleStates"],
      "additionalProperties": false
    },

    "SpecInterfaces": {
      "type": "object",
      "description": "Typed inputs, outputs, event bindings, API contracts, modalities",
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InterfacePort" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/InterfacePort" }
        },
        "eventsConsumed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "eventsProduced": {
          "type": "array",
          "items": { "type": "string" }
        },
        "apiContracts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "ref":  { "type": "string" }
            }
          }
        },
        "supportedModalities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "structured-data", "image", "audio", "video", "binary"]
          },
          "description": "Input/output modalities the agent can process"
        }
      },
      "required": ["inputs", "outputs"],
      "additionalProperties": false
    },

    "InterfacePort": {
      "type": "object",
      "properties": {
        "name":        { "type": "string" },
        "schemaRef":   { "type": "string" },
        "required":    { "type": "boolean", "default": true },
        "description": { "type": "string" }
      },
      "required": ["name"],
      "additionalProperties": false
    },

    "MemoryModel": {
      "type": "object",
      "description": "Memory bindings, types, read strategies, write policies, retention",
      "properties": {
        "memoryBindings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "memoryType": { "type": "string" },
              "access": {
                "type": "string",
                "enum": ["read", "write", "read-write", "append-only"]
              }
            },
            "required": ["memoryType", "access"]
          }
        },
        "memoryTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["working", "task-state", "episodic", "semantic", "procedural",
                     "policy", "graph", "audit", "preference"]
          }
        },
        "readStrategies": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["exact-key", "sparse", "dense", "hybrid", "graph-traversal",
                     "policy-filtered", "procedure-retrieval", "audit-replay"]
          }
        },
        "writePolicies": {
          "type": "object",
          "properties": {
            "allowCreate":                          { "type": "boolean" },
            "allowUpdate":                          { "type": "boolean" },
            "allowDelete":                          { "type": "boolean" },
            "requiresProvenance":                   { "type": "boolean" },
            "requiresValidationBeforeSemanticWrite": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "consolidationRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retentionPolicy": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["memoryBindings", "memoryTypes", "readStrategies", "writePolicies"],
      "additionalProperties": false
    },

    "ToolsAndResources": {
      "type": "object",
      "description": "Tool declarations, resources, tool selection policy",
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id":      { "type": "string" },
              "type":    { "type": "string", "enum": ["retrieval", "api", "function", "mcp", "internal"] },
              "access":  { "type": "string", "enum": ["invoke", "read", "write"] },
              "purpose": { "type": "string" }
            },
            "required": ["id"]
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id":   { "type": "string" },
              "type": { "type": "string" }
            },
            "required": ["id"]
          }
        },
        "toolSelectionPolicy": {
          "type": "object",
          "properties": {
            "allowDynamicSelection":                      { "type": "boolean" },
            "denyExternalNetworkToolsForSensitiveData":   { "type": "boolean" },
            "requirePolicyCheckBeforeWriteTools":         { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "GovernanceSpec": {
      "type": "object",
      "description": "Policy references, approvals, data handling, risk profile",
      "properties": {
        "policyRefs": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "id":              { "type": "string" },
                  "description":     { "type": "string" },
                  "enforcementMode": { "type": "string", "enum": ["hard", "soft"] }
                },
                "required": ["id"]
              }
            ]
          },
          "description": "Links to governing policy documents"
        },
        "approvals": {
          "type": "object",
          "properties": {
            "requiredFor": { "type": "array", "items": { "type": "string" } },
            "approvers":   { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "dataHandling": {
          "type": "object",
          "properties": {
            "supportedClassifications": { "type": "array", "items": { "type": "string" } },
            "defaultClassification":    { "type": "string" },
            "redactBeforeLLM":          { "type": "boolean" },
            "encryptAtRest":            { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "riskProfile": {
          "type": "object",
          "properties": {
            "impactLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "primaryRisks": { "type": "array", "items": { "type": "string" } },
            "mitigations":  { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "required": ["policyRefs", "dataHandling", "riskProfile"],
      "additionalProperties": false
    },

    "LearningModel": {
      "type": "object",
      "description": "Learning level (L0-L5), adaptation targets, drift controls, rollback, prompt versioning",
      "properties": {
        "learningLevel": {
          "type": "string",
          "enum": ["L0", "L1", "L2", "L3", "L4", "L5"],
          "description": "L0=no learning; L1=memory-only; L2=retrieval/policy; L3=skill induction; L4=planner/prompt; L5=param updates"
        },
        "adaptationTargets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "learningSources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "driftControls": {
          "type": "object",
          "properties": {
            "enabled":        { "type": "boolean" },
            "monitors":       { "type": "array", "items": { "type": "string" } },
            "actionOnBreach": { "type": "string" }
          },
          "additionalProperties": false
        },
        "rollbackPolicy": {
          "type": "object",
          "properties": {
            "supported":               { "type": "boolean" },
            "rollbackToLastGoodVersion": { "type": "boolean" },
            "requiresApproval":        { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "promptVersioning": {
          "type": "object",
          "properties": {
            "currentVersion":   { "type": "string" },
            "abTestEnabled":    { "type": "boolean" },
            "variants":         { "type": "array", "items": { "type": "object" } },
            "rollbackVersion":  { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "required": ["learningLevel"],
      "additionalProperties": false
    },

    "EvaluationModel": {
      "type": "object",
      "description": "Evaluation spec refs, online/offline metrics, release gates",
      "properties": {
        "evaluationSpecRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "onlineMetrics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "offlineMetrics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "releaseGates": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },

    "ObservabilitySpec": {
      "type": "object",
      "description": "Trace requirements, logged artifacts, audit mode, alerts",
      "properties": {
        "traceEnabled": {
          "type": "boolean",
          "description": "Whether execution traces are mandatory"
        },
        "loggedArtifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "auditMode": {
          "type": "string",
          "enum": ["minimal", "standard", "full", "regulated"]
        },
        "alerts": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["traceEnabled"],
      "additionalProperties": false
    },

    "InteroperabilitySpec": {
      "type": "object",
      "description": "MCP, A2A protocol, compatibility declarations",
      "properties": {
        "mcp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "supportedCapabilities": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "agentToAgent": {
          "type": "object",
          "properties": {
            "enabled":          { "type": "boolean" },
            "supportsHandoff":  { "type": "boolean" },
            "supportsDelegation": { "type": "boolean" },
            "returnContract":   { "type": "string" }
          },
          "additionalProperties": false
        },
        "compatibility": {
          "type": "object",
          "properties": {
            "backwardCompatibleFrom": { "type": "string" },
            "schemaCompatibility":    { "type": "string" },
            "deprecatedFields":       { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "SecuritySpec": {
      "type": "object",
      "description": "Authentication, authorization, secrets handling, network policy",
      "properties": {
        "authn": {
          "type": "object",
          "properties": {
            "required":    { "type": "boolean" },
            "mechanisms":  { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "authz": {
          "type": "object",
          "properties": {
            "enforcementMode": { "type": "string", "enum": ["policy-engine", "rbac", "abac"] },
            "requiredScopes":  { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "secretsHandling": {
          "type": "object",
          "properties": {
            "externalSecretManager": { "type": "boolean" },
            "allowInlineSecrets":    { "type": "boolean" },
            "rotationPolicy":        { "type": "string" }
          },
          "additionalProperties": false
        },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "outboundInternetAccess":    { "type": "boolean" },
            "allowedInternalServices":  { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "required": ["authn", "authz"],
      "additionalProperties": false
    },

    "DeploymentSpec": {
      "type": "object",
      "description": "Runtime class, scaling, locality constraints, dependencies",
      "properties": {
        "runtimeClass": { "type": "string" },
        "scalingModel": {
          "type": "object",
          "properties": {
            "mode":        { "type": "string", "enum": ["horizontal", "vertical", "replicated", "serverless"] },
            "minReplicas": { "type": "integer", "minimum": 0 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "scaleOn":     { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "localityConstraints": {
          "type": "object",
          "additionalProperties": true
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "documentation": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "Duration": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?(ms|s|m|h)$",
      "description": "Duration string (e.g., '100ms', '5s', '1m', '1h')"
    }
  }
}
