{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.io/schemas/product-shape-capability-matrix.json",
  "title": "Product Shape Capability Matrix",
  "type": "object",
  "required": ["version", "generated", "source", "matrix"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "matrix": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/MatrixRow"
      }
    }
  },
  "definitions": {
    "MatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "productId",
        "kind",
        "surfaces",
        "lifecycleStatus",
        "lifecycleExecutionAllowed",
        "requiredKernelCapabilities",
        "requiredToolchainAdapters",
        "requiredArtifactManifests",
        "requiredDeploymentTargets",
        "requiredSecurityPrivacyGates",
        "requiredDataCloudSupport",
        "requiredYappcVisibility",
        "requiredAgentRuntimeSupport",
        "currentEvidenceRefs",
        "missingEvidenceRefs",
        "blockers",
        "nextActions",
        "validationCommands"
      ],
      "properties": {
        "productId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "kind": {
          "type": "string"
        },
        "lifecycleStatus": {
          "type": "string",
          "enum": ["disabled", "planned", "partial", "enabled"]
        },
        "lifecycleExecutionAllowed": {
          "type": "boolean"
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredKernelCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredToolchainAdapters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredArtifactManifests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredDeploymentTargets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredSecurityPrivacyGates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredDataCloudSupport": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredYappcVisibility": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredAgentRuntimeSupport": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "currentEvidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "missingEvidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextActions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validationCommands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
