{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghatana.local/schemas/product-family-asset-registry.schema.json",
  "title": "Product Family Asset Registry",
  "type": "object",
  "required": ["version", "assets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "sourceProduct",
          "status",
          "maturity",
          "evidenceRefs",
          "owner"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "sourceProduct": {
            "type": "string",
            "enum": ["phr", "digital-marketing"]
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "hardened", "production", "shared"]
          },
          "maturity": {
            "type": "string",
            "enum": ["draft", "validated", "release-ready"]
          },
          "targetPromotion": {
            "type": "string",
            "enum": ["shared-package", "kernel-plugin", "template", "schema-pack", "none"]
          },
          "owner": {
            "type": "string",
            "minLength": 2
          },
          "description": {
            "type": "string"
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    }
  }
}
