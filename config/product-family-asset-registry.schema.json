{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghatana.local/schemas/product-family-asset-registry.schema.json",
  "title": "Product Family Asset Registry",
  "type": "object",
  "required": ["version", "assets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "type",
          "sourceProduct",
          "status",
          "maturity",
          "reuseMode",
          "targetPromotion",
          "owner",
          "ownerApproval",
          "freshness",
          "paths",
          "tests",
          "dependencies",
          "requiredFoundations",
          "constraints",
          "compatibility",
          "productUsage",
          "evidenceRefs"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "type": {
            "type": "string",
            "enum": ["ui-component", "service", "workflow", "policy", "gate-pack", "pattern", "connector"]
          },
          "sourceProduct": {
            "type": "string",
            "enum": ["phr", "digital-marketing"]
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "hardened", "production", "shared"]
          },
          "maturity": {
            "type": "string",
            "enum": ["draft", "validated", "release-ready"]
          },
          "reuseMode": {
            "type": "string",
            "enum": ["reference", "template", "shared-package", "kernel-plugin", "schema-pack"]
          },
          "targetPromotion": {
            "type": "string",
            "enum": ["shared-package", "kernel-plugin", "template", "schema-pack", "none"]
          },
          "owner": {
            "type": "string",
            "minLength": 2
          },
          "ownerApproval": {
            "type": "object",
            "required": ["approvedBy", "approvedAt", "approvalStatus"],
            "additionalProperties": false,
            "properties": {
              "approvedBy": {
                "type": "string",
                "minLength": 2
              },
              "approvedAt": {
                "type": "string",
                "format": "date-time"
              },
              "approvalStatus": {
                "type": "string",
                "enum": ["approved", "pending", "rejected"]
              }
            }
          },
          "freshness": {
            "type": "object",
            "required": ["sourceCommitSha", "targetCommitSha", "validatedAt"],
            "additionalProperties": false,
            "properties": {
              "sourceCommitSha": {
                "type": "string",
                "minLength": 7
              },
              "targetCommitSha": {
                "type": "string",
                "minLength": 7
              },
              "validatedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "description": {
            "type": "string"
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "tests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "requiredFoundations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "compatibility": {
            "type": "object",
            "required": ["productTypes", "runtime", "constraints"],
            "additionalProperties": false,
            "properties": {
              "productTypes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 2
                }
              },
              "runtime": {
                "type": "string",
                "minLength": 2
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 2
                }
              }
            }
          },
          "productUsage": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["productId", "usage", "state"],
              "additionalProperties": false,
              "properties": {
                "productId": {
                  "type": "string",
                  "minLength": 2
                },
                "usage": {
                  "type": "string",
                  "minLength": 3
                },
                "state": {
                  "type": "string",
                  "enum": ["production-used", "recommended", "planned"]
                }
              }
            }
          },
          "evidenceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    }
  }
}
