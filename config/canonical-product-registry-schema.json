{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.io/schemas/canonical-product-registry.json",
  "title": "Canonical Product Registry Schema",
  "description": "Single source of truth for product registration in the Ghatana monorepo. This registry drives generation of product-shape.json, Gradle includes, pnpm workspace entries, CI matrices, and conformance checks.",
  "type": "object",
  "required": ["version", "registry"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for migration tracking",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "registry": {
      "type": "object",
      "description": "Map of product ID to product configuration",
      "additionalProperties": {
        "$ref": "#/definitions/Product"
      }
    }
  },
  "definitions": {
    "Product": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "kind",
        "type",
        "metadata",
        "gradleModules",
        "surfaces",
        "lifecycleExecutionAllowed"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Canonical product identifier (kebab-case)",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "description": "Human-readable product name"
        },
        "description": {
          "type": "string",
          "description": "Product description"
        },
        "type": {
          "type": "string",
          "enum": ["product", "platform", "shared-service"],
          "description": "Legacy coarse classification of the module"
        },
        "kind": {
          "type": "string",
          "enum": ["platform-provider", "business-product", "shared-service", "domain-pack", "demo/example"],
          "description": "Canonical registry kind used by generators and conformance filters"
        },
        "manifestPath": {
          "type": ["string", "null"],
          "description": "Relative path to product manifest file from repo root, or null if no manifest exists"
        },
        "manifestFormat": {
          "type": ["string", "null"],
          "enum": ["yaml", "json", null],
          "description": "Format of the manifest file, or null if no manifest exists"
        },
        "buildFile": {
          "type": "string",
          "description": "Explicit Gradle build file that owns manifest-backed conformance"
        },
        "gradleModules": {
          "type": "array",
          "description": "Gradle module paths for this product",
          "items": {
            "type": "string",
            "pattern": "^:[a-z0-9:-]+$"
          }
        },
        "surfaces": {
          "type": "array",
          "description": "Product runtime surfaces (typed, not boolean)",
          "items": {
            "$ref": "#/definitions/Surface"
          }
        },
        "pnpmPackages": {
          "type": "array",
          "description": "pnpm workspace package patterns for this product",
          "items": {
            "type": "string"
          }
        },
        "ci": {
          "$ref": "#/definitions/CIConfiguration",
          "description": "CI/CD configuration for this product"
        },
        "conformance": {
          "$ref": "#/definitions/ConformanceConfiguration",
          "description": "Conformance check configuration"
        },
        "metadata": {
          "type": "object",
          "required": ["owner", "status"],
          "description": "Additional product metadata",
          "properties": {
            "owner": {
              "type": "string",
              "description": "Team or owner responsible for this product"
            },
            "created": {
              "type": "string",
              "format": "date",
              "description": "Creation date"
            },
            "documentation": {
              "type": "string",
              "description": "Path to product documentation"
            },
            "status": {
              "type": "string",
              "enum": ["active", "deprecated", "experimental"],
              "description": "Product status"
            }
          }
        },
        "lifecycleProfile": {
          "type": "string",
          "description": "Lifecycle profile ID from product-lifecycle-profiles.json (e.g., standard-web-api-product)"
        },
        "lifecycleStatus": {
          "type": "string",
          "enum": ["disabled", "planned", "partial", "enabled"],
          "description": "Lifecycle rollout status for this product"
        },
        "lifecycleExecutionAllowed": {
          "type": "boolean",
          "description": "Whether lifecycle execution is allowed for this product. When false, the product is in a NOT_READY state and lifecycle operations will be blocked."
        },
        "lifecycleMigration": {
          "$ref": "#/definitions/ProductLifecycleMigration",
          "description": "Lifecycle migration status for this product"
        },
        "lifecycleReadiness": {
          "$ref": "#/definitions/ProductLifecycleReadiness",
          "description": "Readiness metadata for disabled, planned, or platform-provider products"
        },
        "lifecycleConfigPath": {
          "type": "string",
          "description": "Path to kernel-product.yaml lifecycle configuration file"
        },
        "lifecycle": {
          "$ref": "#/definitions/ProductLifecycleConfiguration",
          "description": "Product lifecycle configuration"
        },
        "toolchain": {
          "$ref": "#/definitions/ProductToolchainConfiguration",
          "description": "Product toolchain configuration"
        },
        "artifacts": {
          "$ref": "#/definitions/ProductArtifactsConfiguration",
          "description": "Product artifacts configuration"
        },
        "deployment": {
          "$ref": "#/definitions/ProductDeploymentConfiguration",
          "description": "Product deployment configuration"
        },
        "environments": {
          "$ref": "#/definitions/ProductEnvironmentConfiguration",
          "description": "Product environment configuration"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "conformance": {
                "properties": {
                  "manifest": { "const": true }
                },
                "required": ["manifest"]
              }
            },
            "required": ["conformance"]
          },
          "then": {
            "required": ["manifestPath", "manifestFormat", "buildFile"],
            "properties": {
              "manifestPath": { "type": "string", "minLength": 1 },
              "manifestFormat": { "enum": ["yaml", "json"] },
              "buildFile": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            },
            "required": ["lifecycle"]
          },
          "then": {
            "properties": {
              "lifecycleStatus": { "const": "enabled" }
            },
            "required": ["lifecycleStatus"]
          }
        },
        {
          "if": {
            "properties": {
              "lifecycleStatus": { "const": "enabled" }
            },
            "required": ["lifecycleStatus"]
          },
          "then": {
            "required": ["lifecycleProfile", "lifecycleConfigPath", "lifecycle", "toolchain", "artifacts", "deployment", "environments"],
            "properties": {
              "lifecycleExecutionAllowed": { "const": true },
              "lifecycleProfile": { "type": "string", "minLength": 1 },
              "lifecycleConfigPath": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "lifecycleStatus": {
                "enum": ["disabled", "planned", "partial"]
              }
            },
            "required": ["lifecycleStatus"]
          },
          "then": {
            "properties": {
              "lifecycleExecutionAllowed": { "const": false }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "platform-provider" }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["lifecycleReadiness"],
            "properties": {
              "lifecycleReadiness": {
                "required": ["requiredGates"],
                "properties": {
                  "requiredGates": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": { "enum": ["data-cloud", "yappc"] }
            },
            "required": ["id"]
          },
          "then": {
            "properties": {
              "lifecycleStatus": {
                "not": { "const": "enabled" }
              },
              "lifecycle": {
                "properties": {
                  "enabled": { "const": false }
                }
              }
            }
          }
        }
      ]
    },
    "Surface": {
      "type": "object",
      "required": ["type", "path", "implementationStatus"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["backend-api", "worker", "portal", "sdk", "web", "mobile", "cli", "operator"],
          "description": "Surface type"
        },
        "implementationStatus": {
          "type": "string",
          "enum": ["implemented", "planned", "backend-only"],
          "description": "Current implementation maturity for this surface. Use backend-only for non-UI runtime surfaces that are implemented without a web/mobile client."
        },
        "path": {
          "type": "string",
          "description": "Relative path to the surface implementation"
        },
        "packagePath": {
          "type": "string",
          "description": "For UI surfaces: path to package.json"
        }
      }
    },
    "CIConfiguration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether CI is enabled for this product"
        },
        "matrix": {
          "type": "object",
          "description": "CI matrix configuration",
          "additionalProperties": true
        },
        "gates": {
          "type": "array",
          "description": "Required CI gates",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ConformanceConfiguration": {
      "type": "object",
      "properties": {
        "manifest": {
          "type": "boolean",
          "description": "Require manifest validation"
        },
        "observability": {
          "type": "boolean",
          "description": "Require observability conformance"
        },
        "security": {
          "type": "boolean",
          "description": "Require security conformance"
        },
        "dataAccess": {
          "type": "boolean",
          "description": "Require data-access contract validation"
        },
        "bridge": {
          "type": "boolean",
          "description": "Require bridge compliance validation"
        },
        "bridgeAdapters": {
          "type": "array",
          "description": "Manifest-driven bridge adapter compliance contracts. Required when bridge conformance is enabled for active business products.",
          "items": {
            "type": "object",
            "required": ["file", "tests"],
            "properties": {
              "file": {
                "type": "string",
                "minLength": 1,
                "description": "Bridge adapter implementation path relative to the repository root"
              },
              "tests": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["file"],
                  "properties": {
                    "file": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Bridge compliance test file path relative to the repository root"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "agentDefinitions": {
          "type": "boolean",
          "description": "Require agent definitions to validate against agent catalog schema"
        },
        "masteryBindings": {
          "type": "boolean",
          "description": "Require mastery bindings to be valid and reference existing skills"
        },
        "evaluationPacks": {
          "type": "boolean",
          "description": "Require evaluation packs to exist for procedural skills"
        },
        "runtimeModule": {
          "type": "boolean",
          "description": "Require agent runtime module to be included in product"
        }
      }
    },
    "ProductLifecycleConfiguration": {
      "type": "object",
      "description": "Product lifecycle configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether lifecycle orchestration is enabled for this product"
        },
        "phases": {
          "type": "object",
          "description": "Phase-specific configuration",
          "additionalProperties": {
            "$ref": "#/definitions/LifecyclePhaseConfiguration"
          }
        }
      }
    },
    "LifecyclePhaseConfiguration": {
      "type": "object",
      "description": "Configuration for a specific lifecycle phase",
      "properties": {
        "defaultSurfaces": {
          "type": "array",
          "description": "Default surfaces to include in this phase",
          "items": {
            "type": "string"
          }
        },
        "mode": {
          "type": "string",
          "enum": ["parallel", "sequential"],
          "description": "Execution mode for this phase"
        },
        "gateOutputs": {
          "type": "object",
          "description": "Gate output states for this phase",
          "properties": {
            "NOT_READY": {
              "type": "object",
              "description": "Output when the phase is NOT_READY",
              "properties": {
                "reasonCode": {
                  "type": "string",
                  "description": "Reason code for NOT_READY state"
                },
                "message": {
                  "type": "string",
                  "description": "Human-readable message explaining the NOT_READY state"
                },
                "blockedReasons": {
                  "type": "array",
                  "description": "Detailed reasons for the blocked state",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "ProductToolchainConfiguration": {
      "type": "object",
      "description": "Product toolchain configuration",
      "properties": {
        "profile": {
          "type": "string",
          "description": "Toolchain profile ID"
        },
        "adapters": {
          "type": "object",
          "description": "Adapter mappings for surfaces and phases",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ProductArtifactsConfiguration": {
      "type": "object",
      "description": "Product artifacts configuration",
      "additionalProperties": {
        "$ref": "#/definitions/ProductArtifactDeclaration"
      }
    },
    "ProductArtifactDeclaration": {
      "type": "object",
      "description": "Artifact declaration for a surface",
      "required": ["type", "packaging"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["jvm-service", "jvm-library", "node-service", "static-web-bundle", "container-image", "mobile-bundle", "sdk-package", "domain-pack", "test-report", "coverage-report"],
          "description": "Artifact type"
        },
        "packaging": {
          "type": "string",
          "enum": ["jar", "distribution", "static-files", "container", "npm", "maven", "apk", "aab", "ipa", "json", "xml"],
          "description": "Packaging format"
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether the artifact is required for a successful phase"
        }
      }
    },
    "ProductLifecycleMigration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not-started", "partial", "ready", "blocked"]
        },
        "readinessReasonCode": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "blockingFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ProductLifecycleReadiness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasonCodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredGates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nextRequiredWork": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingManifests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockerGateAdapterMatrix": {
          "type": "object",
          "description": "Explicit blocker, gate, and adapter matrix for future product shape readiness",
          "properties": {
            "blockers": {
              "type": "array",
              "description": "List of blocker reason codes preventing lifecycle execution",
              "items": { "type": "string" }
            },
            "gates": {
              "type": "array",
              "description": "List of gates with adapter associations",
              "items": {
                "type": "object",
                "required": ["gateId"],
                "properties": {
                  "gateId": {
                    "type": "string",
                    "description": "Unique gate identifier"
                  },
                  "description": {
                    "type": "string",
                    "description": "Human-readable gate description"
                  },
                  "evidenceRequired": {
                    "type": "boolean",
                    "description": "Whether evidence is required for this gate"
                  },
                  "adapterId": {
                    "type": "string",
                    "description": "Associated adapter identifier"
                  },
                  "requiredFor": {
                    "type": "array",
                    "description": "Lifecycle phases or surfaces this gate is required for",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            },
            "adapters": {
              "type": "array",
              "description": "List of required adapters with their readiness status",
              "items": {
                "type": "object",
                "required": ["adapterId"],
                "properties": {
                  "adapterId": {
                    "type": "string",
                    "description": "Unique adapter identifier"
                  },
                  "type": {
                    "type": "string",
                    "description": "Adapter type (e.g., gradle-java-service, pnpm-vite-react)"
                  },
                  "required": {
                    "type": "boolean",
                    "description": "Whether this adapter is required"
                  },
                  "status": {
                    "type": "string",
                    "description": "Adapter implementation status"
                  },
                  "readiness": {
                    "type": "string",
                    "enum": ["ready", "partial", "planned", "blocked"],
                    "description": "Adapter readiness status"
                  },
                  "reasonCode": {
                    "type": "string",
                    "description": "Reason code if not ready"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "ProductDeploymentConfiguration": {
      "type": "object",
      "description": "Product deployment configuration",
      "properties": {
        "targets": {
          "type": "array",
          "description": "Deployment targets (e.g., local-compose, kubernetes)",
          "items": {
            "type": "string"
          }
        },
        "defaultEnvironment": {
          "type": "string",
          "description": "Default deployment environment"
        },
        "healthChecks": {
          "type": "array",
          "description": "Health check profiles",
          "items": {
            "type": "string"
          }
        },
        "rollback": {
          "$ref": "#/definitions/ProductRollbackConfiguration",
          "description": "Rollback configuration"
        }
      }
    },
    "ProductRollbackConfiguration": {
      "type": "object",
      "description": "Product rollback configuration",
      "required": ["strategy"],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["previous-artifact", "blue-green", "canary"],
          "description": "Rollback strategy"
        }
      }
    },
    "ProductEnvironmentConfiguration": {
      "type": "object",
      "description": "Product environment configuration",
      "properties": {
        "supported": {
          "type": "array",
          "description": "Supported environments",
          "items": {
            "type": "string",
            "enum": ["local", "dev", "staging", "prod"]
          }
        },
        "defaults": {
          "type": "object",
          "description": "Default configuration per environment",
          "additionalProperties": {
            "type": "object"
          }
        }
      }
    }
  }
}
