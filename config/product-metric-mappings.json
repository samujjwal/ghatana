{
  "$schema": "./product-metric-mappings.schema.json",
  "version": "1.0.0",
  "description": "Maps SLO budget configurations to actual runtime metrics from observability systems",
  "metricSources": {
    "prometheus": {
      "baseUrl": "http://localhost:9090",
      "description": "Prometheus metrics endpoint for runtime telemetry"
    },
    "grafana": {
      "baseUrl": "http://localhost:3001",
      "description": "Grafana dashboard for SLO visualization"
    }
  },
  "products": {
    "digital-marketing": {
      "workflows": {
        "campaign-lifecycle": {
          "latencyMs": {
            "p50": {
              "metricName": "http_request_duration_seconds_bucket",
              "labels": {
                "workflow": "campaign-lifecycle",
                "product": "digital-marketing",
                "le": "0.2"
              },
              "query": "histogram_quantile(0.5, rate(http_request_duration_seconds_bucket{workflow=\"campaign-lifecycle\",product=\"digital-marketing\"}[5m])) * 1000"
            },
            "p95": {
              "metricName": "http_request_duration_seconds_bucket",
              "labels": {
                "workflow": "campaign-lifecycle",
                "product": "digital-marketing",
                "le": "0.8"
              },
              "query": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{workflow=\"campaign-lifecycle\",product=\"digital-marketing\"}[5m])) * 1000"
            },
            "p99": {
              "metricName": "http_request_duration_seconds_bucket",
              "labels": {
                "workflow": "campaign-lifecycle",
                "product": "digital-marketing",
                "le": "1.4"
              },
              "query": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{workflow=\"campaign-lifecycle\",product=\"digital-marketing\"}[5m])) * 1000"
            }
          },
          "throughputRps": {
            "min": {
              "metricName": "http_requests_total",
              "labels": {
                "workflow": "campaign-lifecycle",
                "product": "digital-marketing"
              },
              "query": "rate(http_requests_total{workflow=\"campaign-lifecycle\",product=\"digital-marketing\"}[5m])"
            }
          },
          "memoryMb": {
            "max": {
              "metricName": "process_resident_memory_bytes",
              "labels": {
                "product": "digital-marketing"
              },
              "query": "process_resident_memory_bytes{product=\"digital-marketing\"} / 1024 / 1024"
            }
          },
          "queueDepth": {
            "max": {
              "metricName": "queue_depth",
              "labels": {
                "workflow": "campaign-lifecycle",
                "product": "digital-marketing"
              },
              "query": "queue_depth{workflow=\"campaign-lifecycle\",product=\"digital-marketing\"}"
            }
          },
          "backgroundJobRuntimeMs": {
            "max": {
              "metricName": "background_job_duration_seconds",
              "labels": {
                "product": "digital-marketing"
              },
              "query": "histogram_quantile(0.99, rate(background_job_duration_seconds_bucket{product=\"digital-marketing\"}[5m])) * 1000"
            }
          }
        }
      }
    },
