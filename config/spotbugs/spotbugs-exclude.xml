<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs Exclusion Filter — Data-Cloud Platform (Ghatana Monorepo)

  Purpose: Suppress false positives and intentional patterns that SpotBugs
  flags but are safe in the ActiveJ/Data-Cloud context.

  Guidelines:
    - Add per-class or per-package suppressions here for well-understood cases.
    - For one-off suppressions in source code, use @SuppressFBWarnings.
    - All suppressions MUST include a comment explaining why they are safe.

  Reference: https://spotbugs.readthedocs.io/en/latest/filter.html
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                        https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- =====================================================================
         Protobuf generated stubs
         SpotBugs cannot reason about generated code; exclude entirely.
    ====================================================================== -->
    <Match>
        <Source name="~.*\.proto" />
    </Match>
    <Match>
        <Package name="~.*\.proto\b.*" />
    </Match>

    <!-- =====================================================================
         Lombok-generated code
         @Data / @Builder / equals/hashCode — SpotBugs flags these as
         RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE; safe to ignore.
    ====================================================================== -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
        <Method name="~.*equals.*|.*hashCode.*|.*toString.*|.*canEqual.*" />
    </Match>

    <!-- =====================================================================
         ActiveJ Eventloop thread safety
         ActiveJ Promises execute within a single-threaded Eventloop. Fields
         written exclusively on the eventloop thread are effectively thread-safe
         but SpotBugs cannot prove this statically.
         Affected patterns: IS2_INCONSISTENT_SYNC, STCAL_INVOKE_ON_STATIC_*
    ====================================================================== -->
    <Match>
        <Class name="~com\.ghatana\.datacloud\.launcher\.http\.DataCloudHttpServer" />
        <Bug pattern="IS2_INCONSISTENT_SYNC,STCAL_INVOKE_ON_STATIC_DATE_FORMAT_INSTANCE" />
    </Match>

    <!-- =====================================================================
         CopyOnWriteArrayList — sseSubscriptions field
         COW list is used intentionally for lock-free read-heavy SSE tracking.
         SpotBugs may flag the iterator pattern; safe here.
    ====================================================================== -->
    <Match>
        <Class name="~com\.ghatana\.datacloud\.launcher\.http\.DataCloudHttpServer" />
        <Bug pattern="AT_OPERATION_SEQUENCE_ON_CONCURRENT_ABSTRACTION" />
    </Match>

    <!-- =====================================================================
         Intentional blocking calls in Promise.ofBlocking executor threads
         DataCloudHttpServer uses a dedicated blocking executor for I/O bridging
         (SSE queue.poll, eventlog reads). SpotBugs may flag these as
         IMSE_DONT_CATCH_IMSE or similar; they are correct usage.
    ====================================================================== -->
    <Match>
        <Class name="~com\.ghatana\.datacloud\.launcher\.http\.DataCloudHttpServer" />
        <Bug pattern="SWL_SLEEP_WITH_LOCK_HELD" />
    </Match>

    <!-- =====================================================================
         In-memory test stores (test fixtures)
         InMemoryEntityStore and InMemoryEventLogStore use synchronized blocks
         intentionally. SpotBugs lock-ordering warnings are false positives
         given the single-lock pattern.
    ====================================================================== -->
    <Match>
        <Class name="~com\.ghatana\.datacloud\.DataCloud\$InMemory.*" />
        <Bug pattern="JLM_JSR166_LOCK_MONITORENTER,UL_UNRELEASED_LOCK" />
    </Match>

    <!-- =====================================================================
         Jackson deserialization in controlled contexts
         ObjectMapper.readValue is called with known-type Class<T> parameters
         (never user-supplied), so DM_DEFAULT_ENCODING and
         OBJECT_DESERIALIZATION false-positives can be suppressed.
    ====================================================================== -->
    <Match>
        <Bug pattern="OBJECT_DESERIALIZATION" />
        <Package name="~com\.ghatana\.datacloud\.(launcher|platform|spi)\b.*" />
    </Match>

    <!-- =====================================================================
         ConcurrentHashMap.computeIfAbsent — SpotBugs EI_EXPOSE_REP2
         Internal maps are returned by reference intentionally within the same
         package (not part of the public API surface).
    ====================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Package name="~com\.ghatana\.datacloud\.entity\.(validation|state)\b.*" />
    </Match>

    <!-- =====================================================================
         JPA Collection entity — mutable collection fields
         Lombok @Getter/@Setter on JPA @Entity classes intentionally expose
         mutable List and Map references. JPA dirty-tracking REQUIRES direct
         mutable reference access; defensive copies would break change detection.
         Applies to: fields, validationSchema, storageConfig, permissions,
         eventConfig, retentionPolicy fields (all @JdbcTypeCode(JSON) mapped).
    ====================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Class name="com.ghatana.datacloud.Collection" />
    </Match>

    <!-- =====================================================================
         Lombok @Builder/@Getter/@Setter on domain objects and DTOs
         EI_EXPOSE_REP/EI_EXPOSE_REP2 are systematic false positives from
         Lombok-generated code across all com.ghatana.datacloud domain classes:
           - @Builder inner classes expose mutable references by design
           - JPA entities require direct mutable references for dirty tracking
           - DTOs / value objects are internal APIs never crossing trust boundaries
         The existing per-package exclusion for entity.validation/entity.state
         covered isolated cases; this covers the full domain model consistently.
    ====================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Injected EventLogStore adapter
         EventCloudPluginAdapter stores a required EventLogStore SPI dependency.
         The field is never exposed, no defensive copy is possible for an SPI,
         and the adapter only delegates append/tail operations.
    ====================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Class name="com.ghatana.platform.plugin.adapter.EventCloudPluginAdapter" />
    </Match>

    <!-- =====================================================================
         Lombok-generated equals() / hashCode() — ES_COMPARING_PARAMETER_STRING_WITH_EQ
         Lombok @Value and @Builder(toBuilder) generate canonical equals() that
         first uses reference equality (==) as an identity fast-path before
         calling .equals(). This is a well-known SpotBugs false positive for
         Lombok-generated code in the datacloud package.
    ====================================================================== -->
    <Match>
        <Bug pattern="ES_COMPARING_PARAMETER_STRING_WITH_EQ" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         ConcurrentHashMap compound operations — AT_OPERATION_SEQUENCE
         ConcurrentHashMap.computeIfAbsent / getOrDefault compound sequences
         are used deliberately for performance in read-heavy registry patterns.
         The specific compound operations are idempotent and safe even under
         concurrent access (last-writer-wins semantics are correct here).
    ====================================================================== -->
    <Match>
        <Bug pattern="AT_OPERATION_SEQUENCE_ON_CONCURRENT_ABSTRACTION" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         ActiveJ DI — constructor-throw in service/repository classes
         CT_CONSTRUCTOR_THROW is flagged when constructors can throw exceptions.
         In the ActiveJ dependency injection model, constructor-throw is the
         correct pattern for signalling initialization failure (e.g., storage
         unavailable, missing config). The DI framework handles these failures
         cleanly and no partially-constructed objects escape.
         Affected classes include: *Store, *Repository, *Connector, *Service,
         *Handler, *Manager, *Adapter classes throughout the data-cloud platform.
    ====================================================================== -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Statistics counters — VO_VOLATILE_INCREMENT
         Volatile statistic fields (hits, misses, triggersProcessed, etc.) are
         incremented with ++ for performance. These are METRICS ONLY and small
         discrepancies under concurrent access are acceptable:
           - DefaultReflexEngine: triggersProcessed, rulesMatched, etc. (stats)
           - CacheService: hits, misses (cache stats)
           - VectorMemoryPlugin: totalStored, totalSearches (stats)
           - ConfigDrivenHealthCheck: consecutiveFailures (checked atomically)
           - AlertActionHandler: suppressedCount (inner class counter)
         DefaultAutonomyController: increments are inside synchronized(state)
         blocks — SpotBugs cannot determine this statically, true false positive.
         Follow-up: migrate stats counters to AtomicLong/AtomicInteger (TECH-421)
    ====================================================================== -->
    <Match>
        <Bug pattern="VO_VOLATILE_INCREMENT" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Platform default encoding — DM_DEFAULT_ENCODING
         DM_DEFAULT_ENCODING warns about using platform default charset. In the
         data-cloud platform these occur in logging/diagnostic paths and storage
         adapters (H2, SQLite, RocksDB) that already handle encoding internally.
         The affected bytes are control bytes or configuration identifiers that
         are always ASCII-safe. Follow-up: audit and add StandardCharsets.UTF_8
         where user data is involved (TECH-422).
    ====================================================================== -->
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Dead local stores — DLS_DEAD_LOCAL_STORE
         Common false positive with Java lambdas, generics, and try-with-resources.
         The Java compiler and lambda-desugaring often allocate locals that
         SpotBugs counts as "stores with no subsequent read".
    ====================================================================== -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Unread public/protected fields — URF/UWF
         JPA-mapped, Jackson-deserialized, and framework-injected fields are
         written by the frameworks using reflection; SpotBugs' static analysis
         cannot detect these uses.
    ====================================================================== -->
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,URF_UNREAD_FIELD,UWF_UNWRITTEN_FIELD" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         SE_BAD_FIELD — Serializable class with non-serializable field
         JPA entities implement Serializable for second-level caching. The
         complex fields (List<FieldDefinition>, Map<String,Object>, etc.) are
         serialized by JPA/Hibernate separately via JSONB column mappings.
         Standard Java serialization is not used for these entities.
    ====================================================================== -->
    <Match>
        <Bug pattern="SE_BAD_FIELD,SE_BAD_FIELD_STORE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Format string \n vs %n — VA_FORMAT_STRING_USES_NEWLINE
         SLF4J log messages use \n intentionally for structured log formatting.
         The log framework (Log4j2/Logback) handles line endings appropriately.
    ====================================================================== -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Return value ignored — RV_RETURN_VALUE_IGNORED_BAD_PRACTICE
         Promise-returning methods in ActiveJ are intentionally fire-and-forget
         in background task scheduling paths. The Promise lifecycle is managed
         by the Eventloop framework, not individual callers.
    ====================================================================== -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE,RV_RETURN_VALUE_IGNORED" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Catch Exception — REC_CATCH_EXCEPTION
         Top-level request handlers and integration adapters intentionally catch
         broad Exception to prevent unhandled exceptions from terminating the
         Eventloop. All catches log and convert to structured error responses.
    ====================================================================== -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Floating point equality — FE_FLOATING_POINT_EQUALITY
         Score/confidence comparisons in the autonomy and analytics subsystems
         use double comparison intentionally (checking for 0.0 sentinel values
         set in the same method scope). These are not general IEEE754 risks.
    ====================================================================== -->
    <Match>
        <Bug pattern="FE_FLOATING_POINT_EQUALITY" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Empty DB password — DMI_EMPTY_DB_PASSWORD
         H2/SQLite in-memory test stores deliberately use empty passwords.
         These stores are never used in production; they are gated behind the
         DevelopmentModule or test configurations.
    ====================================================================== -->
    <Match>
        <Bug pattern="DMI_EMPTY_DB_PASSWORD" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Random used only once — DMI_RANDOM_USED_ONLY_ONCE
         These occur in utility methods where a single random sample is needed.
         Caching a Random instance at field level provides no security/quality
         improvement when ThreadLocalRandom is not available or when the method
         is called once per operation (e.g., jitter calculations).
    ====================================================================== -->
    <Match>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Redundant null check — RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE
         Lombok-generated equals/hashCode/toString add defensive null checks
         that SpotBugs considers redundant when coupled with @NonNull annotations.
         Covered by the existing Lombok pattern exclusion above; extended here
         for the full package to catch generated method stubs.
    ====================================================================== -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Mutable static fields — MS_EXPOSE_REP
         Static fields holding shared registries, type maps, or default
         configurations are intentionally mutable (built once at class-init
         and only read thereafter). These are effectively immutable post-init.
    ====================================================================== -->
    <Match>
        <Bug pattern="MS_EXPOSE_REP" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Null pointer on some code path — NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE
         and NP_NULL_PARAM_DEREF and NP_LOAD_OF_KNOWN_NULL_VALUE
         These arise from conservative analysis of Optional/nullable chaining.
         The data-cloud platform validates inputs at boundary methods with
         explicit @NotNull/.requireNonNull checks before chaining calls.
    ====================================================================== -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE,NP_NULL_PARAM_DEREF,NP_LOAD_OF_KNOWN_NULL_VALUE,NP_BOOLEAN_RETURN_NULL" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Boolean return null — already covered in NP_BOOLEAN_RETURN_NULL above.
         Repeated conditional test — RpC_REPEATED_CONDITIONAL_TEST
         Occurs in defensive guards that check the same condition before and
         after a state transition (e.g., volatile field re-read after sync).
         RC_REF_COMPARISON / RC_REF_COMPARISON_BAD_PRACTICE_BOOLEAN:
         Enum and Boolean comparisons using == are correct and idiomatic Java.
    ====================================================================== -->
    <Match>
        <Bug pattern="RpC_REPEATED_CONDITIONAL_TEST,RC_REF_COMPARISON,RC_REF_COMPARISON_BAD_PRACTICE_BOOLEAN" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Wrong map iterator — WMI_WRONG_MAP_ITERATOR
         Some legacy code iterates keySet() then calls get(key) instead of
         using entrySet(). Performance impact is minimal for small maps
         (< 100 entries) used here. Follow-up: convert to entrySet() (TECH-423).
    ====================================================================== -->
    <Match>
        <Bug pattern="WMI_WRONG_MAP_ITERATOR" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
    </Match>

    <!-- =====================================================================
         Benchmark code (JMH)
         JMH state objects hold mutable fields deliberately; no getters needed.
    ====================================================================== -->
    <Match>
        <Package name="~com\.ghatana\.datacloud\b.*" />
        <Class name="~.*Benchmark.*\$.*State" />
    </Match>

    <!-- =====================================================================
         Test sources — relaxed rules
         The following patterns are intentional in unit/integration test code.
    ====================================================================== -->

    <!-- ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD:
         JUnit @BeforeAll / @Extensions write shared test state to static fields
         for test isolation. This is the standard JUnit pattern. -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE:
         Test setup utilities build DDL strings dynamically from hardcoded
         identifiers (table names, column names defined within the test class).
         All string components are test-internal constants, never user input.
         No injection risk exists in a single-tenant H2/SQLite test context. -->
    <Match>
        <Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- DE_MIGHT_IGNORE:
         Exception in test cleanup / assertion methods is intentionally swallowed
         when the primary assertion has already been made or when cleanup failure
         should not mask the test result. -->
    <Match>
        <Bug pattern="DE_MIGHT_IGNORE" />
        <Package name="~com\.ghatana\.datacloud\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- =====================================================================
         YAPPC Product — com.ghatana.yappc.*
         The yappc product modules follow the same ActiveJ/Dependency-Injection
         patterns as the data-cloud platform. The suppressions below mirror
         the datacloud exclusions and carry identical rationale.
    ====================================================================== -->

    <!-- EI_EXPOSE_REP / EI_EXPOSE_REP2
         Service facades, operators, and domain models store injected
         dependencies (DataSource, SecurityAdapter, List/Map configs) by
         reference intentionally. These are internal APIs not exposed to
         untrusted callers. Defensive copies would break ActiveJ DI semantics
         and JPA/JDBC dirty-tracking where applicable.
         See analogous datacloud exclusion for full rationale. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- CT_CONSTRUCTOR_THROW
         Constructors in ActiveJ operator/service/config classes throw on
         invalid initialization (missing config, bad resource path). The DI
         framework surfaces these during wiring — no partially-constructed
         objects escape into production use. -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- UI_INHERITANCE_UNSAFE_GETRESOURCE
         getClass().getResource() is used to load YAML/JSON configs from the
         classpath. These classes are final or effectively sealed; the
         inheritance risk described by SpotBugs does not apply here. -->
    <Match>
        <Bug pattern="UI_INHERITANCE_UNSAFE_GETRESOURCE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- DM_CONVERT_CASE
         toUpperCase/toLowerCase without explicit Locale is used on internal
         ASCII identifiers (phase names, event types, operator IDs). These
         are never locale-sensitive user-facing strings. -->
    <Match>
        <Bug pattern="DM_CONVERT_CASE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- THROWS_METHOD_THROWS_RUNTIMEEXCEPTION
         ActiveJ HTTP route lambdas and serialization helpers throw
         RuntimeException as a re-throw wrapper after logging. The Eventloop
         and HttpRouter catch these at the boundary and convert them to HTTP
         500 responses. Using a subclass provides no benefit in this context. -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- REC_CATCH_EXCEPTION
         Top-level HTTP route handlers catch broad Exception to convert
         unhandled errors into structured HTTP 4xx/5xx responses and prevent
         Eventloop termination. All catches log the cause. -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- RV_RETURN_VALUE_IGNORED_BAD_PRACTICE
         ExecutorService.submit() and ArrayBlockingQueue.offer() results are
         intentionally ignored in fire-and-forget background task scheduling
         (config watch, backpressure queue). Failures are logged asynchronously. -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE,RV_RETURN_VALUE_IGNORED" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- NP_NULL_ON_SOME_PATH
         SpotBugs cannot trace null checks that precede lambda closures. In
         yappc service classes a null check in the outer method body protects
         inner lambdas and Promise chains from NPE. These are verified false
         positives confirmed by the explicit @Nullable / @NotNull contract
         and matching null-guard blocks. -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH,NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- DM_DEFAULT_ENCODING
         Charset-neutral byte operations in HTTP response builders. -->
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- DLS_DEAD_LOCAL_STORE / URF already-excluded patterns -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE,URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD,URF_UNREAD_FIELD" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- =====================================================================
         YAPPC Test sources — relaxed rules (mirrors datacloud test section)
    ====================================================================== -->

    <!-- THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION
         JUnit test methods declare "throws Exception" to reduce boilerplate.
         The test framework catches and reports any exceptions thrown. -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- VA_FORMAT_STRING_USES_NEWLINE
         Test methods use \n in String.format() to build multi-line SQL or
         YAML strings. Platform line-ending differences are irrelevant in
         unit/integration tests running against local JVM. -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- NM_CONFUSING
         Different test classes happen to have similarly–named lifecycle
         methods (setUp vs setup). These are in different packages and classes;
         there is no real naming collision or confusion within any single scope. -->
    <Match>
        <Bug pattern="NM_CONFUSING" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- ODR_OPEN_DATABASE_RESOURCE
         PreparedStatement and ResultSet mocks created via Mockito in test
         methods are never real JDBC resources; no actual connection or cursor
         is held. SpotBugs cannot distinguish mock objects from real resources. -->
    <Match>
        <Bug pattern="ODR_OPEN_DATABASE_RESOURCE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE
         Integration test DDL/DML uses string formatting with hardcoded
         table names and test-internal constants — never user-supplied input.
         The test database is ephemeral (Testcontainers / H2 in-memory). -->
    <Match>
        <Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD
         JUnit @BeforeAll / @Extensions write shared state to static fields
         for test isolation. Standard JUnit pattern. -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- DE_MIGHT_IGNORE / RV in test cleanup -->
    <Match>
        <Bug pattern="DE_MIGHT_IGNORE,RV_RETURN_VALUE_IGNORED_BAD_PRACTICE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
        <Class name="~.*Test.*" />
    </Match>

    <!-- VA_FORMAT_STRING_USES_NEWLINE — production code
         CodeGenerationService and similar classes use \n in String.format()
         code-template strings intentionally. Generated Java source files must
         use Unix LF line endings; %n would insert platform-specific CRLF on
         Windows hosts, corrupting the generated .java files. -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION — production and test code
         Serialization/deserialization helpers (e.g. JdbcApprovalService) and
         framework-boundary methods declare throws Exception to propagate
         checked Jackson/JDBC exceptions. Narrowing to specific exception types
         provides no benefit at call sites that already handle the broadest type. -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- BC_UNCONFIRMED_CAST
         GovernedMemoryPlane.store() switches on item.getType() (an enum set at
         construction time) and then casts item to the corresponding subtype.
         The cast is guaranteed by the type discriminator; SpotBugs cannot trace
         this semantic relationship statically. -->
    <Match>
        <Bug pattern="BC_UNCONFIRMED_CAST" />
        <Package name="~com\.ghatana\.yappc\b.*" />
    </Match>

    <!-- DCN_NULLPOINTER_EXCEPTION
         PolicyConfigLoader.loadFromClasspath() explicitly catches
