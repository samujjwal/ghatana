{
  "includeRoots": [
    "products/phr",
    "products/finance",
    "products/digital-marketing",
    "products/flashit"
  ],
  "fileAllowlist": [
    "docs/SECRETS_CLASSIFICATION.md",
    "docs/kernel/KERNEL_PURITY_RULES.md",
    "docs/process/PRODUCT_TRUTHFULNESS_POLICY.md"
  ],
  "excludeFragments": [
    "/node_modules/",
    "/dist/",
    "/build/",
    "/.git/",
    "/docs/archive/",
    "/.env.development",
    "/.env.local",
    "/.env.production",
    "/pnpm-lock.yaml",
    "/package-lock.json",
    "/yarn.lock"
  ],
  "scannableNames": [
    "Dockerfile",
    "package.json",
    "README.md",
    "REVIEW_REPORT.md"
  ],
  "scannableExtensions": [
    ".yml",
    ".yaml",
    ".env",
    ".example",
    ".sh"
  ],
  "patterns": [
    {
      "id": "PLACEHOLDER_SECRET",
      "pattern": "\\b(sk-placeholder|changeme|password123|your_super_secret_[a-z0-9_]*|your_[a-z0-9_]+(?:_id|_key|_secret|_dsn|_email)?|postgres:password|admin/admin|minioadmin123|guest/guest)\\b",
      "flags": "i"
    },
    {
      "id": "PRODUCT_DEFAULT_CREDENTIAL",
      "pattern": "\\b(ghatana123|redis123|flashit_dev_password|flashit_test_password)\\b"
    },
    {
      "id": "UNSAFE_ENV_DEFAULT",
      "pattern": "\\$\\{(?:[A-Z0-9_]*(?:PASSWORD|SECRET|TOKEN|KEY|DSN|DATABASE_URL|REDIS_URL)[A-Z0-9_]*):-[^}]+\\}"
    }
  ]
}
