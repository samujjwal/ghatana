{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.io/schemas/domain-registry.json",
  "title": "Domain Registry Schema",
  "type": "object",
  "required": ["version", "domains"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "domains": {
      "type": "array",
      "minItems": 17,
      "items": {
        "$ref": "#/definitions/domain"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "domain": {
      "type": "object",
      "required": [
        "id",
        "name",
        "ownerLayer",
        "classification",
        "primaryLocations",
        "secondaryLocations",
        "allowedConsumers",
        "forbiddenDependencies",
        "requiredChecks",
        "productAssociations",
        "currentStateEvidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ownerLayer": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "string",
          "enum": [
            "existing-executable",
            "existing-partial",
            "declared-only",
            "target-architecture",
            "anti-pattern"
          ]
        },
        "primaryLocations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "secondaryLocations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedConsumers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbiddenDependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredChecks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "productAssociations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "currentStateEvidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  }
}