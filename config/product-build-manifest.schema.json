{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.dev/schemas/product-build-manifest.schema.json",
  "title": "Product Build Manifest",
  "description": "Schema for validating product build manifests",
  "type": "object",
  "required": ["schemaVersion", "productId", "buildNumber", "version", "gitCommit", "gitBranch", "timestamp", "surfaces", "buildMetadata"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "productId": {
      "type": "string",
      "minLength": 1
    },
    "buildNumber": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "gitCommit": {
      "type": "string",
      "minLength": 1
    },
    "gitBranch": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["surface", "surfaceType", "buildStatus", "artifacts", "buildDurationMs"],
        "properties": {
          "surface": {
            "type": "string",
            "minLength": 1
          },
          "surfaceType": {
            "type": "string",
            "minLength": 1
          },
          "buildStatus": {
            "type": "string",
            "enum": ["succeeded", "failed", "skipped"]
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "path", "fingerprint", "sizeBytes", "producedBy"],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "fingerprint": {
                  "type": "string",
                  "minLength": 1
                },
                "sizeBytes": {
                  "type": "integer",
                  "minimum": 0
                },
                "producedBy": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "buildDurationMs": {
            "type": "integer",
            "minimum": 0
          },
          "buildLogPath": {
            "type": "string"
          }
        }
      }
    },
    "buildMetadata": {
      "type": "object",
      "required": ["buildTool", "buildToolVersion", "environment", "buildTrigger", "triggeredBy"],
      "properties": {
        "buildTool": {
          "type": "string",
          "minLength": 1
        },
        "buildToolVersion": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "buildTrigger": {
          "type": "string",
          "minLength": 1
        },
        "triggeredBy": {
          "type": "string",
          "minLength": 1
        },
        "ciRunId": {
          "type": "string"
        }
      }
    }
  }
}
