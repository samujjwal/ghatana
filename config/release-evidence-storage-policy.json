{
  "version": "1.0.0",
  "description": "Release evidence storage policy - separates canonical schemas from generated evidence",
  "policy": {
    "canonicalSchemas": {
      "location": "config/",
      "description": "Canonical schema definitions that define the structure of evidence",
      "files": [
        "canonical-product-registry-schema.json",
        "canonical-product-registry.json",
        "release-proof-waivers.json"
      ],
      "ownership": "platform-team",
      "versioning": "semantic-versioning"
    },
    "generatedEvidence": {
      "location": ".kernel/evidence/",
      "description": "Generated evidence from release proof scripts",
      "subdirectories": {
        "atomic-workflow-failure-injection": "Evidence from atomic workflow failure-injection tests",
        "runtime-dependency-failure-injection": "Evidence from runtime dependency failure-injection tests",
        "ai-governance-behavioral-proof": "Evidence from AI governance behavioral proof",
        "a11y-behavioral-tests": "Evidence from accessibility behavioral tests",
        "i18n-behavioral-proof": "Evidence from internationalization behavioral proof",
        "domain-invariant-tests": "Evidence from domain-specific invariant tests",
        "slo-cost-budgets": "Evidence from SLO and cost budget validation",
        "product-release-readiness": "Product-specific release readiness evidence"
      },
      "namingConvention": "{proof-type}-latest.json",
      "retentionPolicy": {
        "keepLatest": true,
        "keepHistorical": 10,
        "historicalNaming": "{proof-type}-{timestamp}.json"
      }
    },
    "releaseEvidence": {
      "location": "release-evidence/",
      "description": "Release-specific evidence for production releases",
      "subdirectories": {
        "smoke": "Smoke test evidence",
        "backup": "Backup drill evidence",
        "openapi-baseline": "OpenAPI baseline evidence"
      },
      "namingConvention": "{release-type}-{timestamp}.json"
    }
  },
  "validationRules": {
    "evidenceMustReferenceCommit": true,
    "evidenceMustHaveTimestamp": true,
    "evidenceMustIncludeViolations": true,
    "evidenceMustIncludeWarnings": true,
    "evidenceMustIncludeEvidenceItems": true,
    "fallbackPostureChecksNotAllowedInRelease": true
  },
  "separationOfConcerns": {
    "canonicalSchemas": {
      "purpose": "Define the structure and requirements for evidence",
      "modifiedBy": "Platform team via PR",
      "reviewRequired": true,
      "ciValidation": true
    },
    "generatedEvidence": {
      "purpose": "Generated by release proof scripts during CI/CD",
      "modifiedBy": "Automated scripts",
      "reviewRequired": false,
      "ciValidation": false
    }
  }
}
