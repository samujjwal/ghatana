{
  "scanScopes": [
    {
      "path": "platform",
      "critical": true,
      "description": "Kernel platform libraries - critical for all products"
    },
    {
      "path": "platform-kernel",
      "critical": true,
      "description": "Kernel core - critical infrastructure"
    },
    {
      "path": "platform-plugins",
      "critical": true,
      "description": "Kernel plugins - critical infrastructure"
    },
    {
      "path": "products/phr",
      "critical": true,
      "description": "PHR product - production healthcare system"
    },
    {
      "path": "products/digital-marketing",
      "critical": true,
      "description": "Digital Marketing OS - production marketing system"
    },
    {
      "path": "products/finance",
      "critical": true,
      "description": "Finance domain pack - production financial system"
    },
    {
      "path": "products/flashit",
      "critical": true,
      "description": "FlashIt product - production memory capture system"
    },
    {
      "path": "products/data-cloud",
      "critical": true,
      "description": "Data Cloud product - production data platform"
    },
    {
      "path": "shared-services",
      "critical": true,
      "description": "Shared services - production infrastructure"
    }
  ],
  "excludedPathSegments": [
    "node_modules",
    "build",
    "dist",
    ".gradle",
    "__tests__",
    "/test/",
    "/tests/",
    "test-utils",
    "scripts/",
    "monitoring/",
    "docs/",
    ".github/",
    "templates/",
    "code-audits/",
    "integration-tests/",
    "frontend/dist/",
    "frontend/build/",
    "frontend/generated/"
  ],
  "excludedFilenamePatterns": [
    "\\.test\\.[jt]sx?$",
    "\\.spec\\.[jt]sx?$",
    "Test\\.java$",
    "IT\\.java$",
    "Spec\\.java$",
    "\\.md$"
  ],
  "scanPatterns": [
    {
      "id": "TODO_FIXME_PROD",
      "severity": "critical",
      "pattern": "\\b(TODO|FIXME|HACK|TEMP|XXX)\\b",
      "description": "TODO / FIXME / HACK / TEMP marker in production code"
    },
    {
      "id": "NOT_IMPLEMENTED",
      "severity": "critical",
      "pattern": "not\\s+implemented|coming\\s+soon|placeholder|stub\\s+implementation|demo\\s+only|remove\\s+before\\s+prod",
      "description": "Explicit \"not implemented\" or placeholder comment"
    },
    {
      "id": "STUB_METHOD_NAME",
      "severity": "critical",
      "pattern": "\\b(stubMethod|fakeImpl|mockImpl|demoImpl|tempImpl|placeholderImpl)\\b",
      "description": "Method name suggests stub implementation"
    },
    {
      "id": "CONSOLE_LOG",
      "severity": "warning",
      "pattern": "console\\.(log|warn|error|debug|info)\\(",
      "description": "console.log/warn/error/debug/info in production TypeScript/JavaScript"
    },
    {
      "id": "SYSOUT_JAVA",
      "severity": "warning",
      "pattern": "System\\.out\\.(print|println)|e\\.printStackTrace\\(\\)",
      "description": "System.out.println or printStackTrace in production Java"
    },
    {
      "id": "RETURN_EMPTY_LIST",
      "severity": "warning",
      "pattern": "return\\s+(Collections\\.emptyList\\(\\)|List\\.of\\(\\)|new ArrayList<>\\(\\)|\\[\\])\\s*;",
      "description": "Method unconditionally returns empty collection — may be a stub"
    },
    {
      "id": "RETURN_NULL_PROMISE",
      "severity": "warning",
      "pattern": "return\\s+Promise\\.of\\(null\\)\\s*;",
      "description": "Method returns Promise.of(null) — likely a stub ActiveJ promise"
    },
    {
      "id": "MOCK_IMPORT_PROD",
      "severity": "critical",
      "pattern": "import\\s+.*from\\s+['\"].*\\/__mocks__\\/|import\\s+.*Mockito|import\\s+.*MockBean",
      "description": "Mock / Mockito import in production (non-test) file"
    },
    {
      "id": "VITEST_IN_PROD",
      "severity": "critical",
      "pattern": "\\bvi\\.fn\\(\\)|\\bvi\\.mock\\(|\\bvi\\.spyOn\\(",
      "description": "Vitest vi.fn/vi.mock/vi.spyOn in production file"
    }
  ]
}
