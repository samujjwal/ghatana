{
  "scanScopes": [
    {
      "path": "platform",
      "critical": true,
      "description": "Kernel platform libraries - critical for all products"
    },
    {
      "path": "platform-kernel",
      "critical": true,
      "description": "Kernel core - critical infrastructure"
    },
    {
      "path": "platform-plugins",
      "critical": true,
      "description": "Kernel plugins - critical infrastructure"
    },
    {
      "path": "products/phr",
      "critical": true,
      "description": "PHR product - production healthcare system"
    },
    {
      "path": "products/digital-marketing",
      "critical": true,
      "description": "Digital Marketing OS - production marketing system"
    },
    {
      "path": "products/finance",
      "critical": true,
      "description": "Finance domain pack - production financial system"
    },
    {
      "path": "products/flashit",
      "critical": true,
      "description": "FlashIt product - production memory capture system"
    },
    {
      "path": "products/data-cloud",
      "critical": true,
      "description": "Data Cloud product - production data platform"
    },
    {
      "path": "shared-services",
      "critical": true,
      "description": "Shared services - production infrastructure"
    }
  ],
  "excludedPathSegments": [
    "node_modules",
    "build",
    "dist",
    ".gradle",
    "__tests__",
    "/test/",
    "/tests/",
    "test-utils",
    "testFixtures",
    "__stories__",
    "platform/java/testing/",
    "platform/typescript/testing/",
    "scripts/",
    "monitoring/",
    "docs/",
    ".github/",
    "templates/",
    "code-audits/",
    "integration-tests/",
    "k6-tests/",
    "/example/",
    "frontend/dist/",
    "frontend/build/",
    "frontend/generated/",
    "generated/",
    "platform/typescript/testing/"
  ],
  "excludedFilenamePatterns": [
    "\\.test\\.[jt]sx?$",
    "\\.spec\\.[jt]sx?$",
    "\\.stories\\.[jt]sx?$",
    "vitest\\.setup\\.[jt]s$",
    "(^|/)test-(import|setup|seed)\\.(mjs|js|ts)$",
    "(^|/)generate-.*\\.(mjs|js|ts)$",
    "(^|/)seed\\.[jt]s$",
    "Test\\.java$",
    "IT\\.java$",
    "Spec\\.java$",
    "\\.md$"
  ],
  "scanPatterns": [
    {
      "id": "TODO_FIXME_PROD",
      "severity": "critical",
      "pattern": "(//|#|/\\*|\\*)\\s*(TODO|FIXME|HACK|TEMP|XXX)\\b",
      "description": "TODO / FIXME / HACK / TEMP marker in production code"
    },
    {
      "id": "NOT_IMPLEMENTED",
      "severity": "critical",
      "pattern": "not\\s+implemented|coming\\s+soon|placeholder\\s+(response|implementation|class|panel)|stub\\s+implementation|demo\\s+only|remove\\s+before\\s+prod",
      "description": "Explicit incomplete implementation marker"
    },
    {
      "id": "STUB_METHOD_NAME",
      "severity": "critical",
      "pattern": "\\b(stubMethod|fakeImpl|mockImpl|demoImpl|tempImpl|placeholderImpl)\\b",
      "description": "Method name suggests stub implementation"
    },
    {
      "id": "CONSOLE_LOG",
      "severity": "warning",
      "pattern": "console\\.(log|warn|error|debug|info)\\(",
      "description": "console.log/warn/error/debug/info in production TypeScript/JavaScript"
    },
    {
      "id": "SYSOUT_JAVA",
      "severity": "warning",
      "pattern": "System\\.out\\.(print|println)|e\\.printStackTrace\\(\\)",
      "description": "System.out.println or printStackTrace in production Java",
      "excludePaths": [
        "(^|/).*Cli\\.java$"
      ]
    },
    {
      "id": "RETURN_EMPTY_LIST",
      "severity": "warning",
      "pattern": "^\\s*return\\s+(Collections\\.emptyList\\(\\)|List\\.of\\(\\)|new ArrayList<>\\(\\)|\\[\\])\\s*;\\s*$",
      "description": "Method unconditionally returns empty collection — may be a stub"
    },
    {
      "id": "RETURN_NULL_PROMISE",
      "severity": "warning",
      "pattern": "^\\s*return\\s+Promise\\.of\\(null\\)\\s*;\\s*$",
      "description": "Method returns Promise.of(null) — likely a stub ActiveJ promise"
    },
    {
      "id": "BRIDGE_AUTH_ALLOW_ALL",
      "severity": "critical",
      "pattern": "BridgeAuthorizationService\\.allowAll\\(",
      "description": "Production bridge authorization must not use allow-all authorization"
    },
    {
      "id": "BRIDGE_AUDIT_NOOP",
      "severity": "critical",
      "pattern": "BridgeAuditEmitter\\.noOp\\(",
      "description": "Production bridge audit emission must not be no-op"
    },
    {
      "id": "BRIDGE_HEALTH_NOOP",
      "severity": "critical",
      "pattern": "BridgeHealthIndicator\\.noOp\\(",
      "description": "Production bridge health indicator must not be no-op"
    },
    {
      "id": "PROMISE_TRUE_HEALTH_DEFAULT",
      "severity": "critical",
      "pattern": "Promise\\.of\\(true\\)",
      "description": "Production health or authorization defaults must not unconditionally return Promise.of(true)",
      "includePaths": [
        "(^|/)(health|auth|authorization|security|policy|policies|gateway)(/|$)",
        "(^|/).*(Health|Auth|Authorization|Security|Policy|Gateway)[^/]*\\.(java|kt|ts|tsx|js|jsx)$"
      ]
    },
    {
      "id": "LIFECYCLE_RESULT_TRUNCATION",
      "severity": "critical",
      "pattern": "return\\s*\\{\\s*status\\s*:\\s*result\\.status\\s*\\}",
      "description": "Lifecycle bridges must not truncate execution results to status only"
    },
    {
      "id": "MOCK_IMPORT_PROD",
      "severity": "critical",
      "pattern": "import\\s+.*from\\s+['\"].*\\/__mocks__\\/|import\\s+.*Mockito|import\\s+.*MockBean",
      "description": "Mock / Mockito import in production (non-test) file"
    },
    {
      "id": "VITEST_IN_PROD",
      "severity": "critical",
      "pattern": "\\bvi\\.fn\\(\\)|\\bvi\\.mock\\(|\\bvi\\.spyOn\\(",
      "description": "Vitest vi.fn/vi.mock/vi.spyOn in production file"
    },
    {
      "id": "IN_MEMORY_MAP_STORAGE",
      "severity": "critical",
      "pattern": "\\b(new Map\\(\\)|providerStorage\\s*=\\s*Map)",
      "description": "In-memory Map storage for providers — use durable Data Cloud storage instead",
      "includePaths": [
        "(^|/)(provider|providers|repository|repositories|persistence|storage|stores|runtime-truth|provenance|approvals|artifacts|eventstore|event-store|secret)(/|$)"
      ]
    },
    {
      "id": "IN_MEMORY_COMMENT",
      "severity": "critical",
      "pattern": "//\\s*(TODO.*replace.*durable|replace.*with.*durable.*storage|placeholder.*storage|stub.*storage)",
      "description": "Comment indicates in-memory or placeholder storage that must be replaced with durable storage"
    }
  ]
}
