{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghatana.io/schemas/product-observability-flows.json",
  "title": "Product Observability Flow Manifest",
  "type": "object",
  "required": ["schemaVersion", "requiredFacets", "flows"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "requiredFacets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/flow"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "flow": {
      "type": "object",
      "required": ["product", "flow", "kind", "facets", "evidence"],
      "properties": {
        "product": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "flow": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": {
          "enum": ["api", "bridge", "background", "frontend", "job"]
        },
        "facets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["type", "file", "requiredFacets"],
      "properties": {
        "type": {
          "const": "behavior"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "requiredFacets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
