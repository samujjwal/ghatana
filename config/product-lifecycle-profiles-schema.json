{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana/config/product-lifecycle-profiles-schema.json",
  "title": "Product Lifecycle Profiles Schema",
  "description": "Schema for product lifecycle profile definitions",
  "type": "object",
  "required": ["version", "profiles"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "profiles": {
      "type": "object",
      "description": "Lifecycle profiles keyed by profile ID",
      "additionalProperties": {
        "$ref": "#/definitions/LifecycleProfile"
      }
    }
  },
  "definitions": {
    "LifecycleProfile": {
      "type": "object",
      "required": ["status", "safeForDefault", "description", "defaultSurfaces", "requiredGates", "defaultAdapters", "phaseOutputs"],
      "properties": {
        "status": {
          "type": "string",
          "description": "Lifecycle profile maturity",
          "enum": ["stable", "experimental"]
        },
        "safeForDefault": {
          "type": "boolean",
          "description": "Whether this profile is safe as a default for enabled lifecycle products"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this profile"
        },
        "defaultSurfaces": {
          "type": "object",
          "description": "Default surfaces to include for each phase",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "requiredGates": {
          "type": "object",
          "description": "Required gates for each phase",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "defaultAdapters": {
          "type": "object",
          "description": "Default adapters for surfaces and phases",
          "additionalProperties": {
            "type": "string"
          }
        },
        "optionalGates": {
          "type": "object",
          "description": "Optional gates for each phase",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "phaseOutputs": {
          "type": "object",
          "description": "Expected output artifact types by phase and surface",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "expectedArtifacts": {
          "type": "object",
          "description": "Legacy alias for expected outputs by phase and surface",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
