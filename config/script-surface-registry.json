      "status": "delete"
    },
    {
      "path": "products/dcmaar/scripts/cleanup-npm-files.sh",
      "kind": "developer-tool",
      "owner": "DCMAAR Team",
      "invokedBy": [],
      "destructive": true,
      "hasDryRun": false,
      "status": "delete"
    },
    {
      "path": "products/tutorputor/scripts/cleanup-empty-dirs.sh",
      "kind": "developer-tool",
      "owner": "Tutorputor Team",
      "invokedBy": [],
      "destructive": true,
      "hasDryRun": false,
      "status": "delete"
    }
  ]
}