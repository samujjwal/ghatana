{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Freshness Policy Schema",
  "description": "Schema for evidence freshness policy configuration defining staleness thresholds and generation modes",
  "type": "object",
  "required": ["version", "description", "defaultThresholdHours", "evidenceTypes", "evidenceFileMappings", "freshnessThresholds", "exemptions"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Policy version"
    },
    "description": {
      "type": "string",
      "description": "Policy description"
    },
    "defaultThresholdHours": {
      "type": "number",
      "minimum": 1,
      "description": "Default freshness threshold in hours"
    },
    "evidenceTypes": {
      "type": "object",
      "description": "Evidence type definitions with their freshness policies",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "thresholdHours", "critical", "failOnStale", "requireSourceBacking", "examples"],
        "properties": {
          "description": {
            "type": "string"
          },
          "thresholdHours": {
            "type": "number",
            "minimum": 1
          },
          "critical": {
            "type": "boolean"
          },
          "failOnStale": {
            "type": "boolean"
          },
          "requireSourceBacking": {
            "type": "boolean"
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidenceFileMappings": {
      "type": "object",
      "description": "Mapping from evidence file names to evidence types",
      "additionalProperties": {
        "type": "string",
        "enum": ["runtime-production", "runtime-executed", "generated-on-demand", "static-configuration", "release-summary"]
      }
    },
    "freshnessThresholds": {
      "type": "object",
      "description": "Named freshness thresholds for different evidence categories",
      "required": ["critical", "standard", "relaxed", "static"],
      "properties": {
        "critical": {
          "type": "number",
          "minimum": 1
        },
        "standard": {
          "type": "number",
          "minimum": 1
        },
        "relaxed": {
          "type": "number",
          "minimum": 1
        },
        "static": {
          "type": "number",
          "minimum": 1
        }
      }
    },
    "exemptions": {
      "type": "object",
      "required": ["description", "exemptedFiles", "exemptedPatterns"],
      "properties": {
        "description": {
          "type": "string"
        },
        "exemptedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exemptedPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
