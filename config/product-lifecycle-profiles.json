  "profiles": {
    "standard-web-api-product": {
      "status": "stable",
      "description": "A product with backend API and web UI surfaces",
      "defaultSurfaces": {
        "dev": [
          "backend-api",
          "web"
        ],
        "validate": [
          "backend-api",
          "web"
        ],
        "test": [
          "backend-api",
          "web"
        ],
        "build": [
          "backend-api",
          "web"
        ],
        "package": [
          "backend-api",
          "web"
        ],
        "deploy": [
          "backend-api",
          "web"
        ]
      },
      "requiredGates": {
        "validate": [
          "registry-validation",
          "manifest-validation",
          "lifecycle-contract-validation"
        ],
        "build": [
          "registry-validation",
          "manifest-validation",
          "typecheck",
          "unit-test",
          "conformance"
        ],
        "deploy": [
          "artifact-validation",
          "environment-validation",
          "health-check",
          "observability-check"
        ]
      },
      "optionalGates": {
        "validate": [
          "security-preflight",
          "policy-action-resource-check",
          "plugin-binding-check"
        ],
        "build": [
          "security-scan",
          "license-policy",
          "bundle-budget"
        ],
        "deploy": [
          "security-scan",
          "privacy-check",
          "license-policy",
          "conformance",
          "e2e",
          "performance",
          "rollback-plan",
          "approval"
        ]
      },
      "defaultAdapters": {
        "backend-api": "gradle-java-service",
        "web": "pnpm-vite-react"
      },
      "expectedArtifacts": {
        "build": {
          "backend-api": [
            "jvm-service"
          ],
          "web": [
            "static-web-bundle"
          ]
        },
        "package": {
          "backend-api": [
            "container-image"
          ],
          "web": [
            "container-image"
          ]
        }
      },
      "safeForDefault": true,
      "phaseOutputs": {
        "build": {
          "backend-api": [
            "jvm-service"
          ],
          "web": [
            "static-web-bundle"
          ]
        },
        "package": {
          "backend-api": [
            "container-image"
          ],
          "web": [
            "container-image"
          ]
        }
      }
    },
