# Build outputs
build/
dist/
out/
target/
*.class

# Dependencies
node_modules/
.pnpm-store/
# pnpm workspace: nested npm lockfiles are not authoritative
# The root pnpm-lock.yaml is the only JS lockfile authority
products/**/package-lock.json
platform/**/package-lock.json
libs/**/package-lock.json
shared-services/**/package-lock.json

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# Gradle
.gradle/
gradle-app.setting
!gradle-wrapper.jar
bin/
build-logic/conventions/bin/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment
.env
.env.development
.env.local
.env.*
.env.*.local
!.env.example

# Test output
coverage/
test-results/
**/playwright-report/
**/test-results.json
**/test-results.xml
**/test_results.txt
.nyc_output/
playwright-report.json
products/**/playwright-report.json

# TypeScript
*.tsbuildinfo
dist-ts/
# Prevent compiled output in source directories (platform and products)
platform/typescript/**/src/**/*.js
platform/typescript/**/src/**/*.d.ts
platform/typescript/**/src/**/*.js.map
platform/typescript/**/src/**/*.d.ts.map
# Products libs/contracts: compiled JS artifacts should only live in dist/
products/*/libs/**/src/**/*.js
products/*/libs/**/src/**/*.js.map
products/*/contracts/**/*.js
products/*/contracts/**/*.js.map
# Prevent dist-ts in modules
products/*/modules/**/dist-ts/

# Turbo
.turbo/

# Generated docs artifacts
**/.docusaurus/

# Local command/run outputs
*_output.txt
*output*.txt
type_check_*.txt
type-check-*.txt
typecheck_*.txt
compose_output.txt
Compilation

# Heap dumps
*.hprof

# Temporary files
*.tmp
*.bak

# Stale/archival files
*.old.*

# Python-specific artifacts
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
dist/
build/
.Python
python-env/
venv/
env/
ENV/
.eggs/
*.egg
