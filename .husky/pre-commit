#!/usr/bin/env sh
# Run lint-staged to enforce formatting and linting rules on staged TypeScript/JavaScript files.
pnpm exec lint-staged

# Validate Gradle build files if any are staged
if git diff --cached --name-only | grep -E "build\.gradle\.kts|\.versions\.toml|settings.gradle.kts"; then
    echo "Checking Gradle build files..."
    ./scripts/validate-gradle-build.sh || exit 1
fi

# Check generated API types for data-cloud UI if OpenAPI specs or generated types are staged
if git diff --cached --name-only | grep -E "products/data-cloud/contracts/openapi/|products/data-cloud/delivery/ui/src/contracts/generated/"; then
    echo "Checking generated API types for data-cloud UI..."
    cd products/data-cloud/delivery/ui && pnpm check:api-types || exit 1
fi
