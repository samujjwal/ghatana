# Studio production profile example. Replace all placeholder values before deploy.
VITE_STUDIO_DEPLOYMENT_PROFILE=production
VITE_STUDIO_ENABLE_PRODUCTION_ACQUISITION=true
VITE_STUDIO_SOURCE_ACQUISITION_BACKEND=kernel
VITE_STUDIO_ENABLE_KERNEL_WORKFLOW_PERSISTENCE=true
VITE_STUDIO_REQUIRE_KERNEL_WORKFLOW_PERSISTENCE=true
VITE_GHATANA_KERNEL_API_BASE_URL=https://kernel.example.com
VITE_STUDIO_TENANT_ID=tenant-example
VITE_STUDIO_WORKSPACE_ID=workspace-example
VITE_STUDIO_PROJECT_ID=project-example
VITE_STUDIO_AUTH_TOKEN=replace-with-production-token
