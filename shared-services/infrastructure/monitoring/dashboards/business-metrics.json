{
    "dashboard": {
        "title": "Business Metrics - Ghatana Platform",
        "uid": "ghatana-business-metrics",
        "tags": [
            "ghatana",
            "business",
            "kpi"
        ],
        "timezone": "browser",
        "schemaVersion": 36,
        "version": 1,
        "refresh": "1m",
        "time": {
            "from": "now-24h",
            "to": "now"
        },
        "panels": [
            {
                "id": 1,
                "title": "Total Events Ingested",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum(increase(eventcloud_events_appended_total[24h]))",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "short",
                        "decimals": 0,
                        "color": {
                            "mode": "thresholds"
                        },
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "value": 0,
                                    "color": "red"
                                },
                                {
                                    "value": 1000,
                                    "color": "yellow"
                                },
                                {
                                    "value": 10000,
                                    "color": "green"
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 2,
                "title": "Active Users (24h)",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 6,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "count(count by (user_id) (auth_authentication_success_total{timestamp>=(time() - 86400)}))",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "short",
                        "decimals": 0
                    }
                }
            },
            {
                "id": 3,
                "title": "Task Completion Rate",
                "type": "gauge",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 12,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum(rate(virtualorg_task_completed_total[1h])) / sum(rate(virtualorg_task_created_total[1h])) * 100",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "min": 0,
                        "max": 100,
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "value": 0,
                                    "color": "red"
                                },
                                {
                                    "value": 70,
                                    "color": "yellow"
                                },
                                {
                                    "value": 90,
                                    "color": "green"
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 4,
                "title": "AI Model Inference Count",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 6,
                    "x": 18,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "sum(increase(ai_inference_requests_total[24h]))",
                        "refId": "A"
                    }
                ]
            },
            {
                "id": 5,
                "title": "Events by Type (24h)",
                "type": "piechart",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 0,
                    "y": 4
                },
                "targets": [
                    {
                        "expr": "sum by (event_type) (increase(eventcloud_events_appended_total[24h]))",
                        "legendFormat": "{{event_type}}",
                        "refId": "A"
                    }
                ]
            },
            {
                "id": 6,
                "title": "Revenue by Tenant (24h)",
                "type": "bargauge",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 8,
                    "y": 4
                },
                "targets": [
                    {
                        "expr": "sum by (tenant) (business_revenue_total{period=\"24h\"})",
                        "legendFormat": "{{tenant}}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "currencyUSD"
                    }
                }
            },
            {
                "id": 7,
                "title": "Top Active Tenants",
                "type": "table",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 16,
                    "y": 4
                },
                "targets": [
                    {
                        "expr": "topk(10, sum by (tenant) (rate(http_requests_total[1h])))",
                        "format": "table",
                        "instant": true,
                        "refId": "A"
                    }
                ]
            },
            {
                "id": 8,
                "title": "Pattern Detection Rate",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 12
                },
                "targets": [
                    {
                        "expr": "sum(rate(pattern_detected_total[5m])) by (pattern_type)",
                        "legendFormat": "{{pattern_type}}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "ops",
                        "custom": {
                            "drawStyle": "line",
                            "fillOpacity": 10,
                            "showPoints": "never"
                        }
                    }
                }
            },
            {
                "id": 9,
                "title": "Workflow Execution Time (Avg)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 12
                },
                "targets": [
                    {
                        "expr": "avg(virtualorg_workflow_duration_seconds) by (workflow_type)",
                        "legendFormat": "{{workflow_type}}",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "s"
                    }
                }
            },
            {
                "id": 10,
                "title": "Agent Activity Heatmap",
                "type": "heatmap",
                "gridPos": {
                    "h": 8,
                    "w": 24,
                    "x": 0,
                    "y": 20
                },
                "targets": [
                    {
                        "expr": "sum by (agent_id, le) (rate(virtualorg_agent_execution_duration_bucket[5m]))",
                        "format": "heatmap",
                        "refId": "A"
                    }
                ],
                "fieldConfig": {
                    "defaults": {
                        "unit": "s"
                    }
                }
            }
        ]
    }
}