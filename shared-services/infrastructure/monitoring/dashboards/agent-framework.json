{
  "annotations": { "list": [] },
  "description": "Agent Framework — custom agents, LLM inference, operator SPI, and confidence tracking",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Agent Processing",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Agent Invocation Rate",
      "targets": [
        { "expr": "sum(rate(agent_invocations_total{instance=~\"$instance\"}[5m])) by (agent_id, agent_type)", "legendFormat": "{{agent_id}} ({{agent_type}})", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Agent Processing Latency",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(agent_processing_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, agent_id))", "legendFormat": "{{agent_id}} p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(agent_processing_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, agent_id))", "legendFormat": "{{agent_id}} p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(agent_processing_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, agent_id))", "legendFormat": "{{agent_id}} p99", "refId": "C" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Agent Results by Status",
      "targets": [
        { "expr": "sum(rate(agent_results_total{instance=~\"$instance\"}[5m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd", "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 },
          "min": 0, "max": 1, "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min"] }, "tooltip": { "mode": "multi" } },
      "title": "Agent Confidence Scores",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(agent_confidence_score_bucket{instance=~\"$instance\"}[5m])) by (le, agent_id))", "legendFormat": "{{agent_id}} median", "refId": "A" },
        { "expr": "histogram_quantile(0.05, sum(rate(agent_confidence_score_bucket{instance=~\"$instance\"}[5m])) by (le, agent_id))", "legendFormat": "{{agent_id}} p5 (low)", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "green", "value": 0.05 } ] }, "unit": "percentunit" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Agent Error Rate",
      "targets": [
        { "expr": "sum(rate(agent_results_total{status=\"ERROR\", instance=~\"$instance\"}[5m])) / sum(rate(agent_invocations_total{instance=~\"$instance\"}[5m]))", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 10,
      "title": "LLM Agent",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "LLM Inference Latency",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llm_inference_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, model))", "legendFormat": "{{model}} p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(llm_inference_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, model))", "legendFormat": "{{model}} p95", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "LLM Token Usage",
      "targets": [
        { "expr": "sum(rate(llm_tokens_total{instance=~\"$instance\"}[5m])) by (model, direction)", "legendFormat": "{{model}} {{direction}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "LLM Calls (5m)",
      "targets": [
        { "expr": "sum(increase(llm_inference_duration_seconds_count{instance=~\"$instance\"}[5m]))", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] }, "unit": "s" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 26 },
      "id": 14,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg LLM Latency",
      "targets": [
        { "expr": "sum(rate(llm_inference_duration_seconds_sum{instance=~\"$instance\"}[5m])) / sum(rate(llm_inference_duration_seconds_count{instance=~\"$instance\"}[5m]))", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 20,
      "title": "Operator SPI",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "title": "Operator Processing Rate",
      "targets": [
        { "expr": "sum(rate(operator_process_count_total{instance=~\"$instance\"}[5m])) by (operator_type, operator_name)", "legendFormat": "{{operator_type}}/{{operator_name}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "title": "Operator Latency (p95/p99)",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(operator_process_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, operator_type))", "legendFormat": "{{operator_type}} p95", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(operator_process_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, operator_type))", "legendFormat": "{{operator_type}} p99", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "id": 23,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "title": "Operator Errors by Type",
      "targets": [
        { "expr": "sum(rate(operator_process_errors_total{instance=~\"$instance\"}[5m])) by (operator_type, error_class)", "legendFormat": "{{operator_type}} — {{error_class}}", "refId": "A" }
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["agent-framework", "llm", "operators"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(agent_invocations_total, instance)",
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "query": { "query": "label_values(agent_invocations_total, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Agent Framework",
  "uid": "agent-framework",
  "version": 1
}
