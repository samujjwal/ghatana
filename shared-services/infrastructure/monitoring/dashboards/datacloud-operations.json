{
  "annotations": { "list": [] },
  "description": "Data-Cloud embedded storage, record type distribution, and graph operations",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Storage Backend Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Storage Operations Rate",
      "targets": [
        { "expr": "sum(rate(datacloud_store_operations_total{instance=~\"$instance\"}[5m])) by (backend, operation)", "legendFormat": "{{backend}} {{operation}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Storage Latency (p95)",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(datacloud_store_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, backend, operation))", "legendFormat": "{{backend}} {{operation}} p95", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(datacloud_store_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, backend, operation))", "legendFormat": "{{backend}} {{operation}} p99", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false, "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Storage Errors Rate",
      "targets": [
        { "expr": "sum(rate(datacloud_store_errors_total{instance=~\"$instance\"}[5m])) by (backend, error_type)", "legendFormat": "{{backend}} {{error_type}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Records (RocksDB)",
      "targets": [
        { "expr": "sum(datacloud_store_record_count{backend=\"rocksdb\", instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Records (SQLite)",
      "targets": [
        { "expr": "sum(datacloud_store_record_count{backend=\"sqlite\", instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Records (H2)",
      "targets": [
        { "expr": "sum(datacloud_store_record_count{backend=\"h2\", instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 } ] }, "unit": "decbytes" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Storage Disk Usage",
      "targets": [
        { "expr": "sum(datacloud_store_disk_bytes{instance=~\"$instance\"}) by (backend)", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 10,
      "title": "Record Type Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "id": 11,
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Records by Type",
      "targets": [
        { "expr": "sum(datacloud_records_total{instance=~\"$instance\"}) by (record_type)", "legendFormat": "{{record_type}}", "refId": "A" }
      ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Operations by Record Type",
      "targets": [
        { "expr": "sum(rate(datacloud_record_operations_total{instance=~\"$instance\"}[5m])) by (record_type, operation)", "legendFormat": "{{record_type}} {{operation}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "GRAPH vs DOCUMENT Ingestion",
      "targets": [
        { "expr": "sum(rate(datacloud_records_total{record_type=~\"GRAPH|DOCUMENT\", instance=~\"$instance\"}[5m])) by (record_type)", "legendFormat": "{{record_type}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 20,
      "title": "Graph Operations",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 23 },
      "id": 21,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Graph Nodes",
      "targets": [
        { "expr": "sum(datacloud_graph_nodes_total{instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "purple", "value": null } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 23 },
      "id": 22,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Graph Edges",
      "targets": [
        { "expr": "sum(datacloud_graph_edges_total{instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 23,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Graph Traversal Latency",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(datacloud_graph_traversal_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, operation))", "legendFormat": "{{operation}} p95", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(datacloud_graph_traversal_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le, operation))", "legendFormat": "{{operation}} p99", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 24,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Graph Query Rate",
      "targets": [
        { "expr": "sum(rate(datacloud_graph_queries_total{instance=~\"$instance\"}[5m])) by (operation)", "legendFormat": "{{operation}}", "refId": "A" }
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["data-cloud", "storage", "graph"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(datacloud_store_operations_total, instance)",
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "query": { "query": "label_values(datacloud_store_operations_total, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Data-Cloud Operations",
  "uid": "datacloud-operations",
  "version": 1
}
