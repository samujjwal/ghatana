{
  "annotations": { "list": [] },
  "description": "Cluster coordination — membership, leader election, distributed locks, and schema registry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Cluster Membership",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 3 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Nodes",
      "targets": [
        { "expr": "sum(cluster_nodes_active{instance=~\"$instance\"})", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Node Join/Leave Events (5m)",
      "targets": [
        { "expr": "sum(increase(cluster_membership_events_total{instance=~\"$instance\"}[5m])) by (event_type)", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Cluster Size Over Time",
      "targets": [
        { "expr": "sum(cluster_nodes_active{instance=~\"$instance\"})", "legendFormat": "total nodes", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 10,
      "title": "Leader Election",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "title": "Current Leaders by Resource",
      "targets": [
        { "expr": "cluster_leader_info{instance=~\"$instance\"}", "legendFormat": "{{resource}}: {{leader_node}}", "refId": "A" }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Leader Elections (5m)",
      "targets": [
        { "expr": "sum(increase(cluster_leader_elections_total{instance=~\"$instance\"}[5m])) by (resource)", "legendFormat": "{{resource}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Leader Lease TTL Remaining",
      "targets": [
        { "expr": "cluster_leader_lease_ttl_seconds{instance=~\"$instance\"}", "legendFormat": "{{resource}}", "refId": "A" }
