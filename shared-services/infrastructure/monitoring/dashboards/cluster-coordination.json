          "unit": "ops"
        }
      },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 22 },
      "id": 32,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Schema Validations Rate",
      "targets": [
        { "expr": "sum(rate(schema_validation_total{instance=~\"$instance\"}[5m])) by (result)", "legendFormat": "{{result}}", "refId": "A" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal" } },
