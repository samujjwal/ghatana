  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["cluster", "coordination", "schema-registry"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(cluster_nodes_active, instance)",
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "query": { "query": "label_values(cluster_nodes_active, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
