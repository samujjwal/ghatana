        { "expr": "histogram_quantile(0.99, sum(rate(cluster_lock_wait_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))", "legendFormat": "p99", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 30,
      "title": "Event Schema Registry",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] }, "unit": "short" }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 22 },
      "id": 31,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Registered Schemas",
      "targets": [
        { "expr": "sum(schema_registry_schemas_total{instance=~\"$instance\"})", "refId": "A" }
