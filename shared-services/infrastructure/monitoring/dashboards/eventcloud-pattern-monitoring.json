{
  "id": "eventcloud-pattern-monitoring",
  "title": "EventCloud - Pattern Monitoring",
  "tags": ["eventcloud", "pattern", "monitoring"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "query": "label_values(eventcloud_pattern_matches, tenant)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "pipelineId",
        "label": "Pipeline",
        "type": "query",
        "query": "label_values(eventcloud_pattern_matches{tenant=~\"$tenant\"}, pipelineId)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "patternId",
        "label": "Pattern",
        "type": "query",
        "query": "label_values(eventcloud_pattern_matches{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}, patternId)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pattern Match Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(eventcloud_pattern_matches{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\",patternId=~\"$patternId\"}[5m])",
          "legendFormat": "{{tenant}}/{{pipelineId}}/{{patternId}}",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "matches/sec",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "Pattern Processing Duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(eventcloud_pattern_processing_duration_bucket{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}[5m]))",
          "legendFormat": "95th percentile - {{tenant}}/{{pipelineId}}",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      }
    },
    {
      "id": 3,
      "title": "Pipeline Execution Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "rate(eventcloud_pipeline_duration_count{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}[5m])",
          "legendFormat": "{{tenant}}/{{pipelineId}}",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "executions/sec",
          "min": 0
        }
      }
    },
    {
      "id": 4,
      "title": "Agent Execution Duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(eventcloud_agent_execution_duration_bucket{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}[5m]))",
          "legendFormat": "{{agentType}} - {{tenant}}/{{pipelineId}}",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        }
      }
    },
    {
      "id": 5,
      "title": "Pattern Effectiveness",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "rate(eventcloud_pattern_matches{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}[1h]) / rate(eventcloud_event_count{tenant=~\"$tenant\"}[1h]) * 100",
          "legendFormat": "Match Rate %",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 10},
              {"color": "green", "value": 25}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Patterns",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "count(count by (patternId) (eventcloud_pattern_matches{tenant=~\"$tenant\",pipelineId=~\"$pipelineId\"}))",
          "legendFormat": "Patterns",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "patterns",
          "min": 0
        }
      }
    },
    {
      "id": 7,
      "title": "Audit Integrity Check",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "eventcloud_audit_integrity_duration{tenant=~\"$tenant\"}",
          "legendFormat": "Last Check (ms)",
          "interval": "30s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 5000}
            ]
          }
        }
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Pattern Changes",
        "datasource": "prometheus",
        "expr": "eventcloud_pattern_updated{tenant=~\"$tenant\"}",
        "iconColor": "rgba(255, 152, 48, 1)"
      },
      {
        "name": "Pipeline Updates",
        "datasource": "prometheus",
        "expr": "eventcloud_pipeline_updated{tenant=~\"$tenant\"}",
        "iconColor": "rgba(50, 172, 45, 1)"
      }
    ]
  },
  "links": [
    {
      "title": "EventLog Dashboard",
      "url": "/d/eventcloud-eventlog-monitoring",
      "type": "dashboards",
      "icon": "logs"
    },
    {
      "title": "LLM Dashboard",
      "url": "/d/eventcloud-llm-monitoring",
      "type": "dashboards",
      "icon": "bolt"
    },
    {
      "title": "System Overview",
      "url": "/d/eventcloud-system-overview",
      "type": "dashboards",
      "icon": "external link"
    }
  ]
}