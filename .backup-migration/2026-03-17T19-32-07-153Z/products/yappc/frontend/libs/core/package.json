{
  "name": "@yappc/core",
  "version": "1.0.0",
  "type": "module",
  "description": "YAPPC core library - types, utilities, API clients, and configuration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/yappc-types": "workspace:*",
    "@ghatana/yappc-utils": "workspace:*",
    "@ghatana/yappc-api": "workspace:*",
    "@ghatana/yappc-config": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3"
  }
}
