{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.com/schemas/domain-pack-schema.json",
  "title": "Domain Pack Schema",
  "description": "Schema for validating domain pack manifests",
  "type": "object",
  "properties": {
    "pack": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique identifier for the domain pack"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable name of the domain pack"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
          "description": "Semantic version"
        },
        "description": {
          "type": "string",
          "maxLength": 500,
          "description": "Description of the domain pack"
        },
        "domain": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "Domain type"
            },
            "region": {
              "type": "string",
              "description": "Geographic region"
            },
            "regulatory_frameworks": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Applicable regulatory frameworks"
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9.-]*$"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["BUSINESS_LOGIC", "COMPLIANCE", "INTEGRATION", "DATA_MANAGEMENT", "WORKFLOW"]
              },
              "description": {
                "type": "string"
              },
              "metadata": {
                "type": "object",
                "description": "Additional metadata"
              }
            },
            "required": ["id", "name", "type"]
          }
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required kernel capabilities"
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "target_capability": {
                "type": "string"
              }
            },
            "required": ["id", "name", "target_capability"]
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            },
            "required": ["name"]
          }
        },
        "deployment": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["domain-pack"]
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["type"]
        },
        "metadata": {
          "type": "object",
          "properties": {
            "created": {
              "type": "string",
              "format": "date"
            },
            "author": {
              "type": "string"
            },
            "documentation": {
              "type": "string"
            }
          }
        }
      },
      "required": ["id", "name", "version", "description", "capabilities"]
    }
  },
  "required": ["pack"],
  "additionalProperties": false
}
