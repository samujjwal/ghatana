{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.com/schemas/plugin-config-schema.json",
  "title": "Plugin Configuration Schema",
  "description": "Schema for validating plugin configuration in PluginManifest",
  "type": "object",
  "properties": {
    "pluginId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique identifier for the plugin (lowercase, alphanumeric with hyphens)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
      "description": "Semantic version (e.g., 1.0.0 or 1.0.0-beta)"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable description of the plugin"
    },
    "author": {
      "type": "string",
      "description": "Plugin author or organization"
    },
    "license": {
      "type": "string",
      "enum": ["Apache-2.0", "MIT", "GPL-3.0", "LGPL-3.0", "Proprietary", "Other"],
      "description": "License under which the plugin is distributed"
    },
    "mainClass": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9._]*$",
      "description": "Fully qualified main class name"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*:[a-z][a-z0-9-]*$"
      },
      "description": "List of capabilities provided by the plugin"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "description": "List of plugin dependencies"
    },
    "requiredKernelVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+"
      },
      "description": "Compatible kernel versions"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "description": "Plugin tags for categorization"
    },
    "tier": {
      "type": "string",
      "enum": ["CORE", "STANDARD", "PREMIUM", "CUSTOM"],
      "description": "Plugin tier affecting resource allocation"
    },
    "resourceQuotas": {
      "type": "object",
      "properties": {
        "maxMemoryMB": {
          "type": "integer",
          "minimum": 64,
          "description": "Maximum memory allocation in MB"
        },
        "maxCpuPercent": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 100.0,
          "description": "Maximum CPU percentage"
        },
        "maxFileDescriptors": {
          "type": "integer",
          "minimum": 32,
          "description": "Maximum file descriptors"
        }
      },
      "description": "Resource quota configuration"
    },
    "configSchema": {
      "type": "object",
      "description": "Plugin-specific configuration schema"
    }
  },
  "required": ["pluginId", "version"],
  "additionalProperties": false
}
