{
  "id": null,
  "uid": "phr-clinical-ops-observability-001",
  "title": "PHR - Clinical Operations Observability",
  "description": "Clinical workflow SLO dashboard for PHR appointments, telemedicine, and consent-sensitive APIs.",
  "tags": ["phr", "clinical", "ghatana"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PHR API Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{product=\"phr\"}[$__rate_interval])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PHR API Latency p95 / p99",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{product=\"phr\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{product=\"phr\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Consent and Emergency Access Signals",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(phr_consent_denials_total[$__rate_interval]))",
          "legendFormat": "consent denials"
        },
        {
          "expr": "sum(increase(phr_emergency_break_glass_events_total[$__rate_interval]))",
          "legendFormat": "break glass events"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reminder and Billing Bridge Stress",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "max(phr_appointment_reminder_queue_lag_seconds)",
          "legendFormat": "reminder lag seconds"
        },
        {
          "expr": "sum(rate(phr_finance_billing_bridge_failures_total[$__rate_interval]))",
          "legendFormat": "billing bridge failures"
        }
      ]
    }
  ]
}