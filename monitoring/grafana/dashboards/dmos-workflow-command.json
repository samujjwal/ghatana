{
  "dashboard": {
    "title": "DMOS Workflow & Command",
    "uid": "dmos-workflow-command",
    "tags": ["dmos", "workflow", "command"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Command Success Rate",
        "targets": [
          {
            "expr": "rate(dmos_command_success_total[5m]) / (rate(dmos_command_success_total[5m]) + rate(dmos_command_failure_total[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Command Failure Rate",
        "targets": [
          {
            "expr": "rate(dmos_command_failure_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Command Duration (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmos_command_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Workflow Execution Duration",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmos_workflow_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Active Workflows",
        "targets": [
          {
            "expr": "dmos_workflow_active_count"
          }
        ],
        "type": "stat"
      },
      {
        "title": "Pending Commands",
        "targets": [
          {
            "expr": "dmos_command_pending_count"
          }
        ],
        "type": "stat"
      }
    ]
  }
}
