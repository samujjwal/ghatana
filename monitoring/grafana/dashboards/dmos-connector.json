{
  "dashboard": {
    "title": "DMOS Connector",
    "uid": "dmos-connector",
    "tags": ["dmos", "connector"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Connector Call Rate",
        "targets": [
          {
            "expr": "rate(dmos_connector_calls_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Connector Failure Rate",
        "targets": [
          {
            "expr": "rate(dmos_connector_failure_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Connector Call Duration (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmos_connector_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Google Ads Connector Status",
        "targets": [
          {
            "expr": "dmos_connector_status{connector_type=\"GOOGLE_ADS\"}"
          }
        ],
        "type": "stat"
      }
    ]
  }
}
