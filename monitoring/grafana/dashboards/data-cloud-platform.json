    {
      "id": 41,
      "type": "traces",
      "title": "Trace Search",
      "description": "Search for traces by service, operation, duration, or tags.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 52
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "limit": 20,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces",
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": [
                "data-cloud"
              ],
              "valueType": "string"
            }
          ]
        }
      ],
      "options": {
        "frameType": "traceql"
      }
    },
    {
      "id": 42,
      "type": "timeseries",
