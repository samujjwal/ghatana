        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "id": 21,
      "targets": [
        {
          "expr": "avg(connector_clickhouse_duration_milliseconds_sum{service=\"data-cloud-platform\"}) / avg(connector_clickhouse_duration_milliseconds_count{service=\"data-cloud-platform\"})",
          "legendFormat": "Avg query duration",
          "refId": "A"
        }
