{
  "dashboard": {
    "title": "Finance Golden Signals",
    "panels": [
      {
        "title": "Finance Request Rate (Traffic)",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{service=\"finance-platform\"}[5m])",
            "legendFormat": "{{method}} {{status}}"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Finance Latency (p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{service=\"finance-platform\"}[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{service=\"finance-platform\"}[5m]))",
            "legendFormat": "p99"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Finance Error Rate",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{service=\"finance-platform\",status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count{service=\"finance-platform\"}[5m])",
            "legendFormat": "Error Rate"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "Finance CPU Usage",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{service=\"finance-platform\"}[5m])",
            "legendFormat": "CPU Usage"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "title": "Finance Memory Usage",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{service=\"finance-platform\",area=\"heap\"} / jvm_memory_max_bytes{service=\"finance-platform\",area=\"heap\"}",
            "legendFormat": "Heap Usage %"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "title": "Finance Transaction Throughput",
        "targets": [
          {
            "expr": "rate(finance_ledger_postings_total{service=\"finance-platform\"}[5m])",
            "legendFormat": "Ledger Postings/sec"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1,
    "uid": "finance-golden-signals"
  }
}
