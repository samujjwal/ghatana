{
  "dashboard": {
    "title": "PHR Golden Signals",
    "panels": [
      {
        "title": "PHR Request Rate (Traffic)",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{service=\"phr-platform\"}[5m])",
            "legendFormat": "{{method}} {{status}}"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "PHR Latency (p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{service=\"phr-platform\"}[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{service=\"phr-platform\"}[5m]))",
            "legendFormat": "p99"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "PHR Error Rate",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{service=\"phr-platform\",status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count{service=\"phr-platform\"}[5m])",
            "legendFormat": "Error Rate"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "PHR CPU Usage",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{service=\"phr-platform\"}[5m])",
            "legendFormat": "CPU Usage"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "title": "PHR Memory Usage",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{service=\"phr-platform\",area=\"heap\"} / jvm_memory_max_bytes{service=\"phr-platform\",area=\"heap\"}",
            "legendFormat": "Heap Usage %"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "title": "PHR JVM GC Time",
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum{service=\"phr-platform\"}[5m])",
            "legendFormat": "GC Time Rate"
          }
        ],
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1,
    "uid": "phr-golden-signals"
  }
}
