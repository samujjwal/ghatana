{
  "id": null,
  "uid": "finance-transaction-observability-001",
  "title": "Finance - Transaction Observability",
  "description": "SLO and tracing-adjacent operational dashboard for Finance transaction processing.",
  "tags": ["finance", "transactions", "ghatana"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Finance API Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{product=\"finance\"}[$__rate_interval])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Finance API Latency p95 / p99",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{product=\"finance\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{product=\"finance\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Finance API 5xx Error Rate",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{product=\"finance\",status=~\"5..\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count{product=\"finance\"}[$__rate_interval]))",
          "legendFormat": "5xx rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ledger Integrity Signals",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(finance_ledger_posting_errors_total[$__rate_interval]))",
          "legendFormat": "posting errors"
        },
        {
          "expr": "sum(increase(finance_ledger_unbalanced_entries_total[$__rate_interval]))",
          "legendFormat": "unbalanced entries"
        }
      ]
    }
  ]
}