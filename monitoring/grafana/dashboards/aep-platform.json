{
  "id": null,
  "uid": "aep-platform-001",
  "title": "AEP — Service Manager",
  "description": "Operational dashboard for the Agentic Event Processor (AEP) service manager.",
  "tags": ["aep", "platform", "ghatana"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"aep-service-manager\"}, instance)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP API",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"aep-service-manager\", instance=~\"$instance\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (ms)",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "5xx Error Rate (%)",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"aep-service-manager\", instance=~\"$instance\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"aep-service-manager\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Pipeline Engine",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pipeline Executions/s",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(aep_pipeline_executions_total{job=\"aep-service-manager\", instance=~\"$instance\"}[1m])) by (pipeline_id)",
          "legendFormat": "{{pipeline_id}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pipeline Errors/s",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "fixedColor": "red", "mode": "fixed" } } },
      "targets": [
        {
          "expr": "sum(rate(aep_pipeline_execution_errors_total{job=\"aep-service-manager\", instance=~\"$instance\"}[1m])) by (pipeline_id)",
          "legendFormat": "{{pipeline_id}} errors"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active Pipelines",
      "gridPos": { "x": 16, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [
        {
          "expr": "sum(aep_pipeline_active_count{job=\"aep-service-manager\", instance=~\"$instance\"})",
          "legendFormat": "Active Pipelines"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Orchestration Queue",
      "gridPos": { "x": 20, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 9000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(aep_orchestrator_queue_size{job=\"aep-service-manager\", instance=~\"$instance\"})",
          "legendFormat": "Queue Size"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Pattern Engine",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pattern Matches/s",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(aep_pattern_matches_total{job=\"aep-service-manager\", instance=~\"$instance\"}[1m])) by (pattern_id)",
          "legendFormat": "{{pattern_id}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Pattern Engine Pending Events",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 50000 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(aep_pattern_engine_pending_events{job=\"aep-service-manager\", instance=~\"$instance\"})",
          "legendFormat": "Pending Events"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "NFA Evaluation Latency (ms)",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(aep_pattern_nfa_evaluation_seconds_bucket{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99 NFA eval"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aep_pattern_nfa_evaluation_seconds_bucket{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 NFA eval"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Kafka",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Kafka Consumer Lag (aep-* groups)",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=~\"aep-.*\"}) by (topic, consumergroup)",
          "legendFormat": "{{consumergroup}} | {{topic}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Kafka Event Ingestion Rate",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(aep_kafka_events_consumed_total{job=\"aep-service-manager\", instance=~\"$instance\"}[1m])) by (topic)",
          "legendFormat": "consumed: {{topic}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "row",
      "title": "JVM",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "JVM Heap (used / max)",
      "gridPos": { "x": 0, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"aep-service-manager\", instance=~\"$instance\", area=\"heap\"}) by (instance)",
          "legendFormat": "{{instance}} used"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"aep-service-manager\", instance=~\"$instance\", area=\"heap\"}) by (instance)",
          "legendFormat": "{{instance}} max"
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "JVM Threads",
      "gridPos": { "x": 8, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(jvm_threads_live_threads{job=\"aep-service-manager\", instance=~\"$instance\"}) by (instance)",
          "legendFormat": "{{instance}} live"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "JVM CPU Usage",
      "gridPos": { "x": 16, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"aep-service-manager\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}} CPU"
        }
      ]
    },
    {
      "id": 21,
      "type": "row",
      "title": "Learning Loop & HITL",
      "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 22,
      "type": "stat",
      "title": "HITL Queue Depth",
      "gridPos": { "x": 0, "y": 46, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(aep_hitl_queue_depth{job=\"aep-service-manager\", instance=~\"$instance\"})",
          "legendFormat": "HITL Pending"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Learning Consolidation Rate",
      "gridPos": { "x": 6, "y": 46, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "rate(aep_learning_consolidations_total{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Consolidations/s"
        },
        {
          "expr": "rate(aep_learning_consolidation_failures_total{job=\"aep-service-manager\", instance=~\"$instance\"}[5m])",
          "legendFormat": "Failures/s"
        }
      ]
    }
  ]
}
