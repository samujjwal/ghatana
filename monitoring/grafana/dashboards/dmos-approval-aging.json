{
  "dashboard": {
    "title": "DMOS Approval Aging",
    "uid": "dmos-approval-aging",
    "tags": ["dmos", "approval"],
    "timezone": "browser",
    "refresh": "1m",
    "panels": [
      {
        "title": "Pending Approvals by Age",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmos_approval_age_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Approval Latency (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(dmos_approval_latency_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Pending Approvals Count",
        "targets": [
          {
            "expr": "dmos_approval_pending_count"
          }
        ],
        "type": "stat"
      },
      {
        "title": "Approvals Aging > 1 Hour",
        "targets": [
          {
            "expr": "count(dmos_approval_age_seconds_bucket{le=\"3600\"})"
          }
        ],
        "type": "stat"
      }
    ]
  }
}
