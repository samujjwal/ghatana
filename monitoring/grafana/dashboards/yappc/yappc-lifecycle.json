{
  "id": null,
  "uid": "yappc-lifecycle-001",
  "title": "YAPPC — Lifecycle Dashboard",
  "description": "Lifecycle phase transitions, stage gate evaluations, and force transition monitoring.",
  "tags": ["yappc", "lifecycle", "transitions"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "production,staging,dev",
        "current": { "text": "production", "value": "production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Phase Distribution",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Lifecycle Phase Distribution",
      "description": "Distribution of projects across lifecycle phases from LifecycleActivityLog events.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "tooltip": false, "legend": false } }
        }
      },
      "targets": [
        {
          "expr": "sum by (phase) (yappc_lifecycle_phase_count)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Stage Transition Rate (per hour)",
      "description": "Rate of stage transitions over time.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(yappc_stage_transitions_total[1h]))",
          "legendFormat": "Transitions/hour",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Gate Evaluation",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Gate Pass/Fail Rate by Stage",
      "description": "Pass/fail rate for gate evaluations across lifecycle stages.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(yappc_gate_evaluations_total{status=\"pass\"}[5m])) by (stage) / sum(rate(yappc_gate_evaluations_total[5m])) by (stage)",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Force Transition Count (24h)",
      "description": "Number of force transitions in the last 24 hours. Alert triggers when > 5/day.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(yappc_force_transitions_total[24h]))",
          "refId": "A"
        }
      ],
      "alert": {
        "conditions": [
          {
            "evaluator": {
              "params": [5],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": ["A", "5m", "now"]
            },
            "reducer": {
              "params": [],
              "type": "last"
            },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "5m",
        "handler": 1,
        "name": "Force Transition Alert",
        "noDataState": "no_data",
        "notifications": []
      }
    }
  ]
}
