{
  "name": "@dmos/ui",
  "version": "0.1.0",
  "private": true,
  "description": "DMOS — Digital Marketing Operating System UI",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run test:route-contract && tsc --noEmit && vite build && node ./scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:route-contract": "vitest run src/__tests__/route-contracts.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:realbackend": "playwright test --config=playwright.config.realbackend.ts",
    "generate-api-types": "openapi -i ../docs/api-contract.yaml -o src/types/api-generated.ts"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "openapi-typescript-codegen": "^0.30.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "author": "Ghatana Digital Marketing Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samujjwal/ghatana.git",
    "directory": "products/digital-marketing/ui"
  },
  "bugs": {
    "url": "https://github.com/samujjwal/ghatana/issues"
  },
  "homepage": "https://github.com/samujjwal/ghatana/tree/main/products/digital-marketing/ui#readme"
}
