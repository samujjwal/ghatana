{
  "name": "@dmos/ui",
  "version": "0.1.0",
  "private": true,
  "description": "DMOS — Digital Marketing Operating System UI",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run test:route-contract && tsc --noEmit && vite build && node ./scripts/check-bundle-budget.mjs",
    "build:docker": "vite build && node ./scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test e2e/a11y.spec.ts e2e/accessibility.spec.ts e2e/approval-detail.spec.ts e2e/campaign-dialogs.spec.ts e2e/dashboard.spec.ts e2e/keyboard-navigation.spec.ts e2e/responsive-layout.spec.ts e2e/screen-reader.spec.ts e2e/state-snapshots.spec.ts",
    "test:e2e:full": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:realbackend": "playwright test --config=playwright.config.realbackend.ts",
    "test": "pnpm run test:unit",
    "test:kernel-lifecycle-ui": "pnpm run test:route-contract",
    "test:route-contract": "vitest run src/__tests__/route-contracts.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate-api-types": "openapi -i ../docs/api-contract.yaml -o src/types/api-generated.ts"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "clsx": "catalog:",
    "jotai": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "openapi-typescript-codegen": "^0.30.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "author": "Ghatana Digital Marketing Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samujjwal/ghatana.git",
    "directory": "products/digital-marketing/ui"
  },
  "bugs": {
    "url": "https://github.com/samujjwal/ghatana/issues"
  },
  "homepage": "https://github.com/samujjwal/ghatana/tree/main/products/digital-marketing/ui#readme"
}
