{
  "schemaVersion": "1.0.0",
  "id": "digital-marketing",
  "version": "1.0.0",
  "product": "digital-marketing",
  "domain": "digital-marketing",
  "rulePrefix": "DM-",
  "kernelCapabilitiesConsumed": [
    "boundary-policy-evaluation",
    "audit-trail",
    "approval-workflow",
    "tenant-context"
  ],
  "policyActions": [
    "read",
    "write",
    "delete",
    "export",
    "sync",
    "launch",
    "pause",
    "resume",
    "increase",
    "publish",
    "execute"
  ],
  "policyResources": [
    "workspaces",
    "contacts",
    "audiences",
    "campaigns",
    "budgets",
    "content",
    "connectors"
  ],
  "pluginsConsumed": [
    "plugin-audit-trail",
    "plugin-compliance",
    "plugin-consent",
    "plugin-human-approval",
    "plugin-risk-management"
  ],
  "bridgesConsumed": [],
  "domainPacksProvided": [
    "digital-marketing-boundary-policy",
    "digital-marketing-compliance-rule-pack"
  ],
  "uiSurfaces": [
    "web"
  ],
  "runtimeServices": [
    "dm-api",
    "dm-application"
  ],
  "dataSensitivity": "marketing-consent",
  "productExtensions": {
    "productName": "Digital Marketing Operating System",
    "mvpScope": "non-regulated local service and small B2B businesses",
    "pluginBindings": {
      "plugin-audit-trail": {
        "requiredHooks": ["onProductBuildCompleted", "onProductDeployed"],
        "runtimeRequired": true
      },
      "plugin-compliance": {
        "requiredHooks": ["onProductValidated", "onProductDeployStarted"],
        "runtimeRequired": true
      }
    },
    "referenceConsumerPolicy": {
      "phrFinanceStatus": "reference-only",
      "forbiddenRulePrefixes": [
        "PHR-",
        "FIN-"
      ]
    },
    "productCode": "DM",
    "boundaryPolicyStoreClass": "com.ghatana.digitalmarketing.pack.DigitalMarketingBoundaryPolicyStore",
    "pluginBindingsClass": "com.ghatana.digitalmarketing.pack.DigitalMarketingPluginBindings",
    "complianceRulePackClass": "com.ghatana.digitalmarketing.pack.DigitalMarketingComplianceRulePack",
    "complianceRuleSets": [
      "DM_MARKETING_INTEGRITY",
      "DM_CONSENT_LIFECYCLE",
      "DM_AUDIT_TRACEABILITY",
      "DM_CAMPAIGN_PREFLIGHT",
      "DM_CLAIMS_DISCLOSURES",
      "DM_EMAIL_COMPLIANCE",
      "DM_CONNECTOR_EXECUTION_SAFETY"
    ]
  },
  "kind": "domain-pack",
  "policies": {
    "actions": [
      "read",
      "write",
      "delete",
      "export",
      "sync",
      "launch",
      "pause",
      "resume",
      "increase",
      "publish",
      "execute"
    ],
    "resources": [
      "workspaces",
      "contacts",
      "audiences",
      "campaigns",
      "budgets",
      "content",
      "connectors"
    ]
  },
  "surfaces": {
    "ui": [
      "web"
    ],
    "runtime": [
      "dm-api",
      "dm-application"
    ]
  },
  "capabilities": [
    {
      "id": "digital-marketing.campaign-operations",
      "name": "Campaign Operations",
      "type": "BUSINESS_LOGIC",
      "description": "Campaign strategy, launch, and optimization workflows"
    }
  ]
}
