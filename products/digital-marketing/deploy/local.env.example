# Digital Marketing Local Environment Configuration
# Copy this file to local.env and fill in your local values.
# local.env is gitignored — never commit credentials.

# Runtime environment
DMOS_ENV=development
DMOS_PERSISTENCE_TYPE=postgres

# Backend API
DMOS_API_PORT=8080

# Web frontend
DMOS_WEB_PORT=5173

# Database (used by the postgres service in local.compose.yaml)
POSTGRES_DB=digital_marketing
DATABASE_USERNAME=dmos
DATABASE_URL=jdbc:postgresql://postgres:5432/digital_marketing
# IMPORTANT: Set a strong local password before deploy; do not commit a real value here.
DATABASE_PASSWORD=<set-local-postgres-password>

# Logging
LOG_LEVEL=info

# Web Frontend build variables
VITE_API_BASE_URL=http://localhost:${DMOS_API_PORT:-8080}
VITE_ENV=development

# Optional: External Service URLs
# GOOGLE_ADS_API_URL=
# FACEBOOK_ADS_API_URL=

# Local smoke flow:
# 1. cp products/digital-marketing/deploy/local.env.example products/digital-marketing/deploy/local.env
# 2. Set DATABASE_PASSWORD in local.env
# 3. node scripts/kernel-product.mjs product package digital-marketing --dry-run --json
# 4. node scripts/kernel-product.mjs product deploy digital-marketing --env local --dry-run --json
# 5. node scripts/kernel-product.mjs product verify digital-marketing --env local --dry-run --json
