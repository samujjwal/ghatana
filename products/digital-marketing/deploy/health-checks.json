{
  "schemaVersion": "1.0.0",
  "productId": "digital-marketing",
  "environment": "local",
  "healthChecks": {
    "backend-api": {
      "type": "http",
      "path": "/health",
      "port": 8080,
      "intervalSeconds": 30,
      "timeoutSeconds": 5,
      "successThreshold": 3,
      "failureThreshold": 3
    },
    "web": {
      "type": "http",
      "path": "/",
      "port": 5173,
      "intervalSeconds": 30,
      "timeoutSeconds": 5,
      "successThreshold": 2,
      "failureThreshold": 3
    }
  }
}
