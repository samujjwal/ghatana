    "title" : "DMOS API",
    "description" : "Digital Marketing Orchestration System API",
    "version" : "1.0.0"
  },
  "components" : {
    "securitySchemes" : {
      "bearerAuth" : {
        "type" : "http",
        "bearerFormat" : "JWT",
        "scheme" : "bearer"
      }
    },
    "schemas" : {
      "CampaignType" : {
        "type" : "string",
        "enum" : [ "EMAIL", "SOCIAL", "PAID_SEARCH", "PUSH", "SMS", "OMNICHANNEL" ],
        "description" : "The channel or method type of a DMOS campaign"
      },
      "CampaignStatus" : {
        "type" : "string",
        "enum" : [ "DRAFT", "PENDING_APPROVAL", "APPROVED", "PENDING_LAUNCH", "LAUNCH_RUNNING", "LAUNCH_FAILED", "EXTERNAL_EXECUTION_BLOCKED", "LAUNCHED", "PAUSED", "COMPLETED", "ARCHIVED", "ROLLED_BACK" ],
        "description" : "Lifecycle status of a DMOS campaign"
      },
      "ErrorBody" : {
        "type" : "object",
        "required" : [ "error", "message", "status", "correlationId" ],
        "properties" : {
          "status" : {
            "type" : "integer",
            "description" : "HTTP status code"
          },
          "details" : {
            "type" : "object",
            "description" : "Additional error details"
          },
          "correlationId" : {
            "type" : "string",
            "description" : "Correlation ID for tracing"
          },
          "error" : {
            "type" : "string",
            "description" : "Error code (e.g., BAD_REQUEST, FORBIDDEN)"
          },
          "message" : {
            "type" : "string",
            "description" : "Human-readable error message"
          }
        }
      },
      "Campaign" : {
        "type" : "object",
        "required" : [ "id", "workspaceId", "name", "status", "type", "createdBy", "createdAt", "updatedAt" ],
        "properties" : {
          "status" : {
            "$ref" : "#/components/schemas/CampaignStatus"
          },
          "workspaceId" : {
            "type" : "string",
            "description" : "Workspace ID"
          },
          "createdBy" : {
            "type" : "string",
            "description" : "User who created the campaign"
          },
          "updatedAt" : {
            "type" : "string",
            "format" : "date-time",
            "description" : "Last update timestamp"
          },
          "createdAt" : {
            "type" : "string",
            "format" : "date-time",
            "description" : "Creation timestamp"
          },
          "name" : {
            "type" : "string",
            "description" : "Campaign name"
          },
          "id" : {
            "type" : "string",
            "description" : "Campaign ID"
          },
          "type" : {
            "$ref" : "#/components/schemas/CampaignType"
          }
        }
      },
      "CreateCampaignRequest" : {
        "type" : "object",
        "required" : [ "name", "type" ],
        "properties" : {
          "name" : {
            "type" : "string",
            "description" : "Campaign name"
          },
          "type" : {
            "$ref" : "#/components/schemas/CampaignType"
          }
        }
      },
      "CampaignListResponse" : {
        "type" : "object",
        "required" : [ "items", "count", "offset" ],
        "properties" : {
          "items" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/Campaign"
            }
          },
          "offset" : {
            "type" : "integer",
            "description" : "Pagination offset"
          },
          "count" : {
            "type" : "integer",
            "description" : "Number of items in this page"
          }
        }
      }
    }
  },
