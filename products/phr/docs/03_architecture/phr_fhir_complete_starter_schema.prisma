generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

enum ResourceStatus {
  draft
  active
  inactive
  entered_in_error
  unknown
}

enum PublicationStatus {
  draft
  active
  retired
  unknown
}

enum AdministrativeGender {
  male
  female
  other
  unknown
}

enum AccessGrantScope {
  read
  write
  export
  share
  emergency
}

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  countryCode String?  @db.VarChar(2)
  timezone    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations Organization[]
  patients      Patient[]
  practitioners Practitioner[]
}

model Identifier {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  system        String?
  value         String
  use           String?
  typeCode      String?
  assignerRef   String?
  periodStart   DateTime?
  periodEnd     DateTime?
  payload       Json?
  createdAt     DateTime @default(now())

  @@index([tenantId, system, value])
}

model Coding {
  id           String   @id @default(uuid()) @db.Uuid
  system       String?
  version      String?
  code         String?
  display      String?
  userSelected Boolean?
}

model HumanName {
  id          String   @id @default(uuid()) @db.Uuid
  use         String?
  family      String?
  given       String[]
  prefix      String[]
  suffix      String[]
  text        String?
  periodStart DateTime?
  periodEnd   DateTime?
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  use         String?
  type        String?
  text        String?
  line        String[]
  city        String?
  district    String?
  state       String?
  postalCode  String?
  country     String?
  periodStart DateTime?
  periodEnd   DateTime?
}

model ContactPoint {
  id          String   @id @default(uuid()) @db.Uuid
  system      String?
  value       String?
  use         String?
  rank        Int?
  periodStart DateTime?
  periodEnd   DateTime?
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  actorType      String
  actorId        String?
  patientId      String?  @db.Uuid
  resourceType   String
  resourceId     String
  action         String
  outcome        String?
  ipAddress      String?
  userAgent      String?
  occurredAt     DateTime @default(now())
  details        Json?

  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, patientId, occurredAt])
}

model ConsentGrant {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @db.Uuid
  patientId       String           @db.Uuid
  grantedToType   String
  grantedToId     String
  scope           AccessGrantScope
  startsAt        DateTime?
  endsAt          DateTime?
  status          ResourceStatus   @default(active)
  restrictions    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, patientId, grantedToType, grantedToId])
}

model Organization {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  logicalId         String   @unique
  active            Boolean  @default(true)
  name              String
  alias             String[]
  resource          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, name])
}

model Practitioner {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  logicalId         String   @unique
  active            Boolean  @default(true)
  gender            AdministrativeGender?
  birthDate         DateTime?
  resource          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, logicalId])
}

model Patient {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  logicalId         String   @unique
  active            Boolean  @default(true)
  gender            AdministrativeGender?
  birthDate         DateTime?
  deceasedBoolean   Boolean?
  deceasedDateTime  DateTime?
  managingOrgId     String?  @db.Uuid
  resource          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  encounters         Encounter[]
  observations       Observation[]
  conditions         Condition[]
  medicationRequests MedicationRequest[]
  appointments       Appointment[]
  consents           ConsentGrant[]

  @@index([tenantId, logicalId])
  @@index([tenantId, managingOrgId])
}

model Encounter {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  logicalId         String         @unique
  patientId         String?        @db.Uuid
  status            ResourceStatus @default(active)
  classCode         String?
  serviceType       String?
  startAt           DateTime?
  endAt             DateTime?
  resource          Json
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  observations       Observation[]
  conditions         Condition[]
  medicationRequests MedicationRequest[]

  @@index([tenantId, patientId, startAt])
}

model Observation {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  logicalId         String         @unique
  patientId         String?        @db.Uuid
  encounterId       String?        @db.Uuid
  status            ResourceStatus @default(active)
  codeSystem        String?
  code              String?
  valueQuantity     Decimal?       @db.Decimal(18,6)
  valueString       String?
  unit              String?
  effectiveDateTime DateTime?
  issuedAt          DateTime?
  resource          Json
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  patient   Patient?   @relation(fields: [patientId], references: [id], onDelete: SetNull)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId, code, effectiveDateTime])
  @@index([tenantId, encounterId])
}

model Condition {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid
  logicalId          String         @unique
  patientId          String?        @db.Uuid
  encounterId        String?        @db.Uuid
  status             ResourceStatus @default(active)
  clinicalStatus     String?
  verificationStatus String?
  category           String?
  codeSystem         String?
  code               String?
  onsetDateTime      DateTime?
  abatementDateTime  DateTime?
  resource           Json
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  patient   Patient?   @relation(fields: [patientId], references: [id], onDelete: SetNull)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId, code])
  @@index([tenantId, encounterId])
}

model Medication {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @db.Uuid
  logicalId         String            @unique
  status            PublicationStatus @default(active)
  codeSystem        String?
  code              String?
  formCode          String?
  amountNumerator   Decimal?          @db.Decimal(18,6)
  amountDenominator Decimal?          @db.Decimal(18,6)
  resource          Json
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  requests MedicationRequest[]

  @@index([tenantId, code])
}

model MedicationRequest {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  logicalId         String         @unique
  patientId         String?        @db.Uuid
  encounterId       String?        @db.Uuid
  medicationId      String?        @db.Uuid
  status            ResourceStatus @default(active)
  intent            String?
  authoredOn        DateTime?
  doNotPerform      Boolean?
  dosageInstruction Json?
  dispenseRequest   Json?
  resource          Json
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  patient    Patient?    @relation(fields: [patientId], references: [id], onDelete: SetNull)
  encounter  Encounter?  @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  medication Medication? @relation(fields: [medicationId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId, authoredOn])
  @@index([tenantId, encounterId])
  @@index([tenantId, medicationId])
}

model Appointment {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid
  logicalId          String         @unique
  patientId          String?        @db.Uuid
  status             ResourceStatus @default(active)
  serviceCategory    String?
  appointmentType    String?
  startAt            DateTime?
  endAt              DateTime?
  minutesDuration    Int?
  cancellationReason String?
  resource           Json
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId, startAt])
}


// ---------- Generic FHIR resource tables ----------

