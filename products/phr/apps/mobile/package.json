{
  "name": "@ghatana/phr-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform ios --platform android",
    "test": "tsx scripts/mobile-contract-test.ts",
    "test:a11y": "jest --selectProjects Node src/__tests__/accessibility-mobile.test.tsx src/screens/__tests__/EmergencyAccessScreen.test.tsx src/screens/__tests__/SettingsScreen.test.tsx --runInBand --silent",
    "test:jest": "jest --passWithNoTests --selectProjects Node",
    "test:jest:native": "jest --passWithNoTests --selectProjects iOS",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^11.4.1",
    "expo": "^55.0.14",
    "expo-local-authentication": "^55.0.13",
    "expo-notifications": "^55.0.18",
    "expo-secure-store": "^14.0.1",
    "react": "^19.2.5",
    "react-native": "0.85"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.15",
    "react-test-renderer": "19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
