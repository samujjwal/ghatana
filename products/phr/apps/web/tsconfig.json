{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["vite/client", "node", "react", "react-dom", "vitest/globals"],
    "paths": {
      "@/*": ["src/*"],
      "@ghatana/charts": [
        "../../../../platform/typescript/charts/src/index.ts"
      ],
      "@ghatana/kernel-product-contracts": [
        "../../../../platform/typescript/kernel-product-contracts/dist/index.d.ts"
      ],
      "@ghatana/kernel-product-contracts/route": [
        "../../../../platform/typescript/kernel-product-contracts/src/route/ProductRouteContract.ts"
      ],
      "@ghatana/product-shell": [
        "../../../../platform/typescript/product-shell/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
