{
  "name": "@ghatana/phr-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "pnpm exec eslint src --max-warnings=0",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test": "pnpm run test:unit",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "jotai": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "scheduler": "^0.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "author": "Ghatana PHR Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samujjwal/ghatana.git",
    "directory": "products/phr/apps/web"
  },
  "bugs": {
    "url": "https://github.com/samujjwal/ghatana/issues"
  },
  "homepage": "https://github.com/samujjwal/ghatana/tree/main/products/phr/apps/web#readme"
}
