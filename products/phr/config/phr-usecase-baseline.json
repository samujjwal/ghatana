      "id": "uc-patient-dashboard",
      "persona": "patient",
      "screen": "DashboardPage",
      "iaRoute": "/dashboard",
      "webRoute": "/dashboard",
      "mobileScreen": "dashboard",
      "backendApis": [
        "GET /mobile/dashboard",
        "GET /patients/:patientId",
        "GET /clinical/observations?patientId=:id",
        "GET /clinical/medications?patientId=:id",
        "GET /consents?patientId=:id"
      ],
      "kernelCapability": "patient-record-read",
      "offlineSupport": true,
      "status": "implemented",
      "notes": "Web and mobile both serve dashboard data. Mobile uses encrypted offline cache with AES-256-GCM."
