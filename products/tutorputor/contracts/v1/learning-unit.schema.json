{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://tutorputor.ghatana.com/schemas/learning-unit/v1",
    "title": "Learning Unit",
    "description": "Canonical Learning Unit schema for evidence-based learning content",
    "type": "object",
    "required": [
        "id",
        "version",
        "domain",
        "level",
        "status",
        "intent",
        "claims",
        "evidence",
        "tasks",
        "artifacts",
        "telemetry",
        "assessment",
        "localization"
    ],
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^LU_[a-z0-9_]+_v[0-9]+$",
            "description": "Unique identifier (format: LU_topic_name_v1)"
        },
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "domain": {
            "type": "string",
            "enum": [
                "physics",
                "math",
                "chemistry",
                "biology",
                "computer_science",
                "engineering"
            ]
        },
        "level": {
            "type": "string",
            "enum": [
                "elementary",
                "secondary",
                "high_school",
                "university",
                "professional"
            ]
        },
        "status": {
            "type": "string",
            "enum": [
                "draft",
                "review",
                "published",
                "archived"
            ]
        },
        "intent": {
            "$ref": "#/definitions/Intent"
        },
        "claims": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/Claim"
            }
        },
        "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/Evidence"
            }
        },
        "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/Task"
            }
        },
        "artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/Artifact"
            }
        },
        "telemetry": {
            "$ref": "#/definitions/TelemetryConfig"
        },
        "assessment": {
            "$ref": "#/definitions/AssessmentConfig"
        },
        "localization": {
            "$ref": "#/definitions/LocalizationConfig"
        },
        "credential": {
            "$ref": "#/definitions/CredentialConfig"
        },
        "publishReadiness": {
            "$ref": "#/definitions/PublishReadinessConfig"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time"
        },
        "createdBy": {
            "type": "string"
        },
        "tenantId": {
            "type": "string"
        }
    },
    "definitions": {
        "Intent": {
            "type": "object",
            "required": [
                "problem",
                "motivation"
            ],
            "properties": {
                "problem": {
                    "type": "string",
                    "minLength": 20,
                    "description": "The misconception or gap being addressed"
                },
                "motivation": {
                    "type": "string",
                    "minLength": 10,
                    "description": "Real-world motivation for learning this"
                },
                "targetMisconceptions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "LocalizedTextResource": {
            "type": "object",
            "required": [
                "default",
                "translations"
            ],
            "properties": {
                "default": {
                    "type": "string",
                    "minLength": 1
                },
                "translations": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            },
            "additionalProperties": false
        },
        "LocalizationFieldCoverage": {
            "type": "object",
            "required": [
                "contentBlocks",
                "captions",
                "transcripts",
                "prompts",
                "feedback",
                "rubrics",
                "accessibilityAlternatives"
            ],
            "properties": {
                "contentBlocks": { "type": "boolean" },
                "captions": { "type": "boolean" },
                "transcripts": { "type": "boolean" },
                "prompts": { "type": "boolean" },
                "feedback": { "type": "boolean" },
                "rubrics": { "type": "boolean" },
                "accessibilityAlternatives": { "type": "boolean" }
            },
            "additionalProperties": false
        },
        "LocalizationConfig": {
            "type": "object",
            "required": [
                "sourceLocale",
                "supportedLocales",
                "requiredFields",
                "publishRequiresCompleteCoverage"
            ],
            "properties": {
                "sourceLocale": {
                    "type": "string",
                    "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
                },
                "supportedLocales": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
                    }
                },
                "requiredFields": {
                    "$ref": "#/definitions/LocalizationFieldCoverage"
                },
                "publishRequiresCompleteCoverage": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "Claim": {
            "type": "object",
            "required": [
                "id",
                "text",
                "bloom"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^C[0-9]+$"
                },
                "text": {
                    "type": "string",
                    "minLength": 10
                },
                "bloom": {
                    "type": "string",
                    "enum": [
                        "remember",
                        "understand",
                        "apply",
                        "analyze",
                        "evaluate",
                        "create"
                    ]
                },
                "localizedText": {
                    "$ref": "#/definitions/LocalizedTextResource"
                },
                "prerequisites": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^LU_[a-z0-9_]+_v[0-9]+\\.C[0-9]+$"
                    }
                }
            }
        },
        "Observable": {
            "type": "object",
            "required": [
                "name",
                "type"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "string",
                        "number",
                        "boolean",
                        "enum"
                    ]
                },
                "enumValues": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "unit": {
                    "type": "string"
                }
            }
        },
        "Evidence": {
            "type": "object",
            "required": [
                "id",
                "claimRef",
                "type",
                "description",
                "observables"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^E[0-9]+$"
                },
                "claimRef": {
                    "type": "string",
                    "pattern": "^C[0-9]+$"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "prediction_vs_outcome",
                        "parameter_targeting",
                        "explanation_quality",
                        "construction_artifact"
                    ]
                },
                "description": {
                    "type": "string"
                },
                "observables": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/Observable"
                    }
                },
                "localizedDescription": {
                    "$ref": "#/definitions/LocalizedTextResource"
                }
            }
        },
        "Task": {
            "type": "object",
            "required": [
                "id",
                "type",
                "claimRef",
                "evidenceRef",
                "prompt"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^T[0-9]+$"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "prediction",
                        "simulation",
                        "explanation",
                        "construction"
                    ]
                },
                "claimRef": {
                    "type": "string",
                    "pattern": "^C[0-9]+$"
                },
                "evidenceRef": {
                    "type": "string",
                    "pattern": "^E[0-9]+$"
                },
                "prompt": {
                    "type": "string",
                    "minLength": 10
                },
                "localizedPrompt": {
                    "$ref": "#/definitions/LocalizedTextResource"
                },
                "localizedFeedback": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/LocalizedTextResource"
                    }
                },
                "confidenceRequired": {
                    "type": "boolean"
                },
                "options": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "localizedOptions": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "simulationRef": {
                    "type": "string"
                },
                "goal": {
                    "type": "string"
                },
                "localizedGoal": {
                    "$ref": "#/definitions/LocalizedTextResource"
                },
                "successCriteria": {
                    "type": "object",
                    "properties": {
                        "rmse": {
                            "type": "string"
                        },
                        "maxAttempts": {
                            "type": "integer"
                        },
                        "timeLimit": {
                            "type": "integer"
                        }
                    }
                },
                "minWords": {
                    "type": "integer"
                },
                "rubricRef": {
                    "type": "string"
                },
                "localizedRubric": {
                    "$ref": "#/definitions/LocalizedTextResource"
                },
                "artifactType": {
                    "type": "string"
                },
                "validationRules": {
                    "type": "object"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "prediction"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "confidenceRequired",
                            "options"
                        ],
                        "properties": {
                            "confidenceRequired": {
                                "const": true
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "simulation"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "simulationRef",
                            "goal",
                            "successCriteria"
                        ]
                    }
                }
            ]
        },
        "Artifact": {
            "type": "object",
            "required": [
                "type",
                "ref",
                "claims"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "simulation",
                        "explainer_video",
                        "visual_article",
                        "infographic"
                    ]
                },
                "ref": {
                    "type": "string"
                },
                "claims": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "pattern": "^C[0-9]+$"
                    }
                },
                "scaffolds": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^T[0-9]+$"
                    }
                },
                "localization": {
                    "type": "object",
                    "properties": {
                        "title": {
                            "$ref": "#/definitions/LocalizedTextResource"
                        },
                        "captions": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        },
                        "transcript": {
                            "$ref": "#/definitions/LocalizedTextResource"
                        },
                        "accessibilityAlternative": {
                            "$ref": "#/definitions/LocalizedTextResource"
                        }
                    }
                }
            }
        },
        "TelemetryConfig": {
            "type": "object",
            "required": [
                "events",
                "processFeatures"
            ],
            "properties": {
                "events": {
                    "type": "array",
                    "minItems": 3,
                    "items": {
                        "type": "string"
                    }
                },
                "processFeatures": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "VivaCondition": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "overconfident_wrong",
                        "speed_anomaly",
                        "pattern_mismatch",
                        "explanation_avoidance"
                    ]
                },
                "threshold": {
                    "type": "integer"
                },
                "completionTimePercentile": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                }
            }
        },
        "AssessmentConfig": {
            "type": "object",
            "required": [
                "model",
                "confidenceLevels",
                "scoring"
            ],
            "properties": {
                "model": {
                    "type": "string",
                    "enum": [
                        "cbm",
                        "cbm_plus_process",
                        "mastery_grid"
                    ]
                },
                "confidenceLevels": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "low",
                            "medium",
                            "high"
                        ]
                    }
                },
                "scoring": {
                    "type": "object",
                    "required": [
                        "correctHighConfidence",
                        "correctMediumConfidence",
                        "correctLowConfidence",
                        "incorrectHighConfidence",
                        "incorrectMediumConfidence",
                        "incorrectLowConfidence"
                    ],
                    "properties": {
                        "correctHighConfidence": {
                            "type": "integer"
                        },
                        "correctMediumConfidence": {
                            "type": "integer"
                        },
                        "correctLowConfidence": {
                            "type": "integer"
                        },
                        "incorrectHighConfidence": {
                            "type": "integer"
                        },
                        "incorrectMediumConfidence": {
                            "type": "integer"
                        },
                        "incorrectLowConfidence": {
                            "type": "integer"
                        }
                    }
                },
                "vivaTrigger": {
                    "type": "object",
                    "properties": {
                        "conditions": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/VivaCondition"
                            }
                        }
                    }
                },
                "localization": {
                    "type": "object",
                    "properties": {
                        "instructions": {
                            "$ref": "#/definitions/LocalizedTextResource"
                        },
                        "feedback": {
                            "type": "object",
                            "additionalProperties": {
                                "$ref": "#/definitions/LocalizedTextResource"
                            }
                        },
                        "rubrics": {
                            "type": "object",
                            "additionalProperties": {
                                "$ref": "#/definitions/LocalizedTextResource"
                            }
                        }
                    }
                }
            }
        },
        "CredentialConfig": {
            "type": "object",
            "required": [
                "skillTags",
                "issueOn"
            ],
            "properties": {
                "skillTags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "issueOn": {
                    "type": "string",
                    "enum": [
                        "all_claims_mastered",
                        "primary_claim_mastered",
                        "completion"
                    ]
                },
                "badgeRef": {
                    "type": "string"
                }
            }
        },
        "AIUseDisclosureConfig": {
            "type": "object",
            "required": [
                "required",
                "configured"
            ],
            "properties": {
                "required": {
                    "type": "boolean"
                },
                "configured": {
                    "type": "boolean"
                },
                "summary": {
                    "type": "string"
                }
            }
        },
        "PublishReadinessConfig": {
            "type": "object",
            "required": [
                "simulationConfigured",
                "assessmentCoverage",
                "accessibilityNotes",
                "telemetryEnabled",
                "aiUseDisclosure",
                "reviewStatus",
                "unresolvedValidationErrors"
            ],
            "properties": {
                "simulationConfigured": {
                    "type": "boolean"
                },
                "assessmentCoverage": {
                    "type": "string",
                    "enum": [
                        "none",
                        "partial",
                        "complete"
                    ]
                },
                "accessibilityNotes": {
                    "type": "string",
                    "minLength": 10
                },
                "telemetryEnabled": {
                    "type": "boolean"
                },
                "aiUseDisclosure": {
                    "$ref": "#/definitions/AIUseDisclosureConfig"
                },
                "reviewStatus": {
                    "type": "string",
                    "enum": [
                        "draft",
                        "in_review",
                        "sme_approved",
                        "qa_approved",
                        "accessibility_approved",
                        "complete"
                    ]
                },
                "unresolvedValidationErrors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
