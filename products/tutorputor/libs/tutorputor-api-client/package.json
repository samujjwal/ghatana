{
  "name": "@tutorputor/api-client",
  "version": "0.1.0",
  "description": "Typed TutorPutor API client derived from @tutorputor/contracts — eliminates hand-rolled per-app fetch wrappers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./learning": {
      "types": "./dist/routes/learning.d.ts",
      "import": "./dist/routes/learning.js"
    },
    "./auth": {
      "types": "./dist/routes/auth.d.ts",
      "import": "./dist/routes/auth.js"
    },
    "./content-studio": {
      "types": "./dist/routes/content-studio.d.ts",
      "import": "./dist/routes/content-studio.js"
    },
    "./analytics": {
      "types": "./dist/routes/analytics.d.ts",
      "import": "./dist/routes/analytics.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "lint": "../../../../node_modules/.bin/eslint src/ --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tutorputor/contracts": "workspace:*",
    "@tutorputor/auth-client": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
