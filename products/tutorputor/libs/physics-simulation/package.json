{
    "name": "@ghatana/tutorputor-physics-simulation",
    "version": "1.0.0",
    "description": "Cross-product physics simulation library with Konva rendering, entity management, and serialization",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./entities": "./src/entities/index.ts",
        "./rendering": "./src/rendering/index.ts",
        "./serialization": "./src/serialization/index.ts",
        "./hooks": "./src/hooks/index.ts",
        "./components": "./src/components/index.ts",
        "./adapters": "./src/adapters/index.ts",
        "./collaboration": "./src/collaboration/index.ts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src --ext .ts,.tsx",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "zod": "^4.3.6",
        "konva": "^10.2.0",
        "react-konva": "^19.2.2",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "yjs": "^13.6.29",
        "y-websocket": "^3.0.0",
        "y-indexeddb": "^9.0.12"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "react-dnd": "^16.0.0",
        "react-dnd-html5-backend": "^16.0.0",
        "jotai": "^2.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.10",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "keywords": [
        "physics",
        "simulation",
        "konva",
        "canvas",
        "education",
        "ghatana"
    ],
    "license": "MIT"
}