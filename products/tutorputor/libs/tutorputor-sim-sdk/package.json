{
    "name": "@ghatana/tutorputor-sim-sdk",
    "version": "0.1.0",
    "description": "Extensibility SDK for creating custom simulation kernels",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./testing": {
            "import": "./dist/testing/index.js",
            "types": "./dist/testing/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@ghatana/tutorputor-contracts": "workspace:*",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.2.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}