{
    "name": "@ghatana/tutorputor-sim-renderer",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Simulation rendering primitives for TutorPutor using PixiJS",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "storybook": "storybook dev -p 6007",
        "build-storybook": "storybook build -o storybook-static"
    },
    "dependencies": {
        "@ghatana/theme": "workspace:*",
        "@ghatana/tokens": "workspace:*",
        "@ghatana/utils": "workspace:*",
        "@ghatana/tutorputor-contracts": "workspace:*",
        "pixi.js": "^8.16.0",
        "d3-shape": "^3.2.0",
        "d3-scale": "^4.0.2",
        "d3": "^7.9.0",
        "three": "^0.182.0",
        "@react-three/fiber": "^9.5.0",
        "@react-three/drei": "^10.7.7",
        "ngl": "^2.4.0"
    },
    "devDependencies": {
        "@storybook/addon-a11y": "^10.2.4",
        "@storybook/addon-links": "^10.2.4",
        "@storybook/react": "^10.2.4",
        "@storybook/react-vite": "^10.2.4",
        "@types/d3-shape": "^3.1.8",
        "@types/d3-scale": "^4.0.9",
        "@types/d3": "^7.4.3",
        "storybook": "^10.2.4",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    }
}