{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "react"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/engine/examples/**/*",
    "src/engine/runtime/biomed-streaming.ts",
    "src/engine/runtime/chemistry-tutor-context.ts",
    "src/engine/author/enhanced-ai-confidence.ts",
    "src/engine/author/template-governance.ts",
    "src/engine/authoring/index.tsx",
    "src/engine/auto-retired.ts",
    "src/engine/auto/index.ts",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
