{
  "name": "@tutorputor/core",
  "version": "1.0.0",
  "description": "Core TutorPutor library combining data access, orchestration, and contracts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./db/testing": {
      "types": "./dist/db/testing.d.ts",
      "import": "./dist/db/testing.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    }
  },
  "files": [
    "dist",
    "prisma",
    "generated"
  ],
  "scripts": {
    "prepare": "prisma generate",
    "build": "tsc -p tsconfig.json && mkdir -p dist/generated && cp -r generated/prisma dist/generated/",
    "lint": "../../../../node_modules/.bin/eslint src/ --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:db:push": "prisma db push",
    "db:init": "node dist/db/init-db.js",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@tutorputor/contracts": "workspace:*",
    "ioredis": "^5.10.1",
    "prisma-redis-cache": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "prisma": "^7.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
