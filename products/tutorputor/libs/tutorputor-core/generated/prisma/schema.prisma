// Add relation to SimulationManifest
model SimulationManifestExtension {
  id                 String             @id
  simulationManifest SimulationManifest @relation("SimulationManifestExtensions", fields: [id], references: [id], onDelete: Cascade)

  metadata Json? // Additional extension metadata
}

model SimulationLinkAudit {
  id                   String             @id @default(cuid())
  experienceId         String
  simulationManifestId String
  simulationManifest   SimulationManifest @relation("SimulationLinkAudits", fields: [simulationManifestId], references: [id], onDelete: Cascade)

  action        String // "linked", "unlinked", "version_changed"
  beforeVersion String?
  afterVersion  String?
  actorId       String

