// =============================================================================
// Automation Rules (content studio experience triggers)
// =============================================================================

model AutomationRule {
  id           String   @id @default(cuid())
  tenantId     String
  experienceId String
  name         String
  description  String?
  trigger      String // JSON: { type, conditions }
  action       String // JSON: { type, params }
