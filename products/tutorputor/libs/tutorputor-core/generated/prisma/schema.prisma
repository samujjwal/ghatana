generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

enum ModuleDomain {
  MATH
  SCIENCE
  TECH
}

enum ModuleDifficulty {
  INTRO
  INTERMEDIATE
  ADVANCED
}

enum ModuleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AssessmentType {
  QUIZ
  PROJECT
  SIMULATION
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
}

enum LearnerDifficultyPreference {
  BEGINNER
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum LearnerModalityPreference {
  VISUAL
  AUDITORY
  KINESTHETIC
  READING
  MIXED
}

enum LearnerPacingPreference {
  SELF_PACED
  GUIDED
  ADAPTIVE
  INTENSIVE
}

enum KnowledgeGapSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum KnowledgeGapDetectionMethod {
  ASSESSMENT
  PREREQUISITE_CHECK
  ADAPTIVE_ANALYSIS
  LEARNER_REPORTED
  AI_PREDICTION
}

// =============================================================================
// Evidence Layer Enums (Phase 1)
// =============================================================================

enum EvidenceSourceType {
  OPENSTAX
  KHAN_ACADEMY
  WIKIPEDIA
  PEER_REVIEWED_JOURNAL
  TEXTBOOK
  CURRICULUM_STANDARD
  DOMAIN_EXPERT
  SIMULATION_RESULT
  CALCULATION
}

enum SupportKind {
  SUPPORTS
  CONTRADICTS
  NEUTRAL
  PARTIALLY_SUPPORTS
}

enum EvidenceFreshnessStatus {
  CURRENT
  STALE
  EXPIRED
  UNKNOWN
}

enum EvidenceVerificationState {
  UNVERIFIED
  VERIFIED
  DISPUTED
  FAILED_VERIFICATION
}

enum LearnerPathwayStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ListingVisibility {
  PUBLIC
  PRIVATE
}

model Module {
  id                   String           @id @default(cuid())
  tenantId             String
  slug                 String
  title                String
  domain               ModuleDomain
  difficulty           ModuleDifficulty
  estimatedTimeMinutes Int
  status               ModuleStatus     @default(PUBLISHED)
  description          String
  version              Int              @default(1)
  authorId             String?
  updatedBy            String?
  publishedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tags                ModuleTag[]
  learningObjectives  ModuleLearningObjective[]
  contentBlocks       ModuleContentBlock[]
  prerequisites       ModulePrerequisite[]      @relation("ModulePrerequisites")
  requiredBy          ModulePrerequisite[]      @relation("ModuleDependents")
  enrollments         Enrollment[]
  revisions           ModuleRevision[]
  marketplaceListings MarketplaceListing[]
  assessments         Assessment[]
  simulationTemplates SimulationTemplate[]
  simulationManifests SimulationManifest[]
  learningExperience  LearningExperience?

  @@unique([tenantId, slug])
  @@index([tenantId, domain])
  @@index([tenantId, status])
}

model ModuleTag {
  id       Int    @id @default(autoincrement())
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId String
  label    String

  @@unique([moduleId, label])
}

model ModuleLearningObjective {
  id            Int    @id @default(autoincrement())
  module        Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId      String
  label         String
  taxonomyLevel String
}

model ModuleContentBlock {
  id         String @id @default(cuid())
  module     Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  orderIndex Int
  blockType  String
  payload    Json
}

model ModulePrerequisite {
  module               Module @relation("ModulePrerequisites", fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId             String
  prerequisite         Module @relation("ModuleDependents", fields: [prerequisiteModuleId], references: [id], onDelete: Cascade)
  prerequisiteModuleId String

  @@id([moduleId, prerequisiteModuleId])
}

model ModuleRevision {
  id        String   @id @default(cuid())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
  version   Int
  snapshot  Json
  createdBy String
  createdAt DateTime @default(now())

  @@index([moduleId, version])
}

model Enrollment {
  id               String           @id @default(cuid())
  tenantId         String
  userId           String
  module           Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  status           EnrollmentStatus @default(NOT_STARTED)
  progressPercent  Int              @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  timeSpentSeconds Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([tenantId, userId, moduleId])
  @@index([tenantId, userId])
}

model Assessment {
  id               String           @id @default(cuid())
  tenantId         String
  module           Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  title            String
  type             AssessmentType   @default(QUIZ)
  status           AssessmentStatus @default(DRAFT)
  version          Int              @default(1)
  passingScore     Int              @default(80)
  attemptsAllowed  Int?
  timeLimitMinutes Int?
  createdBy        String
  updatedBy        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  objectives AssessmentObjective[]
  items      AssessmentItem[]
  attempts   AssessmentAttempt[]

  @@index([tenantId, moduleId])
  @@index([tenantId, status])
}

model AssessmentObjective {
  id            String     @id @default(cuid())
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  label         String
  taxonomyLevel String
}

model AssessmentItem {
  id           String     @id @default(cuid())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String
  orderIndex   Int
  itemType     String
  prompt       String
  stimulus     String?
  choices      Json?
  modelAnswer  String?
  rubric       String?
  points       Int        @default(10)
  metadata     Json?
}

model AssessmentAttempt {
  id               String                  @id @default(cuid())
  tenantId         String
  assessment       Assessment              @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId     String
  userId           String
  status           AssessmentAttemptStatus @default(IN_PROGRESS)
  responses        Json?
  scorePercent     Int?
  feedback         Json?
  startedAt        DateTime                @default(now())
  submittedAt      DateTime?
  gradedAt         DateTime?
  timeSpentSeconds Int?

  @@index([tenantId, userId])
  @@index([tenantId, assessmentId])
}

model AssessmentDraft {
  id        String   @id @default(cuid())
  tenantId  String
  moduleId  String
  createdBy String
  payload   Json
  createdAt DateTime @default(now())

  @@index([tenantId, moduleId])
  @@index([tenantId, createdBy])
}

model LearningEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  moduleId  String?
  eventType String
  payload   Json?
  timestamp DateTime @default(now())

  @@index([tenantId, eventType])
  @@index([tenantId, userId])
}

model MarketplaceListing {
  id          String            @id @default(cuid())
  tenantId    String
  module      Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId    String
  creatorId   String
  priceCents  Int               @default(0)
  status      ListingStatus     @default(DRAFT)
  visibility  ListingVisibility @default(PUBLIC)
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, moduleId])
  @@index([tenantId, creatorId])
}

// =============================================================================
// Learning Pathways
// =============================================================================

enum PathwayStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model LearningPath {
  id        String        @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  goal      String
  status    PathwayStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  nodes LearningPathNode[]

  @@unique([tenantId, userId, status])
  @@index([tenantId, userId])
}

model LearningPathNode {
  id          String       @id @default(cuid())
  pathId      String
  path        LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  moduleId    String
  orderIndex  Int
  isOptional  Boolean      @default(false)
  completedAt DateTime?

  @@unique([pathId, moduleId])
  @@index([pathId])
}

// =============================================================================
// Teacher/Classroom
// =============================================================================

model Classroom {
  id          String   @id @default(cuid())
  tenantId    String
  teacherId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roster      ClassroomStudent[]
  assignments ClassroomAssignment[]

  @@index([tenantId, teacherId])
}

model ClassroomStudent {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  userId      String
  displayName String
  email       String?
  enrolledAt  DateTime  @default(now())

  @@unique([classroomId, userId])
  @@index([classroomId])
}

model ClassroomAssignment {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  moduleId    String
  assignedAt  DateTime  @default(now())
  dueAt       DateTime?

  @@unique([classroomId, moduleId])
  @@index([classroomId])
}

// =============================================================================
// Collaboration (Q&A, Discussions)
// =============================================================================

enum ThreadStatus {
  OPEN
  RESOLVED
  CLOSED
}

model Thread {
  id         String       @id @default(cuid())
  tenantId   String
  moduleId   String?
  title      String
  status     ThreadStatus @default(OPEN)
  authorId   String
  authorName String
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  posts Post[]

  @@index([tenantId, moduleId])
  @@index([tenantId, status])
  @@index([tenantId, authorId])
}

model Post {
  id         String   @id @default(cuid())
  threadId   String
  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  content    String
  isAnswer   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([threadId])
}

enum HelpRequestStatus {
  PENDING
  ANSWERED
  ESCALATED
}

model HelpRequest {
  id         String            @id @default(cuid())
  tenantId   String
  userId     String
  moduleId   String
  question   String
  status     HelpRequestStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  answeredAt DateTime?

  @@index([tenantId, status])
  @@index([tenantId, userId])
}

// =============================================================================
// Billing/Payments
// =============================================================================

enum CheckoutStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model CheckoutSession {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  listingId   String
  amountCents Int
  status      CheckoutStatus @default(PENDING)
  paymentUrl  String?
  successUrl  String?
  cancelUrl   String?
  createdAt   DateTime       @default(now())
  completedAt DateTime?

  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model Purchase {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  listingId   String
  moduleId    String
  amountCents Int
  purchasedAt DateTime @default(now())

  @@unique([tenantId, userId, moduleId])
  @@index([tenantId, userId])
  @@index([tenantId, moduleId])
}

// =============================================================================
// Subscription & Payment Management
// =============================================================================

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  UNPAID
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  ANNUAL
}

model StripeCustomer {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  stripeCustomerId String   @unique
  email            String
  name             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions  Subscription[]
  paymentMethods PaymentMethod[]
  invoices       Invoice[]

  @@index([tenantId])
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  customer             StripeCustomer     @relation(fields: [stripeCustomerId], references: [stripeCustomerId], onDelete: Cascade)
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  tier                 SubscriptionTier
  status               SubscriptionStatus
  billingInterval      BillingInterval
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  invoices       Invoice[]
  usageSnapshots UsageSnapshot[]

  @@index([tenantId])
  @@index([stripeCustomerId])
  @@index([status])
}

model PaymentMethod {
  id                    String         @id @default(cuid())
  tenantId              String
  customer              StripeCustomer @relation(fields: [stripeCustomerId], references: [stripeCustomerId], onDelete: Cascade)
  stripeCustomerId      String
  stripePaymentMethodId String         @unique
  type                  String
  isDefault             Boolean        @default(false)
  lastFour              String?
  brand                 String?
  expMonth              Int?
  expYear               Int?
  createdAt             DateTime       @default(now())

  transactions Transaction[]

  @@index([tenantId])
  @@index([stripeCustomerId])
}

model Invoice {
  id               String         @id @default(cuid())
  tenantId         String
  customer         StripeCustomer @relation(fields: [stripeCustomerId], references: [stripeCustomerId], onDelete: Cascade)
  stripeCustomerId String
  subscription     Subscription?  @relation(fields: [subscriptionId], references: [id])
  subscriptionId   String?
  stripeInvoiceId  String         @unique
  number           String
  status           String
  currency         String
  subtotalCents    Int
  taxCents         Int
  totalCents       Int
  amountPaidCents  Int
  amountDueCents   Int
  dueDate          DateTime
  paidAt           DateTime?
  hostedInvoiceUrl String?
  invoicePdfUrl    String?
  createdAt        DateTime       @default(now())

  transactions Transaction[]

  @@index([tenantId])
  @@index([stripeCustomerId])
  @@index([subscriptionId])
  @@index([status])
}

model Transaction {
  id                    String         @id @default(cuid())
  tenantId              String
  invoice               Invoice?       @relation(fields: [invoiceId], references: [id])
  invoiceId             String?
  paymentMethod         PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId       String?
  stripePaymentIntentId String?
  stripeChargeId        String?
  type                  String
  status                String
  amountCents           Int
  currency              String
  failureReason         String?
  receiptUrl            String?
  createdAt             DateTime       @default(now())
  processedAt           DateTime?

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
}

model WebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  data          Json
  processed     Boolean   @default(false)
  processedAt   DateTime?
  error         String?
  createdAt     DateTime  @default(now())

  @@index([processed])
  @@index([type])
}

model UsageSnapshot {
  id             String       @id @default(cuid())
  tenantId       String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
  periodStart    DateTime
  periodEnd      DateTime
  users          Int          @default(0)
  modules        Int          @default(0)
  storageGB      Float        @default(0)
  classrooms     Int          @default(0)
  vrSessions     Int          @default(0)
  capturedAt     DateTime     @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([periodStart, periodEnd])
}

// =============================================================================
// LTI Integration
// =============================================================================

model LTIPlatform {
  id           String   @id @default(cuid())
  tenantId     String
  platformName String
  issuer       String
  clientId     String
  jwksUrl      String
  authUrl      String
  tokenUrl     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, issuer])
  @@index([tenantId])
}

// =============================================================================
// Social Learning - Study Groups (Block 4 - Days 41-45)
// =============================================================================

enum StudyGroupVisibility {
  PUBLIC
  PRIVATE
  CLASSROOM_ONLY
}

enum StudyGroupStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum StudyGroupRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

model StudyGroup {
  id              String               @id @default(cuid())
  tenantId        String
  name            String
  description     String
  coverImageUrl   String?
  createdBy       String
  visibility      StudyGroupVisibility @default(PUBLIC)
  maxMembers      Int                  @default(50)
  requireApproval Boolean              @default(false)
  allowGuestView  Boolean              @default(false)
  subjects        String // JSON array
  modules         String? // JSON array of module IDs
  memberCount     Int                  @default(1)
  status          StudyGroupStatus     @default(ACTIVE)
  lastActivityAt  DateTime             @default(now())
  archivedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  members      StudyGroupMember[]
  joinRequests StudyGroupJoinRequest[]
  invites      StudyGroupInvite[]
  sessions     StudySession[]
  chatRoom     ChatRoom?
  forum        Forum?
  sharedNotes  SharedNote[]

  @@index([tenantId, status])
  @@index([tenantId, visibility])
  @@index([tenantId, createdBy])
}

model StudyGroupMember {
  id                   String         @id @default(cuid())
  group                StudyGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId              String
  userId               String
  role                 StudyGroupRole @default(MEMBER)
  invitedBy            String?
  messagesCount        Int            @default(0)
  notificationsEnabled Boolean        @default(true)
  mutedUntil           DateTime?
  lastActiveAt         DateTime       @default(now())
  joinedAt             DateTime       @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model StudyGroupJoinRequest {
  id              String            @id @default(cuid())
  group           StudyGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId         String
  userId          String
  message         String?
  status          JoinRequestStatus @default(PENDING)
  reviewedBy      String?
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())

  @@unique([groupId, userId, status])
  @@index([groupId, status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model StudyGroupInvite {
  id           String       @id @default(cuid())
  group        StudyGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
  invitedEmail String
  invitedBy    String
  status       InviteStatus @default(PENDING)
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime     @default(now())

  @@unique([groupId, invitedEmail])
  @@index([invitedEmail, status])
}

// =============================================================================
// Social Learning - Study Sessions
// =============================================================================

enum StudySessionType {
  DISCUSSION
  REVIEW
  QUIZ_PRACTICE
  VIDEO_CALL
  COLLABORATIVE
}

enum StudySessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model StudySession {
  id              String             @id @default(cuid())
  group           StudyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId         String
  title           String
  description     String?
  createdBy       String
  scheduledAt     DateTime
  duration        Int // minutes
  timezone        String             @default("UTC")
  type            StudySessionType   @default(DISCUSSION)
  meetingUrl      String?
  maxParticipants Int?
  rsvpDeadline    DateTime?
  moduleId        String?
  lessonIds       String? // JSON array
  agenda          String?
  attachments     String? // JSON array
  status          StudySessionStatus @default(SCHEDULED)
  startedAt       DateTime?
  endedAt         DateTime?
  notes           String?
  recordingUrl    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  rsvps SessionRsvp[]

  @@index([groupId, scheduledAt])
  @@index([groupId, status])
}

enum RsvpStatus {
  ATTENDING
  MAYBE
  NOT_ATTENDING
}

model SessionRsvp {
  id        String       @id @default(cuid())
  session   StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  userId    String
  status    RsvpStatus
  note      String?
  createdAt DateTime     @default(now())

  @@unique([sessionId, userId])
}

// =============================================================================
// Social Learning - Discussion Forums
// =============================================================================

enum ForumScope {
  GLOBAL
  STUDY_GROUP
  CLASSROOM
  MODULE
}

enum ForumStatus {
  ACTIVE
  ARCHIVED
  LOCKED
}

model Forum {
  id                  String      @id @default(cuid())
  tenantId            String
  name                String
  description         String
  iconUrl             String?
  scope               ForumScope  @default(GLOBAL)
  scopeId             String? // groupId, classroomId, or moduleId
  allowAnonymousPosts Boolean     @default(false)
  requireModeration   Boolean     @default(false)
  allowAttachments    Boolean     @default(true)
  allowPolls          Boolean     @default(true)
  categories          String? // JSON array of ForumCategory
  topicCount          Int         @default(0)
  postCount           Int         @default(0)
  lastPostAt          DateTime?
  status              ForumStatus @default(ACTIVE)
  studyGroup          StudyGroup? @relation(fields: [studyGroupId], references: [id])
  studyGroupId        String?     @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  topics ForumTopic[]

  @@index([tenantId, scope])
  @@index([tenantId, scopeId])
}

enum TopicStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  DELETED
}

model ForumTopic {
  id             String      @id @default(cuid())
  forum          Forum       @relation(fields: [forumId], references: [id], onDelete: Cascade)
  forumId        String
  categoryId     String?
  title          String
  slug           String
  authorId       String
  authorName     String
  content        String
  contentFormat  String      @default("markdown")
  attachments    String? // JSON array
  viewCount      Int         @default(0)
  replyCount     Int         @default(0)
  likeCount      Int         @default(0)
  isPinned       Boolean     @default(false)
  isLocked       Boolean     @default(false)
  isAnswered     Boolean     @default(false)
  answerId       String?
  status         TopicStatus @default(PUBLISHED)
  moderatedBy    String?
  moderatedAt    DateTime?
  moderationNote String?
  lastReplyAt    DateTime?
  lastReplyBy    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  posts ForumPost[]

  @@unique([forumId, slug])
  @@index([forumId, isPinned])
  @@index([forumId, status])
  @@index([authorId])
}

model ForumPost {
  id               String      @id @default(cuid())
  topic            ForumTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId          String
  authorId         String
  authorName       String
  isAnonymous      Boolean     @default(false)
  content          String
  contentFormat    String      @default("markdown")
  attachments      String? // JSON array
  parentId         String?
  depth            Int         @default(0)
  likeCount        Int         @default(0)
  isAcceptedAnswer Boolean     @default(false)
  status           TopicStatus @default(PUBLISHED)
  moderatedBy      String?
  moderatedAt      DateTime?
  isEdited         Boolean     @default(false)
  editedAt         DateTime?
  editHistory      String? // JSON array of PostEdit
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  reactions PostReaction[]

  @@index([topicId, createdAt])
  @@index([topicId, parentId])
  @@index([authorId])
}

enum ReactionType {
  LIKE
  HELPFUL
  INSIGHTFUL
  QUESTION
  CELEBRATE
}

model PostReaction {
  id        String       @id @default(cuid())
  post      ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
}

// =============================================================================
// Social Learning - Peer Tutoring
// =============================================================================

enum TutorStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

model TutorProfile {
  id                   String      @id @default(cuid())
  tenantId             String
  userId               String
  displayName          String
  bio                  String
  avatarUrl            String?
  subjects             String // JSON array
  modules              String? // JSON array of module IDs
  qualifications       String? // JSON array
  isAvailable          Boolean     @default(true)
  availabilitySchedule String? // JSON array of AvailabilitySlot
  timezone             String      @default("UTC")
  responseTime         String      @default("Usually within 2 hours")
  sessionTypes         String // JSON array of TutoringSessionType
  maxSessionsPerWeek   Int         @default(5)
  pricePerHour         Int? // In cents, if paid tutoring
  rating               Float       @default(0)
  reviewCount          Int         @default(0)
  sessionsCompleted    Int         @default(0)
  totalHelpedStudents  Int         @default(0)
  status               TutorStatus @default(ACTIVE)
  verifiedAt           DateTime?
  verifiedBy           String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  requests TutoringRequest[] @relation("TutorRequests")
  sessions TutoringSession[] @relation("TutorSessions")
  reviews  TutoringReview[]  @relation("TutorReviews")

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([tenantId, isAvailable])
}

enum TutoringRequestStatus {
  OPEN
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

model TutoringRequest {
  id                 String                @id @default(cuid())
  tenantId           String
  studentId          String
  tutor              TutorProfile?         @relation("TutorRequests", fields: [tutorId], references: [id])
  tutorId            String?
  subject            String
  moduleId           String?
  lessonId           String?
  title              String
  description        String
  attachments        String? // JSON array
  preferredTypes     String // JSON array of TutoringSessionType
  preferredTime      DateTime?
  estimatedDuration  Int                   @default(60)
  urgency            String                @default("medium")
  status             TutoringRequestStatus @default(OPEN)
  acceptedAt         DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  sessions TutoringSession[]

  @@index([tenantId, status])
  @@index([tenantId, studentId])
  @@index([tenantId, tutorId])
}

enum TutoringSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

model TutoringSession {
  id              String                @id @default(cuid())
  tenantId        String
  request         TutoringRequest       @relation(fields: [requestId], references: [id])
  requestId       String
  studentId       String
  tutor           TutorProfile          @relation("TutorSessions", fields: [tutorId], references: [id])
  tutorId         String
  type            String // TutoringSessionType
  scheduledAt     DateTime
  duration        Int // minutes
  meetingUrl      String?
  moduleId        String?
  lessonId        String?
  notes           String?
  sharedResources String? // JSON array
  status          TutoringSessionStatus @default(SCHEDULED)
  startedAt       DateTime?
  endedAt         DateTime?
  actualDuration  Int?
  recordingUrl    String?
  transcriptUrl   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  reviews  TutoringReview[]
  chatRoom ChatRoom?

  @@index([tenantId, status])
  @@index([tenantId, studentId])
  @@index([tenantId, tutorId])
  @@index([scheduledAt])
}

model TutoringReview {
  id            String          @id @default(cuid())
  session       TutoringSession @relation(fields: [sessionId], references: [id])
  sessionId     String
  tutor         TutorProfile    @relation("TutorReviews", fields: [tutorId], references: [id])
  tutorId       String
  reviewerId    String
  rating        Int // 1-5
  helpfulness   Int // 1-5
  communication Int // 1-5
  knowledge     Int // 1-5
  comment       String?
  privateNote   String?
  response      String?
  respondedAt   DateTime?
  isVisible     Boolean         @default(true)
  moderatedBy   String?
  moderatedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([sessionId, reviewerId])
  @@index([tutorId, isVisible])
}

// =============================================================================
// Social Learning - Real-time Chat
// =============================================================================

enum ChatRoomType {
  DIRECT
  STUDY_GROUP
  CLASSROOM
  TUTORING
  SUPPORT
}

model ChatRoom {
  id                String           @id @default(cuid())
  tenantId          String
  type              ChatRoomType
  name              String?
  studyGroup        StudyGroup?      @relation(fields: [studyGroupId], references: [id])
  studyGroupId      String?          @unique
  tutoringSession   TutoringSession? @relation(fields: [tutoringSessionId], references: [id])
  tutoringSessionId String?          @unique
  participants      String // JSON array of user IDs
  maxParticipants   Int?
  isEncrypted       Boolean          @default(false)
  retentionDays     Int              @default(90)
  messageCount      Int              @default(0)
  lastMessageAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  messages     ChatMessage[]
  readReceipts ChatReadReceipt[]

  @@index([tenantId, type])
  @@index([tenantId, studyGroupId])
}

enum ChatMessageType {
  TEXT
  IMAGE
  FILE
  CODE
  MATH
  QUIZ_SHARE
  SYSTEM
}

model ChatMessage {
  id          String          @id @default(cuid())
  room        ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId      String
  senderId    String
  senderName  String
  type        ChatMessageType @default(TEXT)
  content     String
  metadata    String? // JSON object
  attachments String? // JSON array
  replyToId   String?
  reactions   String? // JSON object: emoji -> userIds[]
  status      String          @default("sent")
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())

  @@index([roomId, createdAt])
  @@index([roomId, senderId])
}

model ChatReadReceipt {
  id                String   @id @default(cuid())
  room              ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId            String
  userId            String
  lastReadMessageId String
  lastReadAt        DateTime @default(now())

  @@unique([roomId, userId])
}

// =============================================================================
// Social Learning - Collaborative Features
// =============================================================================

model SharedNote {
  id            String      @id @default(cuid())
  tenantId      String
  createdBy     String
  studyGroup    StudyGroup? @relation(fields: [studyGroupId], references: [id])
  studyGroupId  String?
  title         String
  content       String // JSON for rich text
  version       Int         @default(1)
  allowEditing  Boolean     @default(false)
  allowComments Boolean     @default(true)
  moduleId      String?
  lessonId      String?
  sharedWith    String? // JSON array of SharedNoteAccess
  lastEditedBy  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  comments NoteComment[]

  @@index([tenantId, createdBy])
  @@index([tenantId, studyGroupId])
}

model NoteComment {
  id          String     @id @default(cuid())
  note        SharedNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  noteId      String
  authorId    String
  anchorStart Int?
  anchorEnd   Int?
  content     String
  parentId    String?
  isResolved  Boolean    @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([noteId, isResolved])
}

model CollaborativeWhiteboard {
  id             String   @id @default(cuid())
  tenantId       String
  studyGroupId   String?
  sessionId      String? // TutoringSession ID
  name           String
  canvasState    String // JSON canvas data
  activeUsers    String? // JSON array of user IDs
  allowAnonymous Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, studyGroupId])
}

// =============================================================================
// Social Learning - Activity & Notifications
// =============================================================================

enum SocialActivityType {
  JOINED_GROUP
  CREATED_TOPIC
  REPLIED_TOPIC
  LIKED_POST
  SCHEDULED_SESSION
  COMPLETED_SESSION
  SHARED_NOTE
  EARNED_BADGE
  HELPED_PEER
}

model SocialActivity {
  id             String             @id @default(cuid())
  tenantId       String
  actorId        String
  actorName      String
  actorAvatarUrl String?
  type           SocialActivityType
  targetType     String // study_group, forum_topic, etc.
  targetId       String
  targetTitle    String
  studyGroupId   String?
  classroomId    String?
  metadata       String? // JSON object
  createdAt      DateTime           @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, actorId])
  @@index([tenantId, studyGroupId])
