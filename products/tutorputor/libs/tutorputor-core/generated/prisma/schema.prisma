enum SocialNotificationType {
  GROUP_INVITE
  GROUP_JOIN_REQUEST
  GROUP_MESSAGE
  TOPIC_REPLY
  POST_MENTION
  POST_REACTION
  TUTORING_REQUEST
  SESSION_REMINDER
  REVIEW_RECEIVED
}

model SocialNotification {
  id         String                 @id @default(cuid())
  tenantId   String
  userId     String
  type       SocialNotificationType
  title      String
  body       String
  iconUrl    String?
  actionUrl  String?
  actorId    String?
  actorName  String?
  targetType String?
  targetId   String?
  isRead     Boolean                @default(false)
  readAt     DateTime?
  emailSent  Boolean                @default(false)
  pushSent   Boolean                @default(false)
