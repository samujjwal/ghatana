{
    "$schema": "../simulation-template.schema.json",
    "id": "chemistry_acid_base_titration",
    "version": "1.0.0",
    "metadata": {
        "title": "Acid-Base Titration Simulator",
        "description": "Perform virtual titrations to determine unknown acid or base concentrations. Observe pH changes and identify equivalence points.",
        "domain": "chemistry",
        "subDomain": "analytical",
        "difficulty": "hard",
        "estimatedDuration": 30,
        "gradeLevel": [
            "high_school",
            "undergraduate"
        ],
        "tags": [
            "titration",
            "pH",
            "acids",
            "bases",
            "neutralization",
            "indicators"
        ],
        "author": "Tutorputor Chemistry Team",
        "license": "CC-BY-4.0"
    },
    "learningObjectives": [
        "Understand the concept of titration and its applications",
        "Learn to identify the equivalence point",
        "Observe pH changes during neutralization reactions",
        "Calculate unknown concentrations using titration data"
    ],
    "prerequisites": [
        "Understanding of acids and bases",
        "Knowledge of molarity and concentration",
        "Familiarity with the pH scale"
    ],
    "entities": [
        {
            "id": "burette",
            "type": "chemistry:glassware",
            "properties": {
                "type": "burette",
                "capacity": {
                    "value": 50,
                    "unit": "mL"
                },
                "currentVolume": {
                    "value": 50,
                    "unit": "mL"
                },
                "solution": {
                    "name": "NaOH",
                    "concentration": {
                        "value": 0.1,
                        "unit": "M"
                    },
                    "type": "base"
                },
                "position": {
                    "value": [
                        0,
                        5,
                        0
                    ]
                },
                "graduations": true
            }
        },
        {
            "id": "erlenmeyer",
            "type": "chemistry:glassware",
            "properties": {
                "type": "erlenmeyer_flask",
                "capacity": {
                    "value": 250,
                    "unit": "mL"
                },
                "currentVolume": {
                    "value": 25,
                    "unit": "mL"
                },
                "solution": {
                    "name": "HCl",
                    "concentration": {
                        "value": 0.1,
                        "unit": "M"
                    },
                    "type": "acid"
                },
                "position": {
                    "value": [
                        0,
                        0,
                        0
                    ]
                },
                "color": "#FFFFFF"
            }
        },
        {
            "id": "ph_meter",
            "type": "chemistry:instrument",
            "properties": {
                "type": "ph_meter",
                "position": {
                    "value": [
                        3,
                        2,
                        0
                    ]
                },
                "precision": 2,
                "autoRead": true
            }
        },
        {
            "id": "indicator",
            "type": "chemistry:indicator",
            "properties": {
                "type": "phenolphthalein",
                "colorBelowPH": "colorless",
                "colorAbovePH": "pink",
                "transitionPH": 8.2,
                "added": false
            }
        },
        {
            "id": "magnetic_stirrer",
            "type": "chemistry:equipment",
            "properties": {
                "type": "magnetic_stirrer",
                "active": true,
                "speed": "medium"
            }
        },
        {
            "id": "titration_curve",
            "type": "visualization:graph",
            "properties": {
                "xAxis": {
                    "label": "Volume NaOH (mL)",
                    "min": 0,
                    "max": 50
                },
                "yAxis": {
                    "label": "pH",
                    "min": 0,
                    "max": 14
                },
                "visible": true
            }
        }
    ],
    "interactions": [
        {
            "id": "add_titrant",
            "type": "button",
            "label": "Add 0.5 mL",
            "action": {
                "type": "dispense",
                "source": "burette",
                "target": "erlenmeyer",
                "amount": 0.5
            }
        },
        {
            "id": "add_drop",
            "type": "button",
            "label": "Add 1 drop",
            "action": {
                "type": "dispense",
                "source": "burette",
                "target": "erlenmeyer",
                "amount": 0.05
            }
        },
        {
            "id": "add_indicator",
            "type": "toggle",
            "label": "Add Phenolphthalein",
            "target": "indicator.added"
        },
        {
            "id": "solution_selector",
            "type": "dropdown",
            "label": "Analyte Solution",
            "target": "erlenmeyer.solution",
            "options": [
                {
                    "value": "HCl",
                    "label": "Hydrochloric Acid (HCl)"
                },
                {
                    "value": "H2SO4",
                    "label": "Sulfuric Acid (H₂SO₄)"
                },
                {
                    "value": "CH3COOH",
                    "label": "Acetic Acid (CH₃COOH)"
                },
                {
                    "value": "unknown",
                    "label": "Unknown Acid"
                }
            ]
        },
        {
            "id": "concentration_slider",
            "type": "slider",
            "label": "NaOH Concentration",
            "target": "burette.solution.concentration",
            "range": [
                0.05,
                0.5
            ],
            "step": 0.05,
            "unit": "M"
        },
        {
            "id": "reset",
            "type": "button",
            "label": "Reset Titration",
            "action": {
                "type": "reset_simulation"
            }
        }
    ],
    "physics": {
        "engine": "chemistry:reaction",
        "reactionRules": {
            "neutralization": true,
            "bufferCalculation": true,
            "equilibrium": true
        },
        "timeScale": 1
    },
    "measurements": [
        {
            "id": "current_ph",
            "type": "sensor",
            "label": "Current pH",
            "source": "ph_meter",
            "precision": 2
        },
        {
            "id": "volume_added",
            "type": "counter",
            "label": "Volume Added",
            "source": "burette",
            "calculation": "initial - current",
            "unit": "mL"
        },
        {
            "id": "equivalence_point",
            "type": "detection",
            "label": "Equivalence Point",
            "method": "derivative_maximum",
            "source": "titration_curve"
        },
        {
            "id": "endpoint",
            "type": "detection",
            "label": "Indicator Endpoint",
            "method": "color_change",
            "source": "indicator"
        }
    ],
    "assessment": {
        "type": "laboratory",
        "tasks": [
            {
                "id": "task_1",
                "instruction": "Titrate 25 mL of 0.1M HCl with 0.1M NaOH. Find the volume at the equivalence point.",
                "expectedOutcome": {
                    "measurement": "volume_added",
                    "tolerance": 0.5,
                    "targetValue": 25
                },
                "points": 20
            },
            {
                "id": "task_2",
                "instruction": "Add phenolphthalein indicator and observe when the color changes.",
                "expectedOutcome": {
                    "measurement": "endpoint",
                    "tolerance": 1,
                    "targetValue": 25
                },
                "points": 15
            },
            {
                "id": "task_3",
                "instruction": "Titrate the unknown acid. Use the equivalence point volume to calculate its concentration.",
                "expectedOutcome": {
                    "calculation": "concentration",
                    "tolerance": 0.01,
                    "formula": "C₁V₁ = C₂V₂"
                },
                "points": 30
            },
            {
                "id": "task_4",
                "instruction": "Observe the pH curve for acetic acid. How does it differ from HCl?",
                "expectedOutcome": {
                    "observation": "buffer_region",
                    "description": "Weak acid shows buffer region with gradual pH change"
                },
                "points": 15
            }
        ],
        "passingScore": 70,
        "hints": [
            "At the equivalence point, moles of acid = moles of base",
            "For monoprotic acids: V₁C₁ = V₂C₂",
            "Weak acids have a buffering region before equivalence",
            "The indicator changes color at the endpoint, which is near (but not exactly at) the equivalence point"
        ]
    },
    "visualization": {
        "type": "3d",
        "renderer": "three.js",
        "camera": {
            "type": "perspective",
            "position": [
                3,
                4,
                6
            ],
            "lookAt": [
                0,
                1,
                0
            ],
            "fov": 45
        },
        "lighting": {
            "ambient": {
                "color": "#ffffff",
                "intensity": 0.6
            },
            "directional": {
                "color": "#ffffff",
                "intensity": 0.5,
                "position": [
                    5,
                    10,
                    5
                ]
            }
        },
        "background": {
            "type": "solid",
            "color": "#f5f5f5"
        },
        "liquidVisualization": {
            "transparency": 0.8,
            "surfaceWaves": true,
            "colorMixing": true
        },
        "annotations": [
            {
                "type": "graph",
                "id": "titration_curve_display",
                "position": "right-panel",
                "size": {
                    "width": 300,
                    "height": 200
                }
            }
        ]
    }
}