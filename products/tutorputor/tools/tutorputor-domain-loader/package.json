{
  "name": "@tutorputor/domain-loader",
  "version": "0.1.0",
  "description": "Domain content loader for physics, chemistry, and other curriculum content",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "../../../../node_modules/.bin/eslint src/ __tests__/ vitest.config.ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "load": "tsx src/cli.ts load",
    "load:physics": "tsx src/cli.ts load --domain=physics",
    "load:chemistry": "tsx src/cli.ts load --domain=chemistry",
    "validate": "tsx src/cli.ts validate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tutorputor/contracts": "workspace:*",
    "@tutorputor/core": "workspace:*",
    "@prisma/client": "7.6.0",
    "@prisma/adapter-libsql": "^7.6.0",
    "@libsql/client": "^0.17.2",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
