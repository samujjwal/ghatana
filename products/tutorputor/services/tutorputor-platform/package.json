{
  "name": "@tutorputor/platform",
  "version": "1.0.0",
  "description": "Consolidated TutorPutor platform service - replaces 28 microservices",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "db:migrate:test": "pnpm --filter @tutorputor/core prisma:migrate:deploy --schema=libs/tutorputor-core/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.982.0",
    "@aws-sdk/s3-request-presigner": "^3.982.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "@prisma/client": "^7.3.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@tutorputor/contracts": "workspace:*",
    "@tutorputor/core": "workspace:*",
    "@tutorputor/simulation": "workspace:*",
    "@types/jsonwebtoken": "^9.0.6",
    "archiver": "^7.0.1",
    "bullmq": "^5.67.2",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.9.2",
    "jose": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "opossum": "^9.0.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "slugify": "^1.6.6",
    "stripe": "^20.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
