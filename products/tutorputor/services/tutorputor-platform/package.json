{
  "name": "@ghatana/tutorputor-platform",
  "version": "1.0.0",
  "description": "Consolidated TutorPutor platform service - replaces 28 microservices",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.7.4",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^7.3.0",
    "@ghatana/tutorputor-db": "workspace:*",
    "@ghatana/tutorputor-contracts": "workspace:*",
    "@ghatana/tutorputor-learning-kernel": "workspace:*",
    "@ghatana/tutorputor-sim-renderer": "workspace:*",
    "@ghatana/tutorputor-simulation-engine": "workspace:*",
    "@ghatana/ui": "workspace:*",
    "ioredis": "^5.9.2",
    "bullmq": "^5.67.2",
    "stripe": "^20.3.0",
    "zod": "^4.3.6",
    "jsonwebtoken": "^9.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "axios": "^1.6.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.1.2",
    "opossum": "^9.0.0",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "prom-client": "^15.1.3",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "slugify": "^1.6.6",
    "nanoid": "^5.0.7",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/archiver": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
