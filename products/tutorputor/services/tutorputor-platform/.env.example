# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (Prisma)
# IMPORTANT: Replace with secure connection string in production
# Use environment-specific secrets management
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# IMPORTANT: Generate secure random secret for production
# Minimum 32 characters, use cryptographic random generator
JWT_SECRET=

# External Services (internal gRPC)
AI_SERVICE_URL=localhost:50051
SIM_RUNTIME_URL=localhost:50052

# Platform Shared Services (optional — omit to disable gracefully)
# AUTH_GATEWAY_URL=http://auth-gateway:8080
# AI_REGISTRY_URL=http://ai-registry:8080
# FEATURE_STORE_URL=http://feature-store:8080

# Object Storage (S3/MinIO)
# IMPORTANT: Use secure credentials from your cloud provider
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=tutorputor

# Observability
SENTRY_DSN=
METRICS_PORT=9090

# Multi-tenancy
DEFAULT_TENANT=default
