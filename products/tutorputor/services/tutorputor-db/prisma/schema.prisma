// =============================================================================
// Content Authoring Models (Admin: Create domains, concepts, examples)
// =============================================================================

model DomainAuthor {
  id          String           @id @default(cuid())
  tenantId    String
  domain      SimulationDomain
  title       String // Display title (e.g., "Physics 101")
  description String
  author      String // Name of domain author
  status      ContentStatus    @default(DRAFT)
  publishedAt DateTime?
  version     Int              @default(1)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  concepts DomainAuthorConcept[]

  @@unique([tenantId, domain])
  @@index([tenantId, status])
}

model DomainAuthorConcept {
  id                 String          @id @default(cuid())
  domainId           String
  domain             DomainAuthor    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  name               String
  description        String
  level              CurriculumLevel
  orderIndex         Int             @default(0)
  learningObjectives String // JSON array of strings
  prerequisites      String // JSON array of concept IDs
  competencies       String // JSON array of competency tags
  keywords           String // JSON array of keywords
  status             ContentStatus   @default(DRAFT)
  version            Int             @default(1)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  simulation    SimulationDefinition?
  visualization VisualizationDefinition?
  examples      ContentExample[]

  @@unique([domainId, name])
  @@index([domainId, level])
}

model SimulationDefinition {
  id                   String              @id @default(cuid())
  conceptId            String              @unique
  concept              DomainAuthorConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  type                 String // e.g., "physics-2D", "interactive_visualization"
  manifest             Json // Full simulation manifest
  estimatedTimeMinutes Int                 @default(15)
  interactivityLevel   String              @default("medium") // low, medium, high
  purpose              String // Pedagogical purpose
  previewConfig        Json? // Configuration for preview
  status               ContentStatus       @default(DRAFT)
  version              Int                 @default(1)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([conceptId])
}

model VisualizationDefinition {
  id         String              @id @default(cuid())
  conceptId  String              @unique
  concept    DomainAuthorConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  type       String // e.g., "graph-2d", "graph-3d", "chart", "diagram", "molecule"
  config     Json // Visualization-specific configuration
  dataSource String              @default("simulation") // simulation, static, dynamic
  status     ContentStatus       @default(DRAFT)
  version    Int                 @default(1)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([conceptId])
}

model ContentExample {
  id                   String              @id @default(cuid())
  conceptId            String
  concept              DomainAuthorConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  title                String
  description          String
  problemStatement     String // Markdown format
  solutionContent      String // Markdown format with steps
  keyLearningPoints    String // JSON array of key points
  difficulty           CurriculumLevel
  estimatedTimeMinutes Int                 @default(20)
  orderIndex           Int                 @default(0)
  status               ContentStatus       @default(DRAFT)
  version              Int                 @default(1)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  visualizationSnapshots VisualizationSnapshot[]

  @@unique([conceptId, title])
  @@index([conceptId, difficulty])
}

model VisualizationSnapshot {
  id              String         @id @default(cuid())
  exampleId       String
  example         ContentExample @relation(fields: [exampleId], references: [id], onDelete: Cascade)
  stepNumber      Int // 1, 2, 3, etc.
  stepDescription String // Description of what's shown at this step
  config          Json // Visualization config at this step
  data            Json? // Data/values rendered at this step
  createdAt       DateTime       @default(now())

  @@unique([exampleId, stepNumber])
  @@index([exampleId])
}

enum AssetType {
  MODEL_3D // .glb, .gltf, .obj, .fbx
  TEXTURE // .png, .jpg, .jpeg, .webp
  AUDIO // .mp3, .wav, .ogg
  VIDEO // .mp4, .webm
  DOCUMENT // .pdf, .doc, .docx
  IMAGE // General images
  OTHER // Misc files
}

enum AssetStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

model Asset {
  id           String      @id @default(cuid())
  tenantId     String
  filename     String // Original filename
  displayName  String? // Optional user-friendly name
  fileType     AssetType
  mimeType     String // e.g., "model/gltf+json", "image/png"
  fileSize     Int // Size in bytes
  url          String // CDN or S3 URL
  thumbnailUrl String? // Generated thumbnail URL
  metadata     Json? // File-specific metadata (dimensions, duration, etc.)
  tags         String? // Comma-separated tags for searching
  uploadedBy   String // User ID who uploaded
  status       AssetStatus @default(UPLOADING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tenantId, fileType])
  @@index([tenantId, status])
  @@index([uploadedBy])
}

model LearningUnit {
  id       String @id
  tenantId String
  domain   String
  level    String
  status   String
  version  Int    @default(1)

  intent     Json
  claims     Json
  evidence   Json
  tasks      Json
  artifacts  Json
  assessment Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  @@index([tenantId, domain])
  @@index([tenantId, status])
}

// =============================================================================
// Content Studio - Unified Authoring (v2.0)
// =============================================================================

enum ExperienceStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentStudioBloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum ValidationStatus {
  PASS
  WARN
  FAIL
}

enum AIOperation {
  GENERATE_EXPERIENCE
  VALIDATE
  IMPROVE
  EXPAND_GRADE
  GENERATE_SIMULATION
  GENERATE_ASSET
}

enum GradeRange {
  K_2
  GRADE_3_5
  GRADE_6_8
  GRADE_9_12
  UNDERGRADUATE
  GRADUATE
}

enum RigorLevel {
  OBSERVATION
  QUALITATIVE
  QUANTITATIVE
}

enum MathLevel {
  NONE
  ARITHMETIC
  ALGEBRA
  CALCULUS
}

enum ScaffoldingLevel {
  HIGH
  MEDIUM
  LOW
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model LearningExperience {
  id       String @id @default(cuid())
  tenantId String

  // Links to existing Module (optional, for backward compatibility)
  moduleId String? @unique
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  // Core content
  title     String
  domain    ModuleDomain
  conceptId String?

  // Intent (embedded JSON for simplicity)
  intentProblem        String
  intentMotivation     String
  intentMisconceptions Json // string[]
  targetGrades         Json // GradeRange[]

  // Curriculum alignment
  curriculumAlignment Json? // CurriculumAlignment[]

  // Grade adaptations (JSON array of GradeAdaptation)
  gradeAdaptations Json // GradeAdaptation[]

  // Simulation reference with versioning
  simulationManifestId String?
  simulationManifest   SimulationManifest? @relation("ExperienceSimulation", fields: [simulationManifestId], references: [id], onDelete: SetNull)
  simulationVersion    String? // Track simulation version for compatibility

  // Assessment configuration (embedded)
  assessmentConfig Json // CBMAssessmentConfig

  // Metadata
  status               ExperienceStatus @default(DRAFT)
  version              Int              @default(1)
  estimatedTimeMinutes Int              @default(30)
  createdBy            String
  lastEditedBy         String?
  publishedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // AI & Guardrails metadata
  promptHash      String? // Hash of refined prompt used for generation
  riskLevel       RiskLevel @default(LOW)
  confidenceScore Float? // AI confidence score (0-1)

  // Relations
  claims                    LearningClaim[]
  evidences                 LearningEvidence[]
  experienceTasks           ExperienceTask[]
  validations               ValidationRecord[]
  revisions                 ExperienceRevision[]
  events                    ExperienceEvent[]
  validationRecordExtendeds ValidationRecordExtended[]
  reviewQueues              ReviewQueue[]
  reviewDecisions           ReviewDecision[]
  experienceAnalytics       ExperienceAnalytics?
  experienceAutoRefinements ExperienceAutoRefinement[]
  claimExamples             ClaimExample[]
  claimSimulations          ClaimSimulation[]
  claimAnimations           ClaimAnimation[]
  
  // Auto-Revision relationships
  abExperiments              ABExperiment[]
  driftSignals              DriftSignal[]
  regenerationInsights      RegenerationInsight[]

  @@index([tenantId, status])
  @@index([tenantId, domain])
  @@index([createdBy])
  @@index([tenantId, riskLevel])
  @@index([promptHash])
}

model LearningClaim {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  claimRef   String // e.g., "C1", "C2"
  text       String
  bloomLevel ContentStudioBloomLevel
  orderIndex Int

  // Prerequisites (JSON array of claim refs from other experiences)
  prerequisites Json? // string[]

  // Grade-specific overrides (JSON)
  gradeOverrides Json? // ClaimOverride[]

  // Content needs analysis (JSON) - NEW
  contentNeeds Json? // { examples: {...}, simulation: {...}, animation: {...} }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - NEW
  examples    ClaimExample[]
  simulations ClaimSimulation[]
  animations  ClaimAnimation[]

  @@unique([experienceId, claimRef])
  @@index([experienceId])
}

model LearningEvidence {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  evidenceRef String // e.g., "E1", "E2"
  claimRef    String // Links to which claim
  type        String // prediction_vs_outcome, parameter_targeting, etc.
  description String
  observables Json // Observable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([experienceId, evidenceRef])
  @@index([experienceId])
}

model ExperienceTask {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  taskRef     String // e.g., "T1", "T2"
  type        String // prediction, simulation, explanation, construction
  claimRef    String
  evidenceRef String
  prompt      String
  orderIndex  Int

  // Type-specific config (JSON)
  config Json // PredictionConfig | SimulationConfig | etc.

  // Grade-specific overrides
  gradeOverrides Json? // TaskOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([experienceId, taskRef])
  @@index([experienceId])
}

model ValidationRecord {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  // Five Pillars scores (0-100)
  authorityScore     Int
  accuracyScore      Int
  usefulnessScore    Int
  harmlessnessScore  Int
  accessibilityScore Int
  gradefitScore      Int

  overallStatus ValidationStatus

  // Detailed issues (JSON)
  issues      Json // ValidationIssue[]
  suggestions Json? // string[]

  validatedAt DateTime @default(now())

  @@index([experienceId])
}

model AIGenerationLog {
  id           String  @id @default(cuid())
  tenantId     String
  userId       String
  experienceId String?

  operation    AIOperation
  provider     String // "openai", "anthropic", "local"
  model        String // "gpt-4", "claude-3.5-sonnet"
  modelVersion String? // Model version for auditability

  // Token usage
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  latencyMs    Int

  // Result
  success      Boolean
  errorMessage String?

  // Request/response (for debugging, optional)
  promptHash  String? // Hash of refined prompt
  requestHash String? // Hash of input for dedup

  // Guardrails metadata
  guardrailsVersion String? // Version of guardrails applied
  riskLevel         RiskLevel @default(LOW)
  confidenceScore   Float? // AI confidence (0-1)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([experienceId])
  @@index([promptHash])
}

// =============================================================================
// Experience Revisions & Events (for audit trail)
// =============================================================================

enum AuthorType {
  HUMAN
  AI_ASSISTED
  AI_GENERATED
}

model ExperienceRevision {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  version    Int
  diff       Json // JSON patch or full snapshot
  authorType AuthorType
  authorId   String
  promptHash String? // If AI-assisted

  createdAt DateTime @default(now())

  @@index([experienceId, version])
  @@index([experienceId, createdAt])
}

enum ExperienceEventType {
  CREATED
  UPDATED
  VALIDATED
  PUBLISHED
  UNPUBLISHED
  CONTENT_CHANGED
  SIMULATION_LINKED
  SIMULATION_UNLINKED
  ANALYTICS_VIEWED
  ANALYTICS_UPDATED
}

model ExperienceEvent {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  eventType ExperienceEventType
  actorId   String
  metadata  Json? // Event-specific data

  createdAt DateTime @default(now())

  @@index([experienceId, eventType])
  @@index([experienceId, createdAt])
}

// =============================================================================
// Simulation Manifest Extensions (for versioning & safety)
// =============================================================================

enum SimulationManifestStatus {
  DRAFT
  REVIEW
  ACTIVE
  DEPRECATED
}

model SimulationManifestVersion {
  id                 String             @id @default(cuid())
  manifestId         String
  simulationManifest SimulationManifest @relation("SimulationManifestVersions", fields: [manifestId], references: [id], onDelete: Cascade)

  version             String
  manifestJson        Json // Full manifest at this version
  safetyConstraints   Json // Safety rules
  pedagogicalTags     Json // Pedagogy metadata
  instrumentationPlan Json // Telemetry plan

  status          SimulationManifestStatus @default(DRAFT)
  riskLevel       RiskLevel                @default(LOW)
  confidenceScore Float?

  createdBy String
  createdAt DateTime @default(now())

  @@unique([manifestId, version])
  @@index([manifestId, status])
}

// Add relation to SimulationManifest
model SimulationManifestExtension {
  id                 String             @id
  simulationManifest SimulationManifest @relation("SimulationManifestExtensions", fields: [id], references: [id], onDelete: Cascade)

  metadata Json? // Additional extension metadata
}

model SimulationLinkAudit {
  id                   String             @id @default(cuid())
  experienceId         String
  simulationManifestId String
  simulationManifest   SimulationManifest @relation("SimulationLinkAudits", fields: [simulationManifestId], references: [id], onDelete: Cascade)

  action        String // "linked", "unlinked", "version_changed"
  beforeVersion String?
  afterVersion  String?
  actorId       String

  createdAt DateTime @default(now())

  @@index([experienceId, createdAt])
  @@index([simulationManifestId, createdAt])
}

// =============================================================================
// AI Prompt Cache (for reuse & cost optimization)
// =============================================================================

model AIPromptCache {
  id       String @id @default(cuid())
  tenantId String

  rawIntentHash     String @unique // Hash of raw user input
  flowType          String // "concept_generation", "simulation_generation", "refinement"
  refinedPrompt     String // Cleaned & enriched prompt
  guardrailsVersion String // Version of guardrails applied

  // Metadata
  domain     String?
  gradeRange String?
  riskLevel  RiskLevel @default(LOW)

  // Linked outputs
  aiOutputIds Json // Array of AIGenerationLog IDs

  // TTL
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId, rawIntentHash])
  @@index([tenantId, flowType])
  @@index([expiresAt])
}

// =============================================================================
// Validation Extensions (for caching & determinism)
// =============================================================================

model ValidationRecordExtended {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  // Input hash for cache key
  inputHash         String // Hash of experience content + simulation version
  validatorsVersion String // Version of validators used

  // Five Pillars scores (0-100)
  authorityScore     Int
  accuracyScore      Int
  usefulnessScore    Int
  harmlessnessScore  Int
  accessibilityScore Int
  gradefitScore      Int

  overallStatus ValidationStatus

  // Detailed checks with metadata
  checks      Json // ValidationCheck[] with per-check metadata
  issues      Json // ValidationIssue[]
  suggestions Json? // string[]

  // Simulation health
  simulationHealthReport Json?

  validatedAt DateTime @default(now())

  @@index([experienceId, inputHash])
  @@index([experienceId, validatedAt])
}

// =============================================================================
// Human-in-the-Loop (HITL) Review System
// =============================================================================

enum ReviewerRole {
  SME // Subject Matter Expert
  PEDAGOGY // Pedagogy Reviewer
  SAFETY // Safety Reviewer
  ADMIN // Admin Override
}

enum ReviewDecisionType {
  APPROVE
  REJECT
  REQUEST_CHANGES
  ESCALATE
}

model ReviewQueue {
  id           String             @id @default(cuid())
  tenantId     String
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  queuedAt   DateTime  @default(now())
  priority   Int       @default(0) // Higher = more urgent
  assignedTo String? // Reviewer user ID
  assignedAt DateTime?

  // Context
  riskLevel     RiskLevel
  triggerReason String // "high_risk", "low_confidence", "policy_violation"
  metadata      Json?

  @@index([tenantId, assignedTo])
  @@index([tenantId, queuedAt])
  @@index([experienceId])
}

model ReviewDecision {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  reviewerId   String
  reviewerRole ReviewerRole
  decision     ReviewDecisionType
  rationale    String // Mandatory explanation
  changes      Json? // Suggested or applied changes

  createdAt DateTime @default(now())

  @@index([experienceId, createdAt])
  @@index([reviewerId, createdAt])
}

// =============================================================================
// Analytics & Regeneration
// =============================================================================

model ExperienceAnalytics {
  id           String             @id @default(cuid())
  experienceId String             @unique
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  // Engagement metrics
  viewCount       Int   @default(0)
  completionCount Int   @default(0)
  completionRate  Float @default(0)
  avgTimeMinutes  Float @default(0)
  dropOffRate     Float @default(0)

  // Simulation metrics
  simulationStarts Int @default(0)
  simulationAborts Int @default(0)
  simulationErrors Int @default(0)

  // Trend windows (JSON arrays)
  trends7d  Json? // 7-day trend data
  trends28d Json? // 28-day trend data

  // Anomaly flags
  hasEngagementDrift Boolean @default(false)
  hasQualityIssues   Boolean @default(false)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([experienceId])
}

model ExperienceAutoRefinement {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  // Source analytics snapshot
  analyticsSnapshot Json
  triggerReason     String // "low_engagement", "high_abort_rate", "aging_simulation"

  // Regenerated candidate
  candidateExperienceId String?
  appliedGuardrails     Json
  aiCompletionId        String?

  // Status
  status     String    @default("pending") // pending, reviewed, accepted, rejected
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driftSignal DriftSignal? @relation(name: "DriftSignal_AutoRefinement")
  regenerationInsight RegenerationInsight? @relation(name: "RegenerationInsight_AutoRefinement")

  @@index([experienceId])
  @@index([status])
}

// =============================================================================
// Evidence-Based Content Models (Claim-Linked Content)
// =============================================================================

model ClaimExample {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claimRef     String
  claim        LearningClaim      @relation(fields: [experienceId, claimRef], references: [experienceId, claimRef], onDelete: Cascade)

  type        String // "REAL_WORLD" | "PROBLEM_SOLVING" | "ANALOGY" | "CASE_STUDY"
  title       String
  description String
  content     Json // { problemStatement?, solution, keyPoints: string[], realWorldConnection? }

  difficulty String @default("INTERMEDIATE") // BEGINNER | INTERMEDIATE | ADVANCED
  orderIndex Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([experienceId, claimRef])
  @@index([type])
}

model ClaimSimulation {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claimRef     String
  claim        LearningClaim      @relation(fields: [experienceId, claimRef], references: [experienceId, claimRef], onDelete: Cascade)

  simulationManifestId String
  simulationManifest   SimulationManifest @relation(fields: [simulationManifestId], references: [id])

  interactionType  String // "parameter_exploration" | "prediction" | "construction"
  goal             String
  successCriteria  Json // { rmse?: string, maxAttempts?: number, timeLimit?: number }
  estimatedMinutes Int    @default(10)

  createdAt DateTime @default(now())

  @@unique([experienceId, claimRef])
  @@index([experienceId])
  @@index([simulationManifestId])
}

model ClaimAnimation {
  id           String             @id @default(cuid())
  experienceId String
  experience   LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claimRef     String
  claim        LearningClaim      @relation(fields: [experienceId, claimRef], references: [experienceId, claimRef], onDelete: Cascade)

  title       String
  description String
  type        String // "2d" | "3d" | "timeline"
  duration    Int // seconds
  config      Json // { keyframes, timeline, controls }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([experienceId, claimRef])
  @@index([experienceId])
}

// =============================================================================
// Auto-Revision and A/B Testing Enhancements
// ============================================================================

model ABExperiment {
  id               String   @id @default(cuid())
  tenantId         String
  experienceId     String
  experience       LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  
  // Version information
  controlVersion   Int
  treatmentVersion Int
  
  // Experiment status
  status           String   @default("draft") // "draft", "running", "completed", "winner_promoted", "failed"
  
  // Sample sizes
  controlSampleSize Int     @default(0)
  treatmentSampleSize Int   @default(0)
  
  // Metrics (JSON storage for flexibility)
  controlMetrics   Json    @default("{}")
  treatmentMetrics Json    @default("{}")
  
  // Statistical results
  pValue           Float?
  confidenceLower  Float?
  confidenceUpper  Float?
  effectSize       Float?
  winner           String?  // "control", "treatment", "inconclusive"
  statisticalPower Float?
  
  // Timestamps
  createdAt        DateTime @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  
  // Metadata
  notes            String?
  priority         Int      @default(0)
  
  @@index([tenantId, status])
  @@index([experienceId])
  @@index([status, createdAt])
}

model DriftSignal {
  id             String   @id @default(cuid())
  tenantId       String
  experienceId   String
  experience     LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  
  // Signal information
  signalType     String   // "engagement_drop", "high_abort_rate", "low_completion", "low_mastery", "negative_feedback"
  severity       String   // "low", "medium", "high"
  metric         String
  value          Float
  threshold      Float
  
  // AI analysis
  recommendation String
  confidence     Float?
  context        Json?    // Additional context for the signal
  
  // Status
  status         String   @default("detected") // "detected", "acknowledged", "addressed", "false_positive"
  
  // Timestamps
  detectedAt     DateTime @default(now())
  acknowledgedAt DateTime?
  addressedAt    DateTime?
  
  // Relationships
  autoRefinementId String? @unique
  autoRefinement  ExperienceAutoRefinement? @relation(name: "DriftSignal_AutoRefinement", fields: [autoRefinementId], references: [id])
  
  @@index([tenantId, experienceId, status])
  @@index([signalType, severity])
  @@index([detectedAt])
}

model RegenerationInsight {
  id             String   @id @default(cuid())
  tenantId       String
  experienceId   String
  experience     LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  
  // Insight classification
  category       String   // "content_difficulty", "content_clarity", "simulation_complexity", "task_alignment", "grade_level"
  issue          String
  suggestedAction String
  priority       Int      // 1-10, higher = more urgent
  
  // Evidence and analysis
  evidence       Json     // Supporting data for the insight
  confidence     Float?   // AI confidence in the insight
  
  // Status tracking
  status         String   @default("identified") // "identified", "analyzed", "addressed", "rejected"
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relationships
  autoRefinementId String? @unique
  autoRefinement  ExperienceAutoRefinement? @relation(name: "RegenerationInsight_AutoRefinement", fields: [autoRefinementId], references: [id])
  
  @@index([tenantId, experienceId, category])
  @@index([priority, status])
  @@index([createdAt])
}

model AutoRevisionConfig {
  id               String @id @default(cuid())
  tenantId         String @unique
  
  // Configuration settings
  enabled          Boolean @default(true)
  driftCheckIntervalHours Int @default(6)
  maxConcurrentRegenerations Int @default(3)
  minSampleSize    Int @default(100)
  significanceThreshold Float @default(0.05)
  
  // Thresholds
  completionRateThreshold Float @default(0.6)
  abortRateThreshold Float @default(0.3)
  averageTimeSpentThreshold Float @default(5.0) // minutes
  masteryRateThreshold Float @default(0.7)
  feedbackScoreThreshold Float @default(3.0) // out of 5
  
  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Metadata
  updatedBy        String?
  notes            String?
}

model AutoRevisionMetrics {
  id               String @id @default(cuid())
  tenantId         String
  
  // Metrics snapshot
  date             DateTime @default(now())
  
  // Drift detection metrics
  driftSignalsDetected Int @default(0)
  experiencesMonitored Int @default(0)
  highSeveritySignals Int @default(0)
  
  // Regeneration metrics
  regenerationsQueued Int @default(0)
  regenerationsCompleted Int @default(0)
  regenerationsFailed Int @default(0)
  averageProcessingTimeMinutes Float @default(0)
  
  // A/B testing metrics
  abExperimentsCreated Int @default(0)
  abExperimentsCompleted Int @default(0)
  averageTestDurationHours Float @default(0)
  improvementRate Float @default(0) // Percentage of improvements
  
  // Performance metrics
  averageEngagementImprovement Float @default(0)
  averageCompletionImprovement Float @default(0)
  averageMasteryImprovement Float @default(0)
  
  // System health
  queueLength Int @default(0)
  processingJobs Int @default(0)
  failedJobs24h Int @default(0)
  
  @@unique([tenantId, date])
  @@index([date])
}
