// ============================================
// VR Labs Models
// ============================================

enum VRLabCategory {
  CHEMISTRY
  PHYSICS
  BIOLOGY
  ASTRONOMY
  ENGINEERING
  ANATOMY
  GEOLOGY
  HISTORY
  ART
  MATHEMATICS
}

enum VRLabDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum VRSessionStatus {
  INITIALIZING
  LOADING
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

enum VRMultiplayerStatus {
  LOBBY
  ACTIVE
  ENDED
}

model VRLab {
  id                String          @id @default(cuid())
  tenantId          String
  slug              String
  title             String
  description       String
  category          VRLabCategory
  difficulty        VRLabDifficulty
  thumbnailUrl      String
  previewVideoUrl   String?
  estimatedDuration Int // minutes
  requiredDevices   String // JSON array
  minRequirements   String // JSON object
  completionRate    Float           @default(0)
  averageRating     Float           @default(0)
  totalSessions     Int             @default(0)
  memberCount       Int             @default(0)
  isPublished       Boolean         @default(false)
  tags              String // JSON array
  prerequisites     String? // JSON array of VRLabIds
  createdBy         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  scenes      VRScene[]
  objectives  VRLabObjective[]
  sessions    VRSession[]
  multiplayer VRMultiplayerSession[]

  @@unique([tenantId, slug])
  @@index([tenantId, category])
  @@index([tenantId, isPublished])
  @@index([tenantId, difficulty])
}

model VRScene {
  id                String  @id @default(cuid())
  labId             String
  name              String
  description       String
  order             Int
  environmentUrl    String
  skyboxUrl         String?
  lightingPreset    String
  spawnPoints       String // JSON array of positions
  ambientSoundUrl   String?
  narrationUrl      String?
  estimatedDuration Int

  lab           VRLab            @relation(fields: [labId], references: [id], onDelete: Cascade)
  interactables VRInteractable[]

  @@index([labId, order])
}

model VRInteractable {
  id                  String  @id @default(cuid())
  sceneId             String
  name                String
  type                String // equipment, chemical, specimen, tool, etc.
  position            String // JSON {x, y, z}
  rotation            String // JSON {x, y, z, w}
  scale               String // JSON {x, y, z}
  modelUrl            String
  materialOverrides   String? // JSON array
  allowedInteractions String // JSON array of interaction types
  interactionRange    Float
  behavior            String // JSON object
  tooltip             String?
  audioFeedbackUrl    String?

  scene VRScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
}

model VRLabObjective {
  id          String  @id @default(cuid())
  labId       String
  title       String
  description String?
  order       Int
  type        String // interaction, observation, quiz, experiment
  criteria    String // JSON object
  hints       String // JSON array
  points      Int
  isOptional  Boolean @default(false)

  lab VRLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, order])
}

model VRSession {
  id                 String          @id @default(cuid())
  tenantId           String
  userId             String
  labId              String
  status             VRSessionStatus
  currentSceneId     String
  deviceType         String
  deviceInfo         String // JSON object
  progress           String // JSON object with completedObjectives, points, etc.
  startedAt          DateTime
  lastActiveAt       DateTime
  endedAt            DateTime?
  totalDuration      Int             @default(0) // seconds
  performanceMetrics String // JSON object

  lab VRLab @relation(fields: [labId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, labId])
  @@index([userId, status])
}

model VRMultiplayerSession {
  id                  String              @id @default(cuid())
  tenantId            String
  labId               String
  hostUserId          String
  maxParticipants     Int
  voiceChatEnabled    Boolean             @default(true)
  spatialAudioEnabled Boolean             @default(true)
  participants        String // JSON array of VRParticipant
  status              VRMultiplayerStatus @default(LOBBY)
  createdAt           DateTime            @default(now())

  lab VRLab @relation(fields: [labId], references: [id])

  @@index([tenantId, status])
  @@index([labId, status])
}

model VRAsset {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  type         String // model, texture, audio, video, skybox, animation, script
  url          String
  size         Int // bytes
  format       String
  s3Key        String
  thumbnailUrl String?
  tags         String // JSON array
  isPublic     Boolean  @default(false)
  status       String   @default("ready") // pending, ready, error
  createdBy    String
  createdAt    DateTime @default(now())

  @@index([tenantId, type])
  @@index([tenantId, isPublic])
}

model VRAnalyticsEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  eventType String
  labId     String?
  sessionId String?
  metadata  String // JSON object
  timestamp DateTime @default(now())

  @@index([tenantId, eventType])
  @@index([tenantId, labId])
  @@index([tenantId, timestamp])
}

// =============================================================================
// Curriculum & Domain Content Models
// =============================================================================

enum CurriculumLevel {
  FOUNDATIONAL
  INTERMEDIATE
  ADVANCED
  RESEARCH
}

enum SimulationDomain {
  CS_DISCRETE
  PHYSICS
  CHEMISTRY
  BIOLOGY
  MEDICINE
  ECONOMICS
  ENGINEERING
  MATHEMATICS
}

enum ContentStatus {
  PUBLISHED
  DRAFT
}

model DomainConcept {
  id                     String           @id @default(cuid())
  tenantId               String
  externalId             String // Original ID from JSON (e.g., "phy_F_1")
  name                   String
  description            String
  domain                 SimulationDomain
  level                  CurriculumLevel
  keywords               String // JSON array
  audienceTags           String // JSON array
  simulationMetadata     Json
  learningObjectMetadata Json
  pedagogicalMetadata    Json
  crossDomainLinks       Json // Array of cross-domain references
  status                 ContentStatus    @default(DRAFT)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  // Relations
  prerequisites       ConceptPrerequisite[] @relation("ConceptDependents")
  requiredBy          ConceptPrerequisite[] @relation("ConceptPrerequisites")
  moduleMapping       ConceptModuleMapping?
  simulationTemplates SimulationTemplate[]

  @@unique([tenantId, externalId])
  @@index([tenantId, domain])
  @@index([tenantId, level])
  @@index([tenantId, status])
}

model ConceptPrerequisite {
  concept        DomainConcept @relation("ConceptDependents", fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId      String
  prerequisite   DomainConcept @relation("ConceptPrerequisites", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  prerequisiteId String

  @@id([conceptId, prerequisiteId])
}

model ConceptModuleMapping {
  id                    String        @id @default(cuid())
  concept               DomainConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId             String        @unique
  moduleId              String
  simulationManifestIds String // JSON array of manifest IDs
  createdAt             DateTime      @default(now())

  @@index([moduleId])
}

enum SimulationTemplateDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SimulationTemplateLicense {
  FREE
  CC_BY
  CC_BY_SA
  CC_BY_NC
  PROPRIETARY
}

enum SimulationTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model SimulationManifest {
  id          String           @id // Stable manifest ID generated from concept
  tenantId    String
  domain      SimulationDomain
  version     String
  title       String
  description String?
  module      Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  moduleId    String?
  manifest    Json // Full SimulationManifest payload
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  templates        SimulationTemplate[]
  experiences      LearningExperience[]         @relation("ExperienceSimulation")
  versions         SimulationManifestVersion[]  @relation("SimulationManifestVersions")
  extension        SimulationManifestExtension? @relation("SimulationManifestExtensions")
  linkAudits       SimulationLinkAudit[]        @relation("SimulationLinkAudits")
  claimSimulations ClaimSimulation[]

  @@index([tenantId, domain])
  @@index([tenantId, moduleId])
}

model SimulationTemplate {
  id                  String                       @id @default(cuid())
  tenantId            String
  slug                String
  title               String
  description         String
  domain              SimulationDomain
  difficulty          SimulationTemplateDifficulty
  tags                String // JSON array of tags
  thumbnailUrl        String?
  license             SimulationTemplateLicense    @default(FREE)
  isPremium           Boolean                      @default(false)
  isVerified          Boolean                      @default(false)
  version             String // Semantic version, e.g. "1.0.0"
  authorId            String
  authorName          String?
  authorAvatarUrl     String?
  organization        String?
  statsViews          Int                          @default(0)
  statsUses           Int                          @default(0)
  statsFavorites      Int                          @default(0)
  statsRating         Float                        @default(0)
  statsRatingCount    Int                          @default(0)
  statsCompletionRate Float                        @default(0)
  statsAvgTimeMinutes Int                          @default(0)
  status              SimulationTemplateStatus     @default(DRAFT)
  publishedAt         DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  // Relations
  concept    DomainConcept?      @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  conceptId  String?
  module     Module?             @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  moduleId   String?
  manifest   SimulationManifest? @relation(fields: [manifestId], references: [id], onDelete: SetNull)
  manifestId String?

  @@unique([tenantId, slug])
  @@index([tenantId, domain])
  @@index([tenantId, difficulty])
  @@index([tenantId, isPremium])
  @@index([tenantId, isVerified])
  @@index([tenantId, status])
}

model Curriculum {
  id          String           @id @default(cuid())
  tenantId    String
  domain      SimulationDomain
  title       String
  description String?
  version     String           @default("1.0.0")
  isPublished Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, domain])
  @@index([tenantId, isPublished])
}

// =============================================================================
// Admin & Tenant Management (Block 4 - Day 38)
// =============================================================================

enum SubscriptionTier {
  FREE
  BASIC
  ENTERPRISE
}

model Tenant {
  id               String           @id @default(cuid())
  name             String
  subdomain        String           @unique
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  settings          TenantSettings?
  users             User[]
  identityProviders IdentityProvider[]

  @@index([subdomain])
}

model TenantSettings {
  id                       String   @id @default(cuid())
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId                 String   @unique
  allowPublicRegistration  Boolean  @default(false)
  requireEmailVerification Boolean  @default(true)
  defaultUserRole          String   @default("student")
  maxUsersPerClassroom     Int      @default(50)
  enabledFeatures          String   @default("[]") // JSON array
  enabledDomainPacks       String   @default("[]") // JSON array
  simulationQuotas         String   @default("{}") // JSON object
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  email       String
  displayName String
  role        String   @default("student")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ssoLinks SsoUserLink[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

// =============================================================================
// SSO & Identity Federation (Block 4 - Day 36)
// =============================================================================

enum IdentityProviderType {
  OIDC
  SAML
}

enum SsoProviderStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_VERIFICATION
}

model IdentityProvider {
  id                   String    @id @default(cuid())
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId             String
  type                 String    @default("oidc")
  displayName          String
  discoveryEndpoint    String
  clientId             String
  clientSecret         String?
  allowedDomains       String    @default("[]") // JSON array
  enabled              Boolean   @default(false)
  status               String    @default("pending_verification")
  roleMapping          String? // JSON object
  lastSuccessfulAuthAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  userLinks SsoUserLink[]

  @@index([tenantId, enabled])
}

model SsoUserLink {
  id          String           @id @default(cuid())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  provider    IdentityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId  String
  externalId  String
  email       String
  displayName String?
  avatarUrl   String?
  lastClaims  String? // JSON object
  linkedAt    DateTime         @default(now())
  lastLoginAt DateTime?

  @@unique([providerId, externalId])
  @@index([userId])
}

// =============================================================================
// Compliance & Audit (Block 4 - Day 39-40)
// =============================================================================

model DataExportRequest {
  id                    String    @id @default(cuid())
  tenantId              String
  userId                String
  status                String    @default("pending")
  requestedAt           DateTime  @default(now())
  estimatedCompletionAt DateTime?
  completedAt           DateTime?
  downloadUrl           String?
  expiresAt             DateTime?

  @@index([tenantId, status])
  @@index([tenantId, userId])
}

model DataDeletionRequest {
  id                  String    @id @default(cuid())
  tenantId            String
  userId              String
  status              String    @default("scheduled")
  requestedAt         DateTime  @default(now())
  scheduledDeletionAt DateTime
  completedAt         DateTime?
  retentionDays       Int       @default(30)

  @@index([tenantId, status])
  @@index([tenantId, userId])
}

model DeletionVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorId      String
  action       String
  resourceType String
  resourceId   String
  outcome      String   @default("success")
  timestamp    DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  metadata     String   @default("{}") // JSON object

  @@index([tenantId, action])
  @@index([tenantId, resourceType])
  @@index([tenantId, actorId])
  @@index([tenantId, timestamp])
}

