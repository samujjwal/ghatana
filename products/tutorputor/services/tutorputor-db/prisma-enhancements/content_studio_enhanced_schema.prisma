// Content Studio Enhanced Schema Additions
// Phase 1.2: Enhanced Database Schema for Evidence-Based Content Generation

// Add missing enums for content types and validation
enum ContentExampleType {
  REAL_WORLD
  PROBLEM_SOLVING
  ANALOGY
  CASE_STUDY
  CONCEPTUAL
  PROCEDURAL
}

enum ContentSimulationType {
  PARAMETER_EXPLORATION
  PREDICTION
  CONSTRUCTION
  EXPERIMENT
  MODELING
  ANALYSIS
}

enum ContentAnimationType {
  TWO_D
  THREE_D
  TIMELINE
  PROCESS_FLOW
  INTERACTIVE
  VISUALIZATION
}

enum ContentDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ValidationPillar {
  EDUCATIONAL
  EXPERIENTIAL
  SAFETY
  TECHNICAL
  ACCESSIBILITY
}

enum ContentGenerationJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ContentGenerationJobType {
  EXAMPLES
  SIMULATION
  ANIMATION
  ALL
}

enum ContentType {
  CLAIM
  EXAMPLE
  SIMULATION
  ANIMATION
}

enum ValidationStatusType {
  PENDING
  PASSED
  FAILED
  WARNING
}

enum EnhancementType {
  SUGGESTIONS
  GRADE_ADAPTATION
  ACCESSIBILITY
  CONTENT_IMPROVEMENT
}

enum EnhancementStatus {
  PENDING
  APPLIED
  REJECTED
}

// Add ContentNeeds table for better tracking and analysis
model ContentNeeds {
  id           String   @id @default(cuid())
  claimId      String
  experienceId String
  
  // Content requirements
  needsExamples    Boolean @default(false)
  needsSimulation  Boolean @default(false)
  needsAnimation   Boolean @default(false)
  
  // Specific requirements
  exampleCount     Int @default(0)
  exampleTypes     ContentExampleType[]
  simulationType   ContentSimulationType?
  animationType    ContentAnimationType?
  
  // Quality requirements
  difficultyLevel  ContentDifficulty @default(INTERMEDIATE)
  estimatedMinutes Int @default(0)
  
  // Metadata
  confidenceScore  Float @default(0.0)
  priorityLevel    Int @default(1)
  autoGenerated    Boolean @default(false)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  analyzedAt DateTime @default(now())
  
  // Relations
  claim      LearningClaim @relation(fields: [experienceId, claimId], references: [experienceId, claimRef], onDelete: Cascade)
  experience LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@unique([claimId])
  @@index([experienceId])
  @@index([priorityLevel(sort: Desc)])
  @@index([autoGenerated])
}

// Add content generation tracking table
model ContentGenerationJob {
  id           String   @id @default(cuid())
  experienceId String
  claimId      String?
  
  // Job details
  jobType    ContentGenerationJobType
  status     ContentGenerationJobStatus @default(PENDING)
  priority   Int @default(1)
  
  // Generation parameters
  parameters Json?
  modelUsed  String?
  promptHash String?
  
  // Results
  results       Json?
  errorMessage  String?
  retryCount    Int @default(0)
  
  // Metrics
  tokensUsed       Int @default(0)
  processingTimeMs Int @default(0)
  confidenceScore  Float @default(0.0)
  
  // Timestamps
  createdAt DateTime @default(now())
  startedAt DateTime?
  completedAt DateTime?
  
  // Relations
  experience LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claim      LearningClaim? @relation(fields: [experienceId, claimId], references: [experienceId, claimRef], onDelete: SetNull)
  
  // Indexes
  @@index([experienceId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([priority(sort: Desc)])
}

// Add content quality metrics table
model ContentQualityMetrics {
  id           String   @id @default(cuid())
  experienceId String
  claimId      String?
  contentType  ContentType
  contentId    String
  
  // Quality scores (0-100)
  educationalQuality  Int @default(0)
  engagementQuality  Int @default(0)
  clarityQuality     Int @default(0)
  accuracyQuality     Int @default(0)
  completenessQuality Int @default(0)
  overallQuality      Int @default(0)
  
  // Validation results
  validationStatus ValidationStatusType @default(PENDING)
  validationErrors  Json?
  validationWarnings Json?
  
  // User feedback
  userRating    Int?
  userFeedback  String?
  
  // AI analysis
  aiConfidence  Float?
  aiSuggestions Json?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastValidatedAt DateTime?
  
  // Relations
  experience LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claim      LearningClaim? @relation(fields: [experienceId, claimId], references: [experienceId, claimRef], onDelete: SetNull)
  
  // Indexes
  @@index([experienceId])
  @@index([contentId])
  @@index([overallQuality(sort: Desc)])
  @@index([validationStatus])
}

// Add enhanced validation results table
model EnhancedValidationResult {
  id           String   @id @default(cuid())
  experienceId String
  claimId      String?
  
  // Validation metadata
  validationType    String
  validationVersion String @default("1.0")
  modelUsed         String?
  
  // Overall results
  isValid         Boolean @default(false)
  overallScore    Int @default(0)
  canPublish      Boolean @default(false)
  confidenceScore Float @default(0.0)
  
  // Pillar scores
  educationalScore  Int @default(0)
  experientialScore Int @default(0)
  safetyScore       Int @default(0)
  technicalScore    Int @default(0)
  accessibilityScore Int @default(0)
  
  // Issues and suggestions
  issues     Json?
  suggestions Json?
  autoFixes  Json?
  
  // Processing metrics
  processingTimeMs Int @default(0)
  tokensAnalyzed   Int @default(0)
  
  // Timestamps
  createdAt DateTime @default(now())
  expiresAt DateTime @default(dbgenerated("(now() + interval '30 days')"))
  
  // Relations
  experience LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claim      LearningClaim? @relation(fields: [experienceId, claimId], references: [experienceId, claimRef], onDelete: SetNull)
  
  // Indexes
  @@index([experienceId])
  @@index([claimId])
  @@index([overallScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([expiresAt])
}

// Add content enhancement tracking table
model ContentEnhancement {
  id           String   @id @default(cuid())
  experienceId String
  claimId      String?
  
  // Enhancement details
  enhancementType   EnhancementType
  targetGradeLevel  String?
  
  // Enhancement data
  originalContent Json?
  enhancedContent  Json?
  suggestions       Json?
  
  // Quality metrics
  improvementScore Float?
  confidenceScore  Float?
  
  // Processing info
  modelUsed          String?
  processingTimeMs  Int @default(0)
  tokensGenerated    Int @default(0)
  
  // Status
  status          EnhancementStatus @default(PENDING)
  appliedBy       String?
  appliedAt        DateTime?
  rejectionReason String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  experience LearningExperience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  claim      LearningClaim? @relation(fields: [experienceId, claimId], references: [experienceId, claimRef], onDelete: SetNull)
  
  // Indexes
  @@index([experienceId])
  @@index([claimId])
  @@index([enhancementType])
  @@index([status])
  @@index([improvementScore(sort: Desc)])
}

// Update existing models to include new relations
model LearningExperience {
  // ... existing fields ...
  
  // New relations
  contentNeeds              ContentNeeds[]
  contentGenerationJobs    ContentGenerationJob[]
  contentQualityMetrics    ContentQualityMetrics[]
  enhancedValidationResults EnhancedValidationResult[]
  contentEnhancements       ContentEnhancement[]
}

model LearningClaim {
  // ... existing fields ...
  
  // New relations
  contentNeeds              ContentNeeds[]
  contentGenerationJobs    ContentGenerationJob[]
  contentQualityMetrics    ContentQualityMetrics[]
  enhancedValidationResults EnhancedValidationResult[]
  contentEnhancements       ContentEnhancement[]
}
