{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Tutorputor AI Tutoring Platform — Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Platform Health Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Tutorputor App",
      "type": "stat",
      "targets": [{"expr": "up{job=\"tutorputor-app\"}", "legendFormat": "app"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Content-Studio-Agents",
      "type": "stat",
      "targets": [{"expr": "up{job=\"content-studio-agents\"}", "legendFormat": "grpc"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "AI Agents Service",
      "type": "stat",
      "targets": [{"expr": "up{job=\"tutorputor-ai-agents\"}", "legendFormat": "ai-agents"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.05},
            {"color": "red", "value": 0.15}
          ]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "App HTTP Error Rate",
      "type": "stat",
      "targets": [{"expr": "rate(http_requests_total{job=\"tutorputor-app\", status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"tutorputor-app\"}[5m])", "legendFormat": "5xx rate"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 3}
          ]},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "App p99 Latency",
      "type": "stat",
      "targets": [{"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"tutorputor-app\"}[5m]))", "legendFormat": "p99"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 10,
      "title": "HTTP Request Metrics (App)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 11,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Request Throughput by Status",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(http_requests_total{job=\"tutorputor-app\", status=~\"2..\"}[5m])", "legendFormat": "2xx"},
        {"expr": "rate(http_requests_total{job=\"tutorputor-app\", status=~\"4..\"}[5m])", "legendFormat": "4xx"},
        {"expr": "rate(http_requests_total{job=\"tutorputor-app\", status=~\"5..\"}[5m])", "legendFormat": "5xx"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 12,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Request Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"tutorputor-app\"}[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"tutorputor-app\"}[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"tutorputor-app\"}[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 20,
      "title": "Content-Studio gRPC & AI Agent Telemetry",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 21,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "gRPC Request Rate by Method (Content-Studio)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(grpc_server_started_total{job=\"content-studio-agents\"}[5m])", "legendFormat": "{{grpc_method}}"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 22,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "LLM Provider Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(tutorputor_llm_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(tutorputor_llm_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(tutorputor_llm_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 30,
      "title": "JVM Runtime (AI Agents + Content-Studio gRPC)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}, "unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "id": 31,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "JVM Heap Memory Used vs Max",
      "type": "timeseries",
      "targets": [
        {"expr": "jvm_memory_used_bytes{job=~\"tutorputor-ai-agents|tutorputor-content-studio-grpc\", area=\"heap\"}", "legendFormat": "{{job}} used"},
        {"expr": "jvm_memory_max_bytes{job=~\"tutorputor-ai-agents|tutorputor-content-studio-grpc\", area=\"heap\"}", "legendFormat": "{{job}} max"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "id": 32,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "JVM Thread Count by State",
      "type": "timeseries",
      "targets": [
        {"expr": "jvm_threads_states_threads{job=~\"tutorputor-ai-agents|tutorputor-content-studio-grpc\"}", "legendFormat": "{{job}} {{state}}"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "id": 33,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "GC Pause Duration (avg)",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(jvm_gc_pause_seconds_sum{job=~\"tutorputor-ai-agents|tutorputor-content-studio-grpc\"}[5m]) / rate(jvm_gc_pause_seconds_count{job=~\"tutorputor-ai-agents|tutorputor-content-studio-grpc\"}[5m])", "legendFormat": "{{job}} GC avg"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "id": 40,
      "title": "Database & Cache",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "id": 41,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "targets": [
        {"expr": "pg_stat_database_numbackends", "legendFormat": "{{datname}}"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "id": 42,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Redis Memory Used vs Max",
      "type": "timeseries",
      "targets": [
        {"expr": "redis_memory_used_bytes", "legendFormat": "used"},
        {"expr": "redis_memory_max_bytes", "legendFormat": "max"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "id": 50,
      "title": "Host Infrastructure",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "percent"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 42},
      "id": 51,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Host CPU Usage %",
      "type": "timeseries",
      "targets": [
        {"expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{job=\"node\", mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 42},
      "id": 52,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "title": "Host Memory Usage %",
      "type": "timeseries",
      "targets": [
        {"expr": "1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})", "legendFormat": "{{instance}}"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}, "unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 42},
      "id": 53,
      "options": {"legend": {"calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom"}},
      "title": "Host Disk Space Available",
      "type": "timeseries",
      "targets": [
        {"expr": "node_filesystem_avail_bytes{job=\"node\", mountpoint=\"/\"}", "legendFormat": "{{instance}} /"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["tutorputor", "platform", "monitoring", "ai-tutoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(up{job=~\"tutorputor.*|content-studio.*\"}, instance)",
        "label": "Instance",
        "name": "instance",
        "options": [],
        "query": "label_values(up{job=~\"tutorputor.*|content-studio.*\"}, instance)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Tutorputor — AI Tutoring Platform",
  "uid": "tutorputor-platform-001",
  "version": 1
}
