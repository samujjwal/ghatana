#!/usr/bin/env bash
#
# ttr-migrate: Run TutorPutor database migrations
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

# Default database URL (matches Docker setup)
export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"

# Parse arguments
ENVIRONMENT="development"
RESET=false
GENERATE_ONLY=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --production|--prod)
            ENVIRONMENT="production"
            shift
            ;;
        --reset)
            RESET=true
            shift
            ;;
        --generate)
            GENERATE_ONLY=true
            shift
            ;;
        --status)
            SHOW_STATUS=true
            shift
            ;;
        --help|-h)
            cat << 'EOF'
Usage: ttr migrate [options]

Run database migrations for TutorPutor.

OPTIONS:
  --production      Run production migrations (no dev features)
  --reset           Reset database (DANGER: destroys data)
  --generate        Generate Prisma client only
  --status          Show migration status
  -h, --help        Show this help

EXAMPLES:
  ttr migrate                   # Run dev migrations
  ttr migrate --production      # Run production migrations
  ttr migrate --reset           # Reset and re-run migrations
  ttr migrate --generate       # Generate Prisma client
  ttr migrate --status         # Check migration status
EOF
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Check database is running
check_database() {
    if ! docker exec tutorputor-postgres pg_isready -U postgres >/dev/null 2>&1; then
        log_error "Database is not running"
        log_info "Start it with: ttr dev --no-seed"
        exit 1
    fi
}

# Show migration status
show_status() {
    log_info "Migration status..."
    
    cd "${ROOT_DIR}/libs/tutorputor-core"
    npx prisma migrate status
}

# Reset database
reset_database() {
    log_warn "This will DELETE ALL DATA in the database!"
    read -p "Are you sure? [y/N] " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Cancelled"
        exit 0
    fi
    
    log_info "Resetting database..."
    
    cd "${ROOT_DIR}/libs/tutorputor-core"
    
    export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"
    DATABASE_URL="$DATABASE_URL" npx prisma migrate reset --force --skip-generate
    
    log_success "Database reset"
}

# Run migrations
run_migrations() {
    log_info "Running migrations ($ENVIRONMENT)..."
    
    cd "${ROOT_DIR}/libs/tutorputor-core"
    
    # Ensure DATABASE_URL is set
    export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"
    
    if [ "$ENVIRONMENT" = "production" ]; then
        DATABASE_URL="$DATABASE_URL" npx prisma migrate deploy
    else
        DATABASE_URL="$DATABASE_URL" npx prisma migrate dev
    fi
    
    log_success "Migrations complete"
}

# Generate Prisma client
generate_client() {
    log_info "Generating Prisma client..."
    
    cd "${ROOT_DIR}/libs/tutorputor-core"
    
    export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"
    DATABASE_URL="$DATABASE_URL" npx prisma generate
    
    log_success "Client generated"
}

# Main
main() {
    echo ""
    log_info "TutorPutor Database Migrations"
    echo "=========================================="
    echo ""
    
    # Check if just showing status
    if [ "${SHOW_STATUS:-}" = "true" ]; then
        check_database
        show_status
        exit 0
    fi
    
    check_database
    
    if [ "$RESET" = "true" ]; then
        reset_database
    fi
    
    if [ "$GENERATE_ONLY" = "true" ]; then
        generate_client
    else
        run_migrations
        generate_client
    fi
    
    echo ""
    log_success "Migration operations complete!"
}

main "$@"
