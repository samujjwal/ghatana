#!/usr/bin/env bash
#
# ttr-prod: Start TutorPutor production environment
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

# Configuration
export TUTORPUTOR_ENV=production

# Parse arguments
BUILD_ONLY=false
DEPLOY_TARGET="local"

while [[ $# -gt 0 ]]; do
    case $1 in
        --build)
            BUILD_ONLY=true
            shift
            ;;
        --k8s)
            DEPLOY_TARGET="kubernetes"
            shift
            ;;
        --docker)
            DEPLOY_TARGET="docker"
            shift
            ;;
        --help|-h)
            cat << 'EOF'
Usage: ttr prod [options]

Start TutorPutor in production mode.

Options:
  --build          Build production images only (don't start)
  --docker         Deploy with Docker Compose (default)
  --k8s            Deploy to Kubernetes
  -h, --help       Show this help

Examples:
  ttr prod                     # Start production locally
  ttr prod --build             # Build images only
  ttr prod --k8s               # Deploy to Kubernetes
EOF
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Verify production readiness
check_production_ready() {
    log_info "Checking production readiness..."
    
    # Check required env vars
    local required_vars=(
        "DATABASE_URL"
        "REDIS_URL"
        "JWT_SECRET"
    )
    
    local missing=()
    for var in "${required_vars[@]}"; do
        if [ -z "${!var:-}" ]; then
            missing+=("$var")
        fi
    done
    
    if [ ${#missing[@]} -ne 0 ]; then
        log_error "Missing required environment variables:"
        for var in "${missing[@]}"; do
            echo "  - $var"
        done
        echo ""
        echo "Set them in your environment or .env file"
        exit 1
    fi
    
    log_success "Production checks passed"
}

# Build production images
build_images() {
    log_info "Building production Docker images..."
    
    cd "$ROOT_DIR"
    
    # Build with docker compose
    docker compose -f docker-compose.yml -f docker-compose.prod.yml build
    
    log_success "Images built"
}

# Deploy with Docker Compose
deploy_docker() {
    log_info "Deploying with Docker Compose..."
    
    cd "$ROOT_DIR"
    
    # Pull latest images
    docker compose -f docker-compose.yml -f docker-compose.prod.yml pull
    
    # Start services
    docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
    
    # Run migrations
    log_info "Running database migrations..."
    docker compose exec platform npx prisma migrate deploy
    
    log_success "Production deployment complete"
    
    echo ""
    echo "Services:"
    docker compose ps
}

# Deploy to Kubernetes
deploy_kubernetes() {
    log_info "Deploying to Kubernetes..."
    
    if ! command -v kubectl >/dev/null 2>&1; then
        log_error "kubectl not installed"
        exit 1
    fi
    
    if ! kubectl cluster-info >/dev/null 2>&1; then
        log_error "No Kubernetes cluster connected"
        exit 1
    fi
    
    cd "$ROOT_DIR/k8s"
    
    # Apply configurations
    kubectl apply -f namespace.yaml
    kubectl apply -f configmap.yaml
    kubectl apply -f secret.yaml
    kubectl apply -f postgres.yaml
    kubectl apply -f redis.yaml
    kubectl apply -f platform.yaml
    kubectl apply -f web.yaml
    kubectl apply -f ingress.yaml
    
    # Wait for rollout
    kubectl rollout status deployment/tutorputor-platform
    kubectl rollout status deployment/tutorputor-web
    
    log_success "Kubernetes deployment complete"
}

# Main
main() {
    echo ""
    log_info "TutorPutor Production Deployment"
    echo "=========================================="
    echo ""
    
    check_production_ready
    build_images
    
    if [ "$BUILD_ONLY" = "false" ]; then
        case "$DEPLOY_TARGET" in
            docker|local)
                deploy_docker
                ;;
            kubernetes|k8s)
                deploy_kubernetes
                ;;
        esac
    fi
    
    echo ""
    log_success "Production ready!"
}

main "$@"
