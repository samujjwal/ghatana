#!/usr/bin/env bash
#
# ttr-test: Flexible test runner for TutorPutor
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }
log_section() { echo -e "${CYAN}▶ $1${NC}"; }

# Test configuration
TEST_MODE="all"
TEST_FILTER=""
WATCH_MODE=false
COVERAGE=false
CI_MODE=false
PARALLEL=true
VERBOSE=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --unit)
            TEST_MODE="unit"
            shift
            ;;
        --integration)
            TEST_MODE="integration"
            shift
            ;;
        --e2e)
            TEST_MODE="e2e"
            shift
            ;;
        --contract)
            TEST_MODE="contract"
            shift
            ;;
        --performance)
            TEST_MODE="performance"
            shift
            ;;
        --resilience)
            TEST_MODE="resilience"
            shift
            ;;
        --watch)
            WATCH_MODE=true
            shift
            ;;
        --coverage)
            COVERAGE=true
            shift
            ;;
        --ci)
            CI_MODE=true
            WATCH_MODE=false
            shift
            ;;
        --serial)
            PARALLEL=false
            shift
            ;;
        --verbose|-v)
            VERBOSE=true
            shift
            ;;
        -f|--filter)
            TEST_FILTER="$2"
            shift 2
            ;;
        --quick)
            TEST_MODE="quick"
            shift
            ;;
        --help|-h)
            cat << 'EOF'
Usage: ttr test [options]

Run TutorPutor tests with flexible options.

TEST TYPES:
  --unit           Run unit tests only
  --integration    Run integration tests
  --e2e            Run end-to-end tests
  --contract       Run contract tests
  --performance    Run performance tests
  --resilience     Run resilience tests
  --quick          Run quick smoke tests
  (no flag)        Run all tests

OPTIONS:
  -f, --filter     Filter tests by pattern
  --watch          Run in watch mode
  --coverage       Generate coverage report
  --ci             CI mode (no watch, exit codes)
  --serial         Run tests serially (not parallel)
  --verbose, -v    Show detailed output
  -h, --help       Show this help

EXAMPLES:
  ttr test                              # Run all tests
  ttr test --unit                       # Unit tests only
  ttr test --unit --watch              # Unit tests in watch mode
  ttr test --e2e -f "auth"              # E2E tests matching "auth"
  ttr test --ci --coverage              # CI mode with coverage
  ttr test --contract                   # Contract tests
  ttr test --quick                      # Quick smoke tests

FILTER PATTERNS:
  ttr test --unit -f "example"          # Tests with "example" in name
  ttr test --e2e -f "**/login/**"      # E2E tests in login folder

CI MODE:
  Exits with non-zero code on test failure
  Runs tests in parallel for speed
  Generates reports in .test-results/
EOF
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Test result tracking
TOTAL_PASSED=0
TOTAL_FAILED=0
TOTAL_SKIPPED=0
FAILED_SUITES=()

# Run tests in a package
run_package_tests() {
    local package_path="$1"
    local package_name="$2"
    local test_cmd="$3"
    
    log_section "Testing: $package_name"
    
    cd "$package_path"
    
    # Build command with options
    local cmd="$test_cmd"
    
    if [ "$CI_MODE" = "true" ]; then
        cmd="$cmd --reporter=dot"
    fi
    
    if [ "$COVERAGE" = "true" ]; then
        cmd="$cmd --coverage"
    fi
    
    if [ "$VERBOSE" = "true" ]; then
        cmd="$cmd --reporter=verbose"
    fi
    
    if [ -n "$TEST_FILTER" ]; then
        cmd="$cmd --testNamePattern='$TEST_FILTER'"
    fi
    
    # Run tests
    local exit_code=0
    if [ "$VERBOSE" = "true" ]; then
        eval "$cmd" || exit_code=$?
    else
        eval "$cmd" 2>&1 | grep -E "(PASS|FAIL|✓|✗|Test Suites|Tests:)" || exit_code=${PIPESTATUS[0]}
    fi
    
    if [ $exit_code -eq 0 ]; then
        log_success "$package_name tests passed"
        ((TOTAL_PASSED++))
    else
        log_error "$package_name tests failed"
        ((TOTAL_FAILED++))
        FAILED_SUITES+=("$package_name")
    fi
    
    return $exit_code
}

# Run unit tests
run_unit_tests() {
    log_info "Running unit tests..."
    
    local packages=(
        "libs/tutorputor-core:Core Library"
        "libs/tutorputor-ai:AI Library"
        "libs/tutorputor-ui:UI Library"
        "services/tutorputor-platform:Platform Service"
    )
    
    for pkg in "${packages[@]}"; do
        IFS=: read -r path name <<< "$pkg"
        local full_path="${ROOT_DIR}/${path}"
        
        if [ -f "${full_path}/package.json" ]; then
            if [ -f "${full_path}/vitest.config.ts" ] || [ -f "${full_path}/jest.config.js" ] || [ -f "${full_path}/jest.config.ts" ]; then
                run_package_tests "$full_path" "$name" "pnpm test" || true
            else
                log_warn "No test config found in $name, skipping"
            fi
        fi
    done
}

# Run integration tests
run_integration_tests() {
    log_info "Running integration tests..."
    
    cd "${ROOT_DIR}/tests/integration"
    
    if [ -f "package.json" ]; then
        run_package_tests "${ROOT_DIR}/tests/integration" "Integration Tests" "pnpm test" || true
    else
        # Direct vitest execution
        if [ -f "${ROOT_DIR}/tests/integration/vitest.config.ts" ]; then
            cd "${ROOT_DIR}/tests/integration"
            run_package_tests "." "Integration Tests" "npx vitest run" || true
        else
            log_warn "No integration tests found"
        fi
    fi
}

# Run E2E tests
run_e2e_tests() {
    log_info "Running E2E tests..."
    
    # Check if dev environment is running
    if ! curl -s http://localhost:3200/health >/dev/null 2>&1; then
        log_warn "Dev environment not running. Starting temporarily..."
        # Start services for E2E tests
        "${SCRIPT_DIR}/ttr-dev" --no-apps &
        local dev_pid=$!
        sleep 30
    fi
    
    cd "${ROOT_DIR}/tests/e2e"
    
    if [ -f "playwright.config.ts" ] || [ -f "playwright.config.js" ]; then
        local cmd="npx playwright test"
        
        if [ -n "$TEST_FILTER" ]; then
            cmd="$cmd --grep='$TEST_FILTER'"
        fi
        
        if [ "$CI_MODE" = "true" ]; then
            cmd="$cmd --reporter=dot"
        fi
        
        run_package_tests "." "E2E Tests" "$cmd" || true
    else
        log_warn "No Playwright config found"
    fi
    
    # Cleanup if we started dev environment
    if [ -n "${dev_pid:-}" ]; then
        kill $dev_pid 2>/dev/null || true
    fi
}

# Run contract tests
run_contract_tests() {
    log_info "Running contract tests..."
    
    local contract_test_dirs=(
        "services/tutorputor-platform/src/workers/content/grpc/__tests__/contract.test.ts"
    )
    
    for test_file in "${contract_test_dirs[@]}"; do
        if [ -f "${ROOT_DIR}/${test_file}" ]; then
            log_section "Contract Test: $(basename "$test_file")"
            
            local dir=$(dirname "${ROOT_DIR}/${test_file}")
            cd "$dir"
            
            if pnpm vitest run "$(basename "$test_file")" 2>&1 | grep -q "PASS\|✓"; then
                log_success "Contract test passed"
                ((TOTAL_PASSED++))
            else
                log_error "Contract test failed"
                ((TOTAL_FAILED++))
                FAILED_SUITES+=("Contract: $(basename "$test_file")")
            fi
        fi
    done
}

# Run performance tests
run_performance_tests() {
    log_info "Running performance tests..."
    
    cd "${ROOT_DIR}/tests/performance"
    
    if [ -f "k6-test.js" ] || [ -f "load-test.js" ]; then
        if command -v k6 >/dev/null 2>&1; then
            log_section "K6 Performance Tests"
            k6 run k6-test.js || true
        else
            log_warn "k6 not installed. Install with: brew install k6"
        fi
    else
        log_warn "No performance tests found"
    fi
}

# Run resilience tests
run_resilience_tests() {
    log_info "Running resilience tests..."
    
    cd "${ROOT_DIR}/tests/resilience"
    
    if [ -d "chaos" ]; then
        log_section "Chaos Engineering Tests"
        # Run chaos tests if available
        if [ -f "chaos/chaos-test.sh" ]; then
            bash chaos/chaos-test.sh || true
        fi
    else
        log_warn "No resilience tests found"
    fi
}

# Run quick smoke tests
run_quick_tests() {
    log_info "Running quick smoke tests..."
    
    log_section "Type Check"
    cd "${ROOT_DIR}"
    if pnpm typecheck 2>&1 | tail -5; then
        log_success "Type check passed"
        ((TOTAL_PASSED++))
    else
        log_error "Type check failed"
        ((TOTAL_FAILED++))
        FAILED_SUITES+=("Type Check")
    fi
    
    log_section "Lint Check"
    if pnpm lint 2>&1 | tail -5; then
        log_success "Lint check passed"
        ((TOTAL_PASSED++))
    else
        log_error "Lint check failed"
        ((TOTAL_FAILED++))
        FAILED_SUITES+=("Lint Check")
    fi
    
    log_section "Core Unit Tests"
    cd "${ROOT_DIR}/libs/tutorputor-core"
    if pnpm test --run 2>&1 | grep -E "(PASS|FAIL|Test Suites)"; then
        log_success "Core tests passed"
        ((TOTAL_PASSED++))
    else
        log_error "Core tests failed"
        ((TOTAL_FAILED++))
        FAILED_SUITES+=("Core Tests")
    fi
}

# Print summary
print_summary() {
    echo ""
    echo "=========================================="
    log_section "Test Summary"
    echo "=========================================="
    echo ""
    
    if [ $TOTAL_FAILED -eq 0 ]; then
        log_success "All tests passed!"
    else
        log_error "Some tests failed"
        echo ""
        echo "Failed suites:"
        for suite in "${FAILED_SUITES[@]}"; do
            echo "  - $suite"
        done
    fi
    
    echo ""
    echo "Results:"
    echo "  Passed:  $TOTAL_PASSED"
    echo "  Failed:  $TOTAL_FAILED"
    echo "  Total:   $((TOTAL_PASSED + TOTAL_FAILED))"
    echo ""
    
    if [ "$COVERAGE" = "true" ]; then
        echo "Coverage reports:"
        echo "  libs/tutorputor-core/coverage/"
        echo "  services/tutorputor-platform/coverage/"
        echo ""
    fi
}

# Main
main() {
    echo ""
    log_info "TutorPutor Test Runner"
    echo "=========================================="
    echo ""
    
    # Check if we're in a valid project
    if [ ! -f "${ROOT_DIR}/pnpm-workspace.yaml" ]; then
        log_error "Not in TutorPutor project root"
        exit 1
    fi
    
    case "$TEST_MODE" in
        unit)
            run_unit_tests
            ;;
        integration)
            run_integration_tests
            ;;
        e2e)
            run_e2e_tests
            ;;
        contract)
            run_contract_tests
            ;;
        performance)
            run_performance_tests
            ;;
        resilience)
            run_resilience_tests
            ;;
        quick)
            run_quick_tests
            ;;
        all)
            run_unit_tests
            run_integration_tests
            run_contract_tests
            run_e2e_tests
            ;;
    esac
    
    print_summary
    
    # Exit with appropriate code
    if [ "$CI_MODE" = "true" ] && [ $TOTAL_FAILED -gt 0 ]; then
        exit 1
    fi
}

main "$@"
