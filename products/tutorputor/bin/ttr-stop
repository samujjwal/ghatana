#!/usr/bin/env bash
#
# ttr-stop: Stop all TutorPutor services
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }

# Parse arguments
STOP_TYPE="all"

while [[ $# -gt 0 ]]; do
    case $1 in
        --services)
            STOP_TYPE="services"
            shift
            ;;
        --apps)
            STOP_TYPE="apps"
            shift
            ;;
        --infra)
            STOP_TYPE="infra"
            shift
            ;;
        --help|-h)
            cat << 'EOF'
Usage: ttr stop [options]

Stop TutorPutor services.

Options:
  --services    Stop backend services only
  --apps        Stop frontend apps only
  --infra       Stop infrastructure only
  (no flag)     Stop everything
  -h, --help    Show this help

Examples:
  ttr stop              # Stop everything
  ttr stop --services   # Stop backend services
  ttr stop --apps       # Stop frontend apps
EOF
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

stop_services() {
    log_info "Stopping backend services..."
    
    # Stop Node.js services
    local pids=(
        "${ROOT_DIR}/.logs/platform.pid"
        "${ROOT_DIR}/.logs/content-gen.pid"
    )
    
    for pid_file in "${pids[@]}"; do
        if [ -f "$pid_file" ]; then
            local pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                kill "$pid" 2>/dev/null || true
                log_success "Stopped process $pid"
            fi
            rm -f "$pid_file"
        fi
    done
    
    # Kill any remaining node processes on our ports
    local ports=("3200" "3201" "3202")
    for port in "${ports[@]}"; do
        local pid=$(lsof -ti :$port 2>/dev/null || true)
        if [ -n "$pid" ]; then
            kill $pid 2>/dev/null || true
            log_warn "Killed process on port $port"
        fi
    done
}

stop_apps() {
    log_info "Stopping frontend applications..."
    
    local pids=(
        "${ROOT_DIR}/.logs/web.pid"
        "${ROOT_DIR}/.logs/admin.pid"
    )
    
    for pid_file in "${pids[@]}"; do
        if [ -f "$pid_file" ]; then
            local pid=$(cat "$pid_file")
            if kill -0 "$pid" 2>/dev/null; then
                kill "$pid" 2>/dev/null || true
                log_success "Stopped process $pid"
            fi
            rm -f "$pid_file"
        fi
    done
}

stop_infrastructure() {
    log_info "Stopping infrastructure..."
    
    cd "$ROOT_DIR"
    
    if docker compose ps -q 2>/dev/null | grep -q .; then
        docker compose down
        log_success "Docker services stopped"
    else
        log_info "No Docker services running"
    fi
}

# Main
main() {
    echo ""
    log_info "Stopping TutorPutor Services"
    echo "=========================================="
    echo ""
    
    case "$STOP_TYPE" in
        all)
            stop_services
            stop_apps
            stop_infrastructure
            log_success "All services stopped"
            ;;
        services)
            stop_services
            ;;
        apps)
            stop_apps
            ;;
        infra)
            stop_infrastructure
            ;;
    esac
    
    echo ""
    log_success "Done!"
}

main "$@"
