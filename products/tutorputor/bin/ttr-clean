#!/usr/bin/env bash
#
# ttr-clean: Clean TutorPutor build artifacts and dependencies
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }
log_section() { echo -e "${CYAN}▶ $1${NC}"; }

# Parse arguments
CLEAN_NODE_MODULES=false
CLEAN_BUILD=false
CLEAN_LOGS=false
CLEAN_DOCKER=false
CLEAN_ALL=false
CLEAN_DIST=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --node-modules)
            CLEAN_NODE_MODULES=true
            shift
            ;;
        --build)
            CLEAN_BUILD=true
            shift
            ;;
        --logs)
            CLEAN_LOGS=true
            shift
            ;;
        --docker)
            CLEAN_DOCKER=true
            shift
            ;;
        --dist)
            CLEAN_DIST=true
            shift
            ;;
        --all)
            CLEAN_ALL=true
            shift
            ;;
        --help|-h)
            cat << 'EOF'
Usage: ttr clean [options]

Clean TutorPutor build artifacts and dependencies.

Options:
  --node-modules    Delete all node_modules directories
  --build           Clean build artifacts (.next, dist, build)
  --logs            Clean log files
  --docker          Clean Docker images and volumes
  --dist            Clean distribution files
  --all             Clean everything (full reset)
  -h, --help        Show this help

Examples:
  ttr clean --logs              # Clean logs only
  ttr clean --build             # Clean build artifacts
  ttr clean --node-modules      # Delete node_modules
  ttr clean --all               # Full reset (WARNING: destructive)

WARNING: --all will:
  - Delete all node_modules
  - Delete all build artifacts
  - Delete all logs
  - Prune Docker system
  - Clear pnpm cache
EOF
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# If no specific option, clean build artifacts by default
if [ "$CLEAN_NODE_MODULES" = "false" ] && [ "$CLEAN_BUILD" = "false" ] && [ "$CLEAN_LOGS" = "false" ] && [ "$CLEAN_DOCKER" = "false" ] && [ "$CLEAN_DIST" = "false" ] && [ "$CLEAN_ALL" = "false" ]; then
    CLEAN_BUILD=true
fi

# If --all, enable everything
if [ "$CLEAN_ALL" = "true" ]; then
    CLEAN_NODE_MODULES=true
    CLEAN_BUILD=true
    CLEAN_LOGS=true
    CLEAN_DOCKER=true
    CLEAN_DIST=true
fi

clean_node_modules() {
    log_section "Cleaning node_modules"
    
    local count=0
    
    # Find and remove node_modules
    while IFS= read -r -d '' dir; do
        rm -rf "$dir"
        ((count++))
        echo "  Removed: $(dirname "$dir")"
    done < <(find "${ROOT_DIR}" -type d -name "node_modules" -print0 2>/dev/null)
    
    log_success "Removed $count node_modules directories"
}

clean_build() {
    log_section "Cleaning build artifacts"
    
    local artifacts=(
        ".next"
        ".turbo"
        "build"
        "dist"
        "*.tsbuildinfo"
        ".eslintcache"
    )
    
    local count=0
    
    for artifact in "${artifacts[@]}"; do
        while IFS= read -r -d '' path; do
            rm -rf "$path"
            ((count++))
        done < <(find "${ROOT_DIR}" -name "$artifact" -print0 2>/dev/null)
    done
    
    log_success "Cleaned $count build artifacts"
}

clean_logs() {
    log_section "Cleaning logs"
    
    if [ -d "${ROOT_DIR}/.logs" ]; then
        local count=$(find "${ROOT_DIR}/.logs" -type f | wc -l)
        rm -rf "${ROOT_DIR}/.logs"
        mkdir -p "${ROOT_DIR}/.logs"
        log_success "Cleaned $count log files"
    else
        log_info "No logs to clean"
    fi
}

clean_docker() {
    log_section "Cleaning Docker"
    
    # Stop and remove containers
    if docker ps -q -f name=tutorputor 2>/dev/null | grep -q .; then
        docker stop $(docker ps -q -f name=tutorputor) 2>/dev/null || true
        log_success "Stopped TutorPutor containers"
    fi
    
    # Remove images if requested
    if [ "$CLEAN_ALL" = "true" ]; then
        docker system prune -f
        log_success "Pruned Docker system"
    fi
    
    # Clean volumes
    docker volume prune -f 2>/dev/null || true
}

clean_dist() {
    log_section "Cleaning distribution files"
    
    if [ -d "${ROOT_DIR}/dist" ]; then
        rm -rf "${ROOT_DIR}/dist"
        log_success "Cleaned dist/"
    fi
    
    # Clean package-specific dist directories
    local count=0
    while IFS= read -r -d '' dir; do
        rm -rf "$dir"
        ((count++))
    done < <(find "${ROOT_DIR}" -type d -name "dist" -not -path "*/node_modules/*" -print0 2>/dev/null)
    
    log_success "Cleaned $count dist directories"
}

clean_cache() {
    if [ "$CLEAN_ALL" = "true" ]; then
        log_section "Cleaning caches"
        
        # pnpm cache
        pnpm store prune 2>/dev/null || true
        
        # Prisma cache
        rm -rf "${ROOT_DIR}/libs/tutorputor-core/node_modules/.prisma" 2>/dev/null || true
        
        log_success "Caches cleaned"
    fi
}

# Main
main() {
    echo ""
    log_info "TutorPutor Cleaner"
    echo "=========================================="
    echo ""
    
    if [ "$CLEAN_ALL" = "true" ]; then
        log_warn "Running FULL CLEAN (destructive operation)"
        echo ""
        read -p "Are you sure? [y/N] " -n 1 -r
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_info "Cancelled"
            exit 0
        fi
        echo ""
    fi
    
    # Run selected cleaners
    [ "$CLEAN_NODE_MODULES" = "true" ] && clean_node_modules
    [ "$CLEAN_BUILD" = "true" ] && clean_build
    [ "$CLEAN_LOGS" = "true" ] && clean_logs
    [ "$CLEAN_DOCKER" = "true" ] && clean_docker
    [ "$CLEAN_DIST" = "true" ] && clean_dist
    clean_cache
    
    echo ""
    log_success "Clean complete!"
    echo ""
    
    if [ "$CLEAN_NODE_MODULES" = "true" ] || [ "$CLEAN_ALL" = "true" ]; then
        echo "Next steps:"
        echo "  pnpm install          # Reinstall dependencies"
        echo "  ttr dev              # Start development"
    fi
}

main "$@"
