#!/usr/bin/env bash
#
# ttr-doctor: Check TutorPutor system health and requirements
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }
log_section() { echo -e "${CYAN}▶ $1${NC}"; }

CHECKS_PASSED=0
CHECKS_FAILED=0
WARNINGS=0

# Default database URL (matches Docker setup)
export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"

# Run a check
run_check() {
    local name="$1"
    local command="$2"
    local required="${3:-true}"
    
    if eval "$command" >/dev/null 2>&1; then
        log_success "$name"
        ((CHECKS_PASSED++))
        return 0
    else
        if [ "$required" = "true" ]; then
            log_error "$name"
            ((CHECKS_FAILED++))
        else
            log_warn "$name (optional)"
            ((WARNINGS++))
        fi
        return 1
    fi
}

# Check prerequisites
check_prerequisites() {
    log_section "Prerequisites"
    
    run_check "Node.js (18+)" "node -v | grep -E 'v1[8-9]|v[2-9][0-9]'"
    run_check "pnpm" "command -v pnpm" 
    run_check "Docker" "docker version"
    run_check "Docker Compose" "docker compose version || docker-compose version"
    run_check "Java (21+)" "java -version 2>&1 | grep -E '(21|22)'" "false"
    run_check "Git" "git --version"
    
    echo ""
}

# Check environment
check_environment() {
    log_section "Environment"
    
    # Check .env files
    if [ -f "${ROOT_DIR}/.env" ]; then
        log_success ".env file exists"
    else
        log_warn ".env file not found (copy from .env.example)"
        ((WARNINGS++))
    fi
    
    # Check node_modules
    if [ -d "${ROOT_DIR}/node_modules" ]; then
        log_success "Root dependencies installed"
    else
        log_error "Root dependencies missing (run: pnpm install)"
        ((CHECKS_FAILED++))
    fi
    
    # Check core library
    if [ -d "${ROOT_DIR}/libs/tutorputor-core/node_modules" ]; then
        log_success "Core library dependencies installed"
    else
        log_warn "Core library dependencies missing"
        ((WARNINGS++))
    fi
    
    echo ""
}

# Check services health
check_services() {
    log_section "Services Health"
    
    # Check if services are running
    local services=(
        "3200:API Gateway"
        "3201:Web App"
        "3202:Admin App"
    )
    
    for service in "${services[@]}"; do
        IFS=: read -r port name <<< "$service"
        
        if nc -z localhost "$port" 2>/dev/null; then
            log_success "$name (port $port)"
        else
            log_warn "$name not running (port $port)"
            ((WARNINGS++))
        fi
    done
    
    echo ""
}

# Check infrastructure
check_infrastructure() {
    log_section "Infrastructure"
    
    # Check Docker containers
    if docker ps --filter "name=tutorputor-postgres" --format "{{.Names}}" | grep -q .; then
        log_success "PostgreSQL running"
    else
        log_warn "PostgreSQL not running"
        ((WARNINGS++))
    fi
    
    if docker ps --filter "name=tutorputor-redis" --format "{{.Names}}" | grep -q .; then
        log_success "Redis running"
    else
        log_warn "Redis not running"
        ((WARNINGS++))
    fi
    
    echo ""
}

# Check database
check_database() {
    log_section "Database"
    
    if docker exec tutorputor-postgres pg_isready -U postgres 2>/dev/null; then
        log_success "PostgreSQL responding"
        
        # Check migrations
        cd "${ROOT_DIR}/libs/tutorputor-core"
        export DATABASE_URL="${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/tutorputor}"
        if DATABASE_URL="$DATABASE_URL" npx prisma migrate status 2>/dev/null | grep -q "Database schema is up to date"; then
            log_success "Database migrations up to date"
        else
            log_warn "Database migrations pending (run: ttr migrate)"
            ((WARNINGS++))
        fi
    else
        log_warn "PostgreSQL not responding"
        ((WARNINGS++))
    fi
    
    echo ""
}

# Check disk space
check_disk_space() {
    log_section "Disk Space"
    
    local available=$(df -h . | tail -1 | awk '{print $4}')
    local percentage=$(df -h . | tail -1 | awk '{print $5}' | tr -d '%')
    
    if [ "$percentage" -lt 80 ]; then
        log_success "Disk space OK ($available available)"
    else
        log_warn "Low disk space ($available available, ${percentage}% used)"
        ((WARNINGS++))
    fi
    
    echo ""
}

# Check if a port is listening
check_common_issues() {
    log_section "Common Issues"
    
    # Check for hanging processes
    local hanging_ports=()
    for port in 3200 3201 3202; do
        if lsof -ti :$port >/dev/null 2>&1; then
            hanging_ports+=("$port")
        fi
    done
    
    if [ ${#hanging_ports[@]} -gt 0 ]; then
        log_warn "Processes found on ports: ${hanging_ports[*]}"
        echo "  Run 'ttr stop' to clean up"
        ((WARNINGS++))
    else
        log_success "No hanging processes"
    fi
    
    # Check log size
    if [ -d "${ROOT_DIR}/.logs" ]; then
        local log_size=$(du -sh "${ROOT_DIR}/.logs" 2>/dev/null | cut -f1)
        log_info "Log directory size: $log_size"
    fi
    
    echo ""
}

# Print fix instructions
print_fix_instructions() {
    if [ $CHECKS_FAILED -gt 0 ] || [ $WARNINGS -gt 0 ]; then
        echo ""
        log_section "Fix Instructions"
        echo ""
        
        if [ $CHECKS_FAILED -gt 0 ]; then
            echo "Required fixes:"
            echo "  1. Install missing prerequisites"
            echo "  2. Run: pnpm install"
            echo "  3. Run: ttr dev --no-seed (to start services)"
            echo ""
        fi
        
        if [ $WARNINGS -gt 0 ]; then
            echo "Recommended actions:"
            echo "  - Start dev environment: ttr dev"
            echo "  - Run migrations: ttr migrate"
            echo "  - Clean logs: ttr clean --logs"
            echo ""
        fi
    fi
}

# Print summary
print_summary() {
    echo "=========================================="
    log_section "Health Check Summary"
    echo "=========================================="
    echo ""
    echo "Checks:"
    echo "  ✓ Passed:   $CHECKS_PASSED"
    echo "  ✗ Failed:   $CHECKS_FAILED"
    echo "  ⚠ Warnings: $WARNINGS"
    echo ""
    
    if [ $CHECKS_FAILED -eq 0 ] && [ $WARNINGS -eq 0 ]; then
        log_success "System is healthy!"
    elif [ $CHECKS_FAILED -eq 0 ]; then
        log_warn "System functional with warnings"
    else
        log_error "System has issues that need attention"
        return 1
    fi
    
    echo ""
}

# Main
main() {
    echo ""
    log_info "TutorPutor Health Check"
    echo "=========================================="
    echo ""
    
    check_prerequisites
    check_environment
    check_services
    check_infrastructure
    check_database
    check_disk_space
    check_common_issues
    
    print_fix_instructions
    print_summary
}

main "$@"
