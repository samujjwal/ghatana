#!/usr/bin/env bash
#
# ttr-status: Show TutorPutor service status
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}ℹ${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1"; }
log_error() { echo -e "${RED}✗${NC} $1"; }
log_section() { echo -e "${CYAN}▶ $1${NC}"; }

# Status symbols
STATUS_UP="${GREEN}●${NC}"
STATUS_DOWN="${RED}●${NC}"
STATUS_UNKNOWN="${YELLOW}●${NC}"

# Check if a port is listening
check_port() {
    local port=$1
    nc -z localhost $port 2>/dev/null && echo "up" || echo "down"
}

# Check Docker container
check_docker() {
    local container=$1
    docker ps --filter "name=$container" --filter "status=running" --format "{{.Names}}" 2>/dev/null | grep -q . && echo "up" || echo "down"
}

# Check PID file
check_pid_file() {
    local pid_file=$1
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            echo "up"
        else
            echo "down"
        fi
    else
        echo "down"
    fi
}

# Get service status
get_service_status() {
    local name=$1
    local type=$2
    local target=$3
    
    case "$type" in
        port)
            check_port "$target"
            ;;
        docker)
            check_docker "$target"
            ;;
        pid)
            check_pid_file "$target"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

# Format status line
format_status() {
    local name="$1"
    local status="$2"
    local url="${3:-}"
    
    local symbol
    case "$status" in
        up)
            symbol="$STATUS_UP"
            ;;
        down)
            symbol="$STATUS_DOWN"
            ;;
        *)
            symbol="$STATUS_UNKNOWN"
            ;;
    esac
    
    if [ -n "$url" ]; then
        printf "  %-20s %s %s\n" "$name" "$symbol" "$url"
    else
        printf "  %-20s %s\n" "$name" "$symbol"
    fi
}

# Print system info
print_system_info() {
    log_section "System Information"
    
    # Node version
    local node_version=$(node -v 2>/dev/null || echo "N/A")
    echo "  Node.js: $node_version"
    
    # Docker
    if command -v docker >/dev/null 2>&1; then
        local docker_version=$(docker version --format '{{.Client.Version}}' 2>/dev/null || echo "N/A")
        echo "  Docker: $docker_version"
    else
        echo "  Docker: Not installed"
    fi
    
    # Disk space
    local disk_usage=$(df -h . | tail -1 | awk '{print $5}')
    echo "  Disk usage: $disk_usage"
    
    echo ""
}

# Print infrastructure status
print_infrastructure() {
    log_section "Infrastructure"
    
    format_status "PostgreSQL" "$(get_service_status "postgres" "docker" "tutorputor-postgres")"
    format_status "Redis" "$(get_service_status "redis" "docker" "tutorputor-redis")"
    
    echo ""
}

# Print services status
print_services() {
    log_section "Backend Services"
    
    format_status "API Gateway" "$(get_service_status "api-gateway" "port" "3200")" "http://localhost:3200"
    format_status "Platform Service" "$(get_service_status "platform" "pid" "${ROOT_DIR}/.logs/platform.pid")"
    
    if [ -f "${ROOT_DIR}/.logs/content-gen.pid" ]; then
        format_status "Content Generation" "$(get_service_status "content-gen" "pid" "${ROOT_DIR}/.logs/content-gen.pid")"
    fi
    
    echo ""
}

# Print apps status
print_apps() {
    log_section "Frontend Applications"
    
    format_status "Web App" "$(get_service_status "web" "port" "3201")" "http://localhost:3201"
    format_status "Admin App" "$(get_service_status "admin" "port" "3202")" "http://localhost:3202"
    
    echo ""
}

# Print quick stats
print_quick_stats() {
    log_section "Quick Stats"
    
    # Count running services
    local running=0
    local total=0
    
    for port in 3200 3201 3202; do
        ((total++))
        if [ "$(check_port $port)" = "up" ]; then
            ((running++))
        fi
    done
    
    echo "  Running services: $running/$total"
    
    # Check Docker
    if docker info >/dev/null 2>&1; then
        local containers=$(docker ps -q | wc -l | tr -d ' ')
        echo "  Docker containers: $containers"
    fi
    
    # Log size
    if [ -d "${ROOT_DIR}/.logs" ]; then
        local log_size=$(du -sh "${ROOT_DIR}/.logs" 2>/dev/null | cut -f1)
        echo "  Log directory: $log_size"
    fi
    
    echo ""
}

# Print actions
print_actions() {
    log_section "Available Actions"
    
    echo "  ttr dev              - Start development environment"
    echo "  ttr stop             - Stop all services"
    echo "  ttr logs <service>   - View service logs"
    echo "  ttr test             - Run tests"
    echo "  ttr doctor           - Full health check"
    echo ""
}

# Main
main() {
    echo ""
    log_info "TutorPutor Service Status"
    echo "=========================================="
    echo ""
    
    print_system_info
    print_infrastructure
    print_services
    print_apps
    print_quick_stats
    print_actions
}

main "$@"
