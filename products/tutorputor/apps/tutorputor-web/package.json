{
  "name": "@tutorputor/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TutorPutor web frontend application",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "../../../../node_modules/.bin/eslint . --ext ts,tsx --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run ../../k6/load-test.js",
    "test:critical": "k6 run ../../k6/critical-journeys.js",
    "test:stress": "k6 run ../../k6/stress-test.js",
    "test:soak": "k6 run ../../k6/soak-test.js"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/realtime": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@sentry/browser": "^10.49.0",
    "@tanstack/query-core": "^5.99.0",
    "@tanstack/react-query": "^5.99.0",
    "@tutorputor/core": "workspace:*",
    "@tutorputor/ui": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "react-router-dom": "^7.14.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "scheduler": "^0.27.0",
    "set-cookie-parser": "^2.7.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
