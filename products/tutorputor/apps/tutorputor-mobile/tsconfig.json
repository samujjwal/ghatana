{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2021"],
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "bundler",
    "types": ["jest", "react", "react-native"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "App.tsx", "index.js"],
  "exclude": ["node_modules", "dist"]
}
