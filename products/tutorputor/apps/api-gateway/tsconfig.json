{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "rootDir": "../..",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "../../types"],
    "paths": {
      "@tutorputor/contracts": ["../../contracts/v1/index.ts"],
      "@tutorputor/contracts/*": ["../../contracts/*"],
      "@tutorputor/core": ["../../libs/tutorputor-core/src/index.ts"],
      "@tutorputor/core/*": ["../../libs/tutorputor-core/src/*"],
      "@tutorputor/simulation": ["../../libs/tutorputor-simulation/src/index.ts"],
      "@tutorputor/simulation/*": ["../../libs/tutorputor-simulation/src/*"]
    },
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "../../types/**/*.d.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "src/e2e/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/routes/audit.ts",
    "src/routes/compliance.ts",
    "src/routes/social.ts",
    "src/routes/sso.ts",
    "src/routes/vr-labs.ts",
    "src/routes/payments.ts",
    "src/routes/gamification.ts",
    "src/routes/search.ts",
    "src/routes/simulation.ts",
    "src/routes/lti.ts",
    "src/routes/health.ts",
    "src/observability/**",
    "src/stubs/**"
  ]
}
