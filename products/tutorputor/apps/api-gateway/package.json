{
  "name": "@tutorputor/api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify-based TutorPutor API gateway wired to contract-driven services",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "../../../../node_modules/.bin/eslint src/ --max-warnings 0",
    "start": "node ./dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tutorputor/core": "workspace:*",
    "@tutorputor/platform": "workspace:*",
    "fastify": "^5.8.4",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
