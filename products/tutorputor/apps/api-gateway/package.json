{
  "name": "@ghatana/tutorputor-api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify-based TutorPutor API gateway wired to contract-driven services",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@ghatana/tutorputor-contracts": "workspace:*",
    "@ghatana/tutorputor-db": "workspace:*",
    "@ghatana/tutorputor-platform": "workspace:*",
    "fastify": "^5.7.4",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}