@Override
public UserProfile createUserProfile(List<AudioSample> enrollmentData) {
    ensureReady();
    
    UserProfile profile = UserProfile.create("New User");
    
    // Extract speaker embedding from enrollment audio
    SpeakerEmbedding embedding = extractSpeakerEmbedding(enrollmentData);
    profile.setSpeakerEmbedding(embedding);
    
    // Compute initial acoustic statistics
    AcousticStatistics stats = computeAcousticStatistics(enrollmentData);
    profile.setAcousticStatistics(stats);
    
    // Build initial language model
    LanguageModel languageModel = buildInitialLanguageModel(enrollmentData);
    profile.setLanguageModel(languageModel);
    
    loadedProfiles.put(profile.getProfileId(), profile);
    return profile;
}

    @Override
    public UserProfile loadUserProfile(String profileId) {
    // Check cache first
    UserProfile cached = loadedProfiles.get(profileId);
    if (cached != null) {
        return cached;
    }
    
    // Load from encrypted storage
    try {
        UserProfile profile = profileStorage.load(profileId).orElse(null);
        if (profile != null) {
            loadedProfiles.put(profileId, profile);
            LOG.info("Loaded user profile: {}", profileId);
        }
        return profile;
    } catch (Exception e) {
        LOG.error("Failed to load profile: {}", profileId, e);
        return null;
    }
}

    @Override
    public void updateUserProfile(UserProfile profile, AdaptationData data) {
        ensureReady();
        
        // Apply adaptation data to profile
        if (data.speakerEmbedding() != null) {
            profile.setSpeakerEmbedding(data.speakerEmbedding());
        }
        if (data.mllrTransform() != null) {
            profile.addMllrTransform(data.mllrTransform());
        }
        if (data.newVocabulary() != null) {
            profile.addVocabularyTerms(data.newVocabulary());
        }
        if (data.wordFrequencies() != null) {
            data.wordFrequencies().forEach(profile::updateWordFrequency);
        }
        if (data.namedEntities() != null) {
            data.namedEntities().forEach(profile::addNamedEntity);
        }
        if (data.acousticStats() != null) {
            profile.setAcousticStats(data.acousticStats());
        }
        if (data.loraUpdate() != null) {
            profile.setVoiceAdapter(data.loraUpdate());
        }
        LOG.debug("Applied adaptation data to user profile");
    }

    @Override
    public void saveUserProfile(UserProfile profile) {
        // Save to encrypted storage
        try {
            profileStorage.save(profile);
            loadedProfiles.put(profile.getProfileId(), profile);
            LOG.info("Saved user profile: {}", profile.getProfileId());
        } catch (Exception e) {
            LOG.error("Failed to save profile: {}", profile.getProfileId(), e);
            throw new RuntimeException("Failed to save profile", e);
        }
    }

    @Override
    public List<ModelInfo> getAvailableModels() {
        // Scan model directory and return available models
        try {
            List<ModelInfo> models = new ArrayList<>();
            Path modelDir = Paths.get(config.modelDirectory());
            
            if (Files.exists(modelDir) && Files.isDirectory(modelDir)) {
                Files.list(modelDir)
                    .filter(Files::isDirectory)
                    .forEach(dir -> {
                        try {
                            ModelInfo modelInfo = loadModelInfo(dir);
                            if (modelInfo != null) {
                                models.add(modelInfo);
                            }
                        } catch (Exception e) {
                            LOG.warn("Failed to load model info from directory: {}", dir, e);
                        }
                    });
            }
            
            // Add default models if directory is empty
            if (models.isEmpty()) {
                models.addAll(getDefaultModels());
            }
            
            return models;
        } catch (Exception e) {
            LOG.error("Failed to scan model directory", e);
            return getDefaultModels();
        }
    }

    @Override
    public void loadModel(String modelId, ModelOptions options) {
        ensureReady();
        
        // Load model with ONNX Runtime
        try {
            // Find model info
            ModelInfo modelInfo = getAvailableModels().stream()
                .filter(m -> m.modelId().equals(modelId))
                .findFirst()
                .orElseThrow(() -> new IllegalArgumentException("Model not found: " + modelId));
            
            // Load model using ONNX Runtime
            OrtEnvironment environment = OrtEnvironment.getEnvironment();
            OrtSession.SessionOptions sessionOptions = new OrtSession.SessionOptions();
            
            // Configure session options
            configureSessionOptions(sessionOptions, options);
            
            // Load model
            Path modelPath = Paths.get(config.modelDirectory(), modelId, "model.onnx");
            OrtSession session = environment.createSession(modelPath.toString(), sessionOptions);
            
            // Store loaded model
            loadedModels.put(modelId, new LoadedModel(session, modelInfo, options));
            
            status.set(new EngineStatus(
                EngineStatus.State.READY,
                modelId,
                activeSessions.size(),
                null
            ));
            
            LOG.info("Successfully loaded model: {}", modelId);
            
        } catch (Exception e) {
            LOG.error("Failed to load model: {}", modelId, e);
            status.set(new EngineStatus(
                EngineStatus.State.ERROR,
                null,
                activeSessions.size(),
                e.getMessage()
            ));
            throw new RuntimeException("Failed to load model: " + modelId, e);
        }
    }

    @Override
    public ModelInfo getActiveModel() {
        String activeModelId = status.get().activeModelId();
        return getAvailableModels().stream()
            .filter(m -> m.modelId().equals(activeModelId))
            .findFirst()
            .orElse(null);
    }

    @Override
    public PersonalizedModel createPersonalizedModel(UserProfile profile) {
        ensureReady();
        
        // Create personalized model with LoRA adapters
        try {
            ModelInfo baseModel = getActiveModel();
            if (baseModel == null) {
                throw new IllegalStateException("No active model loaded");
            }
            
            // Create LoRA adapter for user profile
            LoRAAdapter adapter = createLoRAAdapter(profile);
            
            // Validate adapter
            if (!adapter.isValid()) {
                throw new IllegalStateException("Failed to create valid LoRA adapter");
            }
            
            PersonalizedModel personalizedModel = new PersonalizedModel(
                baseModel,
                profile.getProfileId(),
                adapter,
                null,
                true
            );
            
            // Store personalized model
            personalizedModels.put(profile.getProfileId(), personalizedModel);
            
            LOG.info("Created personalized model for user: {}", profile.getProfileId());
            return personalizedModel;
            
        } catch (Exception e) {
            LOG.error("Failed to create personalized model for user: {}", profile.getProfileId(), e);
            throw new RuntimeException("Failed to create personalized model", e);
        }
    }

    @Override
    public EngineStatus getStatus() {
        return status.get();
    }

    @Override
    public EngineMetrics getMetrics() {
        return metricsCollector.getMetrics();
    }

    @Override
    public boolean isReady() {
        return initialized && status.get().isReady();
    }

    @Override
    public void close() {
        // Close all active sessions
        activeSessions.values().forEach(session -> {
            try {
                session.close();
            } catch (Exception e) {
                // Log and continue
            }
        });
        activeSessions.clear();
        
        // Release ONNX Runtime resources
        try {
            // Close all loaded models
            for (LoadedModel model : loadedModels.values()) {
                try {
                    model.getSession().close();
                } catch (Exception e) {
                    LOG.warn("Failed to close model session", e);
                }
            }
            loadedModels.clear();
            
            // Close ONNX environment
            OrtEnvironment.getEnvironment().close();
            
            LOG.info("Successfully released ONNX Runtime resources");
        } catch (Exception e) {
            LOG.error("Failed to release ONNX Runtime resources", e);
        }
        
        status.set(new EngineStatus(
            EngineStatus.State.SHUTDOWN,
            null,
            0,
            null
        ));
    }

    private void ensureReady() {
        if (!isReady()) {
            throw new IllegalStateException("Engine is not ready: " + status.get().state());
        }
    }

    void removeSession(String sessionId) {
        activeSessions.remove(sessionId);
        metricsCollector.recordSessionEnd();
    }
    
    // Conversion methods between API and model classes
    private com.ghatana.stt.core.model.AudioData convertToModelAudioData(AudioData apiAudio) {
        return new com.ghatana.stt.core.model.AudioData(
            apiAudio.data(),
            apiAudio.sampleRate(),
            apiAudio.channels(),
            com.ghatana.stt.core.model.AudioData.AudioFormat.PCM_16BIT
        );
    }
    
    private com.ghatana.stt.core.model.TranscriptionOptions convertToModelTranscriptionOptions(TranscriptionOptions apiOptions) {
        return com.ghatana.stt.core.model.TranscriptionOptions.builder()
            .language(apiOptions.language())
            .enablePunctuation(apiOptions.enablePunctuation())
            .enableWordTiming(apiOptions.enableWordTimings())
            .maxAlternatives(apiOptions.maxAlternatives())
            .build();
    }
    
    private TranscriptionResult convertToApiTranscriptionResult(com.ghatana.stt.core.model.TranscriptionResult modelResult) {
        // Convert model WordTiming to API WordTiming
        List<WordTiming> apiWordTimings = modelResult.wordTimings().stream()
            .map(modelWordTiming -> new WordTiming(
                modelWordTiming.word(),
                (long) (modelWordTiming.startTime() * 1000),
                (long) (modelWordTiming.endTime() * 1000),
                (float) modelWordTiming.confidence()
            ))
            .toList();
        
        return TranscriptionResult.builder()
            .text(modelResult.text())
            .confidence((float) modelResult.confidence())
            .wordTimings(apiWordTimings)
            .processingTimeMs(modelResult.processingTime().totalMs())
            .modelUsed("whisper-cpp")
            .language(modelResult.language())
            .isFinal(true)
            .build();
    }
}
