        "jotai": "^2.16.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build:types": "tsc -p tsconfig.types.json",
        "typecheck": "tsc --noEmit"
