# =============================================================================
# Audio-Video Product Suite - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
# All values shown are defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
AUDIO_VIDEO_ENV=development
AUDIO_VIDEO_LOG_LEVEL=info
AUDIO_VIDEO_DATA_DIR=${HOME}/.ghatana/audio-video

# -----------------------------------------------------------------------------
# Speech-to-Text (STT) Service
# -----------------------------------------------------------------------------
STT_GRPC_HOST=0.0.0.0
STT_GRPC_PORT=50051
STT_GRPC_URL=http://localhost:50051

# Model configuration
STT_MODEL_PATH=${AUDIO_VIDEO_DATA_DIR}/models/stt
STT_DEFAULT_MODEL=whisper-tiny
STT_USE_GPU=true
STT_NUM_THREADS=4
STT_OPTIMIZATION_LEVEL=3
STT_PRELOAD_MODELS=true

# Performance tuning
STT_TARGET_RTF=0.3
STT_MAX_MEMORY_MB=1024
STT_AUDIO_BUFFER_MS=1000
STT_STREAMING_CHUNK_MS=100

# Adaptation
STT_ENABLE_ADAPTATION=true
STT_ADAPTATION_LEARNING_RATE=0.001
STT_MAX_VOCABULARY_SIZE=10000

# -----------------------------------------------------------------------------
# Text-to-Speech (TTS) Service
# -----------------------------------------------------------------------------
TTS_GRPC_HOST=0.0.0.0
TTS_GRPC_PORT=50052
TTS_GRPC_URL=http://localhost:50052

# Model configuration
TTS_MODEL_PATH=${AUDIO_VIDEO_DATA_DIR}/models/tts
TTS_DEFAULT_VOICE=en-US-default
TTS_USE_GPU=true
TTS_NUM_THREADS=4

# Audio output
TTS_SAMPLE_RATE=22050
TTS_AUDIO_FORMAT=wav

# Prosody defaults
TTS_DEFAULT_SPEED=1.0
TTS_DEFAULT_PITCH=0.0
TTS_DEFAULT_ENERGY=1.0

# -----------------------------------------------------------------------------
# AI Voice Service
# -----------------------------------------------------------------------------
AI_VOICE_GRPC_HOST=0.0.0.0
AI_VOICE_GRPC_PORT=50053
AI_VOICE_GRPC_URL=http://localhost:50053

# Model configuration
AI_VOICE_MODEL_PATH=${AUDIO_VIDEO_DATA_DIR}/models/ai-voice
AI_VOICE_CACHE_DIR=${AUDIO_VIDEO_DATA_DIR}/cache/ai-voice
AI_VOICE_USE_GPU=true

# Voice cloning
AI_VOICE_CLONING_EPOCHS=100
AI_VOICE_CLONING_LEARNING_RATE=0.0001
AI_VOICE_MIN_AUDIO_LENGTH=1.0
AI_VOICE_MAX_AUDIO_LENGTH=10.0

# Stem separation
AI_VOICE_DEMUCS_MODEL=htdemucs

# -----------------------------------------------------------------------------
# Observability - OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=audio-video
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=always_on
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
LOG_FILE=${AUDIO_VIDEO_DATA_DIR}/logs/audio-video.log
LOG_MAX_SIZE_MB=100
LOG_MAX_FILES=10

# Correlation ID header
LOG_CORRELATION_HEADER=X-Correlation-ID

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# mTLS configuration
MTLS_ENABLED=false
MTLS_CERT_PATH=/etc/ssl/certs/server.crt
MTLS_KEY_PATH=/etc/ssl/private/server.key
MTLS_CA_PATH=/etc/ssl/certs/ca.crt

# JWT authentication
JWT_ENABLED=false
JWT_ISSUER=https://auth.ghatana.com
JWT_AUDIENCE=audio-video-api
JWT_PUBLIC_KEY_PATH=/etc/ssl/jwt/public.pem

# RBAC
RBAC_ENABLED=false
RBAC_POLICY_PATH=/etc/audio-video/rbac-policy.yaml

# Secrets (use Vault in production)
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=

# -----------------------------------------------------------------------------
# Database (for profile storage)
# -----------------------------------------------------------------------------
DB_TYPE=sqlite
DB_PATH=${AUDIO_VIDEO_DATA_DIR}/data/profiles.db

# PostgreSQL (production)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=audio_video
# DB_USER=audio_video
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis (for caching)
# -----------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Message Queue (for async processing)
# -----------------------------------------------------------------------------
MQ_ENABLED=false
MQ_TYPE=kafka

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=audio-video

# RabbitMQ
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# -----------------------------------------------------------------------------
# Health Checks
# -----------------------------------------------------------------------------
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
HEALTH_LIVENESS_PATH=/health/live
HEALTH_READINESS_PATH=/health/ready

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST_SIZE=200

# -----------------------------------------------------------------------------
# Desktop Application (Tauri)
# -----------------------------------------------------------------------------
TAURI_DEV_HOST=localhost
TAURI_DEV_PORT=1420
