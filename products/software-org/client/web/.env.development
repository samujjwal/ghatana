# Development environment for software-org web app

# MSW mocks are DISABLED by default - use real backend
# Set VITE_USE_MOCKS=true to enable mocks for isolated testing
VITE_USE_MOCKS=false

# Base API URL - points to the Node.js Fastify backend
# The backend serves /api/v1/* routes that match MSW contracts
VITE_API_URL=http://localhost:3101
VITE_WS_URL=http://localhost:3101

# Optional: app metadata
VITE_APP_ENV=development
VITE_APP_NAME=SoftwareOrg-Web
