# Environment for running with MSW mocks enabled
# Use this for isolated frontend testing without backend
#
# Usage: cp .env.mocks .env.local (or set env vars directly)

# Enable MSW mocks
VITE_USE_MOCKS=true
VITE_MOCK_API=true

# Base API URL (intercepted by MSW when mocks are enabled)
VITE_API_URL=http://localhost:3000/api/v1

# Optional: app metadata
VITE_APP_ENV=development
VITE_APP_NAME=SoftwareOrg-Web
