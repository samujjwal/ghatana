{
    "name": "@ghatana/software-org-backend",
    "version": "1.0.0",
    "description": "Software-Org Persona Management Backend API",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc --skipLibCheck",
        "start": "node dist/server.js",
        "db:generate": "prisma generate",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "seed:observe": "tsx src/scripts/seed-observability.ts",
        "seed:complete": "tsx src/scripts/seed-complete-data.ts",
        "seed:config": "tsx src/scripts/seed-from-config.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@fastify/compress": "^8.3.1",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/helmet": "^13.0.2",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/sensible": "^6.0.4",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-prometheus": "^0.208.0",
        "@opentelemetry/sdk-node": "^0.208.0",
        "@prisma/adapter-pg": "^7.2.0",
        "@prisma/client": "^7.2.0",
        "@sentry/node": "^10.32.1",
        "@sinclair/typebox": "^0.34.45",
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.2.3",
        "fastify": "^5.6.2",
        "fastify-socket.io": "^5.1.0",
        "js-yaml": "^4.1.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.16.3",
        "socket.io": "^4.8.3",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.0.3",
        "@types/pg": "^8.16.0",
        "@vitest/coverage-v8": "^4.0.16",
        "prisma": "^7.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16"
    }
}