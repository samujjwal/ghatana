# Database - Uses shared ghatana-postgres container (see root docker-compose.yml)
DATABASE_URL="postgresql://ghatana:ghatana123@localhost:5432/software_org_dev"

# Server
NODE_ENV="development"
PORT=3101
HOST="0.0.0.0"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:4000"

# Logging
LOG_LEVEL="info"

# Config Loader
# Base path for YAML configuration (departments, personas, workflows, etc.)
# CONFIG_PATH="/home/samujjwal/Developments/ghatana/products/software-org/config"
CONFIG_PATH="/Users/samujjwal/Development/ghatana/products/software-org/config"

# Java API Integration
# Set to "true" to use mock service (development/testing)
# Set to "false" to call real Java service (production)
JAVA_API_MOCK="true"
JAVA_API_BASE_URL="http://localhost:8080"

# Observability
ENABLE_TELEMETRY=false
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=""

# Sentry
SENTRY_DSN=""
