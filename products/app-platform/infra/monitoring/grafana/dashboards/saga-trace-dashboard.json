{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "AppPlatform Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "STORY-K05-032 — Cross-service saga execution trace dashboard. Visualizes saga step completion, step latencies, compensation events, and failure rates. Searchable by saga_id and correlation_id. Data sourced from Micrometer metrics emitted by SagaOrchestrator + SagaCorrelationPropagator.",
  "editable": true,
  "fiscalYearStartMonth": 3,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Saga Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Active Sagas",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(appplatform_saga_active_total{saga_type=~\"$saga_type\"})",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Completed Sagas (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(appplatform_saga_completed_total{saga_type=~\"$saga_type\"}[$__range])",
          "legendFormat": "Completed",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Failed Sagas (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(appplatform_saga_failed_total{saga_type=~\"$saga_type\"}[$__range])",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Compensation Events (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(appplatform_saga_compensation_total{saga_type=~\"$saga_type\"}[$__range])",
          "legendFormat": "Compensations",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "title": "Failure Rate (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(appplatform_saga_failed_total{saga_type=~\"$saga_type\"}[1h]) / (rate(appplatform_saga_completed_total{saga_type=~\"$saga_type\"}[1h]) + rate(appplatform_saga_failed_total{saga_type=~\"$saga_type\"}[1h]) + 0.001)",
          "legendFormat": "Failure Rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Saga Throughput & Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "title": "Saga Starts / Completions / Failures per Second",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(appplatform_saga_started_total{saga_type=~\"$saga_type\"}[$__rate_interval])) by (saga_type)",
          "legendFormat": "Started — {{saga_type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(appplatform_saga_completed_total{saga_type=~\"$saga_type\"}[$__rate_interval])) by (saga_type)",
          "legendFormat": "Completed — {{saga_type}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(appplatform_saga_failed_total{saga_type=~\"$saga_type\"}[$__rate_interval])) by (saga_type)",
          "legendFormat": "Failed — {{saga_type}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "p95"] } },
      "title": "Saga End-to-End Duration — p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(appplatform_saga_duration_milliseconds_bucket{saga_type=~\"$saga_type\"}[$__rate_interval])) by (le, saga_type))",
          "legendFormat": "p50 — {{saga_type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(appplatform_saga_duration_milliseconds_bucket{saga_type=~\"$saga_type\"}[$__rate_interval])) by (le, saga_type))",
          "legendFormat": "p95 — {{saga_type}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(appplatform_saga_duration_milliseconds_bucket{saga_type=~\"$saga_type\"}[$__rate_interval])) by (le, saga_type))",
          "legendFormat": "p99 — {{saga_type}}",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Step-Level Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "title": "Step Latency p95 by Step Name (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(appplatform_saga_step_duration_milliseconds_bucket{saga_type=~\"$saga_type\", step_name=~\"$saga_step\"}[$__rate_interval])) by (le, step_name))",
          "legendFormat": "p95 — {{step_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Step" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "Completions" }, "properties": [{ "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "Failures" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] },
          { "matcher": { "id": "byName", "options": "Compensations" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "options": { "sortBy": [{ "displayName": "Failures", "desc": true }], "footer": { "show": false } },
      "title": "Step Completions / Failures / Compensations (current window)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(appplatform_saga_step_completed_total{saga_type=~\"$saga_type\"}[$__range])) by (step_name)",
          "legendFormat": "{{step_name}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(appplatform_saga_step_failed_total{saga_type=~\"$saga_type\"}[$__range])) by (step_name)",
          "legendFormat": "{{step_name}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(appplatform_saga_compensation_total{saga_type=~\"$saga_type\"}[$__range])) by (step_name)",
          "legendFormat": "{{step_name}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "step_name": "Step",
              "Value #A": "Completions",
              "Value #B": "Failures",
              "Value #C": "Compensations"
            },
            "excludeByName": { "Time": true }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Compensation & Failure Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Compensation Events by Step (rate/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(appplatform_saga_compensation_total{saga_type=~\"$saga_type\"}[$__rate_interval])) by (step_name)",
          "legendFormat": "Compensate — {{step_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "pieType": "pie" },
      "title": "Saga Failure Distribution by Type",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(appplatform_saga_failed_total{saga_type=~\"$saga_type\"}[$__range])) by (failure_reason)",
          "legendFormat": "{{failure_reason}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Search by saga_id / correlation_id",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Filter metrics to a specific saga_id. The saga_id label is propagated via SagaCorrelationPropagator to all Kafka headers and span tags. Use this to drill into a single saga execution.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 41,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Step Latency for saga_id: $saga_id_filter",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(appplatform_saga_step_duration_milliseconds_bucket{saga_id=~\"$saga_id_filter\"}[$__rate_interval])) by (le, step_name))",
          "legendFormat": "p99 — {{step_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Filter by correlation_id to trace an entire business flow across multiple saga types.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Saga Type" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "Step" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "custom.displayMode", "value": "color-text" }, { "id": "mappings", "value": [{ "type": "value", "options": { "COMPLETED": { "text": "✓ COMPLETED", "color": "green" }, "FAILED": { "text": "✗ FAILED", "color": "red" }, "COMPENSATING": { "text": "↩ COMPENSATING", "color": "yellow" } } }] }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 42,
      "options": { "footer": { "show": false } },
      "title": "Saga Steps for correlation_id: $correlation_id_filter",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "appplatform_saga_step_info{correlation_id=~\"$correlation_id_filter\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "saga_type": "Saga Type",
              "step_name": "Step",
              "status": "Status",
              "duration_ms": "Duration (ms)"
            },
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true }
          }
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["sagas", "event-bus", "k-05", "observability", "k-06", "appplatform"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(appplatform_saga_started_total, saga_type)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "saga_type",
        "options": [],
        "query": { "query": "label_values(appplatform_saga_started_total, saga_type)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "label": "Saga Type",
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(appplatform_saga_step_duration_milliseconds_bucket, step_name)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "saga_step",
        "options": [],
        "query": { "query": "label_values(appplatform_saga_step_duration_milliseconds_bucket, step_name)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "label": "Step Name",
        "type": "query"
      },
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "hide": 0,
        "name": "saga_id_filter",
        "options": [{ "selected": true, "text": ".*", "value": ".*" }],
        "query": ".*",
        "label": "saga_id (regex)",
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": ".*", "value": ".*" },
        "hide": 0,
        "name": "correlation_id_filter",
        "options": [{ "selected": true, "text": ".*", "value": ".*" }],
        "query": ".*",
        "label": "correlation_id (regex)",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AppPlatform — Saga Execution Trace",
  "uid": "appplatform-saga-trace-v1",
  "version": 1,
  "weekStart": "sunday"
}
