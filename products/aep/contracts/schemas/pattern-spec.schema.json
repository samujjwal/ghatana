{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ghatana.io/aep/pattern-spec.schema.json",
  "title": "PatternSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "semantics",
    "pattern",
    "emit",
    "lifecycle",
    "governance",
    "observability"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "aep.ghatana.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "PatternSpec"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tenantId", "owner"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tenantId": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timePolicy", "uncertaintyPolicy", "replayPolicy"],
      "properties": {
        "timePolicy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode", "allowedLateness"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["event_time", "processing_time", "detection_time"]
            },
            "allowedLateness": {
              "$ref": "#/$defs/duration"
            }
          }
        },
        "uncertaintyPolicy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["minPatternConfidence"],
          "properties": {
            "minPatternConfidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "replayPolicy": {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["deterministic", "recorded_agent_output", "blocked"]
            }
          }
        }
      }
    },
    "pattern": {
      "$ref": "#/$defs/patternExpr"
    },
    "emit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "outputSchema"],
      "properties": {
        "eventType": {
          "type": "string",
          "minLength": 1
        },
        "outputSchema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patternExpr"
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": true,
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "DRAFT",
            "CANDIDATE",
            "VALIDATED",
            "SHADOW",
            "RECOMMENDED",
            "APPROVED",
            "ACTIVE",
            "DEGRADED",
            "RETIRED"
          ]
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reviewPolicy"],
      "properties": {
        "reviewPolicy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "required": ["metrics", "tracing"],
      "properties": {
        "metrics": {
          "type": "boolean"
        },
        "tracing": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "duration": {
      "type": "string",
      "pattern": "^P(T.*|[0-9].*)"
    },
    "patternExpr": {
      "type": "object",
      "additionalProperties": true,
      "oneOf": [
        {
          "required": ["event"],
          "properties": {
            "event": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": ["operator"],
          "properties": {
            "operator": {
              "type": "string",
              "enum": [
                "AND",
                "OR",
                "NOT",
                "SEQ",
                "WITHIN",
                "TIMES",
                "REPEAT",
                "WINDOW",
                "ABSENCE",
                "FILTER",
                "AGENT_PREDICATE",
                "AGENT_ENRICH",
                "AGENT_EXTRACT",
                "AGENT_PATTERN_SYNTHESIS",
                "AGENT_EXPLANATION",
                "AGENT_REVIEW",
                "AGENT_ACTION",
                "AGENT_REFLECTION"
              ]
            },
            "operands": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/patternExpr"
              }
            },
            "pattern": {
              "$ref": "#/$defs/patternExpr"
            },
            "agentRef": {
              "type": "string",
              "minLength": 1
            },
            "inputSchema": {
              "type": "string",
              "minLength": 1
            },
            "outputSchema": {
              "type": "string",
              "minLength": 1
            },
            "within": {
              "$ref": "#/$defs/duration"
            },
            "condition": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
