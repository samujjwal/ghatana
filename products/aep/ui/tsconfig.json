{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vite/client"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@ghatana/design-system": [
        "../../../platform/typescript/capabilities/design-system/src/index.ts"
      ],
      "@ghatana/canvas-core": [
        "../../../platform/typescript/capabilities/canvas-core/src"
      ],
      "@ghatana/theme": ["../../../platform/typescript/theme/src"],
      "@ghatana/tokens": ["../../../platform/typescript/tokens/src"],
      "@ghatana/utils": [
        "../../../platform/typescript/foundation/platform-utils/src/index.ts"
      ],
      "@ghatana/platform-utils": [
        "../../../platform/typescript/foundation/platform-utils/src/index.ts"
      ]
    },
    "baseUrl": "."
  },
  "include": ["src"]
}
