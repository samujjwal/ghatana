{
  "name": "@ghatana/dcmaar",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "libs/typescript/*",
    "libs/typescript/agent-core/*",
    "libs/rust/*",
    "apps/*",
    "apps/guardian/libs/*",
    "apps/guardian/libs/guardian-dashboard-core",
    "framework/*",
    "contracts/proto-core"
  ],
  "scripts": {
    "dev": "pnpm --filter \"./apps/**\" --filter \"./framework/**\" dev",
    "build": "pnpm run build:libs && pnpm run build:framework && pnpm run build:apps",
    "build:libs": "pnpm --filter \"./libs/**\" build",
    "build:framework": "pnpm --filter \"./framework/**\" build",
    "build:apps": "pnpm --filter \"./apps/**\" build",
    "test": "pnpm run test:libs && pnpm run test:framework && pnpm run test:apps",
    "test:libs": "pnpm --filter \"./libs/**\" test",
    "codegen:runtime-config": "node ci/scripts/codegen/runtime-config-types.js",
    "test:framework": "pnpm --filter \"./framework/**\" test",
    "test:apps": "pnpm --filter \"./apps/**\" test"
  },
