#!/bin/bash
# Guardian macOS postinstall script
set -e

APP_PATH="/Applications/Guardian.app"
LAUNCH_AGENT="$HOME/Library/LaunchAgents/com.ghatana.guardian.plist"

# Create LaunchAgent to start Guardian on login
mkdir -p "$HOME/Library/LaunchAgents"
cat > "$LAUNCH_AGENT" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ghatana.guardian</string>
    <key>Program</key>
    <string>/Applications/Guardian.app/Contents/MacOS/guardian</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/var/log/guardian.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/guardian.log</string>
</dict>
</plist>
EOF

chmod 644 "$LAUNCH_AGENT"

# Load the LaunchAgent
launchctl load "$LAUNCH_AGENT" 2>/dev/null || true

echo "Guardian installed at $APP_PATH"
echo "Launch agent loaded. Guardian will start on next login."
echo ""
echo "To start Guardian now, run:"
echo "  launchctl load ~/Library/LaunchAgents/com.ghatana.guardian.plist"
