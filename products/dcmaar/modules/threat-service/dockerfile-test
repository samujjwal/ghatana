# Build stage
FROM golang:1.20-alpine AS builder

# Install build dependencies
RUN apk add --no-cache \
    git \
    gcc \
    musl-dev \
    make

# Set working directory
WORKDIR /app

# Download dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Install test dependencies
RUN go install github.com/golang/mock/mockgen@latest && \
    go install github.com/vektra/mockery/v2@latest && \
    go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest

# Build test binary
RUN CGO_ENABLED=0 GOOS=linux go test -c -o /app/bin/test-runner ./...

# Test runner stage
FROM alpine:3.18

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

# Set working directory
WORKDIR /app

# Copy test binary and test data
COPY --from=builder /app/bin/test-runner ./test-runner
COPY --from=builder /app/testdata ./testdata

# Copy configuration
COPY config/test.yaml /app/config/config.yaml

# Set environment variables
ENV ENVIRONMENT=test
ENV LOG_LEVEL=debug
ENV CLICKHOUSE_HOST=localhost
ENV CLICKHOUSE_PORT=9000
ENV REDIS_ADDR=localhost:6379

# Set entrypoint
ENTRYPOINT ["/app/test-runner", "-test.v"]

# Default command (can be overridden)
CMD ["-test.coverprofile=coverage.out"]
