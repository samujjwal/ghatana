{
  "name": "@ghatana/dcmaar-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:all": "vitest run --run",
    "lint": "eslint 'src/**/*.{ts,tsx}' --ignore-pattern '**/*.test.*' --ignore-pattern '**/*.spec.*' --ignore-pattern 'src/**/*.d.ts' --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss}\"",
    "prepare": "echo 'Skipping husky installation in subpackage'",
    "tauri": "tauri",
    "start:update-server": "node update-server.js",
    "mock:start": "node ../../tools/mock-config-server/index.js",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:integration:external": "USE_EXTERNAL_MOCK=1 npx jest src/__tests__/mockServer.integration.test.ts -i --runInBand --testTimeout=60000",
    "test:integration:external:nocov": "USE_EXTERNAL_MOCK=1 npx jest src/__tests__/mockServer.integration.test.ts -i --runInBand --testTimeout=60000 --coverage=false",
    "test:integration:jest": "npx jest src/__tests__/mockServer.integration.test.ts -i --runInBand --testTimeout=60000",
    "dev:all": "concurrently -n VITE,UPDATE,TAURI -c bgBlue.bold,bgGreen.bold,bgMagenta.bold \"pnpm dev\" \"pnpm start:update-server\" \"cd src-tauri && cargo tauri dev\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/x-date-pickers": "^8.17.0",
    "@tanstack/react-query": "^5.90.7",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tauri-apps/api": "^2.9.0",
    "axios": "^1.13.2",
