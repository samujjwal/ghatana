# ============================================
# GUARDIAN PARENTAL CONTROL - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
#
# Security Note: NEVER commit .env to version control!
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
NODE_ENV=development
PORT=3001

# --------------------------------------------
# Database Configuration (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgresql://guardian:guardian@localhost:5432/guardian_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=guardian_db
DB_USER=guardian
DB_PASSWORD=your_secure_database_password_min_16_chars
DB_POOL_MAX=20
DB_POOL_MIN=2

# --------------------------------------------
# Authentication & Security
# --------------------------------------------
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_must_be_at_least_32_characters_long_generate_random
JWT_REFRESH_SECRET=your_refresh_secret_must_be_at_least_32_characters_long_generate_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production
COOKIE_MAX_AGE=604800000

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# Logging & Monitoring
# --------------------------------------------
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=logs/guardian.log

# Sentry Error Monitoring (optional)
# Sign up at: https://sentry.io
SENTRY_DSN=

# Prometheus Metrics Port
PROMETHEUS_PORT=9464

# --------------------------------------------
# Email Configuration (SMTP)
# --------------------------------------------
# For Gmail: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_PASS=your-app-password
SMTP_FROM=Guardian <noreply@guardian.app>
FRONTEND_URL=http://localhost:3000

# --------------------------------------------
# WebSocket Configuration
# --------------------------------------------
WS_PORT=3002
WS_HEARTBEAT_INTERVAL=30000

# --------------------------------------------
# File Upload
# --------------------------------------------
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# --------------------------------------------
# Redis (Optional - for distributed rate limiting)
# --------------------------------------------
# If not set, in-memory rate limiting will be used
# REDIS_URL=redis://localhost:6379

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Set NODE_ENV=production
# [ ] Generate random JWT_SECRET (32+ chars)
# [ ] Generate random JWT_REFRESH_SECRET (32+ chars)
# [ ] Use strong DB_PASSWORD (16+ chars)
# [ ] Configure CORS_ORIGIN to production domains only
# [ ] Set up SENTRY_DSN for error monitoring
# [ ] Configure valid SMTP credentials
# [ ] Enable database SSL/TLS
# [ ] Set up automated database backups
# [ ] Configure Redis for distributed rate limiting
# ============================================
