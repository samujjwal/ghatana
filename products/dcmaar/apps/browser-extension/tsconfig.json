{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ghatana/dcmaar-browser-extension-core": [
        "../../../../libs/typescript/browser-extension-core/src"
      ],
      "@ghatana/dcmaar-types": ["../../../../libs/typescript/types/src"],
      "@ghatana/dcmaar-plugin-abstractions": [
        "../../../../libs/typescript/plugin-abstractions/src"
      ],
      "@ghatana/dcmaar-guardian-plugins": ["../../packages/guardian-plugins/src"],
      "@ghatana/dcmaar-shared-ui-charts": [
        "../../../../libs/typescript/shared-ui-charts/src"
      ],
      "@ghatana/dcmaar-shared-ui-tailwind": [
        "../../../../libs/typescript/shared-ui-tailwind/src"
      ]
    },
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "chrome",
      "@testing-library/jest-dom"
    ]
  },
  "include": ["src"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
