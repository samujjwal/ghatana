{
  "manifest_version": 3,
  "name": "Guardian - Parental Control & Performance Monitor",
  "version": "1.0.0",
  "description": "Parental control with website blocking, screen time tracking, and real-time browser performance monitoring",
  "icons": {
    "16": "assets/icon-16.svg",
    "48": "assets/icon-48.svg",
    "128": "assets/icon-128.svg"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.svg",
      "48": "assets/icon-48.svg"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard/index.html",
        "blocked.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}