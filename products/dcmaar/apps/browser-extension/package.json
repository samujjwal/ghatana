{
  "name": "@dcmaar/browser-extension",
  "version": "1.0.0",
  "description": "Guardian - Browser performance monitoring extension built with @ghatana/yappc-browser-extension-core",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s build:chrome build:firefox build:edge postbuild",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "postbuild": "node scripts/update-manifest.mjs",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Lint not configured'",
    "test": "vitest"
  },
  "dependencies": {
    "@dcmaar/browser-extension-core": "workspace:*",
    "@dcmaar/types": "workspace:*",
    "@dcmaar/plugin-abstractions": "workspace:*",
    "@dcmaar/guardian-plugins": "workspace:*",
    "@ghatana/charts": "workspace:*",
    "eventemitter3": "^5.0.4",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.39",
    "@types/node": "25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "browser-extension",
    "performance-monitoring",
    "web-vitals",
    "analytics",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "YAPPC",
  "license": "MIT"
}