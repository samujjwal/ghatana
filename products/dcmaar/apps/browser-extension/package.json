{
  "name": "@ghatana/dcmaar-browser-extension",
  "version": "1.0.0",
  "description": "Guardian - Browser performance monitoring extension built with @ghatana/yappc-browser-extension-core",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s build:chrome build:firefox build:edge postbuild",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "postbuild": "node scripts/update-manifest.mjs",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Lint not configured'",
    "test": "vitest"
  },
  "dependencies": {
    "@ghatana/dcmaar-browser-extension-core": "workspace:*",
    "@ghatana/dcmaar-types": "workspace:*",
    "@ghatana/dcmaar-plugin-abstractions": "workspace:*",
    "@ghatana/dcmaar-guardian-plugins": "workspace:*",
    "@ghatana/charts": "workspace:*",
    "eventemitter3": "^5.0.4",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.36",
    "@types/node": "25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.4",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "browser-extension",
    "performance-monitoring",
    "web-vitals",
    "analytics",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "YAPPC",
  "license": "MIT"
}