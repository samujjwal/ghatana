{
  "name": "@dcmaar/parent-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Guardian Parent Mobile App - React Native",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output dist/index.ios.bundle --assets-dest dist && react-native bundle --platform android --dev false --entry-file index.js --bundle-output dist/index.android.bundle --assets-dest dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@dcmaar/dashboard-core": "workspace:*",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.13.1",
    "date-fns": "^4.1.0",
    "jotai": "^2.19.1",
    "react": "^19.2.4",
    "react-native": "0.84",
    "react-native-chart-kit": "^6.12.0",
    "react-native-push-notification": "^8.1.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "@react-native-vector-icons/material-icons": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/eslint-config": "^0.84.1",
    "@react-native/metro-config": "^0.84.1",
    "@react-native/typescript-config": "^0.84.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^30.3.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.4",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
