{
  "extends": "./config/tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "webextension-polyfill",
      "chrome",
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "tests/**/*",
    "test/**/*",
    "unit/**/*",
    "scripts/**/*",
    "*.config.ts",
    "vite.config.performance.ts",
    "*.config.js"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
