{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "EventEnvelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "required": ["meta", "events"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["tenant_id", "device_id", "session_id", "timestamp"],
      "additionalProperties": true,
      "properties": {
        "tenant_id": {
          "type": "string"
        },
        "device_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ]
        },
        "schema_version": {
          "type": "string"
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "schema_version": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "source_os": {
      "type": "string"
    },
    "source_arch": {
      "type": "string"
    }
  }
}
