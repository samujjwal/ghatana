{
  "name": "@ghatana/dcmaar-device-health-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:isolated": "node scripts/run-playwright-isolated.js",
    "clean": "rimraf dist .vite",
    "prebuild": "pnpm run clean",
    "setup:native-host": "node scripts/setup-native-host.js",
    "postbuild": "bash scripts/verify-no-test-helpers.sh && node scripts/copy-icons-postbuild.cjs",
    "dev": "vite",
    "build": "run-s build:chrome build:firefox build:edge",
    "build:with-native-host": "run-s build:chrome build:firefox build:edge && pnpm run setup:native-host",
    "build:testhooks": "VITE_ENABLE_TEST_HOOKS=true VITE_INGEST_ENDPOINT='dcmaar-test-sink://local' pnpm run build",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "package": "run-s package:chrome package:firefox package:edge",
    "package:chrome": "pnpm run build:chrome && zip -r dist/chrome.zip dist/chrome",
    "package:firefox": "pnpm run build:firefox && zip -r dist/firefox.zip dist/firefox",
    "package:edge": "pnpm run build:edge && zip -r dist/edge.zip dist/edge",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run --coverage --run __tests__/unit",
    "test:integration": "vitest run --coverage --run __tests__/it",
    "e2e:serve": "node ./dist-scripts/serve-e2e-fixtures.js || node ./scripts/serve-e2e-fixtures.ts",
    "e2e:run:local": "echo 'Run build:testhooks then run Playwright tests with a persistent context manually (see README)'",
    "e2e:run": "pnpm run build:scripts && node ./dist-scripts/e2e-run.js",
    "e2e:run:ci": "pnpm run build:testhooks && pnpm run build:scripts && node ./dist-scripts/e2e-run.js --timeout=15000",
    "e2e:orchestrate": "pnpm run build:scripts && node ./dist-scripts/e2e-orchestrator.js",
    "setup:source": "pnpm run build:scripts && node ./dist-scripts/setup-source.js",
    "setup:sink-addon": "pnpm run build:scripts && node ./dist-scripts/setup-sink-addon.js",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "test:integration:playwright": "pnpm exec playwright test",
    "test:e2e": "pnpm run test:e2e:chrome",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e:all && pnpm run test:e2e:new",
    "fix:console-logs": "./scripts/replace-console-logs.sh",
    "test:e2e:chrome": "pnpm run build:testhooks && pnpm exec playwright test --project=chromium",
    "test:e2e:chrome:coverage": "PW_ENABLE_COVERAGE=true pnpm run build:testhooks && PW_ENABLE_COVERAGE=true pnpm exec playwright test --project=chromium",
    "test:e2e:ci:chrome": "pnpm run test:e2e:chrome",
    "test:e2e:ci:chrome:headed": "pnpm run build:testhooks && pnpm exec playwright test --project=chromium --headed --workers=1 --trace=on-first-retry",
    "test:e2e:firefox": "pnpm run build:testhooks && pnpm exec playwright test --project=firefox",
    "test:e2e:edge": "pnpm run build:testhooks && pnpm exec playwright test --project=msedge",
    "test:e2e:all": "pnpm run build:testhooks && pnpm exec playwright test --all-projects",
    "test:e2e:coverage": "pnpm run test:e2e:chrome:coverage",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:debug": "pnpm exec playwright test --debug",
    "test:e2e:update": "pnpm exec playwright test --update-snapshots",
    "test:e2e:report": "pnpm exec playwright show-report",
    "test:e2e:onboarding": "pnpm exec playwright test tests/e2e/onboarding-tour.spec.ts",
    "test:e2e:alerts": "pnpm exec playwright test tests/e2e/performance-alerts.spec.ts",
    "test:e2e:export": "pnpm exec playwright test tests/e2e/data-export.spec.ts",
    "test:e2e:settings": "pnpm exec playwright test tests/e2e/settings.spec.ts",
    "test:e2e:lifecycle": "pnpm exec playwright test tests/e2e/extension-lifecycle.spec.ts",
    "test:e2e:phase6": "pnpm exec playwright test tests/e2e/onboarding-tour.spec.ts tests/e2e/performance-alerts.spec.ts tests/e2e/data-export.spec.ts tests/e2e/settings.spec.ts tests/e2e/extension-lifecycle.spec.ts",
    "test:coverage": "vitest run --coverage",
    "test:coverage:html": "vitest run --coverage --coverage.reporter=html",
    "test:perf": "vitest run src/storage/__tests__/StoragePerformance.test.ts",
    "test:fuzz": "vitest run --run ./tests/fuzz",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit -p tsconfig.types.json",
    "type-check:watch": "tsc --noEmit --watch -p tsconfig.types.json",
    "prepare": "echo 'Skipping husky installation in subpackage'",
    "postinstall": "playwright install chromium firefox msedge",
    "setup:playwright": "bash scripts/setup-playwright.sh",
    "setup:playwright:deps": "echo 'Run: sudo npx playwright install-deps chromium firefox msedge'",
    "validate": "run-s type-check lint build test",
    "quality-check": "bash scripts/prevent-chronic-debt.sh",
    "quality-fix": "run-s lint:fix format quality-check",
    "ci:quality": "run-s quality-check type-check lint format:check",
    "ci:test": "run-s test:unit test:integration",
    "ci:build": "run-s build:chrome build:firefox build:edge",
    "ci:full": "run-s ci:quality ci:test ci:build test:e2e:chrome",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "deps:check": "npm outdated",
    "deps:update": "npm update --save",
    "sbom": "sh ../../ops/scripts/generate-extension-sbom.sh",
    "sbom:summary": "node ../../ops/scripts/sbom-summary.js apps/extension/sbom.json 12",
    "build:prod": "vite build --config vite.config.performance.ts",
    "analyze:bundle": "pnpm run build:chrome && node scripts/analyze-bundle.js",
    "perf:monitor": "VITE_ENABLE_PERF_MONITORING=true pnpm run dev",
    "test:e2e:new": "pnpm run build:testhooks && pnpm exec playwright test tests/e2e/extension-lifecycle.spec.ts tests/e2e/message-passing.spec.ts"
  },
  "dependencies": {
    "@ghatana/dcmaar-types": "workspace:*",
    "@ghatana/dcmaar-config-presets": "workspace:*",
    "@ghatana/dcmaar-connectors": "workspace:*",
    "@ghatana/dcmaar-shared-ui-core": "workspace:*",
    "@ghatana/dcmaar-shared-ui-tailwind": "workspace:*",
    "@ghatana/dcmaar-browser-extension-core": "workspace:*",
    "@ghatana/dcmaar-shared-ui-charts": "workspace:*",
    "@ghatana/dcmaar-plugin-abstractions": "workspace:*",
    "@ghatana/dcmaar-plugin-extension": "workspace:*",
    "@tanstack/react-query": "^5.90.20",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "eventemitter3": "^5.0.4",
    "jsonschema": "^1.5.0",
    "p-queue": "^9.1.0",
    "p-retry": "^7.1.1",
    "pako": "^2.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@cyclonedx/cyclonedx-npm": "^4.1.2",
    "@eslint/js": "^9.39.2",
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "2.2.0",
    "@playwright/test": "1.58.1",
    "@tailwindcss/postcss": "4.1.18",
    "@types/chrome": "^0.1.36",
    "@types/node": "25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "0.12.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-legacy": "7.2.1",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitejs/plugin-vue-jsx": "5.1.4",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.5.1",
    "fast-check": "^4.5.3",
    "globby": "16.1.0",
    "husky": "^9.1.7",
    "idb": "^8.0.3",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react-router-dom": "^7.13.0",
    "rimraf": "^6.1.2",
    "strip-json-comments": "5.0.3",
    "tailwindcss": "4.1.18",
    "terser": "5.46.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": "./prettier.config.cjs",
  "peerDependencies": {
    "@headlessui/react": "2.2.9",
    "@heroicons/react": "2.2.0",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.1.16",
    "@types/chrome": "^0.1.24",
    "@types/node": "24.7.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/webextension-polyfill": "0.12.4",
    "@vitejs/plugin-legacy": "7.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitejs/plugin-vue": "6.0.1",
    "@vitejs/plugin-vue-jsx": "5.1.1",
    "@vitest/coverage-istanbul": "^4.0.13",
    "@vitest/coverage-v8": "4.0.13",
    "@vitest/ui": "4.0.13",
    "autoprefixer": "^10.4.21",
    "globby": "15.0.0",
    "idb": "^8.0.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.9.5",
    "strip-json-comments": "5.0.3",
    "tailwindcss": "4.1.16",
    "terser": "5.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13",
    "web-vitals": "^5.1.0",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.1.12"
  }
}