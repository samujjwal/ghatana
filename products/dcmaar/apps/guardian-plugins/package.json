{
    "name": "@ghatana/dcmaar-guardian-plugins",
    "version": "1.0.0",
    "description": "Guardian browser-extension plugins for the DCMAAR platform",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "dev": "tsc --watch",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@ghatana/dcmaar-plugin-abstractions": "workspace:*",
        "@ghatana/dcmaar-types": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}