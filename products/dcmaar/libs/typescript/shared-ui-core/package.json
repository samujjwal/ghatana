{
  "name": "@ghatana/dcmaar-shared-ui-core",
  "version": "0.1.0",
  "description": "@deprecated - Use @ghatana/tokens and @ghatana/utils directly. Shared UI core library - framework-agnostic design tokens, types, hooks, and utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ghatana/tokens": "workspace:*",
    "@ghatana/utils": "workspace:*"
  },
  "keywords": [
    "dcmaar",
    "shared",
    "ui",
    "design-tokens",
    "types",
    "hooks",
    "utilities"
  ],
  "author": "DCMAAR Team",
  "license": "MIT"
}