{
  "name": "@dcmaar/types",
  "version": "1.0.0",
  "description": "Shared type definitions for DCMAAR framework",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./common": {
      "types": "./src/common/index.ts",
      "require": "./dist/common/index.js",
      "import": "./dist/common/index.js"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "require": "./dist/errors/index.js",
      "import": "./dist/errors/index.js"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "require": "./dist/utils/index.js",
      "import": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "dcmaar",
    "types",
    "framework"
  ],
  "author": "DCMAAR Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "peerDependencies": {}
}
