{
  "name": "@dcmaar/browser-extension-core",
  "version": "1.0.0",
  "description": "Core framework for building browser extensions with Source-Processor-Sink architecture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "webextension",
    "framework",
    "pipeline"
  ],
  "author": "DCMAAR Team",
  "license": "MIT",
  "dependencies": {
    "@dcmaar/types": "workspace:*",
    "@dcmaar/plugin-abstractions": "workspace:*",
    "@dcmaar/connectors": "workspace:*",
    "webextension-polyfill": "^0.12.0",
    "@ghatana/events": "workspace:*",
    "@ghatana/browser-events": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/webextension-polyfill": "^0.12.5",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
