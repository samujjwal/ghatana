{
  "name": "@ghatana/dcmaar-shared-ui-tailwind",
  "version": "0.1.0",
  "description": "@deprecated - Use @ghatana/ui directly. Shared Tailwind CSS components for DCMAAR platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Button": {
      "types": "./dist/components/Button.d.ts",
      "import": "./dist/components/Button.js"
    },
    "./Card": {
      "types": "./dist/components/Card.d.ts",
      "import": "./dist/components/Card.js"
    },
    "./Input": {
      "types": "./dist/components/Input.d.ts",
      "import": "./dist/components/Input.js"
    },
    "./Select": {
      "types": "./dist/components/Select.d.ts",
      "import": "./dist/components/Select.js"
    },
    "./Toggle": {
      "types": "./dist/components/Toggle.d.ts",
      "import": "./dist/components/Toggle.js"
    },
    "./Badge": {
      "types": "./dist/components/Badge.d.ts",
      "import": "./dist/components/Badge.js"
    },
    "./Spinner": {
      "types": "./dist/components/Spinner.d.ts",
      "import": "./dist/components/Spinner.js"
    },
    "./Skeleton": {
      "types": "./dist/components/Skeleton.d.ts",
      "import": "./dist/components/Skeleton.js"
    },
    "./StatusBadge": {
      "types": "./dist/components/StatusBadge.d.ts",
      "import": "./dist/components/StatusBadge.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/dcmaar-shared-ui-core": "workspace:*",
    "@ghatana/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "tailwindcss": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "dcmaar",
    "shared",
    "ui",
    "components",
    "tailwind",
    "react"
  ],
  "author": "DCMAAR Team",
  "license": "MIT"
}