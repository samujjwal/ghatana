{{!
  Environment Configuration Template
  Generates environment variables for API endpoint
}}
#
{{to.name}}
API Configuration
{{uppercase (snakeCase to.id)}}_API_URL={{apiEndpoint}}
{{uppercase (snakeCase to.id)}}_API_TIMEOUT={{timeout}}
{{uppercase (snakeCase to.id)}}_API_RETRIES={{retries}}
{{#if (eq authType "jwt")}}
  {{uppercase (snakeCase to.id)}}_AUTH_TYPE=jwt
{{/if}}