{{!--
  React CRUD Operations Feature Template
  
  Variables:
  - entityName: Name of the entity (singular, PascalCase)
  - entityNamePlural: Plural form of entity name
  - fields: Array of field definitions
  - apiEndpoint: API endpoint for the entity
  - hasSearch: Whether to include search functionality
  - hasPagination: Whether to include pagination
--}}
import React, { useState } from 'react';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { {{entityName}} } from '@/types/{{kebabCase entityName}}';
import { api } from '@/lib/api';

/**
 * CRUD operations for {{entityName}}.
 * 
 * @doc.type feature
 * @doc.purpose Manage {{entityNamePlural}} with full CRUD operations
 * @doc.layer feature
 * @doc.pattern CRUD
 */
export function {{entityName}}Manager() {
  const queryClient = useQueryClient();
  const [selectedId, setSelectedId] = useState<string | null>(null);
  {{#if hasSearch}}
  const [searchQuery, setSearchQuery] = useState('');
  {{/if}}
  {{#if hasPagination}}
  const [page, setPage] = useState(1);
  const [pageSize] = useState(10);
  {{/if}}

  // Fetch {{entityNamePlural}}
  const { data: {{camelCase entityNamePlural}}, isLoading, error } = useQuery({
    queryKey: ['{{camelCase entityNamePlural}}'{{#if hasSearch}}, searchQuery{{/if}}{{#if hasPagination}}, page, pageSize{{/if}}],
    queryFn: () => api.get<{{entityName}}[]>('{{apiEndpoint}}'{{#if hasSearch}}, { params: { search: searchQuery } }{{/if}}{{#if hasPagination}}, { params: { page, pageSize } }{{/if}}),
  });

  // Create {{entityName}}
  const createMutation = useMutation({
    mutationFn: (data: Omit<{{entityName}}, 'id'>) => 
      api.post<{{entityName}}>('{{apiEndpoint}}', data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['{{camelCase entityNamePlural}}'] });
    },
  });

  // Update {{entityName}}
  const updateMutation = useMutation({
    mutationFn: ({ id, data }: { id: string; data: Partial<{{entityName}}> }) =>
      api.put<{{entityName}}>(`{{apiEndpoint}}/${id}`, data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['{{camelCase entityNamePlural}}'] });
    },
  });

  // Delete {{entityName}}
  const deleteMutation = useMutation({
    mutationFn: (id: string) => api.delete(`{{apiEndpoint}}/${id}`),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['{{camelCase entityNamePlural}}'] });
    },
  });

  const handleCreate = async (data: Omit<{{entityName}}, 'id'>) => {
    try {
      await createMutation.mutateAsync(data);
    } catch (error) {
      console.error('Failed to create {{entityName}}:', error);
    }
  };

  const handleUpdate = async (id: string, data: Partial<{{entityName}}>) => {
    try {
      await updateMutation.mutateAsync({ id, data });
    } catch (error) {
      console.error('Failed to update {{entityName}}:', error);
    }
  };

  const handleDelete = async (id: string) => {
    if (confirm('Are you sure you want to delete this {{entityName}}?')) {
      try {
        await deleteMutation.mutateAsync(id);
      } catch (error) {
        console.error('Failed to delete {{entityName}}:', error);
      }
    }
  };

  if (isLoading) return <div>Loading {{entityNamePlural}}...</div>;
  if (error) return <div>Error loading {{entityNamePlural}}: {error.message}</div>;

  return (
    <div className="{{kebabCase entityName}}-manager">
      <header>
        <h2>{{entityNamePlural}}</h2>
        <button onClick={() => {/* Open create form */}}>
          Create {{entityName}}
        </button>
      </header>

      {{#if hasSearch}}
      <div className="search-bar">
        <input
          type="text"
          placeholder="Search {{entityNamePlural}}..."
          value={searchQuery}
          onChange={(e) => setSearchQuery(e.target.value)}
        />
      </div>
      {{/if}}

      <div className="{{kebabCase entityName}}-list">
        {{{camelCase entityNamePlural}}?.map((item) => (
          <div key={item.id} className="{{kebabCase entityName}}-item">
            {{#each fields}}
            <div className="field-{{kebabCase name}}">
              <strong>{{label}}:</strong> {item.{{name}}}
            </div>
            {{/each}}
            <div className="actions">
              <button onClick={() => handleUpdate(item.id, {/* updated data */})}>
                Edit
              </button>
              <button onClick={() => handleDelete(item.id)}>
                Delete
              </button>
            </div>
          </div>
        ))}
      </div>

      {{#if hasPagination}}
      <div className="pagination">
        <button 
          onClick={() => setPage(p => Math.max(1, p - 1))}
          disabled={page === 1}
        >
          Previous
        </button>
        <span>Page {page}</span>
        <button onClick={() => setPage(p => p + 1)}>
          Next
        </button>
      </div>
      {{/if}}
    </div>
  );
}
