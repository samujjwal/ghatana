{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://yappc.dev/schemas/composition/v1.json",
    "title": "YAPPC Composition Schema",
    "description": "Universal project composition schema for multi-module projects",
    "type": "object",
    "required": [
        "version",
        "metadata",
        "modules"
    ],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+$",
            "description": "Schema version"
        },
        "type": {
            "type": "string",
            "enum": [
                "custom",
                "template",
                "preset"
            ],
            "description": "Composition type"
        },
        "metadata": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "minLength": 2,
                    "maxLength": 50,
                    "description": "Project name"
                },
                "description": {
                    "type": "string",
                    "maxLength": 500,
                    "description": "Project description"
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Project tags"
                },
                "author": {
                    "type": "string",
                    "description": "Project author"
                },
                "license": {
                    "type": "string",
                    "enum": [
                        "MIT",
                        "Apache-2.0",
                        "GPL-3.0",
                        "BSD-3-Clause",
                        "ISC"
                    ],
                    "description": "Project license"
                }
            }
        },
        "modules": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/module"
            },
            "description": "List of modules in the composition"
        },
        "integrations": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/integration"
            },
            "description": "List of integrations between modules"
        },
        "lifecycle": {
            "type": "object",
            "properties": {
                "hooks": {
                    "type": "object",
                    "properties": {
                        "pre-generation": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post-generation": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "pre-build": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post-build": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "module": {
            "type": "object",
            "required": [
                "id",
                "name",
                "type",
                "pack",
                "path"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Unique module identifier"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable module name"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "application",
                        "library",
                        "service",
                        "infrastructure",
                        "tool"
                    ],
                    "description": "Module type"
                },
                "pack": {
                    "type": "string",
                    "description": "Pack to use for this module"
                },
                "path": {
                    "type": "string",
                    "description": "Relative path for module output"
                },
                "enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether module is enabled"
                },
                "condition": {
                    "type": "string",
                    "description": "Conditional expression for module inclusion"
                },
                "variables": {
                    "type": "object",
                    "description": "Module-specific variables"
                },
                "dependencies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of module IDs this module depends on"
                },
                "outputs": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Module output definitions"
                }
            }
        },
        "integration": {
            "type": "object",
            "required": [
                "id",
                "name",
                "type",
                "from",
                "to"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Unique integration identifier"
                },
                "name": {
                    "type": "string",
                    "description": "Human-readable integration name"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "api-client",
                        "datasource",
                        "event-stream",
                        "shared-types",
                        "service-mesh"
                    ],
                    "description": "Integration type"
                },
                "from": {
                    "type": "string",
                    "description": "Source module ID"
                },
                "to": {
                    "type": "string",
                    "description": "Target module ID"
                },
                "templates": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Templates to use for integration"
                },
                "variables": {
                    "type": "object",
                    "description": "Integration-specific variables"
                },
                "condition": {
                    "type": "string",
                    "description": "Conditional expression for integration"
                }
            }
        }
    }
}