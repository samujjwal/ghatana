plugins { id 'application' id 'java' id 'com.diffplug.spotless' version '6.25.0'
id 'checkstyle' id 'jacoco' } group = '{{packageName}}' version = '1.0.0'
description = '{{description}}' java { toolchain { languageVersion =
JavaLanguageVersion.of({{javaVersion}}) } } application { mainClass = '{{packageName}}.{{className}}'
} repositories { mavenCentral() } dependencies { // ActiveJ dependencies
implementation 'io.activej:activej-http:6.0' implementation
'io.activej:activej-inject:6.0' implementation
'io.activej:activej-launcher:6.0' implementation
'io.activej:activej-boot:6.0' implementation
'io.activej:activej-serializer:6.0' implementation
'io.activej:activej-promise:6.0' // Logging implementation
'ch.qos.logback:logback-classic:1.4.14' implementation
'org.slf4j:slf4j-api:2.0.12'

{{#if enableOtel}}
  // OpenTelemetry implementation 'io.opentelemetry:opentelemetry-api:1.34.1'
  implementation
  'io.opentelemetry.instrumentation:opentelemetry-instrumentation-annotations:1.32.0'
  runtimeOnly 'io.opentelemetry.javaagent:opentelemetry-javaagent:1.32.0'
{{/if}}

// Testing testImplementation 'org.junit.jupiter:junit-jupiter-api:5.10.2'
testImplementation 'org.junit.jupiter:junit-jupiter-engine:5.10.2'
testImplementation 'io.activej:activej-test:6.0' testImplementation
'org.assertj:assertj-core:3.25.3' testImplementation
'org.mockito:mockito-core:5.10.0' testImplementation
'org.mockito:mockito-junit-jupiter:5.10.0' } test { useJUnitPlatform()
finalizedBy jacocoTestReport } jacocoTestReport { dependsOn test reports {
xml.required = true html.required = true } } checkstyle { toolVersion =
'10.12.7' configFile = file("${rootProject.projectDir}/.yappc/checkstyle.xml") }
spotless { java { googleJavaFormat() removeUnusedImports()
trimTrailingWhitespace() endWithNewline() } } tasks.register('dockerBuild',
Exec) { group = 'docker' description = 'Build Docker image'
{{#if enableDocker}}
  commandLine 'docker', 'build', '-t', "${project.name}:${project.version}", '.'
{{else}}
  doFirst { throw new GradleException("Docker is disabled. Enable it by setting
  enableDocker=true") }
{{/if}}
} tasks.register('dockerRun', Exec) { group = 'docker' description = 'Run Docker
container'
{{#if enableDocker}}
  commandLine 'docker', 'run', '-p', '{{port}}:{{port}}', '--rm',
  "${project.name}:${project.version}"
{{else}}
  doFirst { throw new GradleException("Docker is disabled. Enable it by setting
  enableDocker=true") }
{{/if}}
} // Custom task to run with OpenTelemetry agent tasks.register('runWithOtel',
JavaExec) { group = 'application' description = 'Run application with
OpenTelemetry agent'
{{#if enableOtel}}
  classpath = sourceSets.main.runtimeClasspath mainClass = application.mainClass
  jvmArgs = [ '-javaagent:build/libs/opentelemetry-javaagent.jar',
  '-Dotel.service.name={{serviceName}}',
  '-Dotel.resource.attributes=service.name={{serviceName}},service.version=${version}',
  '-Dotel.exporter.otlp.endpoint=http://localhost:4317' ]
{{else}}
  doFirst { throw new GradleException("OpenTelemetry is disabled. Enable it by
  setting enableOtel=true") }
{{/if}}
}