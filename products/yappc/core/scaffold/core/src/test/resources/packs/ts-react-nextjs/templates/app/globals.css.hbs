{{#if enableTailwind}}@tailwind base; @tailwind components; @tailwind utilities;
  @layer base { :root { --foreground: #000; --background: #fff; } @media
  (prefers-color-scheme: dark) { :root { --foreground: #fff; --background: #000;
  } } } @layer components { .container { @apply max-w-7xl mx-auto px-4 sm:px-6
  lg:px-8; } }{{else}}/* Global styles */ :root { --foreground: #000;
  --background: #fff; --primary: #3b82f6; --primary-dark: #1e40af; } @media
  (prefers-color-scheme: dark) { :root { --foreground: #fff; --background: #000;
  } } * { box-sizing: border-box; padding: 0; margin: 0; } html, body {
  max-width: 100vw; overflow-x: hidden; font-family: system-ui, -apple-system,
  BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; } body { color:
  var(--foreground); background: var(--background); } a { color: inherit;
  text-decoration: none; } .container { max-width: 1200px; margin: 0 auto;
  padding: 0 1rem; } .grid { display: grid; gap: 1.5rem; } @media (min-width:
  768px) { .grid { grid-template-columns: repeat(2, 1fr); } } @media (min-width:
  1024px) { .grid { grid-template-columns: repeat(3, 1fr); } }{{/if}}