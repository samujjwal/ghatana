{{>../shared/partials/license-header}}
{
  "name": "{{projectName}}",
  "private": true,
  "version": "{{version}}",
  "description": "{{description}}",
  "author": "{{author}}",
  "license": "{{license}}",
  "type": "module",
  {{>../shared/partials/package-scripts framework="vite" testFramework="vitest" port=port enableDocker=enableDocker}},
  "dependencies": {
    "react": "^18.3.1",
