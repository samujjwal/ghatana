    "react-redux": "^9.1.2"{{/eq}}{{#eq stateManagement "jotai"}},
    "jotai": "^2.10.0"{{/eq}}{{#eq stateManagement "valtio"}},
    "valtio": "^2.0.0"{{/eq}}{{#eq cssFramework "tailwind"}},
    "tailwindcss": "^3.4.13",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15"{{/eq}}{{#eq cssFramework "styled-components"}},
    "styled-components": "^6.1.13"{{/eq}}{{#eq cssFramework "emotion"}},
