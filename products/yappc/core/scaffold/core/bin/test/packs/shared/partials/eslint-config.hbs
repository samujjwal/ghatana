{{! Shared ESLint configuration partial }}
{ "extends": [ "@eslint/js/recommended", "@typescript-eslint/recommended",
{{#if framework}}
  {{#eq framework "react"}}"plugin:react/recommended",
    "plugin:react-hooks/recommended",{{/eq}}
  {{#eq framework "next"}}"next/core-web-vitals",{{/eq}}
{{/if}}
"plugin:@typescript-eslint/recommended-type-checked", "prettier" ], "parser":
"@typescript-eslint/parser", "parserOptions": { "ecmaVersion": "latest",
"sourceType": "module", "project": ["./tsconfig.json", "./tsconfig.node.json"]{{#if
  framework
}}{{#eq framework "react"}}, "ecmaFeatures": { "jsx": true }{{/eq}}{{/if}}
}, "plugins": [ "@typescript-eslint"{{#if framework}}{{#eq framework "react"}},
    "react", "react-hooks"{{/eq}}{{/if}}
], "rules": { "@typescript-eslint/no-unused-vars": ["error", {
"argsIgnorePattern": "^_" }], "@typescript-eslint/no-explicit-any": "warn",
"@typescript-eslint/prefer-const": "error"{{#if framework}}{{#eq
    framework "react"
  }}, "react/react-in-jsx-scope": "off", "react/prop-types": "off"{{/eq}}{{/if}}
}, "settings": {
{{#if framework}}{{#eq framework "react"}}"react": { "version": "detect" }{{/eq}}{{/if}}
}, "ignorePatterns": ["dist", "build", "node_modules", "*.config.js",
"*.config.ts"] }