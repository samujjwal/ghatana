{{#if enableRouter}}
{{>../shared/partials/license-header}}

import { useState, useEffect } from 'react'
import { ApiResponse } from '../types'
import { apiClient } from '../services/api'

const Home = () => {
  const [data, setData] = useState<ApiResponse | null>(null)
  const [loading, setLoading] = useState(false)

  const fetchData = async () => {
    setLoading(true)
    try {
      const response = await apiClient.get('/health')
      setData(response)
    } catch (error) {
      console.error('Failed to fetch data:', error)
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    fetchData()
  }, [])

  return (
    <div className="home">
      <h2>Welcome to {{projectName}}</h2>
      <p>This is the home page of your new React application.</p>
      
      <div className="api-demo">
        <h3>API Demo</h3>
        <button onClick={fetchData} disabled={loading}>
          {loading ? 'Loading...' : 'Fetch Health Status'}
        </button>
        {data && (
          <pre>{JSON.stringify(data, null, 2)}</pre>
        )}
      </div>

      <div className="features">
        <h3>What's included:</h3>
        <ul>
          <li>React 18 with TypeScript</li>
          <li>Vite for fast development</li>
          <li>React Router for navigation</li>
          <li>Modern CSS with custom properties</li>
          <li>API client service</li>
          <li>Testing with Vitest</li>
          <li>ESLint + Prettier</li>
          {{#if enablePWA}}<li>Progressive Web App features</li>{{/if}}
          {{#if enableDocker}}<li>Docker deployment ready</li>{{/if}}
        </ul>
      </div>
    </div>
  )
}

export default Home
{{else}}
// Home page component is only generated when enableRouter is true
{{/if}}