{
    "id": "ts-node-express",
    "name": "TypeScript Node.js Express API",
    "description": "TypeScript Node.js REST API with Express",
    "version": "1.0.0",
    "type": "application",
    "language": "typescript",
    "buildSystem": "npm",
    "requiredVariables": [
        "projectName"
    ],
