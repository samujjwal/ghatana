// Item represents a sample resource.
type Item struct {
ID string `json:"id"`
Name string `json:"name"`
Description string `json:"description,omitempty"`
CreatedAt string `json:"created_at,omitempty"`
}

// Welcome returns a welcome message handler.
func Welcome() http.HandlerFunc {
return func(w http.ResponseWriter, r *http.Request) {
resp := map[string]string{
"message": "Welcome to {{projectName}} API",
"version": "v1",
}
writeJSON(w, http.StatusOK, resp)
}
}

// ListItems returns a handler that lists all items.
func ListItems() http.HandlerFunc {
return func(w http.ResponseWriter, r *http.Request) {
// TODO: Implement actual list logic
items := []Item{
{ID: "1", Name: "Sample Item 1", Description: "A sample item"},
{ID: "2", Name: "Sample Item 2", Description: "Another sample item"},
}
writeJSON(w, http.StatusOK, map[string]interface{}{
"items": items,
