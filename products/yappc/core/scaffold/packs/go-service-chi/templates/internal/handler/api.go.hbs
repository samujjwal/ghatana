// CreateItem returns a handler that creates a new item.
func CreateItem() http.HandlerFunc {
return func(w http.ResponseWriter, r *http.Request) {
var item Item
if err := json.NewDecoder(r.Body).Decode(&item); err != nil {
http.Error(w, "Invalid request body", http.StatusBadRequest)
return
}

// TODO: Implement actual create logic
item.ID = "new-id"
item.CreatedAt = "2024-01-01T00:00:00Z"

writeJSON(w, http.StatusCreated, item)
}
}

// GetItem returns a handler that retrieves a single item.
func GetItem() http.HandlerFunc {
return func(w http.ResponseWriter, r *http.Request) {
id := chi.URLParam(r, "id")
if id == "" {
http.Error(w, "Item ID is required", http.StatusBadRequest)
return
}

// TODO: Implement actual get logic
item := Item{
ID: id,
Name: "Sample Item",
Description: "This is a sample item",
CreatedAt: "2024-01-01T00:00:00Z",
}

writeJSON(w, http.StatusOK, item)
}
}

// UpdateItem returns a handler that updates an existing item.
func UpdateItem() http.HandlerFunc {
return func(w http.ResponseWriter, r *http.Request) {
id := chi.URLParam(r, "id")
if id == "" {
http.Error(w, "Item ID is required", http.StatusBadRequest)
return
}

var item Item
if err := json.NewDecoder(r.Body).Decode(&item); err != nil {
http.Error(w, "Invalid request body", http.StatusBadRequest)
return
}

// TODO: Implement actual update logic
item.ID = id

writeJSON(w, http.StatusOK, item)
}
}

