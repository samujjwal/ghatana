# Generated by YAPPC - Air configuration for hot reload
# https://github.com/cosmtrek/air

root = "."
tmp_dir = "tmp"

[build]
bin = "./tmp/{{projectName}}"
cmd = "go build -o ./tmp/{{projectName}} ./cmd/{{projectName}}"
delay = 1000
exclude_dir = ["assets", "tmp", "vendor", "node_modules", "bin"]
exclude_file = []
exclude_regex = ["_test.go"]
exclude_unchanged = false
follow_symlink = false
full_bin = ""
include_dir = []
include_ext = ["go", "tpl", "tmpl", "html", "yaml", "yml", "json"]
kill_delay = "0s"
log = "build-errors.log"
send_interrupt = false
stop_on_error = true

[color]
build = "yellow"
main = "magenta"
runner = "green"
watcher = "cyan"

[log]
time = false

[misc]
clean_on_exit = true

[screen]
clear_on_rebuild = true