{
"name": "{{projectName}}",
"version": "0.1.0",
"private": true,
"type": "module",
"scripts": {
"dev": "vite",
"build": "vite build",
"preview": "vite preview",
{{#if enableVitest}}
"test": "vitest",
"test:ui": "vitest --ui",
"test:coverage": "vitest --coverage",
{{/if}}
"lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
"format": "prettier --write src/"
},
"dependencies": {
"vue": "^3.4.0",
{{#if enableRouter}}
"vue-router": "^4.2.0",
{{/if}}
{{#if enablePinia}}
"pinia": "^2.1.0"
{{/if}}
},
"devDependencies": {
"@vitejs/plugin-vue": "^5.0.0",
"vite": "^5.0.0",
"typescript": "^5.3.0",
"vue-tsc": "^1.8.0",
{{#if enableTailwind}}
"tailwindcss": "^3.4.0",
"autoprefixer": "^10.4.0",
"postcss": "^8.4.0",
{{/if}}
{{#if enableVitest}}
"vitest": "^1.0.0",
"@vue/test-utils": "^2.4.0",
{{/if}}
"eslint": "^8.56.0",
"eslint-plugin-vue": "^9.19.0",
"prettier": "^3.1.0"
}
}