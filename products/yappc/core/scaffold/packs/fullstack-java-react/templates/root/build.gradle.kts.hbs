plugins {
idea
}

idea {
project {
jdkName = "{{javaVersion}}"
}
}

tasks.register("clean") {
group = "build"
description = "Clean all build outputs"

dependsOn(":backend:clean")
doLast {
delete(layout.buildDirectory)
}
}

tasks.register("build") {
group = "build"
description = "Build all projects"

dependsOn(":backend:build")
}