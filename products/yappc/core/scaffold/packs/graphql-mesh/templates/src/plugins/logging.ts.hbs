import pino from "pino";
import type { Plugin } from "graphql-yoga";

const LOG_LEVEL = process.env.LOG_LEVEL ?? "{{logLevel}}";

/**
* Application logger instance
*/
export const logger = pino({
level: LOG_LEVEL,
transport:
process.env.NODE_ENV === "development"
? {
target: "pino-pretty",
options: {
colorize: true,
translateTime: "SYS:standard",
ignore: "pid,hostname",
},
}
: undefined,
formatters: {
level: (label) => ({ level: label }),
},
base: {
service: "{{projectName}}",
version: process.env.npm_package_version ?? "0.0.0",
},
});

/**
* Create logging plugin for GraphQL operations
*/
export function createLoggingPlugin(): Plugin {
return {
onExecute({ args }) {
const startTime = process.hrtime.bigint();
const operationName = args.operationName ?? "anonymous";
const requestId = crypto.randomUUID();

logger.debug(
{ operationName, requestId },
"GraphQL operation started"
);

return {
onExecuteDone({ result }) {
const duration = Number(process.hrtime.bigint() - startTime) / 1_000_000;
const hasErrors = "errors" in result && result.errors?.length;

if (hasErrors) {
logger.warn(
{
operationName,
requestId,
duration: Math.round(duration * 100) / 100,
errors: result.errors?.map((e) => e.message),
},
"GraphQL operation completed with errors"
);
} else {
logger.info(
{
operationName,
requestId,
duration: Math.round(duration * 100) / 100,
},
"GraphQL operation completed"
);
}
},
};
},

onSubscribe({ args }) {
const operationName = args.operationName ?? "anonymous";
logger.debug({ operationName }, "Subscription started");

return {
onSubscribeResult() {
logger.debug({ operationName }, "Subscription result");
},
onSubscribeError({ error }) {
logger.error({ operationName, error }, "Subscription error");
},
};
},

onParse({ params }) {
const startTime = process.hrtime.bigint();

return {
onParseEnd() {
const duration = Number(process.hrtime.bigint() - startTime) / 1_000_000;
logger.trace({ duration }, "Parse completed");
},
};
},
};
}