{{#if enableCaching}}
import { useResponseCache } from "@graphql-yoga/plugin-response-cache";
import type { Plugin } from "graphql-yoga";
import type { MeshConfig } from "../types.js";
import { logger } from "./logging.js";

interface CacheEntry {
data: unknown;
timestamp: number;
ttl: number;
}

/**
* In-memory cache store
*/
const cache = new Map<string, CacheEntry>();

    /**
    * Create response caching plugin
    */
    export function createCachePlugin(config: MeshConfig): Plugin {
    const maxAge = config.cacheMaxAge * 1000; // Convert to milliseconds

    return useResponseCache({
    session: (request) => {
    // Cache per user if authenticated
    const auth = request.headers.get("authorization");
    if (auth) {
    return auth;
    }
    return null; // Shared cache for anonymous
    },

    ttl: maxAge,

    // Only cache queries
    enabled: ({ request }) => {
    return request.method === "GET" || request.method === "POST";
    },

    // Custom cache implementation
    cache: {
    async get(key) {
    const entry = cache.get(key);
    if (!entry) return undefined;

    // Check if expired
    if (Date.now() > entry.timestamp + entry.ttl) {
    cache.delete(key);
    return undefined;
    }

    logger.debug({ key: key.slice(0, 20) }, "Cache hit");
    return entry.data;
    },

    async set(key, value, ttl) {
    cache.set(key, {
    data: value,
    timestamp: Date.now(),
    ttl: ttl ?? maxAge,
    });
    logger.debug({ key: key.slice(0, 20), ttl }, "Cache set");
    },

    async invalidate(keys) {
    for (const key of keys) {
    cache.delete(key);
    }
    logger.debug({ count: keys.length }, "Cache invalidated");
    },
    },
    });
    }

    /**
    * Invalidate cache for specific types
    */
    export function invalidateType(typeName: string): void {
    let count = 0;
    for (const key of cache.keys()) {
    if (key.includes(typeName)) {
    cache.delete(key);
    count++;
    }
    }
    logger.info({ typeName, count }, "Invalidated cache for type");
    }

    /**
    * Clear entire cache
    */
    export function clearCache(): void {
    const count = cache.size;
    cache.clear();
    logger.info({ count }, "Cache cleared");
    }

    /**
    * Get cache stats
    */
    export function getCacheStats(): { size: number; keys: string[] } {
    return {
    size: cache.size,
    keys: Array.from(cache.keys()).map((k) => k.slice(0, 30)),
    };
    }

    // Periodic cleanup of expired entries
    setInterval(() => {
    const now = Date.now();
    let cleaned = 0;

    for (const [key, entry] of cache) {
    if (now > entry.timestamp + entry.ttl) {
    cache.delete(key);
    cleaned++;
    }
    }

    if (cleaned > 0) {
    logger.debug({ cleaned }, "Cleaned expired cache entries");
    }
    }, 60000);
    {{else}}
    // Caching is disabled. Enable it in pack.json to use cache plugin.
    export {};
    {{/if}}