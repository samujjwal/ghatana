import { describe, it, expect, beforeAll, afterAll } from "vitest";
import { createServer } from "../src/server.js";
import type { MeshConfig } from "../src/types.js";

describe("GraphQL Mesh Gateway", () => {
const testConfig: MeshConfig = {
port: 0, // Random port
enablePlayground: false,
enableIntrospection: true,
logLevel: "error",
{{#if enableAuth}}
enableAuth: false, // Disable for tests
{{/if}}
{{#if enableCaching}}
enableCaching: false,
cacheMaxAge: 60,
{{/if}}
{{#if enableRateLimiting}}
enableRateLimiting: false,
rateLimitMax: 100,
{{/if}}
{{#if enableMetrics}}
enableMetrics: false,
{{/if}}
{{#if enableCors}}
enableCors: true,
corsOrigin: "*",
{{/if}}
};

describe("Health Queries", () => {
let server: Awaited<ReturnType<typeof createServer>>;
    let url: string;

    beforeAll(async () => {
    server = await createServer(testConfig);
    url = await server.start();
    });

    afterAll(async () => {
    await server.stop();
    });

    it("should return health status", async () => {
    const response = await fetch(url, {
    method: "POST",
    headers: {
    "Content-Type": "application/json",
    },
    body: JSON.stringify({
    query: `query { _health { status timestamp } }`,
    }),
    });

    expect(response.ok).toBe(true);

    const result = await response.json();
    expect(result.data._health.status).toBe("healthy");
    expect(result.data._health.timestamp).toBeDefined();
    });

    it("should return version info", async () => {
    const response = await fetch(url, {
    method: "POST",
    headers: {
    "Content-Type": "application/json",
    },
    body: JSON.stringify({
    query: `query { _version { version node } }`,
    }),
    });

    expect(response.ok).toBe(true);

    const result = await response.json();
    expect(result.data._version.version).toBeDefined();
    expect(result.data._version.node).toContain("v");
    });
    });

    describe("Mutations", () => {
    let server: Awaited<ReturnType<typeof createServer>>;
        let url: string;

        beforeAll(async () => {
        server = await createServer(testConfig);
        url = await server.start();
        });

        afterAll(async () => {
        await server.stop();
        });

        it("should respond to ping mutation", async () => {
        const response = await fetch(url, {
        method: "POST",
        headers: {
        "Content-Type": "application/json",
        },
        body: JSON.stringify({
        query: `mutation { _ping(message: "hello") { message timestamp } }`,
        }),
        });

        expect(response.ok).toBe(true);

        const result = await response.json();
        expect(result.data._ping.message).toBe("hello");
        });
        });

        describe("Introspection", () => {
        let server: Awaited<ReturnType<typeof createServer>>;
            let url: string;

            beforeAll(async () => {
            server = await createServer(testConfig);
            url = await server.start();
            });

            afterAll(async () => {
            await server.stop();
            });

            it("should allow introspection", async () => {
            const response = await fetch(url, {
            method: "POST",
            headers: {
            "Content-Type": "application/json",
            },
            body: JSON.stringify({
            query: `query { __schema { queryType { name } } }`,
            }),
            });

            expect(response.ok).toBe(true);

            const result = await response.json();
            expect(result.data.__schema.queryType.name).toBe("Query");
            });
            });

            describe("Error Handling", () => {
            let server: Awaited<ReturnType<typeof createServer>>;
                let url: string;

                beforeAll(async () => {
                server = await createServer(testConfig);
                url = await server.start();
                });

                afterAll(async () => {
                await server.stop();
                });

                it("should handle invalid queries gracefully", async () => {
                const response = await fetch(url, {
                method: "POST",
                headers: {
                "Content-Type": "application/json",
                },
                body: JSON.stringify({
                query: `query { nonExistentField }`,
                }),
                });

                const result = await response.json();
                expect(result.errors).toBeDefined();
                expect(result.errors.length).toBeGreaterThan(0);
                });

                it("should handle malformed requests", async () => {
                const response = await fetch(url, {
                method: "POST",
                headers: {
                "Content-Type": "application/json",
                },
                body: "not valid json",
                });

                expect(response.status).toBe(400);
                });
                });
                });