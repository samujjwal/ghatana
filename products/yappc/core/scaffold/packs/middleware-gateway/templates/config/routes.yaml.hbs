# Routes Configuration
# Define upstream service routing rules

routes:
# Example: User Service
- prefix: /api/users
upstream: http://user-service:3000
methods: [GET, POST, PUT, DELETE]
timeout: 30000
retries: 2
{{#if enableAuth}}
auth: true
{{/if}}
{{#if enableRateLimiting}}
rateLimit:
max: 100
timeWindow: "1m"
{{/if}}
headers:
X-Service-Name: "{{projectName}}"
stripPrefix: true

# Example: Product Service
- prefix: /api/products
upstream: http://product-service:3001
methods: [GET, POST, PUT, DELETE]
timeout: 30000
{{#if enableAuth}}
auth: true
{{/if}}
stripPrefix: true

# Example: Public Endpoints (no auth)
- prefix: /api/public
upstream: http://public-service:3002
methods: [GET]
timeout: 10000
auth: false
{{#if enableRateLimiting}}
rateLimit:
max: 1000
timeWindow: "1m"
{{/if}}
stripPrefix: true

# Example: WebSocket Support (future)
# - prefix: /ws
# upstream: ws://websocket-service:3003
# websocket: true

# Add more routes as needed
# Routes are matched in order, first match wins