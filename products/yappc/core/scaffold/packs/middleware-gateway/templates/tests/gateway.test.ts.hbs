import { describe, it, expect, beforeAll, afterAll } from "vitest";
import Fastify from "fastify";
import { createGateway } from "../src/gateway.js";
import type { GatewayConfig } from "../src/types.js";

describe("Gateway", () => {
const testConfig: GatewayConfig = {
port: 0, // Use random available port
logLevel: "error",
{{#if enableRateLimiting}}
rateLimiting: {
max: 100,
timeWindow: "1m",
},
{{/if}}
{{#if enableAuth}}
jwtSecret: "test-secret-key-for-testing-only",
{{/if}}
{{#if enableCircuitBreaker}}
circuitBreaker: {
threshold: 50,
timeout: 30000,
},
{{/if}}
};

describe("Health Endpoints", () => {
let app: ReturnType<typeof Fastify>;

    beforeAll(async () => {
    app = await createGateway(testConfig, []);
    await app.ready();
    });

    afterAll(async () => {
    await app.close();
    });

    it("should return healthy status on /health", async () => {
    const response = await app.inject({
    method: "GET",
    url: "/health",
    });

    expect(response.statusCode).toBe(200);

    const body = JSON.parse(response.payload);
    expect(body.status).toBe("healthy");
    expect(body.timestamp).toBeDefined();
    });

    it("should return ready status on /health/ready", async () => {
    const response = await app.inject({
    method: "GET",
    url: "/health/ready",
    });

    expect(response.statusCode).toBe(200);

    const body = JSON.parse(response.payload);
    expect(body.status).toMatch(/healthy|degraded/);
    expect(body.uptime).toBeGreaterThan(0);
    expect(body.checks).toBeDefined();
    });

    it("should return ok on /health/live", async () => {
    const response = await app.inject({
    method: "GET",
    url: "/health/live",
    });

    expect(response.statusCode).toBe(200);

    const body = JSON.parse(response.payload);
    expect(body.status).toBe("ok");
    });
    });

    {{#if enableMetrics}}
    describe("Metrics Endpoint", () => {
    let app: ReturnType<typeof Fastify>;

        beforeAll(async () => {
        app = await createGateway(testConfig, []);
        await app.ready();
        });

        afterAll(async () => {
        await app.close();
        });

        it("should expose Prometheus metrics on /metrics", async () => {
        const response = await app.inject({
        method: "GET",
        url: "/metrics",
        });

        expect(response.statusCode).toBe(200);
        expect(response.headers["content-type"]).toContain("text/plain");
        expect(response.payload).toContain("nodejs_");
        });
        });
        {{/if}}

        {{#if enableRateLimiting}}
        describe("Rate Limiting", () => {
        let app: ReturnType<typeof Fastify>;

            beforeAll(async () => {
            const config = {
            ...testConfig,
            rateLimiting: {
            max: 3,
            timeWindow: "1m",
            },
            };
            app = await createGateway(config, []);
            await app.ready();
            });

            afterAll(async () => {
            await app.close();
            });

            it("should include rate limit headers", async () => {
            const response = await app.inject({
            method: "GET",
            url: "/health",
            });

            expect(response.headers["x-ratelimit-limit"]).toBeDefined();
            expect(response.headers["x-ratelimit-remaining"]).toBeDefined();
            });
            });
            {{/if}}

            describe("Error Handling", () => {
            let app: ReturnType<typeof Fastify>;

                beforeAll(async () => {
                app = await createGateway(testConfig, []);
                await app.ready();
                });

                afterAll(async () => {
                await app.close();
                });

                it("should return 404 for unknown routes", async () => {
                const response = await app.inject({
                method: "GET",
                url: "/unknown/path",
                });

                expect(response.statusCode).toBe(404);
                });

                it("should handle OPTIONS requests for CORS", async () => {
                const response = await app.inject({
                method: "OPTIONS",
                url: "/health",
                headers: {
                Origin: "http://localhost:3000",
                },
                });

                // Should not error
                expect(response.statusCode).toBeLessThan(500);
                });
                });
                });