{
"name": "{{projectName}}",
"version": "0.1.0",
"description": "{{description}}",
"type": "module",
"scripts": {
"dev": "tsx watch src/index.ts",
"build": "tsc",
"start": "node dist/index.js",
"lint": "biome check .",
"lint:fix": "biome check --fix .",
"format": "biome format --write .",
"test": "vitest run",
"test:watch": "vitest",
"test:coverage": "vitest run --coverage",
"typecheck": "tsc --noEmit"
},
"dependencies": {
"fastify": "^4.28.1",
"@fastify/http-proxy": "^10.0.0",
"@fastify/cors": "^9.0.1",
"@fastify/helmet": "^11.1.1",
"@fastify/under-pressure": "^8.5.0",
"pino": "^9.4.0",
"pino-pretty": "^11.3.0",
"yaml": "^2.6.0",
"zod": "^3.23.8"{{#if enableRateLimiting}},
"@fastify/rate-limit": "^9.1.0"{{/if}}{{#if enableAuth}},
"@fastify/jwt": "^8.0.1"{{/if}}{{#if enableCircuitBreaker}},
"opossum": "^8.1.4"{{/if}}{{#if enableMetrics}},
"prom-client": "^15.1.3",
"@fastify/metrics": "^11.0.0"{{/if}}
},
"devDependencies": {
"@biomejs/biome": "^1.9.4",
"@types/node": "^22.9.0",
"tsx": "^4.19.2",
"typescript": "^5.6.3",
"vitest": "^2.1.2"{{#if enableCircuitBreaker}},
"@types/opossum": "^8.1.0"{{/if}}
},
"engines": {
"node": ">=18.0.0",
"pnpm": ">=9.0.0"
},
"packageManager": "pnpm@9.14.4"
}