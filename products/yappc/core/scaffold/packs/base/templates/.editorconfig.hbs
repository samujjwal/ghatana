# EditorConfig for
{{projectName}}
# https://editorconfig.org/ root = true [*] charset = utf-8 end_of_line = lf
insert_final_newline = true trim_trailing_whitespace = true indent_style = space
indent_size = 4 [*.{yml,yaml}] indent_size = 2 [*.json] indent_size = 2
[*.{js,ts}] indent_size = 2 [*.{md,markdown}] trim_trailing_whitespace = false
[*.gradle] indent_size = 4 [*.java] indent_size = 4 max_line_length = 120
[Dockerfile*] indent_style = tab [Makefile] indent_style = tab