replicaCount: 1

image:
repository: "{{dockerRegistry}}/{{kebabCase projectName}}"
tag: "latest"
pullPolicy: IfNotPresent

service:
type: ClusterIP
port: 80

ingress:
enabled: false
className: ""
hosts:
- host: {{kebabCase projectName}}.example.com
paths:
- path: /
pathType: Prefix

resources: {}

autoscaling:
enabled: false
minReplicas: 1
maxReplicas: 5
targetCPUUtilizationPercentage: 80