//! Database schema definitions
//!
//! Contains SQLx model definitions and queries

use sqlx::FromRow;
use chrono::{DateTime, Utc};
use uuid::Uuid;

/// Base entity trait for common fields
pub trait BaseEntity {
fn id(&self) -> Uuid;
fn created_at(&self) -> DateTime<Utc>;
    fn updated_at(&self) -> DateTime<Utc>;
        }

        /// Example entity model
        #[derive(Debug, Clone, FromRow)]
        pub struct ExampleEntity {
        pub id: Uuid,
        pub name: String,
        pub description: Option<String>,
            pub created_at: DateTime<Utc>,
                pub updated_at: DateTime<Utc>,
                    }

                    impl BaseEntity for ExampleEntity {
                    fn id(&self) -> Uuid {
                    self.id
                    }

                    fn created_at(&self) -> DateTime<Utc> {
                        self.created_at
                        }

                        fn updated_at(&self) -> DateTime<Utc> {
                            self.updated_at
                            }
                            }

                            /// Example entity repository
                            pub struct ExampleRepository;

                            impl ExampleRepository {
                            pub async fn find_by_id(pool: &sqlx::PgPool, id: Uuid) -> Result<Option<ExampleEntity>,
                                sqlx::Error> {
                                sqlx::query_as::<_, ExampleEntity>("SELECT * FROM example_entity WHERE id = $1")
                                    .bind(id)
                                    .fetch_optional(pool)
                                    .await
                                    }

                                    pub async fn find_all(pool: &sqlx::PgPool, limit: i64, offset: i64) -> Result
                                    <Vec<ExampleEntity>, sqlx::Error> {
                                        sqlx::query_as::<_, ExampleEntity>(
                                            "SELECT * FROM example_entity ORDER BY created_at DESC LIMIT $1 OFFSET $2"
                                            )
                                            .bind(limit)
                                            .bind(offset)
                                            .fetch_all(pool)
                                            .await
                                            }

                                            pub async fn create(pool: &sqlx::PgPool, name: &str, description: Option
                                            <&str>) -> Result<ExampleEntity, sqlx::Error> {
                                                    sqlx::query_as::<_, ExampleEntity>(
                                                        "INSERT INTO example_entity (name, description) VALUES ($1, $2)
                                                        RETURNING *"
                                                        )
                                                        .bind(name)
                                                        .bind(description)
                                                        .fetch_one(pool)
                                                        .await
                                                        }

                                                        pub async fn delete(pool: &sqlx::PgPool, id: Uuid) -> Result
                                                        <bool, sqlx::Error> {
                                                            let result = sqlx::query("DELETE FROM example_entity WHERE
                                                            id = $1")
                                                            .bind(id)
                                                            .execute(pool)
                                                            .await?;

                                                            Ok(result.rows_affected() > 0)
                                                            }
                                                            }