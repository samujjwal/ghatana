# Database Configuration
spring:
datasource:
url: jdbc:{{#if (eq databaseType "postgresql")}}postgresql{{else if (eq databaseType
"mysql")}}mysql{{else}}h2{{/if}}://{{databaseHost}}:{{databasePort}}/{{databaseName}}
username: ${DB_USERNAME:postgres}
password: ${DB_PASSWORD:postgres}
driver-class-name: {{#if (eq databaseType "postgresql")}}org.postgresql.Driver{{else if (eq databaseType
"mysql")}}com.mysql.cj.jdbc.Driver{{else}}org.h2.Driver{{/if}}
hikari:
maximum-pool-size: {{connectionPoolSize}}
minimum-idle: 5
idle-timeout: 30000
connection-timeout: 20000
max-lifetime: 1800000
jpa:
hibernate:
ddl-auto: validate
show-sql: false
open-in-view: false
properties:
hibernate:
format_sql: true
jdbc:
batch_size: 50
order_inserts: true
order_updates: true
{{#if enableMigrations}}
flyway:
enabled: true
locations: classpath:db/migration
baseline-on-migrate: true
baseline-version: 0
{{/if}}