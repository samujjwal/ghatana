[package]
name = "{{projectName}}"
version = "0.1.0"
edition = "{{edition}}"
description = "{{description}}"
rust-version = "{{rustVersion}}"
authors = ["YAPPC Generator"]
license = "Apache-2.0"

[dependencies]
# Web framework
axum = { version = "0.7", features = ["macros"] }
tokio = { version = "1", features = ["full"] }
tower = "0.4"
tower-http = { version = "0.5", features = ["cors", "trace", "timeout", "compression-gzip"] }

# Serialization
serde = { version = "1", features = ["derive"] }
serde_json = "1"

# Logging & Tracing
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
{{#if enableTracing}}
opentelemetry = { version = "0.21", features = ["rt-tokio"] }
opentelemetry-otlp = "0.14"
tracing-opentelemetry = "0.22"
{{/if}}

# Configuration
config = "0.14"
dotenvy = "0.15"

# Error handling
thiserror = "1"
anyhow = "1"

# Async utilities
futures = "0.3"

# HTTP client (for external calls)
reqwest = { version = "0.11", features = ["json", "rustls-tls"], default-features = false }

{{#if enableMetrics}}
# Metrics
metrics = "0.22"
metrics-exporter-prometheus = "0.13"
axum-prometheus = "0.6"
{{/if}}

[dev-dependencies]
tokio-test = "0.4"
tower = { version = "0.4", features = ["util"] }
http-body-util = "0.1"
hyper = { version = "1", features = ["full"] }

[profile.release]
lto = true
codegen-units = 1
panic = "abort"
strip = true

[profile.dev]
opt-level = 0
debug = true

[lints.rust]
unsafe_code = "forbid"

[lints.clippy]
all = "warn"
pedantic = "warn"
nursery = "warn"