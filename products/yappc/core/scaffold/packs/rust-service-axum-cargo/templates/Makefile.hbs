# Generated by YAPPC - {{projectName}}
# {{description}}

BINARY_NAME := {{projectName}}
VERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo "dev")
BUILD_TIME ?= $(shell date -u '+%Y-%m-%dT%H:%M:%SZ')

.PHONY: all build clean test lint run dev help docker-build docker-run release

all: build

## build: Build the binary in release mode
build:
@echo "Building $(BINARY_NAME)..."
cargo build --release

## build-debug: Build the binary in debug mode
build-debug:
@echo "Building $(BINARY_NAME) (debug)..."
cargo build

## clean: Clean build artifacts
clean:
@echo "Cleaning..."
cargo clean

## test: Run tests
test:
@echo "Testing..."
cargo test --all-features

## test-verbose: Run tests with output
test-verbose:
@echo "Testing (verbose)..."
cargo test --all-features -- --nocapture

## lint: Run clippy and check formatting
lint:
@echo "Linting..."
cargo fmt -- --check
cargo clippy --all-features -- -D warnings

## fmt: Format code
fmt:
@echo "Formatting..."
cargo fmt

## run: Run the application
run:
@echo "Running..."
cargo run

## dev: Run with hot reload (requires cargo-watch)
dev:
@if command -v cargo-watch > /dev/null; then \
cargo watch -x run; \
else \
echo "cargo-watch not found. Install with: cargo install cargo-watch"; \
exit 1; \
fi

## check: Check for errors without building
check:
cargo check --all-features

## audit: Check for security vulnerabilities
audit:
@if command -v cargo-audit > /dev/null; then \
cargo audit; \
else \
echo "cargo-audit not found. Install with: cargo install cargo-audit"; \
fi

## doc: Generate documentation
doc:
cargo doc --no-deps --open

## docker-build: Build Docker image
docker-build:
docker build -t $(BINARY_NAME):$(VERSION) .

## docker-run: Run Docker container
docker-run:
docker run -p {{port}}:{{port}} --rm $(BINARY_NAME):$(VERSION)

## docker-compose-up: Start with docker-compose
docker-compose-up:
docker-compose up -d

## docker-compose-down: Stop docker-compose
docker-compose-down:
docker-compose down

## release: Create a release build with optimizations
release:
cargo build --release
@echo "Release binary: target/release/$(BINARY_NAME)"

## help: Show this help
help:
@echo "Available targets:"
@sed -n 's/^## //p' $(MAKEFILE_LIST) | column -t -s ':'