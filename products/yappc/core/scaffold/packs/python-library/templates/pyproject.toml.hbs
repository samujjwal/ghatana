[project]
name = "{{kebabCase projectName}}"
version = "0.1.0"
{{#if description}}
description = "{{description}}"
{{/if}}
{{#if author}}
authors = [{ name = "{{author}}" }]
{{/if}}
requires-python = "{{pythonVersion}}"
readme = "README.md"
license = { text = "MIT" }

dependencies = []

[project.optional-dependencies]
dev = [
"pytest>=7.4.0",
"ruff>=0.1.0",
"mypy>=1.7.0",
]

{{#if (eq buildTool "poetry")}}
[tool.poetry]
name = "{{kebabCase projectName}}"
version = "0.1.0"
description = "{{#if description}}{{description}}{{else}}A Python library{{/if}}"
authors = ["{{#if author}}{{author}}{{else}}Your Name <you@example.com>{{/if}}"]

    [tool.poetry.dependencies]
    python = "{{pythonVersion}}"

    [tool.poetry.group.dev.dependencies]
    pytest = "^7.4.0"
    ruff = "^0.1.0"
    mypy = "^1.7.0"

    [build-system]
    requires = ["poetry-core"]
    build-backend = "poetry.core.masonry.api"
    {{else}}
    [build-system]
    requires = ["hatchling"]
    build-backend = "hatchling.build"
    {{/if}}

    [tool.ruff]
    line-length = 100
    target-version = "py311"

    [tool.mypy]
    python_version = "3.11"
    strict = true

    [tool.pytest.ini_options]
    testpaths = ["tests"]