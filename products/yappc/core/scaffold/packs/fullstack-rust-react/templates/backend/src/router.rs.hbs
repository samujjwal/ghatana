use axum::{
routing::get,
Router,
};
use tower_http::{
cors::{Any, CorsLayer},
trace::TraceLayer,
};

use crate::handlers;

pub fn create_router() -> Router {
let cors = CorsLayer::new()
.allow_origin(Any)
.allow_methods(Any)
.allow_headers(Any);

Router::new()
.route("/api/health", get(handlers::health))
.route("/api/example", get(handlers::get_example))
.layer(cors)
.layer(TraceLayer::new_for_http())
}