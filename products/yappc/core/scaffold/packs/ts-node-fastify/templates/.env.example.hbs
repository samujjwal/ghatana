# Server Configuration
NODE_ENV=development
PORT={{port}}
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL="{{databaseUrl}}"

# API Configuration
API_PREFIX=/api/v1

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
ENABLE_SWAGGER={{enableSwagger}}
ENABLE_METRICS={{enableMetrics}}
