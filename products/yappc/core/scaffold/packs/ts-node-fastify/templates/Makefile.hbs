# {{projectName}} Makefile
# Generated by YAPPC

.PHONY: all dev build test lint format clean docker help

.DEFAULT_GOAL := help

# Variables
SERVICE_NAME := {{projectName}}
PORT := {{port}}

## Development

dev: ## Start development server with hot reload
pnpm dev

## Build

build: ## Build for production
pnpm build

## Testing

test: ## Run tests
pnpm test

test-watch: ## Run tests in watch mode
pnpm test:watch

test-coverage: ## Run tests with coverage
pnpm test:coverage

## Code Quality

lint: ## Run linter
pnpm lint

lint-fix: ## Run linter and fix issues
pnpm lint:fix

format: ## Format code
pnpm format

typecheck: ## Run type checking
pnpm typecheck

check: lint typecheck test ## Run all checks

## Database

db-generate: ## Generate Prisma client
pnpm prisma:generate

db-migrate: ## Run database migrations
pnpm prisma:migrate

db-push: ## Push schema to database
pnpm prisma:push

db-studio: ## Open Prisma Studio
pnpm prisma:studio

## Docker

docker-build: ## Build Docker image
docker build -t $(SERVICE_NAME) .

docker-run: ## Run Docker container
docker run -p $(PORT):$(PORT) --env-file .env $(SERVICE_NAME)

docker-compose-up: ## Start services with docker-compose
docker-compose up -d

docker-compose-down: ## Stop services
docker-compose down

docker-compose-logs: ## View logs
docker-compose logs -f

## Cleanup

clean: ## Clean build artifacts
pnpm clean
rm -rf dist node_modules .turbo coverage

## Help

help: ## Show this help
@echo "{{projectName}} - Available targets:"
@echo ""
@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf " \033[36m%-20s\033[0m
%s\n", $$1, $$2}'