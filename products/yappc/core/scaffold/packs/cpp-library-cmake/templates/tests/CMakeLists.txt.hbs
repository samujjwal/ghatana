{{#if enableTesting}}
include(FetchContent)

FetchContent_Declare(
googletest
GIT_REPOSITORY https://github.com/google/googletest.git
GIT_TAG v1.14.0
)
FetchContent_MakeAvailable(googletest)

add_executable({{snakeCase projectName}}_test
test_{{snakeCase projectName}}.cpp
)

target_link_libraries({{snakeCase projectName}}_test
{{pascalCase projectName}}
gtest_main
)

include(GoogleTest)
gtest_discover_tests({{snakeCase projectName}}_test)
{{/if}}