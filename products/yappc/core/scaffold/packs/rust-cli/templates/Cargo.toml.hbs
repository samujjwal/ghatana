[package]
name = "{{kebabCase projectName}}"
version = "0.1.0"
edition = "{{rustEdition}}"
{{#if description}}
description = "{{description}}"
{{/if}}
{{#if author}}
authors = ["{{author}}"]
{{/if}}

[dependencies]
clap = { version = "4.4", features = ["derive"] }
anyhow = "1.0"

[[bin]]
name = "{{kebabCase projectName}}"
path = "src/main.rs"