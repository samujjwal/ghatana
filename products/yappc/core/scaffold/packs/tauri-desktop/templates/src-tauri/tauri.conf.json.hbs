{
"$schema": "https://schema.tauri.app/config/2",
"productName": "{{displayName}}",
"version": "{{version}}",
"identifier": "{{bundleId}}",
"build": {
"beforeDevCommand": "pnpm dev",
"devUrl": "http://localhost:1420",
"beforeBuildCommand": "pnpm build",
"frontendDist": "../dist"
},
"app": {
"withGlobalTauri": true,
"windows": [
{
"title": "{{displayName}}",
"width": {{windowWidth}},
"height": {{windowHeight}},
"minWidth": {{minWindowWidth}},
"minHeight": {{minWindowHeight}},
"resizable": true,
"fullscreen": false,
"center": true{{#if useCustomTitlebar}},
"decorations": false{{/if}}
}
],
"security": {
"csp": null
}{{#if enableSystemTray}},
"trayIcon": {
"iconPath": "icons/icon.png",
"iconAsTemplate": true
}{{/if}}
},
"bundle": {
"active": true,
"targets": "all",
"icon": [
"icons/32x32.png",
"icons/128x128.png",
"icons/128x128@2x.png",
"icons/icon.icns",
"icons/icon.ico"
],
"category": "Utility",
"shortDescription": "{{description}}",
"longDescription": "{{description}}",
"copyright": "Copyright © 2024",
"windows": {
"wix": null,
"nsis": {
"installMode": "currentUser"
}
},
"macOS": {
"minimumSystemVersion": "10.15",
"signingIdentity": null,
"providerShortName": null
},
"linux": {
"appimage": {
"bundleMediaFramework": false
}
}
}{{#if enableAutoUpdater}},
"plugins": {
"updater": {
"endpoints": [
"https://releases.example.com/{{projectName}}/\{{{{target}}}}/\{{{{arch}}}}/\{{{{current_version}}}}"
],
"pubkey": ""
}
}{{/if}}
}