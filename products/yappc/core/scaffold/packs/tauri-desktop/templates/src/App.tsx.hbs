import { useState, useEffect } from "react";
import { useTauriGreet, useTauriInfo } from "./hooks/useTauri";
{{#if useCustomTitlebar}}
import { TitleBar } from "./components/TitleBar";
{{/if}}

function App() {
const [name, setName] = useState("");
const { greet, greeting, isLoading: isGreeting } = useTauriGreet();
const { info, fetchInfo, isLoading: isLoadingInfo } = useTauriInfo();

useEffect(() => {
fetchInfo();
}, [fetchInfo]);

const handleSubmit = async (e: React.FormEvent) => {
e.preventDefault();
await greet(name);
};

return (
<div className="app-container">
    {{#if useCustomTitlebar}}
    <TitleBar title="{{displayName}}" />
    {{/if}}

    <main className="main-content">
        <header className="app-header">
            <h1>Welcome to {{displayName}}</h1>
            <p className="subtitle">Built with Tauri + React + TypeScript</p>
        </header>

        <section className="greeting-section">
            <form onSubmit={handleSubmit} className="greeting-form">
                <input type="text" value={name} onChange={(e)=> setName(e.target.value)}
                placeholder="Enter your name..."
                className="input"
                />
                <button type="submit" className="button" disabled={isGreeting}>
                    {isGreeting ? "Loading..." : "Greet"}
                </button>
            </form>

            {greeting && (
            <p className="greeting-result">{greeting}</p>
            )}
        </section>

        <section className="info-section">
            <h2>System Information</h2>
            {isLoadingInfo ? (
            <p>Loading system info...</p>
            ) : info ? (
            <div className="info-grid">
                <div className="info-item">
                    <span className="label">App Version:</span>
                    <span className="value">{info.appVersion}</span>
                </div>
                <div className="info-item">
                    <span className="label">Platform:</span>
                    <span className="value">{info.platform}</span>
                </div>
                <div className="info-item">
                    <span className="label">Architecture:</span>
                    <span className="value">{info.arch}</span>
                </div>
                <div className="info-item">
                    <span className="label">Tauri Version:</span>
                    <span className="value">{info.tauriVersion}</span>
                </div>
            </div>
            ) : null}
        </section>

        <footer className="app-footer">
            <p>
                <a href="https://tauri.app" target="_blank" rel="noreferrer">
                    Tauri Docs
                </a>
                {" | "}
                <a href="https://react.dev" target="_blank" rel="noreferrer">
                    React Docs
                </a>
            </p>
        </footer>
    </main>
</div>
);
}

export default App;