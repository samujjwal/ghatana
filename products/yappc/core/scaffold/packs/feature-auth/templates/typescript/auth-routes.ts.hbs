        const user = await createUser({ email, passwordHash, name });

        const tokens = generateTokenPair(user.id, user.email, user.roles);

        return reply.status(201).send({
        accessToken: tokens.accessToken,
        refreshToken: tokens.refreshToken,
        tokenType: 'Bearer',
        expiresIn: 86400,
        });
        });

        fastify.post<{ Body: { refreshToken: string } }>('/auth/refresh', async (request, reply) => {
            const { refreshToken } = request.body;

            try {
            const payload = verifyToken(refreshToken);

            if (payload.type !== 'refresh') {
            return reply.status(401).send({ error: 'Invalid token type' });
            }

            // TODO: Fetch user roles from database
            const tokens = generateTokenPair(payload.sub, payload.email, ['USER']);

            return reply.send({
            accessToken: tokens.accessToken,
            refreshToken: tokens.refreshToken,
            tokenType: 'Bearer',
            expiresIn: 86400,
            });
            } catch {
            return reply.status(401).send({ error: 'Invalid refresh token' });
            }
            });

            fastify.post('/auth/logout', { preHandler: [fastify.authenticate] }, async (request, reply) => {
            // In stateless JWT, logout is handled client-side
            // For token blacklisting, add token to a blacklist store
            return reply.send({ message: 'Logged out successfully' });
            });
            }

            // Placeholder functions - replace with actual database operations
            async function findUserByEmail(_email: string) {
            return null; // Replace with database lookup
            }

            async function createUser(_data: { email: string; passwordHash: string; name: string }) {
            return { id: 'user-id', email: _data.email, roles: ['USER'] }; // Replace with database insert
            }