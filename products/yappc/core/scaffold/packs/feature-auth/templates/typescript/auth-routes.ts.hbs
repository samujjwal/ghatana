import type { FastifyInstance } from 'fastify';
import bcrypt from 'bcrypt';
import { generateTokenPair, verifyToken } from '../services/jwt';
import type { LoginRequest, RegisterRequest, TokenResponse } from '../types/auth';

export default async function authRoutes(fastify: FastifyInstance) {
fastify.post<{ Body: LoginRequest }>('/auth/login', async (request, reply) => {
    const { email, password } = request.body;

    // TODO: Replace with actual user lookup from database
    const user = await findUserByEmail(email);

    if (!user) {
    return reply.status(401).send({ error: 'Invalid credentials' });
    }

    const isValidPassword = await bcrypt.compare(password, user.passwordHash);

    if (!isValidPassword) {
    return reply.status(401).send({ error: 'Invalid credentials' });
    }

    const tokens = generateTokenPair(user.id, user.email, user.roles);

    const response: TokenResponse = {
    accessToken: tokens.accessToken,
    refreshToken: tokens.refreshToken,
    tokenType: 'Bearer',
    expiresIn: 86400, // 24 hours
    };

    return reply.send(response);
    });

    fastify.post<{ Body: RegisterRequest }>('/auth/register', async (request, reply) => {
        const { email, password, name } = request.body;

        // TODO: Replace with actual user creation in database
        const existingUser = await findUserByEmail(email);

        if (existingUser) {
        return reply.status(409).send({ error: 'Email already registered' });
        }

