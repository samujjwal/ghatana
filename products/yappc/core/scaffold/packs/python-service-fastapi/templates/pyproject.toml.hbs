[project]
name = "{{projectName}}"
version = "0.1.0"
description = "{{description}}"
requires-python = "{{pythonVersion}}"
dependencies = [
"fastapi>=0.104.0",
"uvicorn[standard]>=0.24.0",
"pydantic>=2.5.0",
"pydantic-settings>=2.1.0",
{{#if enableMetrics}}
"prometheus-fastapi-instrumentator>=6.1.0",
{{/if}}
]

[project.optional-dependencies]
dev = [
"pytest>=7.4.0",
"pytest-asyncio>=0.21.0",
"httpx>=0.25.0",
{{#if features.enableLinting}}
"ruff>=0.1.0",
{{/if}}
{{#if features.enableTypeChecking}}
"mypy>=1.7.0",
{{/if}}
]

{{#if buildTool "uv"}}
[tool.uv]
dev-dependencies = [
"pytest>=7.4.0",
"pytest-asyncio>=0.21.0",
]
{{/if}}

{{#if features.enableLinting}}
[tool.ruff]
line-length = 100
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W"]
ignore = []
{{/if}}

{{#if features.enableTypeChecking}}
[tool.mypy]
python_version = "3.11"
strict = true
warn_return_any = true
warn_unused_configs = true
{{/if}}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"