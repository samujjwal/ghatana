"""Health check endpoints."""
from fastapi import APIRouter

router = APIRouter()


@router.get("/")
async def health_check():
"""Health check endpoint."""
return {
"status": "healthy",
"service": "{{projectName}}"
}


@router.get("/ready")
async def readiness_check():
"""Readiness check endpoint."""
return {"status": "ready"}


@router.get("/live")
async def liveness_check():
"""Liveness check endpoint."""
return {"status": "alive"}