use actix_web::{web, HttpResponse, Responder};
use serde_json::json;

pub fn configure(cfg: &mut web::ServiceConfig) {
cfg.service(
web::scope("/api/v1")
.route("/hello", web::get().to(hello)),
);
}

async fn hello() -> impl Responder {
HttpResponse::Ok().json(json!({
"message": "Hello from {{projectName}}!"
}))
}