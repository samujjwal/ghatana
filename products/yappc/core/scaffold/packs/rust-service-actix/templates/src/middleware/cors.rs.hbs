use actix_cors::Cors;
use actix_web::http;

pub fn cors_middleware() -> Cors {
Cors::default()
.allowed_origin_fn(|_origin, _req_head| true)
.allowed_methods(vec!["GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"])
.allowed_headers(vec![
http::header::AUTHORIZATION,
http::header::ACCEPT,
http::header::CONTENT_TYPE,
])
.max_age(3600)
}