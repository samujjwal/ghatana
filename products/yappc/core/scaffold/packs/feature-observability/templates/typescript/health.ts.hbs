export interface HealthCheck {
name: string;
check: () => Promise<HealthCheckResult>;
    }

    export interface HealthCheckResult {
    status: 'healthy' | 'unhealthy' | 'degraded';
    message?: string;
    details?: Record<string, unknown>;
        }

        export interface HealthStatus {
        status: 'healthy' | 'unhealthy' | 'degraded';
        service: string;
        timestamp: string;
        checks: Record<string, HealthCheckResult>;
            }

            const healthChecks: HealthCheck[] = [];

            // Register a health check
            export function registerHealthCheck(check: HealthCheck): void {
            healthChecks.push(check);
            }

            // Run all health checks
            export async function runHealthChecks(): Promise<HealthStatus> {
                const results: Record<string, HealthCheckResult> = {};
                    let overallStatus: 'healthy' | 'unhealthy' | 'degraded' = 'healthy';

                    for (const check of healthChecks) {
                    try {
                    results[check.name] = await check.check();

                    if (results[check.name].status === 'unhealthy') {
                    overallStatus = 'unhealthy';
                    } else if (results[check.name].status === 'degraded' && overallStatus !== 'unhealthy') {
                    overallStatus = 'degraded';
                    }
                    } catch (error) {
                    results[check.name] = {
                    status: 'unhealthy',
                    message: error instanceof Error ? error.message : 'Unknown error',
                    };
                    overallStatus = 'unhealthy';
                    }
                    }

                    return {
                    status: overallStatus,
                    service: '{{serviceName}}',
                    timestamp: new Date().toISOString(),
                    checks: results,
                    };
                    }

                    // Liveness check - basic check if service is running
                    export async function livenessCheck(): Promise<HealthCheckResult> {
                        return {
                        status: 'healthy',
                        message: 'Service is running',
                        };
                        }

                        // Readiness check - checks if service is ready to receive traffic
                        export async function readinessCheck(): Promise<HealthStatus> {
                            return runHealthChecks();
                            }

                            // Default health check registration
                            registerHealthCheck({
                            name: 'memory',
                            check: async () => {
                            const used = process.memoryUsage();
                            const heapUsedMB = Math.round(used.heapUsed / 1024 / 1024);
                            const heapTotalMB = Math.round(used.heapTotal / 1024 / 1024);
                            const ratio = used.heapUsed / used.heapTotal;

                            return {
                            status: ratio > 0.9 ? 'degraded' : 'healthy',
                            message: `Heap: ${heapUsedMB}MB / ${heapTotalMB}MB`,
                            details: {
                            heapUsed: heapUsedMB,
                            heapTotal: heapTotalMB,
                            ratio: Math.round(ratio * 100),
                            },
                            };
                            },
                            });