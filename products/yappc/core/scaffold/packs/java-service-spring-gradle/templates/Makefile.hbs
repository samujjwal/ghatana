# {{projectName}} Makefile
# Generated by YAPPC

.PHONY: all dev build test lint format clean docker help

.DEFAULT_GOAL := help

# Variables
SERVICE_NAME := {{projectName}}
PORT := {{port}}

## Development

dev: ## Start development server
./gradlew bootRun --args='--spring.profiles.active=dev'

## Build

build: ## Build the application
./gradlew build

build-jar: ## Build JAR file
./gradlew bootJar

## Testing

test: ## Run tests
./gradlew test

test-coverage: ## Run tests with coverage
./gradlew test jacocoTestReport

## Code Quality

lint: ## Run static analysis
./gradlew spotlessCheck

lint-fix: format ## Fix lint issues (alias for format)

format: ## Format code
./gradlew spotlessApply

check: lint test ## Run all checks

## Docker

docker-build: ## Build Docker image
docker build -t $(SERVICE_NAME) .

docker-run: ## Run Docker container
docker run -p $(PORT):$(PORT) \
-e SPRING_PROFILES_ACTIVE=prod \
-e DATABASE_URL=jdbc:postgresql://host.docker.internal:5432/$(SERVICE_NAME) \
$(SERVICE_NAME)

docker-compose-up: ## Start services with docker-compose
docker-compose up -d

docker-compose-down: ## Stop services
docker-compose down

docker-compose-logs: ## View logs
docker-compose logs -f

## Database

db-start: ## Start PostgreSQL with Docker
docker-compose up -d db

db-stop: ## Stop PostgreSQL
docker-compose stop db

## Cleanup

clean: ## Clean build artifacts
./gradlew clean
rm -rf build .gradle

## Help

help: ## Show this help
@echo "{{projectName}} - Available targets:"
@echo ""
@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf " \033[36m%-20s\033[0m
%s\n", $$1, $$2}'