{
    "id": "svelte-vite",
    "name": "Svelte with Vite",
    "description": "Svelte application with Vite build tool",
    "version": "1.0.0",
    "type": "application",
    "language": "javascript",
    "buildSystem": "npm",
    "requiredVariables": [
        "projectName"
    ],
    "optionalVariables": [
        "description",
        "author",
        "typescript"
    ],
    "defaults": {
        "typescript": "true"
    },
    "features": [],
    "dependencies": {
        "svelte": "^4.2.0"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^3.0.0",
        "vite": "^5.0.0"
    }
}