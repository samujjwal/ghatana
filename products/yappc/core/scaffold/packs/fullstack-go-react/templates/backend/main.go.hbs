package main

import (
"fmt"
"log"
"net/http"

"{{moduleName}}/backend/config"
"{{moduleName}}/backend/router"
)

func main() {
cfg := config.Load()
r := router.New()

addr := fmt.Sprintf(":%d", cfg.Port)
log.Printf("🚀 Server running at http://localhost%s", addr)

if err := http.ListenAndServe(addr, r); err != nil {
log.Fatal(err)
}
}