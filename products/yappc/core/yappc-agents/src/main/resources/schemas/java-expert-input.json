{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yappc.ghatana.com/schemas/java-expert-input.json",
  "title": "Java Expert Input",
  "description": "Input schema for the Java Expert agent - provides code context and questions for analysis",
  "type": "object",
  "required": ["codeContext", "question"],
  "additionalProperties": false,
  
  "properties": {
    "codeContext": {
      "type": "string",
      "minLength": 10,
      "maxLength": 50000,
      "description": "The Java code to be analyzed",
      "examples": [
        "public class HelloWorld {\n    public static void main(String[] args) {\n        System.out.println(\"Hello, World!\");\n    }\n}"
      ]
    },
    
    "question": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500,
      "description": "The specific question about the code",
      "examples": [
        "Is this code thread-safe?",
        "How can I improve the performance of this method?",
        "Are there any security vulnerabilities?"
      ]
    },
    
    "projectMetadata": {
      "type": "object",
      "description": "Additional context about the project",
      "additionalProperties": true,
      "properties": {
        "languageVersion": {
          "type": "string",
          "description": "Java version being used",
          "examples": ["Java 17", "Java 21"]
        },
        "framework": {
          "type": "string",
          "description": "Primary framework used",
          "examples": ["Spring Boot", "Quarkus", "Micronaut"]
        },
        "buildTool": {
          "type": "string",
          "enum": ["Maven", "Gradle", "Ant"],
          "description": "Build tool used in the project"
        },
        "dependencies": {
          "type": "array",
          "description": "Key dependencies relevant to the analysis",
          "items": {
            "type": "string"
          }
        }
      }
    },
    
    "focusAreas": {
      "type": "array",
      "description": "Specific areas to focus the analysis on",
      "items": {
        "type": "string",
        "enum": [
          "performance",
          "security",
          "maintainability",
          "testability",
          "scalability",
          "best-practices",
          "design-patterns"
        ]
      },
      "default": ["best-practices"],
      "minItems": 1,
      "maxItems": 5
    },
    
    "outputFormat": {
      "type": "string",
      "enum": ["detailed", "summary", "checklist"],
      "default": "detailed",
      "description": "Preferred format for the response"
    }
  }
}
