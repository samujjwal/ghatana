{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yappc.ghatana.com/schemas/java-expert-output.json",
  "title": "Java Expert Output",
  "description": "Output schema for the Java Expert agent - analysis results and recommendations",
  "type": "object",
  "required": ["analysisId", "recommendation", "timestamp"],
  "additionalProperties": false,
  
  "properties": {
    "analysisId": {
      "type": "string",
      "description": "Unique identifier for this analysis",
      "pattern": "^[a-zA-Z0-9-_]{20,50}$"
    },
    
    "recommendation": {
      "type": "string",
      "minLength": 10,
      "description": "Main recommendation or summary from the analysis"
    },
    
    "suggestions": {
      "type": "array",
      "description": "List of specific improvement suggestions",
      "items": {
        "type": "object",
        "required": ["title", "description", "severity"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this suggestion"
          },
          "title": {
            "type": "string",
            "description": "Short title of the suggestion"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the suggestion"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"],
            "description": "Severity/importance level"
          },
          "category": {
            "type": "string",
            "enum": ["performance", "security", "maintainability", "testability", "scalability", "best-practices", "design-patterns"],
            "description": "Category of the suggestion"
          },
          "codeExample": {
            "type": "object",
            "description": "Code example showing the improvement",
            "properties": {
              "before": {
                "type": "string",
                "description": "Original code"
              },
              "after": {
                "type": "string",
                "description": "Improved code"
              },
              "language": {
                "type": "string",
                "default": "java"
              }
            }
          },
          "references": {
            "type": "array",
            "description": "Reference links or documentation",
            "items": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    },
    
    "metrics": {
      "type": "object",
      "description": "Analysis metrics and scores",
      "properties": {
        "complexityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Code complexity score (0-100, lower is better)"
        },
        "qualityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall code quality score (0-100, higher is better)"
        },
        "linesOfCode": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of lines of code analyzed"
        },
        "analysisDuration": {
          "type": "integer",
          "description": "Analysis duration in milliseconds"
        }
      }
    },
    
    "summary": {
      "type": "object",
      "description": "Executive summary of the analysis",
      "properties": {
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Positive aspects of the code"
        },
        "concerns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Areas of concern"
        },
        "overallAssessment": {
          "type": "string",
          "enum": ["excellent", "good", "needs-improvement", "requires-attention"],
          "description": "Overall quality assessment"
        }
      }
    },
    
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the analysis was performed"
    },
    
    "metadata": {
      "type": "object",
      "description": "Additional metadata about the analysis",
      "properties": {
        "model": {
          "type": "string",
          "description": "LLM model used for analysis"
        },
        "tokensUsed": {
          "type": "integer",
          "description": "Total tokens consumed"
        },
        "version": {
          "type": "string",
          "description": "Agent version used"
        }
      }
    }
  }
}
