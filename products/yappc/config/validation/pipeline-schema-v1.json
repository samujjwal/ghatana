{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.ai/schemas/yappc/pipeline-schema-v1.json",
  "title": "YAPPC Pipeline Schema",
  "description": "Schema for validating YAPPC AEP pipeline definitions",
  "version": "1.0.0",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "ghatana.aep/v1",
      "description": "API version for the pipeline"
    },
    "kind": {
      "type": "string",
      "const": "Pipeline",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Pipeline name (lowercase, hyphens only)"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Pipeline description"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true,
          "description": "Pipeline tags"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["inputs", "operators", "error_handling"],
      "properties": {
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "topic", "description"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "topic": {
                "type": "string",
                "pattern": "^[a-z0-9.-]+$"
              },
              "schema": {
                "type": "string",
                "pattern": "^[a-z0-9-]+-v\\d+$"
              },
              "description": {
                "type": "string",
                "minLength": 5
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "topic": {
                "type": "string",
                "pattern": "^[a-z0-9.-]+$"
              },
              "description": {
                "type": "string",
                "minLength": 5
              }
            }
          }
        },
        "operators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "type", "description"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9-]+$"
              },
              "type": {
                "type": "string",
                "enum": ["validator", "agent", "transformer", "router", "backpressure", "aggregator", "metrics", "agent-operator"]
              },
              "agent_id": {
                "type": "string",
                "pattern": "^agent\\.yappc\\.[a-zA-Z0-9-]+$"
              },
              "config": {
                "type": "object",
                "additionalProperties": true
              },
              "description": {
                "type": "string",
                "minLength": 5
              }
            },
            "oneOf": [
              {
                "properties": {
                  "type": { "const": "agent" }
                },
                "required": ["agent_id"]
              },
              {
                "properties": {
                  "type": { "const": "agent-operator" }
                },
                "required": ["agent_id"]
              },
              {
                "not": {
                  "properties": {
                    "type": { "enum": ["agent", "agent-operator"] }
                  }
                }
              }
            ]
          }
        },
        "error_handling": {
          "type": "object",
          "required": ["strategy"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["dead_letter", "circuit_breaker", "retry"]
            },
            "dead_letter_topic": {
              "type": "string",
              "pattern": "^[a-z0-9.-]+$"
            },
            "circuit_breaker": {
              "type": "object",
              "properties": {
                "failure_threshold": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100
                },
                "recovery_timeout_ms": {
                  "type": "integer",
                  "minimum": 1000
                },
                "half_open_max_calls": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "retry_policy": {
              "type": "object",
              "properties": {
                "max_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "backoff_ms": {
                  "type": "integer",
                  "minimum": 100
                },
                "max_backoff_ms": {
                  "type": "integer",
                  "minimum": 1000
                },
                "backoff_multiplier": {
                  "type": "number",
                  "minimum": 1.0,
                  "maximum": 5.0
                }
              }
            }
          }
        },
        "monitoring": {
          "type": "object",
          "properties": {
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "type", "description"],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["counter", "gauge", "histogram"]
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z0-9_]+$"
                    }
                  },
                  "description": {
                    "type": "string",
                    "minLength": 5
                  }
                }
              }
            },
            "alerts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "condition", "description"],
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "condition": {
                    "type": "string",
                    "minLength": 3
                  },
                  "description": {
                    "type": "string",
                    "minLength": 5
                  }
                }
              }
            }
          }
        },
        "dependencies": {
          "type": "object",
          "properties": {
            "services": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "schemas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "configs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
