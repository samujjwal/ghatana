{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghatana.ai/schemas/yappc/events/memory-events-events-v1.json",
  "title": "Memory Domain Events",
  "description": "Event schemas for the Memory domain agents in YAPPC",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "domainContext"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this domain event"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "memory-events.memory.stored",
        "memory-events.memory.retrieved",
        "memory-events.memory.expired",
        "memory-events.memory.consolidated",
        "memory-events.memory.redacted",
        "memory-events.episode.captured",
        "memory-events.pattern.learned",
        "memory-events.policy.synthesized"
      ],
      "description": "The type of Memory domain event"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the event occurred"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Correlation ID linking related events in a workflow"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier for multi-tenancy isolation"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "User who triggered or is associated with this event"
    },
    "agentId": {
      "type": "string",
      "pattern": "^agent\\.yappc\\.memory-events.*$",
      "description": "ID of the Memory domain agent emitting this event"
    },
    "domainContext": {
      "type": "object",
      "description": "Domain-specific context for Memory events",
      "required": [
        "domain",
        "operationId"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "const": "memory-events",
          "description": "Always 'memory-events' for this schema"
        },
        "operationId": {
          "type": "string",
          "format": "uuid",
          "description": "Unique ID for the domain operation"
        },
        "projectId": {
          "type": "string",
          "format": "uuid",
          "description": "Associated project ID"
        },
        "phase": {
          "type": "string",
          "description": "YAPPC lifecycle phase this event belongs to"
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload data",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "description": "Event metadata for tracing and observability",
      "properties": {
        "source": {
          "type": "string",
          "description": "Agent or system that emitted the event"
        },
        "version": {
          "type": "string",
          "default": "1.0.0"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Classification tags"
        }
      }
    }
  },
  "definitions": {
    "eventTypes": {
      "description": "All valid Memory domain event types",
      "enum": [
        "memory-events.memory.stored",
        "memory-events.memory.retrieved",
        "memory-events.memory.expired",
        "memory-events.memory.consolidated",
        "memory-events.memory.redacted",
        "memory-events.episode.captured",
        "memory-events.pattern.learned",
        "memory-events.policy.synthesized"
      ]
    }
  }
}
