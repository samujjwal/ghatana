{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Task Domain Definition",
    "type": "object",
    "required": [
        "domain",
        "tasks"
    ],
    "properties": {
        "domain": {
            "type": "object",
            "required": [
                "id",
                "name",
                "description",
                "order",
                "icon",
                "color",
                "agent_personas",
                "audit_artifacts",
                "inputs",
                "outputs"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "order": {
                    "type": "integer"
                },
                "icon": {
                    "type": "string"
                },
                "color": {
                    "type": "string"
                },
                "agent_personas": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "audit_artifacts": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "inputs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "outputs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "tasks": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "description"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "inputs": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "outputs": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "audit_artifacts": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "required_capabilities": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}