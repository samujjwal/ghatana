# =============================================================================
# YAPPC Docker Compose Environment Variables — TEMPLATE
# =============================================================================
# Copy to .env and set real values. NEVER commit the .env file itself.
# =============================================================================

# --- Database ---
POSTGRES_USER=ghatana
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=yappc
DATABASE_URL=jdbc:postgresql://ghatana-postgres:5432/yappc

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# --- AI ---
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434

# --- Tracing ---
JAEGER_ENDPOINT=http://jaeger:14250

# --- JVM ---
JVM_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=200
