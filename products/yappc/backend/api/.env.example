# YAPPC Backend API - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=jdbc:postgresql://localhost:5432/yappc
DATABASE_USERNAME=yappc
DATABASE_PASSWORD=your_secure_password_here

# ============================================================================
# LLM API Keys
# ============================================================================

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Optional: Azure OpenAI Configuration
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ============================================================================
# LLM Configuration
# ============================================================================

# Default LLM provider (openai, anthropic, azure)
LLM_DEFAULT_PROVIDER=openai

# Default model for each provider
LLM_OPENAI_MODEL=gpt-4
LLM_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# LLM request timeout (milliseconds)
LLM_TIMEOUT_MS=60000

# LLM retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_MS=1000

# Circuit breaker configuration
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RESET_MS=60000

# Response cache TTL (milliseconds)
LLM_CACHE_TTL_MS=3600000

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ============================================================================
# Observability
# ============================================================================

# Enable LLM cost tracking
LLM_OBSERVABILITY_ENABLED=true

# Daily budget alert threshold (USD)
LLM_DAILY_BUDGET_THRESHOLD=100.0

# ============================================================================
# Security
# ============================================================================

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here-change-in-production

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Feature Flags
# ============================================================================

# Enable AI features
AI_FEATURES_ENABLED=true

# Enable A/B testing for prompts
AI_AB_TESTING_ENABLED=true

# ============================================================================
# Development
# ============================================================================

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Enable debug logging for LLM requests
LLM_DEBUG_LOGGING=false
