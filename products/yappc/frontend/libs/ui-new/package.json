{
  "name": "@yappc/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "YAPPC UI library - components, chat, notifications",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
