{
  "name": "@yappc/ui",
  "version": "1.0.0",
  "description": "YAPPC UI Components - Consolidated UI and base-ui components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./base": {
      "import": "./dist/base/index.mjs",
      "require": "./dist/base/index.js",
      "types": "./dist/base/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./styles": {
      "import": "./dist/styles.css",
      "require": "./dist/styles.css"
    },
    "./theme": {
      "import": "./dist/components/theme/index.mjs",
      "require": "./dist/components/theme/index.js",
      "types": "./dist/components/theme/index.d.ts"
    },
    "./base-ui": {
      "import": "./dist/components/base-ui/index.mjs",
      "require": "./dist/components/base-ui/index.js",
      "types": "./dist/components/base-ui/index.d.ts"
    },
    "./development-ui": {
      "import": "./dist/components/development-ui/index.mjs",
      "require": "./dist/components/development-ui/index.js",
      "types": "./dist/components/development-ui/index.d.ts"
    },
    "./initialization-ui": {
      "import": "./dist/components/initialization-ui/index.mjs",
      "require": "./dist/components/initialization-ui/index.js",
      "types": "./dist/components/initialization-ui/index.d.ts"
    },
    "./navigation-ui": {
      "import": "./dist/components/navigation-ui/index.mjs",
      "require": "./dist/components/navigation-ui/index.js",
      "types": "./dist/components/navigation-ui/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "build:styles": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --minify",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ghatana/platform-utils": "workspace:*",
    "@yappc/core": "workspace:*",
    "@yappc/state": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jotai": "^2.19.1",
    "lucide-react": "^1.7.0",
    "react-aria": "^3.47.0",
    "react-router-dom": "^7.14.0",
    "react-stately": "^3.45.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@storybook/test": "^8.6.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghatana/ghatana.git",
    "directory": "products/yappc/frontend/libs/yappc-ui"
  },
  "keywords": [
    "yappc",
    "ui",
    "components",
    "react",
    "typescript",
    "tailwindcss"
  ],
  "author": "Ghatana AI Platform",
  "license": "Apache-2.0"
}
