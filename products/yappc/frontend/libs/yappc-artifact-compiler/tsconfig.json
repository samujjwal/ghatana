{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "allowImportingTsExtensions": false,
    "paths": {
      "@ghatana/ui-builder": ["../../../../platform/typescript/ui-builder/dist/index.d.ts"],
      "@ghatana/ui-builder/*": ["../../../../platform/typescript/ui-builder/dist/*"],
      "@ghatana/ds-schema": ["../../../../platform/typescript/ds-schema/dist/index.d.ts"],
      "@ghatana/ds-schema/*": ["../../../../platform/typescript/ds-schema/dist/*"]
    },
    "outDir": "./dist",
    "rootDir": "./src",
    "declarationDir": "./dist",
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "noEmit": false,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "__tests__"
  ]
}
