{
  "name": "@yappc/canvas",
  "version": "1.0.0",
  "description": "World-class, production-ready Canvas library for diagramming applications",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts",
    "./components": "./src/components/index.ts",
