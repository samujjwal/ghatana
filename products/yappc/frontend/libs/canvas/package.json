    "./ai/layout": "./src/ai/PredictiveLayout.ts",
    "./config/personas": "./src/config/personaConfigs.ts",
    "./config/z-index": "./src/config/z-index.ts",
    "./config/phase-colors": "./src/config/phase-colors.ts",
