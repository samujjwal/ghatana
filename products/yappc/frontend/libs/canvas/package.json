  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@ghatana/canvas": "workspace:*",
    "@yappc/core": "workspace:*",
    "jotai": "^2.17.0",
    "@xyflow/react": "^12.10.0",
    "@yappc/ui": "workspace:*",
    "@yappc/ai": "workspace:*",
    "@ghatana/design-system": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "js-yaml": "^4.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
