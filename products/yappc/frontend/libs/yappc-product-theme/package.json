{
  "name": "@yappc/product-theme",
  "version": "1.0.0",
  "description": "YAPPC product-specific theme presets, lifecycle semantic tokens, and MUI bridge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lifecycle-presets": {
      "import": "./dist/lifecycle-presets.js",
      "types": "./dist/lifecycle-presets.d.ts"
    },
    "./mui-bridge": {
      "import": "./dist/mui-bridge.js",
      "types": "./dist/mui-bridge.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/tokens": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@yappc/ui": "workspace:*"
  },
  "peerDependencies": {
    "@mui/material": "^9.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
