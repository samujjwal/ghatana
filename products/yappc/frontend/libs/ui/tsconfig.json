{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../../dist/out-tsc/ui",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/ui.tsbuildinfo",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@yappc/state": [
        "../../libs/state/src"
      ],
      "@yappc/state/*": [
        "../../libs/state/src/*"
      ],
      "@yappc/shortcuts": [
        "../../libs/shortcuts/src"
      ],
      "@yappc/shortcuts/*": [
        "../../libs/shortcuts/src/*"
      ],
      "@yappc/base-ui": [
        "../../libs/base-ui/src"
      ],
      "@yappc/base-ui/*": [
        "../../libs/base-ui/src/*"
      ],
      "@yappc/theme": [
        "../../libs/theme/src"
      ],
      "@yappc/theme/*": [
        "../../libs/theme/src/*"
      ],
      "@yappc/core/types": [
        "../../libs/types/src"
      ],
      "@yappc/core/types/*": [
        "../../libs/types/src/*"
      ],
      "@ghatana/yappc-types/*": [
        "../../libs/types/src/*"
      ],
      "@ghatana/yappc-types/devsecops/*": [
        "../../libs/types/src/devsecops/*"
      ],
      "@ghatana/yappc-state": [
        "../../libs/state/src"
      ],
      "@ghatana/yappc-state/*": [
        "../../libs/state/src/*"
      ],
      "@ghatana/yappc-store": [
        "../../libs/state/src"
      ],
      "@ghatana/yappc-store/*": [
        "../../libs/state/src/*"
      ],
      "@ghatana/canvas": [
        "../canvas/src/index.ts"
      ],
      "@ghatana/canvas/*": [
        "../canvas/src/*"
      ],
      "@yappc/core/api": [
        "../../libs/api/src"
      ],
      "@yappc/core/api/*": [
        "../../libs/api/src/*"
      ],
      "@ghatana/yappc-api/*": [
        "../../libs/api/src/*"
      ]
    },
    "types": [
      "node",
      "jest",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.*",
    "**/*.stories.*",
    "src/canvas-atoms.ts",
    "src/test"
  ],
  "references": []
}
