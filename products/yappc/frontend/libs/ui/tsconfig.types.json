{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "composite": false,
    "incremental": false,
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "rootDir": "./src",
    "tsBuildInfoFile": "../../node_modules/.cache/tsbuildinfo/ui.types.tsbuildinfo",
    "isolatedModules": false,
    "noEmitOnError": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {},
    "types": [],
    "typeRoots": [
      "./types",
      "../../node_modules/@types"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src/components/DevSecOps/index.ts",
    "types/**/*"
  ],
  "references": [],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__stories__/**",
    "**/*.stories.*",
    "src/stories/**",
    "src/test/**",
    "src/test-utils/**",
    "src/ux/index-old.ts"
  ]
}