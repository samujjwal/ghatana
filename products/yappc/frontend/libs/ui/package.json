    "./state": "./src/state.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/*": "./src/hooks/*",
    "./traceability": "./src/traceability/index.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.90.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.17",
    "@floating-ui/react-dom": "^2.1.7",
    "@yappc/collab": "workspace:*",
    "@yappc/state": "workspace:*",
    "@mui/material": "^7.3.0",
    "framer-motion": "^12.35.0",
    "jotai": "^2.17.0",
    "jotai-devtools": "^0.13.0",
    "react-router-dom": "^7.5.0",
    "zod": "^4.3.6",
    "@yappc/canvas": "workspace:*",
    "@yappc/ui": "workspace:*",
    "@yappc/ai": "workspace:*"
  },
  "scripts": {
