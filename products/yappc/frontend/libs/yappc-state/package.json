{
  "name": "@yappc/state",
  "version": "1.0.0",
  "description": "YAPPC State Management - Store and hooks for app state",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.mjs",
      "require": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./config-hooks": {
      "import": "./dist/store/config-hooks/index.mjs",
      "require": "./dist/store/config-hooks/index.js",
      "types": "./dist/store/config-hooks/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@yappc/core": "workspace:*",
    "jotai": "^2.19.1",
    "nanostores": "^1.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghatana/ghatana.git",
    "directory": "products/yappc/frontend/libs/yappc-state"
  },
  "keywords": [
    "yappc",
    "state",
    "store",
    "hooks",
    "react"
  ]
}
