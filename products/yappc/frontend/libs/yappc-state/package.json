{
  "name": "yappc-state",
  "version": "1.0.0",
  "description": "YAPPC State Management - Store and hooks for app state",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./config-hooks": {
      "import": "./dist/store/config-hooks/index.js",
      "types": "./dist/store/config-hooks/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@ghatana/state": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "yappc-core": "workspace:*",
    "jotai": "^2.20.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghatana/ghatana.git",
    "directory": "products/yappc/frontend/libs/yappc-state"
  },
  "keywords": [
    "yappc",
    "state",
    "store",
    "hooks",
    "react"
  ]
}
