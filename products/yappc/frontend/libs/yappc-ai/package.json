{
  "name": "yappc-ai",
  "version": "1.0.0",
  "description": "YAPPC AI Components - Consolidated AI and chat functionality",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./chat": {
      "import": "./dist/chat/index.js",
      "types": "./dist/chat/index.d.ts"
    },
    "./messaging": {
      "import": "./dist/messaging/index.js",
      "types": "./dist/messaging/index.d.ts"
    },
    "./notifications": {
      "import": "./dist/notifications/index.js",
      "types": "./dist/notifications/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "yappc-core": "workspace:*",
    "yappc-ui": "workspace*",
    "@ghatana/design-system": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "@ghatana/platform-events": "workspace:*",
    "openai": "^6.34.0",
    "ai": "^6.0.158",
    "nanostores": "^1.2.0",
    "zod": "^4.3.6",
    "lucide-react": "^1.8.0",
    "clsx": "^2.1.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghatana/ghatana.git",
    "directory": "products/yappc/frontend/libs/yappc-ai"
  },
  "keywords": [
    "yappc",
    "ai",
    "chat",
    "openai",
    "react",
    "typescript"
  ],
  "author": "Ghatana AI Platform",
  "license": "Apache-2.0"
}
