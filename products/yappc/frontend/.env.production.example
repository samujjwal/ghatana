# YAPPC Production Environment Configuration
# Copy this file to .env.production and fill in the values

# =============================================================================
# API Configuration
# =============================================================================

# GraphQL API endpoint
VITE_GRAPHQL_ENDPOINT=https://api.yappc.com/graphql

# REST API endpoint
VITE_API_ENDPOINT=https://api.yappc.com

# WebSocket endpoint
VITE_WS_ENDPOINT=wss://api.yappc.com/ws

# =============================================================================
# Authentication
# =============================================================================

# OAuth Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GITHUB_CLIENT_ID=your-github-client-id
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id

# OAuth Redirect URIs
VITE_OAUTH_REDIRECT_URI=https://app.yappc.com/auth/callback

# =============================================================================
# Feature Flags
# =============================================================================

# Enable real-time collaboration
VITE_ENABLE_REALTIME=true

# Enable canvas collaboration
VITE_ENABLE_CANVAS_COLLAB=true

# Enable chat
VITE_ENABLE_CHAT=true

# Enable notifications
VITE_ENABLE_NOTIFICATIONS=true

# =============================================================================
# Monitoring & Analytics
# =============================================================================

# Sentry DSN for error tracking
VITE_SENTRY_DSN=https://your-sentry-dsn

# Google Analytics ID
VITE_GA_ID=G-XXXXXXXXXX

# LogRocket App ID
VITE_LOGROCKET_APP_ID=your-app-id

# =============================================================================
# Performance
# =============================================================================

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Performance budget (milliseconds)
VITE_PERFORMANCE_BUDGET_FCP=1800
VITE_PERFORMANCE_BUDGET_LCP=2500
VITE_PERFORMANCE_BUDGET_TTI=3800

# =============================================================================
# Storage
# =============================================================================

# IndexedDB database name
VITE_IDB_NAME=yappc-production

# Cache TTL (milliseconds)
VITE_CACHE_TTL=300000

# =============================================================================
# Build Configuration
# =============================================================================

# Environment
NODE_ENV=production

# Build mode
VITE_MODE=production

# Enable source maps
VITE_SOURCE_MAPS=false

# Enable bundle analysis
VITE_ANALYZE_BUNDLE=false

# =============================================================================
# Security
# =============================================================================

# Content Security Policy
VITE_CSP_ENABLED=true

# HTTPS only
VITE_HTTPS_ONLY=true

# Secure cookies
VITE_SECURE_COOKIES=true

# =============================================================================
# Deployment
# =============================================================================

# Deployment environment
VITE_DEPLOYMENT_ENV=production

# Version
VITE_APP_VERSION=1.0.0

# Build timestamp
VITE_BUILD_TIMESTAMP=auto

# Git commit hash
VITE_GIT_COMMIT=auto
