# YAPPC Development Environment Configuration
# Copy this file to .env.development and fill in the values

# =============================================================================
# API Configuration
# =============================================================================

# GraphQL API endpoint
VITE_GRAPHQL_ENDPOINT=http://localhost:8080/graphql

# REST API endpoint
VITE_API_ENDPOINT=http://localhost:8080

# WebSocket endpoint
VITE_WS_ENDPOINT=ws://localhost:8080/ws

# =============================================================================
# Authentication
# =============================================================================

# OAuth Client IDs (development)
VITE_GOOGLE_CLIENT_ID=your-dev-google-client-id
VITE_GITHUB_CLIENT_ID=your-dev-github-client-id
VITE_MICROSOFT_CLIENT_ID=your-dev-microsoft-client-id

# OAuth Redirect URIs
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# =============================================================================
# Feature Flags
# =============================================================================

# Enable real-time collaboration
VITE_ENABLE_REALTIME=true

# Enable canvas collaboration
VITE_ENABLE_CANVAS_COLLAB=true

# Enable chat
VITE_ENABLE_CHAT=true

# Enable notifications
VITE_ENABLE_NOTIFICATIONS=true

# =============================================================================
# Development Tools
# =============================================================================

# Enable React DevTools
VITE_ENABLE_REACT_DEVTOOLS=true

# Enable Redux DevTools
VITE_ENABLE_REDUX_DEVTOOLS=true

# Enable debug logging
VITE_DEBUG=true

# Enable hot module replacement
VITE_HMR=true

# =============================================================================
# Monitoring & Analytics
# =============================================================================

# Disable in development
VITE_SENTRY_DSN=
VITE_GA_ID=
VITE_LOGROCKET_APP_ID=

# =============================================================================
# Performance
# =============================================================================

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Relaxed performance budgets for development
VITE_PERFORMANCE_BUDGET_FCP=3000
VITE_PERFORMANCE_BUDGET_LCP=4000
VITE_PERFORMANCE_BUDGET_TTI=5000

# =============================================================================
# Storage
# =============================================================================

# IndexedDB database name
VITE_IDB_NAME=yappc-development

# Cache TTL (milliseconds) - shorter for development
VITE_CACHE_TTL=60000

# =============================================================================
# Build Configuration
# =============================================================================

# Environment
NODE_ENV=development

# Build mode
VITE_MODE=development

# Enable source maps
VITE_SOURCE_MAPS=true

# Enable bundle analysis
VITE_ANALYZE_BUNDLE=false

# =============================================================================
# Security
# =============================================================================

# Relaxed for development
VITE_CSP_ENABLED=false
VITE_HTTPS_ONLY=false
VITE_SECURE_COOKIES=false

# =============================================================================
# Deployment
# =============================================================================

# Deployment environment
VITE_DEPLOYMENT_ENV=development

# Version
VITE_APP_VERSION=0.0.0-dev

# Build timestamp
VITE_BUILD_TIMESTAMP=auto

# Git commit hash
VITE_GIT_COMMIT=auto
