{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "apps/**/src/**/*",
    "libs/**/src/**/*",
    "packages/**/src/**/*",
    "apps/**/src/generated/**/*",
    "libs/**/src/generated/**/*",
    "types/**/*",
    "vitest.config.*",
    "vitest.*.config.*",
    "vitest.setup.*"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.stories.*",
    "**/__tests__/**",
    "**/test/**",
    "**/test-utils/**",
    "**/__examples__/**",
    "**/*.generated.*",
    "**/*.config.d.ts"
  ]
}
