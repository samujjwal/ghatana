apps/mobile-cap/ios/
apps/mobile-cap/dist/

# Test results
test-results/
playwright-report/
playwright/.cache/

# Compiled TypeScript config outputs (should never be committed)
*.config.d.ts
*.config.d.ts.map
*.config.js.map
*.setup.d.ts
*.setup.d.ts.map
*.setup.js
*.setup.js.map

# Debug and diagnostic artifacts
debug-*.js
check-*.json
check-*.stderr

# Report artifacts
eslint-report.*
eslint-top30.*
lint-target.json
lint.json
print-config.err
.jscpd-report.html/

# Recommendation: don't keep generated declarations, maps, or legacy jsx inside source folders.
# If these files are tracked already, remove them from git and commit the deletion instead
# of relying on .gitignore.
**/src/**/*.d.ts
**/src/**/*.map
**/src/**/*.jsx
