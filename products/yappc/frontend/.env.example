# =============================================================================
# CANVAS APPLICATION - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development
# Never commit .env.local to version control
# See docs-site/docs/deployment/environment-variables.md for full documentation
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:5173
NEXT_PUBLIC_API_URL=http://localhost:3000/api
PORT=5173

# =============================================================================
# AEP (Agentic Event Processor) Configuration
# =============================================================================
# 
# YAPPC supports two modes for using AEP:
# 
# 1. LIBRARY MODE (Default for Development)
#    - AEP runs as an in-process library
#    - No external service needed
#    - Perfect for rapid development
#    - Automatically used when NODE_ENV=development
#
# 2. SERVICE MODE (For Staging/Production)
#    - AEP runs as an external microservice
#    - Requires AEP service to be running
#    - Production-ready distributed setup
#    - Automatically used when NODE_ENV=staging|production
#
# To override the default mode for your environment, set AEP_MODE explicitly:
# AEP_MODE=library   # Force library mode (all environments)
# AEP_MODE=service   # Force service mode (all environments)

# AEP Service Configuration (only used in SERVICE mode)
# AEP_SERVICE_HOST=localhost
# AEP_SERVICE_PORT=7106

# AEP Library Configuration (only used in LIBRARY mode)
# AEP_LIBRARY_DEBUG=true
# AEP_LIBRARY_CACHE_SIZE=1000

# AEP Global Settings (all modes)
# AEP_METRICS_ENABLED=false
# AEP_LOG_LEVEL=debug
# AEP_TRACING_ENABLED=false

# For more details, see .env.aep-mode

# =============================================================================
# End of AEP Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# AI / LLM Configuration
# -----------------------------------------------------------------------------
# Default provider: 'openai', 'anthropic', or 'local' (Ollama)
# For dev/test, use 'local' to avoid API costs
DEFAULT_LLM_PROVIDER=local

# Ollama (Local LLM - Recommended for Dev/Test)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Start: ollama serve
# Pull models: ollama pull llama3.2:3b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (Production - Paid API)
# Only required if DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Production Alternative - Paid API)
# Only required if DEFAULT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI General Settings
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_EMBEDDING_BATCH_SIZE=50
EMBEDDING_PIPELINE_INTERVAL=900000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://canvas:dev123@localhost:5432/canvas_dev
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=false
DATABASE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Redis (Caching & Real-Time Features)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_TTL_DEFAULT=3600

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_org_here
SENTRY_PROJECT=canvas-web
SENTRY_AUTH_TOKEN=your_auth_token_here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# Datadog (Optional Monitoring)
# -----------------------------------------------------------------------------
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_APP_KEY=your-datadog-app-key
# DATADOG_SITE=datadoghq.com

# -----------------------------------------------------------------------------
# GrowthBook (Feature Flags)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-your-client-key-here
GROWTHBOOK_API_HOST=https://api.growthbook.io
GROWTHBOOK_SECRET_KEY=secret_dev_your-secret-key

# Feature Flags (fallback if GrowthBook unavailable)
NEXT_PUBLIC_FEATURE_FLAGS={"canvas_collaboration":true,"canvas_export":true,"canvas_history":true,"canvas_gestures":true,"canvas_minimap":true}

# -----------------------------------------------------------------------------
# Canvas Deployment System
# -----------------------------------------------------------------------------
CANVAS_DEPLOYMENT_ENABLED=true
CANVAS_BLUE_GREEN_ENABLED=true
CANVAS_HEALTH_CHECK_INTERVAL=30000
CANVAS_HEALTH_CHECK_TIMEOUT=5000
CANVAS_HEALTH_CHECK_RETRIES=3
CANVAS_ROLLBACK_ENABLED=true
CANVAS_ROLLBACK_ERROR_THRESHOLD=5
CANVAS_TRAFFIC_SHIFT_DURATION=300000

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
AUTH_SECRET=your-very-long-random-secret-string-here
AUTH_PROVIDER=local
# OKTA_CLIENT_ID=your-okta-client-id
# OKTA_CLIENT_SECRET=your-okta-client-secret
# OKTA_DOMAIN=yourcompany.okta.com

# -----------------------------------------------------------------------------
# AWS Services (S3 for exports, CloudWatch, etc.)
# -----------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_S3_BUCKET_EXPORTS=canvas-exports-dev
# AWS_S3_BUCKET_BACKUPS=canvas-backups-dev

# -----------------------------------------------------------------------------
# PagerDuty (Incident Management)
# -----------------------------------------------------------------------------
# PAGERDUTY_API_KEY=your-pagerduty-api-key
# PAGERDUTY_SERVICE_ID=PXXXXXX

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SESSION_SECRET=your-session-secret-here
SESSION_MAX_AGE=86400000
CSRF_ENABLED=true

# -----------------------------------------------------------------------------
# Performance & Optimization
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PERFORMANCE_MONITORING=true
BUNDLE_ANALYZER=false
LOG_LEVEL=debug
LOG_FORMAT=pretty
ENABLE_SOURCE_MAPS=true

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Enable dev tools (inspector, bundle analysis, etc.)
NEXT_PUBLIC_DEV_TOOLS_ENABLED=true
