{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["vite/client", "@react-router/node", "node"],
    "paths": {
      "yappc-ai": ["../libs/yappc-ai/src/index.ts"],
      "yappc-ai/*": ["../libs/yappc-ai/src/*"],
      "yappc-api": ["../libs/api/src/index.ts"],
      "yappc-api/*": ["../libs/api/src/*"],
      "yappc-auth": ["../libs/yappc-auth/dist/index.js"],
      "yappc-auth/*": ["../libs/yappc-auth/dist/*"],
      "yappc-config-compiler": ["../libs/config-compiler/src/index.ts"],
      "yappc-config-compiler/*": ["../libs/config-compiler/src/*"],
      "yappc-config-schema": ["../libs/config-schema/src/index.ts"],
      "yappc-config-schema/*": ["../libs/config-schema/src/*"],
      "yappc-core": ["../libs/yappc-core/src/index.ts"],
      "yappc-core/*": ["../libs/yappc-core/src/*"],
      "yappc-initialization-ui": ["../libs/yappc-initialization-ui/src/index.ts"],
      "yappc-initialization-ui/*": ["../libs/yappc-initialization-ui/src/*"],
      "yappc-product-theme": ["../libs/yappc-product-theme/src/index.ts"],
      "yappc-product-theme/*": ["../libs/yappc-product-theme/src/*"],
      "yappc-state": ["../libs/yappc-state/src/index.ts"],
      "yappc-state/*": ["../libs/yappc-state/src/*"],
      "yappc-ui": ["../libs/yappc-ui/src/index.ts"],
      "yappc-ui/*": ["../libs/yappc-ui/src/*"],
      "@yappc/ai": ["src/types/module-shims.d.ts"],
      "@yappc/ai/*": ["src/types/module-shims.d.ts"],
      "@ghatana/ui-builder": ["../../../../platform/typescript/ui-builder/src/index.ts"],
      "@ghatana/ui-builder/*": ["../../../../platform/typescript/ui-builder/src/*"],
      "@ghatana/ds-schema": ["../../../../platform/typescript/ds-schema/src/index.ts"],
      "@ghatana/ds-schema/*": ["../../../../platform/typescript/ds-schema/src/*"],
      "@ghatana/platform-utils": ["../../../../platform/typescript/platform-utils/src/index.ts"],
      "@ghatana/platform-utils/*": ["../../../../platform/typescript/platform-utils/src/*"],
      "@yappc/product-theme": ["../libs/yappc-product-theme/src/index.ts"],
      "@yappc/product-theme/*": ["../libs/yappc-product-theme/src/*"],
      "@yappc/ui": ["../libs/yappc-ui/src/index.ts"],
      "@yappc/ui/*": ["../libs/yappc-ui/src/*"],
      "@yappc/api": ["../libs/api/src/index.ts"],
      "@yappc/api/*": ["../libs/api/src/*"],
      "@yappc/auth": ["../libs/yappc-auth/dist/index.js"],
      "@yappc/auth/rbac": ["../libs/yappc-auth/dist/auth/rbac/index.js"],
      "@yappc/auth/oauth": ["../libs/yappc-auth/dist/auth/oauth/index.js"],
      "@yappc/auth/security": ["../libs/yappc-auth/dist/security/index.js"],
      "@yappc/config-schema": ["../libs/config-schema/src/index.ts"],
      "@yappc/config-schema/*": ["../libs/config-schema/src/*"],
      "@yappc/config-compiler": ["../libs/config-compiler/src/index.ts"],
      "@yappc/config-compiler/*": ["../libs/config-compiler/src/*"],
      "@ghatana/theme": ["src/theme/index.ts"],
      "@ghatana/theme/provider": ["src/theme/provider.ts"],
      "@ghatana/canvas": ["src/shims/ghatana-canvas.ts"],
      "@ghatana/canvas/*": ["src/shims/ghatana-canvas.ts"],
      "@yappc/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/types": ["src/types/module-shims.d.ts"],
      "@yappc/core/types/*": ["src/types/module-shims.d.ts"],
      "@yappc/core/api": ["../libs/api/src"],
      "@/shared/*": ["src/shared/*", "../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src", ".react-router/types/**/*.ts"],
  "exclude": ["node_modules", "dist", ".react-router/types/**/*.ts", "**/*.test.*", "**/*.spec.*"]
}
