{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "rootDir": "../../../../",
    "rootDirs": [
      ".",
      "./.react-router/types",
      "../../../../platform/typescript/ds-schema/src",
      "../../../../platform/typescript/ui-builder/src",
      "../libs/yappc-ui/src/components/components/Toast",
      "../libs/yappc-ui/src/components/utils",
      "../libs/yappc-ui/src/components/theme",
      "../libs/yappc-ui/src/components/tokens",
      "../libs/yappc-product-theme/src"
    ],
    "types": ["vite/client", "@react-router/node"],
    "paths": {
      "@yappc/ai": ["src/types/module-shims.d.ts"],
      "@yappc/ai/*": ["src/types/module-shims.d.ts"],
      "@ghatana/ui-builder": [
        "../../../../platform/typescript/ui-builder/src/index.ts"
      ],
      "@ghatana/ui-builder/*": [
        "../../../../platform/typescript/ui-builder/src/*"
      ],
      "@ghatana/ds-schema": ["../../../../platform/typescript/ds-schema/src/index.ts"],
      "@ghatana/ds-schema/*": ["../../../../platform/typescript/ds-schema/src/*"],
      "@ghatana/platform-utils": ["../../../../platform/typescript/platform-utils/src/index.ts"],
      "@ghatana/platform-utils/*": ["../../../../platform/typescript/platform-utils/src/*"],
      "@yappc/product-theme": ["../libs/yappc-product-theme/src/index.ts"],
      "@yappc/product-theme/*": ["../libs/yappc-product-theme/src/*"],
      "@yappc/ui": ["../libs/yappc-ui/src/index.ts"],
      "@yappc/ui/*": ["../libs/yappc-ui/src/*"],
      "@yappc/api": ["../libs/api/src/index.ts"],
      "@yappc/api/*": ["../libs/api/src/*"],
      "@yappc/auth": ["../libs/yappc-auth/dist/index.js"],
      "@yappc/auth/rbac": ["../libs/yappc-auth/dist/auth/rbac/index.js"],
      "@yappc/auth/oauth": ["../libs/yappc-auth/dist/auth/oauth/index.js"],
      "@yappc/auth/security": ["../libs/yappc-auth/dist/security/index.js"],
      "@yappc/config-schema": ["../libs/config-schema/src/index.ts"],
      "@yappc/config-schema/*": ["../libs/config-schema/src/*"],
      "@yappc/config-compiler": ["../libs/config-compiler/src/index.ts"],
      "@yappc/config-compiler/*": ["../libs/config-compiler/src/*"],
      "@ghatana/theme": ["src/theme/index.ts"],
      "@ghatana/theme/provider": ["src/theme/provider.ts"],
      "@ghatana/canvas": ["src/shims/ghatana-canvas.ts"],
      "@ghatana/canvas/*": ["src/shims/ghatana-canvas.ts"],
      "@yappc/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/types": ["src/types/module-shims.d.ts"],
      "@yappc/core/types/*": ["src/types/module-shims.d.ts"],
      "@yappc/core/api": ["../libs/api/src"],
      "@/shared/*": ["src/shared/*", "../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src",
    ".react-router/types/**/*.ts",
    "../../../../platform/typescript/ds-schema/src/**/*",
    "../../../../platform/typescript/ui-builder/src/**/*",
    "../libs/yappc-product-theme/src/index.ts",
    "../libs/yappc-product-theme/src/mui-bridge.tsx",
    "../libs/yappc-product-theme/src/lifecycle-presets.ts",
    "../libs/yappc-ui/src/index.ts",
    "../libs/yappc-ui/src/components/theme/index.ts",
    "../libs/yappc-ui/src/components/tokens/index.ts",
    "../libs/yappc-ui/src/components/components/Toast/Toast.tailwind.tsx",
    "../libs/yappc-ui/src/components/components/Toast/index.ts",
    "../libs/yappc-ui/src/components/utils/cn.ts"
  ],
  "files": ["src/utils/Logger.ts"],
  "references": [
    {
      "path": "../libs/api/tsconfig.json"
    },
    {
      "path": "../libs/config-schema/tsconfig.json"
    },
    {
      "path": "../libs/config-compiler/tsconfig.json"
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/routes/app/project/canvas/**/*",
    "src/components/canvas/ai/**/*",
    "src/components/canvas/Canvas.tsx",
    "src/components/canvas/CanvasProgressWidget.tsx",
    "src/components/canvas/CanvasShowcaseDemo.tsx",
    "src/components/canvas/TechStackBadges.tsx",
    "src/components/canvas/content/**/*",
    "src/components/canvas/examples/**/*",
    "src/components/canvas/lifecycle/**/*",
    "src/components/canvas/modes/**/*",
    "src/components/canvas/plugins/**/*",
    "src/components/canvas/unified/index.ts",
    "src/components/canvas/unified/CustomNodeRenderer.tsx",
    "src/components/canvas/unified/nodes/**/*",
    "src/components/canvas/unified/RectangleNode.tsx",
    "src/components/canvas/unified/TextNode.tsx",
    "src/components/canvas/unified/UnifiedStatusBar.tsx",
    "src/components/canvas/validation/**/*",
    "src/components/canvas/versioning/**/*",
    "src/factories/canvasAPIFactory.ts",
    "src/routes/mobile/**/*",
    "src/test/**/*",
    "src/test-utils/**/*",
    "src/setupTests.ts",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../libs/**/*.stories.*",
    "../libs/**/stories/**/*",
    "../../../../platform/typescript/ui-builder/src/**/__tests__/**/*",
    "../../../../platform/typescript/ds-schema/src/**/__tests__/**/*",
    "../../libs/**/__tests__/**/*",
    "../../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../../libs/**/stories/**/*",
    "../../libs/**/storybook/**/*"
  ]
}
