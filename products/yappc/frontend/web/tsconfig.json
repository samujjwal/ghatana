{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["vite/client", "@react-router/node", "node"],
    "paths": {
      "yappc-ai": ["../libs/yappc-ai/src/index.ts"],
      "yappc-ai/*": ["../libs/yappc-ai/src/*"],
      "yappc-api": ["../libs/api/src/index.ts"],
      "yappc-api/*": ["../libs/api/src/*"],
      "yappc-auth": ["../libs/yappc-auth/dist/index.js"],
      "yappc-auth/*": ["../libs/yappc-auth/dist/*"],
      "yappc-config-compiler": ["../libs/config-compiler/src/index.ts"],
      "yappc-config-compiler/*": ["../libs/config-compiler/src/*"],
      "yappc-config-schema": ["../libs/config-schema/src/index.ts"],
      "yappc-config-schema/*": ["../libs/config-schema/src/*"],
      "yappc-core": ["../libs/yappc-core/src/index.ts"],
      "yappc-core/*": ["../libs/yappc-core/src/*"],
      "yappc-initialization-ui": ["../libs/yappc-initialization-ui/src/index.ts"],
      "yappc-initialization-ui/*": ["../libs/yappc-initialization-ui/src/*"],
      "yappc-product-theme": ["../libs/yappc-product-theme/src/index.ts"],
      "yappc-product-theme/*": ["../libs/yappc-product-theme/src/*"],
      "yappc-state": ["../libs/yappc-state/src/index.ts"],
      "yappc-state/*": ["../libs/yappc-state/src/*"],
      "yappc-ui": ["../libs/yappc-ui/src/index.ts"],
      "yappc-ui/*": ["../libs/yappc-ui/src/*"],
      "@yappc/ai": ["src/types/module-shims.d.ts"],
      "@yappc/ai/*": ["src/types/module-shims.d.ts"],
      "@ghatana/ui-builder": [
        "../../../../platform/typescript/ui-builder/src/index.ts"
      ],
      "@ghatana/ui-builder/*": [
        "../../../../platform/typescript/ui-builder/src/*"
      ],
      "@ghatana/ds-schema": ["../../../../platform/typescript/ds-schema/src/index.ts"],
      "@ghatana/ds-schema/*": ["../../../../platform/typescript/ds-schema/src/*"],
      "@ghatana/platform-utils": ["../../../../platform/typescript/platform-utils/src/index.ts"],
      "@ghatana/platform-utils/*": ["../../../../platform/typescript/platform-utils/src/*"],
      "@yappc/product-theme": ["../libs/yappc-product-theme/src/index.ts"],
      "@yappc/product-theme/*": ["../libs/yappc-product-theme/src/*"],
      "@yappc/ui": ["../libs/yappc-ui/src/index.ts"],
      "@yappc/ui/*": ["../libs/yappc-ui/src/*"],
      "@yappc/api": ["../libs/api/src/index.ts"],
      "@yappc/api/*": ["../libs/api/src/*"],
      "@yappc/auth": ["../libs/yappc-auth/dist/index.js"],
      "@yappc/auth/rbac": ["../libs/yappc-auth/dist/auth/rbac/index.js"],
      "@yappc/auth/oauth": ["../libs/yappc-auth/dist/auth/oauth/index.js"],
      "@yappc/auth/security": ["../libs/yappc-auth/dist/security/index.js"],
      "@yappc/config-schema": ["../libs/config-schema/src/index.ts"],
      "@yappc/config-schema/*": ["../libs/config-schema/src/*"],
      "@yappc/config-compiler": ["../libs/config-compiler/src/index.ts"],
      "@yappc/config-compiler/*": ["../libs/config-compiler/src/*"],
      "@ghatana/theme": ["src/theme/index.ts"],
      "@ghatana/theme/provider": ["src/theme/provider.ts"],
      "@ghatana/canvas": ["src/shims/ghatana-canvas.ts"],
      "@ghatana/canvas/*": ["src/shims/ghatana-canvas.ts"],
      "@yappc/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/types": ["src/types/module-shims.d.ts"],
      "@yappc/core/types/*": ["src/types/module-shims.d.ts"],
      "@yappc/core/api": ["../libs/api/src"],
      "@/shared/*": ["src/shared/*", "../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*",
    "src/routes.ts",
    ".react-router/types/**/*.ts"
  ],
  "files": ["src/utils/Logger.ts"],
  "references": [],
  "exclude": [
    "node_modules",
    "dist",
    ".react-router/types/**/*.ts",
    "src/routes/_archived/**/*",
    "src/components/workflow/**/*",
    "src/templates/**/*",
    "src/state/devsecops.ts",
    "src/pages",
    "src/components/ui",
    "src/__tests__",
    "src/services/ai",
    "src/clients/ai",
    "src/hooks/useWorkspaceAdmin.ts",
    "src/hooks/useContextualAI.ts",
    "src/hooks/useSurfaceCanvas.ts",
    "src/hooks/useCanvasManagers.ts",
    "src/hooks/useCanvasValidation.ts",
    "src/hooks/useVirtualAgents.ts",
    "src/hooks/useAIAssistant.ts",
    "src/hooks/useCanvasNodeOps.ts",
    "src/hooks/useUnifiedCanvas.ts",
    "src/services/ConfigPersistence/**/*",
    "src/services/ContractDriven/**/*",
    "src/services/migration/**/*",
    "src/routes/app/project/canvas.tsx",
    "src/components/ai",
    "src/components/canvas/**/*",
    "src/components/canvas/UnifiedPlaygroundToolbar.tsx",
    "src/components/canvas/workspace/index.ts",
    "src/components/canvas/nodes/CodePreviewPopover.tsx",
    "src/components/canvas/CanvasPhaseNavigator.tsx",
    "src/routes/app/project/canvas/**/*",
    "src/routes/app/project/_archived",
    "src/components/index.ts",
    "src/components/CollaborativeCanvas.tsx",
    "src/components/OnboardingChecklist.tsx",
    "src/factories/canvasAPIFactory.ts",
    "src/services/RequirementTransformer/**/*",
    "src/services/registry/**/*",
    "src/services/export/**/*",
    "src/services/collaboration/**/*",
    "src/services/agentService.ts",
    "src/services/canvas/index.ts",
    "src/services/canvas/CanvasCommands.ts",
    "src/services/canvas/CanvasPersistence.ts",
    "src/services/canvas/HookMigration.ts",
    "src/services/canvas/agents/**/*",
    "src/services/canvas/diff/**/*",
    "src/services/canvas/export/**/*",
    "src/services/canvas/hooks/**/*",
    "src/services/canvas/lifecycle/CanvasLifecycle.ts",
    "src/services/canvas/storage/**/*",
    "src/services/canvas/templates/**/*",
    "src/services/canvas/__tests__/**/*",
    "src/services/canvas/performance.bench.ts",
    "src/services/layers/**/*",
    "src/services/persistence.ts",
    "src/services/persistence/**/*",
    "src/services/rail/**/*",
    "src/state/tools/**/*",
    "src/components/knowledge-graph/**/*",
    "src/test/**/*",
    "src/test-utils/**/*",
    "src/setupTests.ts",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../libs/**/*.stories.*",
    "../libs/**/stories/**/*",
    "../../../../platform/typescript/ui-builder/src/**/__tests__/**/*",
    "../../../../platform/typescript/ds-schema/src/**/__tests__/**/*",
    "../../libs/**/__tests__/**/*",
    "../../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../../libs/**/stories/**/*",
    "../../libs/**/storybook/**/*",
    "src/pages/collaboration/TeamDashboardPage.tsx",
    "src/pages/collaboration/TeamChatPage.tsx"
  ]
}
