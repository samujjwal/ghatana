{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "rootDir": "..",
    "rootDirs": [
      ".",
      "./.react-router/types",
      "../libs/yappc-ui/src/components/components/Toast",
      "../libs/yappc-ui/src/components/utils"
    ],
    "types": ["vite/client", "@react-router/node"],
    "paths": {
      "@yappc/ai": ["src/types/module-shims.d.ts"],
      "@yappc/ai/*": ["src/types/module-shims.d.ts"],
      "@ghatana/canvas": ["src/types/module-shims.d.ts"],
      "@ghatana/canvas/*": ["src/types/module-shims.d.ts"],
      "@yappc/api": ["../libs/api/src/index.ts"],
      "@yappc/api/*": ["../libs/api/src/*"],
      "@yappc/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/testing/*": ["../libs/yappc-core/src/testing/*"],
      "@yappc/core/types": ["src/types/module-shims.d.ts"],
      "@yappc/core/types/*": ["src/types/module-shims.d.ts"],
      "@yappc/core/api": ["../libs/api/src"],
      "@/shared/*": ["src/shared/*", "../shared/*"],
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src",
    ".react-router/types/**/*.ts",
    "../libs/yappc-ui/src/components/components/Toast/Toast.tailwind.tsx",
    "../libs/yappc-ui/src/components/components/Toast/index.ts",
    "../libs/yappc-ui/src/components/utils/cn.ts"
  ],
  "references": [
    {
      "path": "../libs/api/tsconfig.json"
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/routes/app/project/canvas/**/*",
    "src/components/canvas/ai/**/*",
    "src/components/canvas/Canvas.tsx",
    "src/components/canvas/CanvasProgressWidget.tsx",
    "src/components/canvas/CanvasShowcaseDemo.tsx",
    "src/components/canvas/TechStackBadges.tsx",
    "src/components/canvas/content/**/*",
    "src/components/canvas/examples/**/*",
    "src/components/canvas/lifecycle/**/*",
    "src/components/canvas/modes/**/*",
    "src/components/canvas/plugins/**/*",
    "src/components/canvas/unified/index.ts",
    "src/components/canvas/unified/CustomNodeRenderer.tsx",
    "src/components/canvas/unified/nodes/**/*",
    "src/components/canvas/unified/RectangleNode.tsx",
    "src/components/canvas/unified/TextNode.tsx",
    "src/components/canvas/unified/UnifiedStatusBar.tsx",
    "src/components/canvas/validation/**/*",
    "src/components/canvas/versioning/**/*",
    "src/factories/canvasAPIFactory.ts",
    "src/utils/**/*",
    "src/routes/mobile/**/*",
    "src/test/**/*",
    "src/test-utils/**/*",
    "src/setupTests.ts",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "../../libs/**/__tests__/**/*",
    "../../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../../libs/**/stories/**/*",
    "../../libs/**/storybook/**/*"
  ]
}
