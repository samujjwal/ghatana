{
  "name": "@ghatana/yappc-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "analyze": "react-router build && open ./dist/stats.html",
    "check:bundle-budget": "node ../scripts/check-web-bundle-budget.cjs",
    "preview": "vite preview",
    "report:bundle-budget": "node ../scripts/check-web-bundle-budget.cjs --report",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:smoke": "vitest run src/__tests__/routes.spec.ts",
    "inventory:routes": "node scripts/generate-route-inventory.mjs",
    "inventory:routes:check": "node scripts/generate-route-inventory.mjs --check",
    "verify:tracker": "node scripts/verify-tracker.mjs",
    "verify:release-readiness": "node scripts/verify-release-readiness.mjs",
    "test:ui": "vitest --ui",
    "test:performance:budgets": "vitest run src/services/performance/__tests__/canvasPerformanceBudgets.test.ts",
    "test:unit:canvas": "jest --config jest.canvas.config.ts src/components/canvas/**/*.test.{ts,tsx}",
    "test:integration:canvas": "jest --config jest.canvas.config.ts src/components/canvas/__tests__/performance-integration.test.tsx",
    "test:performance:canvas": "jest --config jest.canvas.config.ts src/components/canvas/__tests__/edge-cases.test.tsx",
    "test:e2e:canvas": "playwright test e2e/canvas-refactoring.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility-contracts.spec.ts",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:performance-memory": "playwright test e2e/performance-memory.spec.ts",
    "test:e2e": "playwright test",
    "test:canvas:all": "node ../../test-runner.js",
    "test:canvas:unit": "node ../../test-runner.js --unit",
    "test:canvas:coverage": "node ../../test-runner.js --coverage",
    "test:canvas:watch": "node ../../test-runner.js --watch"
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ghatana/canvas": "workspace:*",
    "@ghatana/design-system": "workspace:*",
    "@ghatana/ds-registry": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/realtime": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/ui-builder": "workspace:*",
    "@growthbook/growthbook-react": "^1.6.5",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@mui/material": "^9.0.0",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "@tanstack/react-query": "^5.99.0",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.2",
    "yappc-ai": "workspace:*",
    "yappc-api": "workspace:*",
    "yappc-auth": "workspace:*",
    "yappc-chat": "workspace:*",
    "yappc-config-schema": "workspace:*",
    "yappc-config-compiler": "workspace:*",
    "yappc-artifact-compiler": "workspace:*",
    "@ghatana/code-editor": "workspace:*",
    "yappc-collab": "workspace:*",
    "yappc-core": "workspace:*",
    "@ghatana/yappc-ide": "workspace:*",
    "yappc-initialization-ui": "workspace*",
    "yappc-product-theme": "workspace:*",
    "yappc-state": "workspace:*",
    "yappc-ui": "workspace*",
    "axe-core": "^4.11.2",
    "axios": "^1.15.0",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "hotkeys-js": "^4.0.3",
    "html-to-image": "^1.11.13",
    "idb-keyval": "^6.2.2",
    "isbot": "^5",
    "jotai": "^2.19.1",
    "jszip": "^3.10.1",
    "konva": "^10.2.5",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "perfect-freehand": "^1.2.3",
    "rbush": "^4.0.1",
    "react": "^19.2.5",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-konva": "^19.2.3",
    "react-router": "^7.14.0",
    "recharts": "^3.8.1",
    "slate": "^0.124.1",
    "slate-react": "^0.124.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.2",
    "@playwright/test": "^1.53.0",
    "msw": "^2.13.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
