{
  "rules": {
    "yappc/no-raw-buttons": [
      "error",
      {
        "allowedFiles": [
          "node_modules",
          "__tests__",
          ".test.",
          ".spec."
        ]
      }
    ],
    "yappc/no-raw-inputs": [
      "error",
      {
        "allowedFiles": [
          "node_modules",
          "__tests__",
          ".test.",
          ".spec."
        ]
      }
    ],
    "yappc/no-raw-select": [
      "error",
      {
        "allowedFiles": [
          "node_modules",
          "__tests__",
          ".test.",
          ".spec."
        ]
      }
    ],
    "yappc/no-hardcoded-color-tokens": [
      "error",
      {
        "allowedFiles": [
          "theme/",
          "tokens/",
          "node_modules",
          "PersonaContext"
        ]
      }
    ],
    "yappc/no-ad-hoc-card-classes": [
      "error"
    ]
  }
}
