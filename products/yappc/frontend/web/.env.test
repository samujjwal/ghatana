# Test environment variables
NODE_ENV=test
VITE_APP_ENV=test
# Single-port architecture - Gateway on port 7002
VITE_API_ORIGIN=http://localhost:7002
VITE_API_URL=http://localhost:7002/api
VITE_USE_MOCKS=true
VITE_APP_NAME=AppCreator-Test
VITE_APP_VERSION=1.0.0-test

# Testing flags
VITE_TEST_MODE=true
VITE_E2E_TESTING=false
VITE_UNIT_TESTING=true

# Feature flags for testing
VITE_FEATURE_NEW_UI=false
VITE_FEATURE_EXPERIMENTAL=false

# API settings
VITE_API_TIMEOUT=5000
VITE_API_RETRY_ATTEMPTS=1

# Logging
VITE_LOG_LEVEL=warn
VITE_ENABLE_CONSOLE_LOGS=false

# Analytics (disabled in test)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=test-analytics-id

# Error tracking (disabled in test)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false

# Performance monitoring
VITE_PERF_MONITORING=false

# Authentication (mocked in tests)
VITE_AUTH_ENABLED=true
VITE_AUTH_URL=/api/auth
VITE_AUTH_CLIENT_ID=test-client-id

# Localization
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es,fr

# Testing utilities
VITE_TEST_USER_EMAIL=test@example.com
VITE_TEST_USER_PASSWORD=password123

# Mock server settings (if using MSW)
VITE_API_MOCKING_ENABLED=true
VITE_API_MOCKING_HANDLERS=./src/mocks/handlers.ts

# Test coverage
VITE_COVERAGE_ENABLED=true
VITE_COVERAGE_REPORT_DIR=coverage

# Playwright settings
VITE_PLAYWRIGHT_TEST_BASE_URL=http://localhost:5173
VITE_PLAYWRIGHT_TEST_TIMEOUT=10000

# Vitest settings
VITEST_SEQUENCE_SEED=12345
VITEST_WORKER_ID=1
VITEST_POOL_ID=1

# React Query DevTools (disabled in test)
VITE_QUERY_DEVTOOLS=false
