{
  "name": "@ghatana/yappc-frontend",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/ensure-tsbuildinfo-dirs.js",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "preview:web": "pnpm --filter web preview",
    "tauri:dev": "pnpm --filter desktop tauri dev",
    "mobile:sync": "pnpm run build:web && pnpm --filter mobile-cap cap sync",
    "android": "pnpm run mobile:sync && pnpm --filter mobile-cap cap open android",
    "ios": "pnpm run mobile:sync && pnpm --filter mobile-cap cap open ios",
    "storybook": "pnpm --filter @ghatana/ui storybook",
    "storybook:ci": "pnpm --filter @ghatana/ui storybook -- --ci -p 6006",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:watch": "graphql-codegen --config codegen.yml --watch",
    "generate:canvas-stories": "node scripts/generate-canvas-feature-stories.js",
    "test": "vitest run --passWithNoTests --config=./vitest.config.ts",
    "test:watch": "vitest --config=./vitest.config.ts",
    "test:coverage": "vitest run --coverage --config=./vitest.coverage.config.ts",
    "test:coverage:strict": "vitest run --coverage --config=./vitest.coverage.config.ts && node scripts/enforce-coverage.js --strict",
    "test:coverage:verbose": "vitest run --coverage --config=./vitest.coverage.config.ts && node scripts/enforce-coverage.js --strict --verbose",
    "test:coverage:enforce": "node scripts/enforce-coverage.js",
    "test:ui": "vitest --ui --config=./vitest.config.ts",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:all": "pnpm run test:typecheck && pnpm run test && pnpm run test:e2e",
    "test:perf": "vitest run --match='**/*.perf.test.ts' --config=./vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headless": "playwright test e2e/headless-verification.spec.ts -c playwright.config.ts -p chromium",
    "playwright:test:serve": "cross-env PLAYWRIGHT_SERVE_HTML=1 playwright test -c playwright.config.ts",
    "playwright:show-report": "playwright show-report",
    "lint": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**'",
    "lint:fix": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --fix",
    "lint:fast": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --cache",
    "lint:fix:fast": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --fix --cache",
    "lint:fix:fast:cache": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "typecheck:build": "tsc -b tsconfig.refs.json",
    "build:types": "node ./scripts/build-types.js",
    "pretypecheck:build": "node ./scripts/build-types.js",
    "typecheck:clean": "tsc -b tsconfig.refs.json --clean",
    "typecheck:refs": "tsc -b tsconfig.refs.json",
    "typecheck:refs:watch": "tsc -b tsconfig.refs.json --watch",
    "typecheck:refs:clean": "tsc -b tsconfig.refs.json --clean",
    "typecheck:refs:force": "tsc -b tsconfig.refs.json --force",
    "typecheck:refs:verbose": "tsc -b tsconfig.refs.json --verbose",
    "typecheck:refs:dry": "tsc -b tsconfig.refs.json --dry",
    "typecheck:refs:show-config": "tsc -b tsconfig.refs.json --showConfig",
    "verify:workspace": "node scripts/verify-workspace-deps.js",
    "verify:build": "node scripts/verify-build.js",
    "verify:ts-refs": "node scripts/verify-ts-refs.js",
    "verify:src-clean": "node scripts/verify-src-clean.js",
    "check:file-sizes": "node scripts/check-file-sizes.js",
    "check:governance": "dependency-cruiser --validate .dependency-cruiser.js --output-type err libs",
    "check:architecture": "dependency-cruiser --validate .dependency-cruiser.js --output-type err-long libs",
    "deps:prune": "pnpm dedupe --check && pnpm list --depth=0",
    "check:deps:graph": "dependency-cruiser --output-type dot --validate .dependency-cruiser.js libs | dot -T svg > docs/dependency-graph.svg",
    "enhance:tsconfig": "node scripts/enhance-typescript-config.js",
    "verify:all": "pnpm run verify:workspace && pnpm run verify:build && pnpm run verify:ts-refs && pnpm run verify:src-clean && pnpm run check:governance",
    "prepare": "husky || true",
    "clean:generated": "node ./scripts/clean-generated.js",
    "validate:routes": "tsx ../scripts/validate-routes.ts",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run verify:all",
    "lighthouse": "lhci autorun",
    "analyze": "pnpm build:web && open apps/web/dist/stats.html",
    "test:smoke:web": "pnpm -C apps/web run test:smoke",
    "jscpd": "jscpd --config .jscpd.json",
    "depcruise": "depcruise --config .dependency-cruiser.json \"apps/**/src/**/*.ts*\"",
    "depcruise:report": "depcruise --config .dependency-cruiser.json \"apps/**/src/**/*.ts*\" --output-type err > depcruise-report.txt",
    "audit:quality": "node scripts/quality-audit.js",
    "audit:security": "npm audit --audit-level high",
    "audit:full": "pnpm run audit:quality && pnpm run audit:security",
    "convert:icon": "node scripts/convert-icon-rgba.js"
  },
  "dependencies": {
    "@growthbook/growthbook-react": "^1.6.4",
    "@open-draft/deferred-promise": "^2.2.0",
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "imask": "^7.6.1",
    "jotai": "^2.17.0",
    "react": "^19.2.4",
    "react-dnd": "^16.0.1",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^7.3.1",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.1",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-search-algolia": "3.9.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.1",
    "@sentry/nextjs": "^10.38.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/webpack-plugin": "^4.9.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/addon-a11y": "^10.2.4",
    "@storybook/addon-docs": "^10.2.4",
    "@storybook/addon-links": "^10.2.4",
    "@storybook/addon-themes": "^10.2.4",
    "@storybook/react": "^10.2.4",
    "@storybook/react-vite": "^10.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bundle-buddy": "^0.2.2",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.7",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "envinfo": "^7.21.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "execa": "^9.6.1",
    "find-up": "^8.0.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.1",
    "globby": "^16.1.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jscpd": "^4.0.8",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "make-dir": "^5.1.0",
    "minimist": "^1.2.8",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "semver": "^7.7.3",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.0",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-mkcert": "^1.17.9",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-react": "^4.0.1",
    "vite-plugin-stylelint": "^6.0.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "webpack-bundle-analyzer": "^5.2.0",
    "which": "^6.0.0",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.2"
}