{
  "name": "@ghatana/yappc-frontend",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "compat/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest --coverage",
    "lint": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**'",
    "lint:fix": "eslint 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:build": "tsc -b tsconfig.refs.json",
    "clean": "rimraf dist node_modules/.cache",
    "codegen": "graphql-codegen --config codegen.yml",
    "storybook": "pnpm --filter @yappc/ui storybook",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "deps:update": "pnpm update --latest",
    "deps:audit": "pnpm audit",
    "lighthouse": "lhci autorun",
    "analyze": "pnpm build && open apps/web/dist/stats.html"
  },
  "dependencies": {
    "@growthbook/growthbook-react": "^1.6.4",
    "@open-draft/deferred-promise": "^2.2.0",
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.0",
    "imask": "^7.6.1",
    "jotai": "^2.17.0",
    "react": "^19.2.4",
    "react-dnd": "^16.0.1",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "vite": "^7.3.1",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.1",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-search-algolia": "3.9.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.1",
    "@sentry/nextjs": "^10.38.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/webpack-plugin": "^4.9.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/addon-a11y": "^10.2.4",
    "@storybook/addon-docs": "^10.2.4",
    "@storybook/addon-links": "^10.2.4",
    "@storybook/addon-themes": "^10.2.4",
    "@storybook/react": "^10.2.4",
    "@storybook/react-vite": "^10.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bundle-buddy": "^0.2.2",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.7",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "envinfo": "^7.21.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "execa": "^9.6.1",
    "find-up": "^8.0.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.1",
    "globby": "^16.1.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jscpd": "^4.0.8",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "make-dir": "^5.1.0",
    "minimist": "^1.2.8",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "semver": "^7.7.3",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.0",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-mkcert": "^1.17.9",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-react": "^4.0.1",
    "vite-plugin-stylelint": "^6.0.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "webpack-bundle-analyzer": "^5.2.0",
    "which": "^6.0.0",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.2"
}
