{
  "name": "@ghatana/yappc-frontend",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "compat/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "build:verify": "pnpm --filter @ghatana/platform-events build && pnpm --filter @ghatana/ds-schema build && pnpm --filter @ghatana/ui-builder build && pnpm --filter yappc-artifact-compiler build",
    "preview": "pnpm --filter web preview",
    "test": "pnpm test:verify",
    "test:full": "vitest",
    "test:verify": "vitest run web/src/components/canvas/nodes/__tests__/PageDesignerNode.test.tsx web/src/components/canvas/registry/__tests__/CanvasRegistryProvider.test.tsx libs/collab/src/websocket/__tests__/*.test.ts libs/yappc-ai/src/hooks/__tests__/useBuilderAI.test.ts libs/yappc-artifact-compiler/src/builder/__tests__/toBuilderDocument.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:quarantine": "cross-env PLAYWRIGHT_QUARANTINE_RETRIES=2 playwright test",
    "test:coverage": "vitest --coverage",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint --no-error-on-unmatched-pattern 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' 'web/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**'",
    "lint:architecture": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint --no-error-on-unmatched-pattern 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' 'web/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --rule 'ghatana-architecture-rules/no-yappc-direct-platform-imports: error'",
    "lint:strict:design-system": "bash ./scripts/lint-strict-design-system.sh",
    "lint:fix": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint --no-error-on-unmatched-pattern 'apps/**/src/**/*.{ts,tsx}' 'libs/**/src/**/*.{ts,tsx}' 'web/src/**/*.{ts,tsx}' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**' --fix",
    "lint:verify": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint --no-error-on-unmatched-pattern --rule 'import/no-unused-modules: off' 'web/src/components/canvas/nodeTypes.ts' 'web/src/components/canvas/nodes/index.ts' 'web/src/components/canvas/registry/CanvasRegistryProvider.tsx' 'libs/collab/src/websocket/index.ts' 'libs/yappc-artifact-compiler/src/synthesis/engine.ts' --ignore-pattern '**/*.d.ts' --ignore-pattern '**/generated/**'",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "type-check": "pnpm typecheck",
    "typecheck:build": "tsc -b tsconfig.refs.json",
    "check:namespaces": "node ./scripts/check-namespace-consistency.js",
    "check:auth-policy": "node ./scripts/check-auth-policy.js",
    "check:duplication-boundaries": "node ./scripts/check-duplication-boundaries.js",
    "check:manifests": "node ./scripts/check-manifest-namespace-consistency.js",
    "check:workspace-deps": "node ./scripts/verify-workspace-deps.js",
    "clean": "rimraf dist node_modules/.cache",
    "codegen": "pnpm codegen:graphql && pnpm codegen:openapi",
    "codegen:graphql": "graphql-codegen --config codegen.yml",
    "codegen:openapi": "npx -y openapi-typescript-codegen -i ../docs/api/openapi.yaml -o web/src/clients/generated/api --client axios",
    "api:generate": "pnpm codegen:openapi",
    "api:check": "pnpm api:generate && git diff --exit-code web/src/clients/generated/api || (echo 'ERROR: Generated API client is stale. Run: pnpm api:generate' && exit 1)",
    "storybook": "pnpm --filter yappc-ui storybook",
    "verify": "pnpm check:namespaces && pnpm check:auth-policy && pnpm check:duplication-boundaries && pnpm check:manifests && pnpm check:workspace-deps && pnpm --filter @ghatana/platform-events build && pnpm --filter @ghatana/ds-schema build && pnpm --filter @ghatana/ui-builder build && pnpm --filter yappc-artifact-compiler build && pnpm typecheck && pnpm lint:verify && pnpm test:verify && pnpm build:verify",
    "deps:update": "pnpm update --latest",
    "deps:audit": "pnpm audit",
    "lighthouse": "lhci autorun",
    "analyze": "pnpm build && open apps/web/dist/stats.html",
    "release:full": "pnpm release:openapi && pnpm release:accessibility && pnpm release:visual && pnpm release:performance",
    "release:openapi": "node ../../scripts/validate-openapi-parity.js ../../docs/api/openapi.yaml ../../docs/api/route-manifest.yaml",
    "release:accessibility": "playwright test --config web/playwright.config.ts --grep '@a11y'",
    "release:visual": "playwright test --config web/playwright.config.ts --grep '@visual'",
    "release:performance": "lhci autorun --collect.url=['http://localhost:4173'] --collect.numberOfRuns=3"
  },
  "dependencies": {
    "@growthbook/growthbook-react": "^1.6.5",
    "@open-draft/deferred-promise": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "imask": "^7.6.1",
    "jotai": "^2.19.1",
    "react": "^19.2.5",
    "react-dnd": "^16.0.1",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.8",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@docusaurus/theme-search-algolia": "3.10.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@sentry/nextjs": "^10.48.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/webpack-plugin": "^5.2.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "bundle-buddy": "^0.2.2",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^17.4.1",
    "dotenv-expand": "^12.0.3",
    "envinfo": "^7.21.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "execa": "^9.6.1",
    "find-up": "^8.0.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "@axe-core/playwright": "^4.11.1",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.0.9",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "make-dir": "^5.1.0",
    "minimist": "^1.2.8",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "semver": "^7.7.4",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "source-map-explorer": "^2.5.3",
    "storybook": "^10.3.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-mkcert": "^2.0.0",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-react": "^4.0.1",
    "vite-plugin-stylelint": "^6.1.0",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "webpack-bundle-analyzer": "^5.3.0",
    "which": "^6.0.1",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
