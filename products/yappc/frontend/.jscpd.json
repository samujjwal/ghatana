{
  "paths": ["apps/**/src", "libs/**/src"],
  "reporters": ["console", "html"],
  "threshold": 0.5,
  "minTokens": 50,
  "mode": "strict",
  "output": ".jscpd-report.html",
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.git/**",
    "**/*.stories.*",
    "**/stories/**",
    "**/*.stories.{ts,tsx,js,jsx,mjs,cjs}",
    "**/__tests__/**",
    "**/test-utils/**",
    "**/*.test.*",
    "**/*.{spec,test}.{ts,tsx,js,jsx}"
  ]
}
