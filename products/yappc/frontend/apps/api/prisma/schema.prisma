///
/// LifecycleArtifact entity for the Lifecycle Hub feature.
/// This is distinct from the core `Artifact` model (which is item-scoped).
/// @doc.type model
/// @doc.purpose Project-scoped lifecycle artifact
/// @doc.layer product
/// @doc.pattern Value Object
///
model LifecycleArtifact {
  id              String         @id @default(cuid())
  projectId       String
  title           String
  type            String
  description     String?
  content         String?
  status          String         @default("draft")
  phase           LifecyclePhase @default(SHAPE)
  fowStage        Int            @default(1)
  createdBy       String         @default("system")
  linkedArtifacts String[]       @default([])

  metadata Json @default("{}")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phase])
  @@index([fowStage])
  @@index([status])
}

///
/// LifecycleItem entity for the Lifecycle Hub tasks.
/// Distinct from the core `Item` model.
/// @doc.type model
/// @doc.purpose Project-scoped lifecycle task item
/// @doc.layer product
/// @doc.pattern Value Object
///
model LifecycleItem {
  id              String         @id @default(cuid())
  projectId       String
  title           String
  description     String?
  status          String         @default("TODO")
  priority        String         @default("MEDIUM")
  estimatedEffort Int?
  phase           LifecyclePhase @default(SHAPE)
  fowStage        Int            @default(1)
  assignedPersona String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([phase])
}

///
/// LifecycleAIInsight entity for AI recommendations in the Lifecycle Hub.
/// Distinct from the core `AIInsight` model.
/// @doc.type model
/// @doc.purpose Project-scoped lifecycle AI insights
/// @doc.layer product
/// @doc.pattern Value Object
///
model LifecycleAIInsight {
  id          String         @id @default(cuid())
  projectId   String
  title       String
  description String?
  confidence  Float          @default(0.5)
  severity    String         @default("INFO")
  status      String         @default("PENDING")
  phase       LifecyclePhase @default(SHAPE)
  fowStage    Int            @default(1)
  agentName   String         @default("AI Assistant")
  metadata    Json           @default("{}")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phase])
  @@index([status])
  @@index([severity])
}

///
/// LifecycleActivityLog entity for audit/evidence in the Lifecycle Hub.
/// Distinct from the core `ActivityLog` model.
/// @doc.type model
/// @doc.purpose Project-scoped lifecycle activity log
/// @doc.layer product
/// @doc.pattern Audit Log
///
model LifecycleActivityLog {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  action      String
  description String?
  metadata    Json     @default("{}")
  timestamp   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

///
/// Activity log for system-wide tracking.
///
model ActivityLog {
  id          String  @id @default(cuid())
  userId      String
  itemId      String?
  phaseId     String?
  workflowId  String?
  action      String
  description String
  metadata    Json    @default("{}")

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([itemId])
  @@index([phaseId])
  @@index([timestamp])
}

