///
/// AI-generated plan for workflows.
/// @doc.type model
/// @doc.purpose Store AI-generated execution plans
/// @doc.layer product
/// @doc.pattern Value Object
///
model AIGeneratedPlan {
  id         String   @id @default(cuid())
  workflowId String   @unique
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  intent  String
  context Json   @default("{}")

  tasks             Json   @default("[]") // Array of PlannedTask objects
  estimatedDuration String
  riskFactors       Json   @default("[]")
  dependencies      Json   @default("[]")

  suggestedAssignments Json @default("[]")
  alternativePlans     Json @default("[]")

  confidence Float
  reasoning  String

  model       String
  generatedAt DateTime @default(now())

  accepted   Boolean   @default(false)
  acceptedAt DateTime?

  @@index([workflowId])
  @@index([generatedAt])
}

///
/// Vector embeddings for semantic search.
/// @doc.type model
/// @doc.purpose Store vector embeddings for items
/// @doc.layer product
/// @doc.pattern Value Object
///
model VectorEmbedding {
  id     String @id @default(cuid())
  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  embedding  Float[] // Vector representation
  dimensions Int // Usually 1536 for OpenAI

  model       String // Embedding model used
  generatedAt DateTime @default(now())

  @@index([itemId])
}

///
/// AI metric tracking for observability.
/// @doc.type model
/// @doc.purpose Track AI model performance and cost
/// @doc.layer product
/// @doc.pattern Value Object
///
model AIMetric {
  id        String @id @default(cuid())
  agentName String
  model     String
  operation String // 'completion', 'embedding', 'prediction', etc.

  tokensUsed Int
  latencyMs  Int
  costUSD    Float

  success      Boolean
  errorMessage String?

  userId    String?
  sessionId String?

  timestamp DateTime @default(now())

  @@index([agentName])
  @@index([model])
  @@index([operation])
  @@index([timestamp])
}

// ============================================================================
// AUDIT & COMPLIANCE (ADDED BY AI)
// ============================================================================

model AuditLogEntry {
  id                String   @id @default(cuid())
  timestamp         DateTime @default(now())
  action            String
  actor             String
  actorRole         String
  resource          String?
  severity          String   @default("info")
  details           String?
  ipAddress         String?
  userAgent         String?
  method            String?
  status            Int?
  responseTime      Int?
  snapshotId        String?
  environment       String?
  approvalRequestId String?
  reason            String?
  success           Boolean?
  error             String?
  metadata          Json?
  tenantId          String?

  @@index([timestamp])
  @@index([actor])
  @@index([action])
  @@index([resource])
  @@index([severity])
}

model RateLimitConfig {
  id                 String    @id @default(cuid())
  userId             String    @unique
  tier               String    @default("free")
  userTiers          Json // { free: {...}, pro: {...} }
  enableAuditLog     Boolean   @default(true)
  maxAuditLogEntries Int       @default(10000)
  alertConfig        Json?
  upgradedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model UpgradeRequest {
  id            String    @id @default(cuid())
  userId        String
  tier          String
  requestedTier String
  currentTier   String
  reason        String?
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model ComplianceAssessment {
  id          String   @id @default(cuid())
  title       String
  description String?
  framework   String
  status      String   @default("DRAFT")
  riskScore   Float?
  findings    Json?
  controls    Json?
  gaps        Json?
  auditTrail  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  remediationPlans RemediationPlan[]
  reports          ComplianceReport[]
  schedules        ReportSchedule[]
}

model RemediationPlan {
  id               String    @id @default(cuid())
  assessmentId     String
  totalEffort      Int?
  completionTarget DateTime?
  riskScore        Float?
  status           String    @default("DRAFT")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assessment ComplianceAssessment @relation(fields: [assessmentId], references: [id])
  steps      RemediationStep[]
}

model RemediationStep {
  id              String    @id @default(cuid())
  planId          String
  controlId       String
  title           String
  description     String?
  priority        String    @default("MEDIUM")
  estimatedEffort Int?
  owner           String?
  deadline        DateTime?
  status          String    @default("OPEN")
  evidence        String[]

  dependencies RemediationStep[] @relation("StepDependencies")
  dependents   RemediationStep[] @relation("StepDependencies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan RemediationPlan @relation(fields: [planId], references: [id])
}

model ComplianceReport {
  id           String   @id @default(cuid())
  assessmentId String
  title        String
  summary      String?
  generatedBy  String
  format       String   @default("PDF")
  url          String?
  framework    String?
  metrics      Json?
  filename     String?
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment ComplianceAssessment @relation(fields: [assessmentId], references: [id])
}

model ReportSchedule {
  id           String    @id @default(cuid())
  assessmentId String
  name         String
  frequency    String // DAILY, WEEKLY, MONTHLY
  recipients   String[]
  config       Json?
  nextRun      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assessment ComplianceAssessment @relation(fields: [assessmentId], references: [id])
}

///
/// Flow State for Golden Flows.
/// @doc.type model
/// @doc.purpose Persist workflow state
/// @doc.layer product
/// @doc.pattern Value Object
///
model FlowState {
  id           String @id @default(cuid())
  flowId       String
  currentState String
  context      Json   @default("{}")
  history      Json   @default("[]")
  artifacts    Json   @default("[]")
  activeTasks  Json   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([flowId])
  @@index([currentState])
}
