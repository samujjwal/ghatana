{
    "name": "@yappc/api-app",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "YAPPC backend API service (Fastify/GraphQL/Prisma). NOTE: This backend service is currently located inside the frontend workspace for historical reasons. It should be relocated to products/yappc/backend/ in a future migration.",
    "scripts": {
        "dev": "pnpm run build && node dist/index.js",
        "build": "tsup src/index.ts --format esm --clean --external @opentelemetry/* --external import-in-the-middle",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:migrate": "npx tsx apply-migrations.mjs",
        "db:push": "prisma db push --schema=prisma/schema.prisma",
        "db:seed": "tsx prisma/seed.ts",
        "db:reset": "prisma migrate reset --schema=prisma/schema.prisma",
        "db:studio": "prisma studio --schema=prisma/schema.prisma"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@fastify/websocket": "^11.2.0",
        "@graphql-yoga/node": "^3.9.1",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
        "@opentelemetry/instrumentation-fastify": "^0.55.0",
        "@opentelemetry/resources": "^2.5.0",
        "@opentelemetry/sdk-node": "^0.211.0",
        "@opentelemetry/sdk-trace-node": "^2.5.0",
        "@opentelemetry/semantic-conventions": "^1.39.0",
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "bcryptjs": "^2.4.3",
        "dotenv": "^17.2.3",
        "fastify": "^5.7.4",
        "graphql": "^16.12.0",
        "graphql-yoga": "^5.18.0",
        "js-yaml": "^4.1.1",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.18.0",
        "prom-client": "^15.1.3",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.2.0",
        "@types/pg": "^8.16.0",
        "@types/ws": "^8.18.1",
        "prisma": "^7.3.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    },
    "prisma": {
        "seed": "tsx --env-file .env.local prisma/seed.ts"
    }
}