# YAPPC API Gateway Environment Configuration Template
# Copy this file to .env for your local development setup

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# API Gateway Port (Frontend talks to this port ONLY)
PORT=7002

# Environment
NODE_ENV=development

# ============================================================================
# JAVA BACKEND CONFIGURATION (Internal)
# ============================================================================

# Java backend URL (internal only - not exposed to frontend)
JAVA_BACKEND_URL=http://localhost:7003

# Java AI backend URL (same as above, legacy alias)
JAVA_AI_BACKEND_URL=http://localhost:7003

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://yappc:password@localhost:5432/yappc

# Redis connection
REDIS_URL=redis://localhost:6379

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret (generate a strong random string)
JWT_SECRET=your-secret-key-here-change-in-production

# Session secret
SESSION_SECRET=your-session-secret-here

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:7001,http://localhost:3000

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# AI Services (configure when implementing)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Cloud Storage (configure when implementing)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Prometheus metrics
METRICS_ENABLED=true

# ============================================================================
# DEVELOPMENT OPTIONS
# ============================================================================

# Enable GraphQL Playground
GRAPHQL_PLAYGROUND=true

# Enable debug mode
DEBUG=false

# Pretty print logs (disable in production)
PRETTY_LOGS=true

# ============================================================================
# NOTES
# ============================================================================
# - Gateway listens on port 7002 (exposed to frontend)
# - Java backend on port 7003 (internal only)
# - All frontend API calls go through port 7002
# - Gateway routes to Node.js (local) or Java (proxy)
