# YAPPC Environment Configuration Template
# Copy this file to .env and .env.local for your local development setup

# ============================================================================
# SINGLE-PORT ARCHITECTURE CONFIGURATION
# ============================================================================
# Frontend talks to ONLY port 7002 (API Gateway)
# Gateway routes to Node.js (local) or Java backend (port 7003, internal)

# API Gateway URL (single entry point for all API calls)
VITE_API_ORIGIN=http://localhost:7002

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
NODE_ENV=development
VITE_APP_ENV=development

# Application Info
VITE_APP_NAME=YAPPC
VITE_APP_VERSION=1.0.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
VITE_ENABLE_LIFECYCLE=true
VITE_ENABLE_CANVAS=true
VITE_ENABLE_AI_AGENTS=true
VITE_ENABLE_DEVTOOLS=true

# ============================================================================
# DEVELOPMENT OPTIONS
# ============================================================================

# Use mock data for development
VITE_USE_MOCKS=false

# Enable debug logging
VITE_DEBUG=false
LOG_LEVEL=info

# Hot reload
VITE_HMR=true

# ============================================================================
# AUTHENTICATION (Optional - configure when ready)
# ============================================================================

# Auth0 / OAuth (configure when implementing auth)
# VITE_AUTH_DOMAIN=
# VITE_AUTH_CLIENT_ID=
# VITE_AUTH_AUDIENCE=

# ============================================================================
# OBSERVABILITY (Optional)
# ============================================================================

# Sentry (error tracking)
# VITE_SENTRY_DSN=

# Analytics
# VITE_ANALYTICS_ID=

# ============================================================================
# NOTES
# ============================================================================
# - DO NOT commit .env.local (contains secrets)
# - Frontend ONLY uses VITE_API_ORIGIN
# - All API calls go through port 7002 (Gateway)
# - Java backend (port 7003) is internal only
