    "idb-keyval": "^6.2.2",
    "isbot": "^5",
    "jotai": "^2.17.0",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.2",
    "perfect-freehand": "^1.2.3",
    "rbush": "^4.0.1",
    "react": "19.2.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
