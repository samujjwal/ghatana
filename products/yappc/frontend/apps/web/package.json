{
  "name": "@ghatana/yappc-web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:smoke": "vitest run src/__tests__/routes.spec.ts",
    "test:ui": "vitest --ui",
    "test:unit:canvas": "jest --config jest.canvas.config.ts src/components/canvas/**/*.test.{ts,tsx}",
    "test:integration:canvas": "jest --config jest.canvas.config.ts src/components/canvas/__tests__/performance-integration.test.tsx",
    "test:performance:canvas": "jest --config jest.canvas.config.ts src/components/canvas/__tests__/edge-cases.test.tsx",
    "test:e2e:canvas": "playwright test e2e/canvas-refactoring.spec.ts",
    "test:canvas:all": "node ../../test-runner.js",
    "test:canvas:unit": "node ../../test-runner.js --unit",
    "test:canvas:coverage": "node ../../test-runner.js --coverage",
    "test:canvas:watch": "node ../../test-runner.js --watch",
    "codegen": "graphql-codegen --config codegen.yml"
  },
  "dependencies": {
    "@apollo/client": "^4.1.3",
    "@base-ui/react": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ghatana/canvas": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/ui": "workspace:*",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@react-router/fs-routes": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.10.0",
    "@ghatana/yappc-ai": "workspace:*",
    "@ghatana/yappc-api": "workspace:*",
    "@ghatana/yappc-auth": "workspace:*",
    "@ghatana/yappc-canvas": "workspace:*",
    "@ghatana/yappc-code-editor": "workspace:*",
    "@ghatana/yappc-ide": "workspace:*",
    "@ghatana/yappc-testing": "workspace:*",
    "@ghatana/yappc-types": "workspace:*",
    "@ghatana/yappc-ui": "workspace:*",
    "@ghatana/yappc-crdt": "workspace:*",
    "@ghatana/yappc-collab": "workspace:*",
    "axe-core": "^4.11.1",
