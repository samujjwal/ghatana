{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "rootDirs": [
      ".",
      "./.react-router/types"
    ],
    "types": [
      "vite/client",
      "@react-router/node",
      "@react-router/dev"
    ],
    "paths": {
      "@ghatana/yappc-shared": [
        "../shared/types/index.ts"
      ],
      "@ghatana/yappc-shared/*": [
        "../shared/types/*"
      ],
      "@ghatana/yappc-mocks": [
        "../../libs/mocks/src/index.ts"
      ],
      "@ghatana/yappc-mocks/*": [
        "../../libs/mocks/src/*"
      ],
      "@ghatana/yappc-ai": [
        "../../libs/ai/src/index.ts"
      ],
      "@ghatana/yappc-ai/*": [
        "../../libs/ai/src/*"
      ],
      "@ghatana/yappc-ai-requirements-service": [
        "../../libs/ai-requirements-service/src/index.ts"
      ],
      "@ghatana/yappc-ai-requirements-service/*": [
        "../../libs/ai-requirements-service/src/*"
      ],
      "@ghatana/canvas": [
        "../../../../../libs/ghatana-canvas/src/index.ts"
      ],
      "@ghatana/canvas/*": [
        "../../../../../libs/ghatana-canvas/src/*"
      ],
      "@ghatana/yappc-canvas": [
        "../../libs/canvas/src/index.ts"
      ],
      "@ghatana/yappc-canvas/*": [
        "../../libs/canvas/src/*"
      ],
      "@ghatana/yappc-sketch": [
        "../../libs/canvas/src/sketch/index.ts"
      ],
      "@ghatana/yappc-sketch/*": [
        "../../libs/canvas/src/sketch/*"
      ],
      "@ghatana/yappc-code-editor": [
        "../../libs/code-editor/src/index.ts"
      ],
      "@ghatana/yappc-code-editor/*": [
        "../../libs/code-editor/src/*"
      ],
      "@ghatana/yappc-ide": [
        "../../libs/ide/src/index.ts"
      ],
      "@ghatana/yappc-ide/*": [
        "../../libs/ide/src/*"
      ],
      "@ghatana/yappc-types": [
        "../../libs/types/src"
      ],
      "@ghatana/yappc-types/*": [
        "../../libs/types/src/*"
      ],
      "@ghatana/yappc-types/devsecops": [
        "../../libs/types/src/devsecops"
      ],
      "@ghatana/yappc-types/devsecops/*": [
        "../../libs/types/src/devsecops/*"
      ],
      "@ghatana/yappc-api": [
        "../../libs/api/src"
      ],
      "@ghatana/yappc-api/*": [
        "../../libs/api/src/*"
      ],
      "@ghatana/yappc-ui": [
        "../../libs/ui/src/index.ts"
      ],
      "@ghatana/yappc-ui/*": [
        "../../libs/ui/src/*"
      ],
      "@ghatana/yappc-store": [
        "../../libs/state/src/index.ts"
      ],
      "@ghatana/yappc-store/*": [
        "../../libs/state/src/*"
      ],
        "../../libs/state/src/index.ts"
      ],
      "@ghatana/yappc-state/*": [
        "../../libs/state/src/*"
      ],
      "@ghatana/yappc-auth": [
        "../../libs/auth/src/index.ts"
      ],
      "@ghatana/yappc-auth/*": [
        "../../libs/auth/src/*"
      ],
      "@ghatana/yappc-audit": [
        "../../libs/audit/src/index.ts"
      ],
      "@ghatana/yappc-audit/*": [
        "../../libs/audit/src/*"
      ],
      "@/shared/*": [
        "../shared/*"
      ],
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "references": [
    {
      "path": "../../libs/types/tsconfig.json"
    },
    {
      "path": "../../libs/state/tsconfig.json"
    },
    {
      "path": "../../libs/graphql/tsconfig.json"
    },
    {
      "path": "../../libs/mocks/tsconfig.json"
    },
    {
      "path": "../../libs/ui/tsconfig.json"
    },
    {
      "path": "../../libs/api/tsconfig.json"
    },
    {
      "path": "../../libs/canvas/tsconfig.json"
    },
    {
      "path": "../../libs/code-editor/tsconfig.json"
    },
    {
      "path": "../../libs/ide/tsconfig.json"
    },
    {
      "path": "../../libs/ai/tsconfig.json"
    }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "../../libs/**/__tests__/**/*",
    "../../libs/**/?(*.)+(spec|test).[tj]s?(x)",
    "../../libs/**/stories/**/*",
    "../../libs/**/storybook/**/*"
  ]
}
