#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"
. "$(dirname -- "$0")/_/performance.sh"

# Enable debug output if HUSKY_DEBUG is set
[ "$HUSKY_DEBUG" = "1" ] && set -x

# Check hook version
if [ -f "$(dirname -- "$0")/version" ]; then
  . "$(dirname -- "$0")/version"
  if [ "$HOOKS_VERSION" != "1.0.0" ]; then
    echo "Warning: pre-push hook version ($HOOKS_VERSION) does not match expected version (1.0.0)"
  fi
fi

# Check for required dependencies
check_dependencies pnpm node || exit 1

# Start performance measurement
start_perf_measurement

# Function to run commands with error handling
run_command() {
  local cmd="$1"
  local name="$2"
  
  echo "Running: $name..."
  if ! eval "$cmd"; then
    echo "Error: $name failed"
    end_perf_measurement "pre-push-failed-$name"
    return 1
  fi
  return 0
}

# Run typecheck
if ! run_command "pnpm run typecheck" "Type checking"; then
  exit 1
fi

# Run tests
if ! run_command "pnpm run test" "Tests"; then
  exit 1
fi

# Log performance
end_perf_measurement "pre-push"
