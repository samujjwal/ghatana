#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"
. "$(dirname -- "$0")/_/performance.sh"

# Enable debug output if HUSKY_DEBUG is set
[ "$HUSKY_DEBUG" = "1" ] && set -x

# Check hook version
if [ -f "$(dirname -- "$0")/version" ]; then
  . "$(dirname -- "$0")/version"
  if [ "$HOOKS_VERSION" != "1.0.0" ]; then
    echo "Warning: commit-msg hook version ($HOOKS_VERSION) does not match expected version (1.0.0)"
  fi
fi

# Check for required dependencies
check_dependencies pnpm commitlint || exit 1

# Start performance measurement
start_perf_measurement

# Run commitlint
if ! pnpm commitlint --edit "$1"; then
  end_perf_measurement "commit-msg-failed"
  exit 1
fi

# Log performance
end_perf_measurement "commit-msg"
