    "prettier": "^3.8.1",
    "storybook": "^10.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
