{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "types": ["vite/client", "node", "react", "react-dom"],
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/hooks/*"],
      "@stores/*": ["src/stores/*"],
      "@types/*": ["src/types/*"],
      "@api/*": ["src/api/*"],
      "@utils/*": ["src/utils/*"],
      "@ghatana/design-system": [
        "../../../platform/typescript/capabilities/design-system"
      ],
      "@ghatana/canvas/flow": [
        "../../../platform/typescript/canvas/src/flow/index.ts"
      ],
      "@ghatana/theme": ["../../../platform/typescript/theme"],
      "@ghatana/tokens": ["../../../platform/typescript/tokens"],
      "@ghatana/platform-utils": [
        "../../../platform/typescript/foundation/platform-utils"
      ],
      "@ghatana/canvas": ["../../../platform/typescript/canvas/src/index.ts"],
      "@ghatana/canvas/*": ["../../../platform/typescript/canvas/src/*/index.ts"],
      "@ghatana/privacy-ui": [
        "../../../platform/typescript/privacy-ui/src"
      ],
      "@ghatana/security-ui": [
        "../../../platform/typescript/security-ui/src"
      ],
      "@ghatana/voice-ui": [
        "../../../platform/typescript/voice-ui/src"
      ],
      "@ghatana/nlp-ui": [
        "../../../platform/typescript/nlp-ui/src"
      ],
      "@ghatana/audit-ui": [
        "../../../platform/typescript/audit-ui/src"
      ],
      "@ghatana/selection-ui": [
        "../../../platform/typescript/selection-ui/src"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "./src/types"
    ]
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "**/*.stories.tsx"
  ],
  "exclude": ["node_modules", "dist", "build"]
}
