{
  "name": "@data-cloud/ui",
  "version": "0.1.0",
  "description": "Data Cloud Platform UI - React + TypeScript + Jotai + Tailwind",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "DC-SHARED-002 Note": "This package requires dependency audit to remove unused workspace dependencies and avoid library sprawl. Unused dependency scan is required to verify all dependencies are actually used.",
  "scripts": {
    "dev": "vite",
    "build": "pnpm generate:api-types && vite build",
    "bundle:check": "bash scripts/check-bundle-budgets.sh",
    "bundle:check:ci": "bash scripts/check-bundle-budgets.sh --skip-build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test": "pnpm run test:readiness",
    "test:coverage": "vitest run --coverage",
    "test:readiness": "vitest run src/__tests__/pages/ContractBacked.test.tsx src/__tests__/api/capabilities.service.test.ts",
    "test:ui": "vitest --ui",
    "test:contract": "vitest run tests/contract",
    "test:contract:watch": "vitest tests/contract",
    "docs:routes:generate": "tsx scripts/generate-route-truth-matrix.ts",
    "docs:routes:check": "tsx scripts/generate-route-truth-matrix.ts --check",
    "generate:api-types": "tsx scripts/generate-api-types.ts",
    "check:api-types": "tsx scripts/check-api-types.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ghatana/audit": "workspace:*",
    "@ghatana/canvas": "workspace:*",
    "@ghatana/design-system": "workspace:*",
    "@ghatana/domain-components": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/realtime": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@ghatana/wizard": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.99.0",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "i18next": "^26.0.4",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-router": "^7.14.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "msw": "^2.13.2",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
