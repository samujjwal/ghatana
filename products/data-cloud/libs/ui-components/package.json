{
  "name": "@data-cloud/ui-components",
  "version": "0.1.0",
  "description": "Reusable UI components for Data Cloud — presentation layer extracted from the application.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./common": {
      "import": "./dist/components/common/index.js",
      "types": "./dist/components/common/index.d.ts"
    },
    "./cards": {
      "import": "./dist/components/cards/index.js",
      "types": "./dist/components/cards/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/platform-utils": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "lucide-react": "^1.8.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  }
}
