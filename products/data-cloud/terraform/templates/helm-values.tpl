# Helm values snippet for data-cloud deployment
# Generated by Terraform — do not edit manually.
# Apply with: helm upgrade data-cloud ./helm/data-cloud -f <(terraform output -raw helm_values_snippet)

kafka:
  bootstrapServers: "${kafka_bootstrap_brokers}"
  sasl:
    mechanism: SCRAM-SHA-512
    secretName: kafka-credentials   # pre-seeded from MSK Secrets Manager secret

postgres:
  host: "${rds_endpoint}"
  port: 5432
  database: "datacloud"
  secretName: rds-credentials       # pre-seeded from RDS Secrets Manager secret

clickhouse:
  hosts:
%{ for ip in clickhouse_ips ~}
    - "${ip}"
%{ endfor ~}
  port: 8123
  database: "datacloud"
  secretName: clickhouse-credentials

opensearch:
  host: "${opensearch_endpoint}"
  port: 443
  scheme: https

ceph:
  endpoint: "${s3_blob_bucket_id}.s3.${aws_region}.amazonaws.com"
  bucket: "${s3_blob_bucket_id}"
  irsaRoleArn: "${s3_irsa_role_arn}"

redis:
  host: "${redis_primary_endpoint}"
  readerHost: "${redis_reader_endpoint}"
  port: 6379
  tls: true
  secretName: redis-credentials     # pre-seeded from ElastiCache Secrets Manager secret

serviceAccount:
  annotations:
    eks.amazonaws.com/role-arn: "${s3_irsa_role_arn}"
