{
  "name": "@ghatana/flashit-tests",
  "version": "1.0.0",
  "description": "Comprehensive test suite for Flashit application",
  "private": true,
  "scripts": {
    "dev": "./run-dev.sh",
    "dev:start": "./run-dev.sh start",
    "dev:stop": "./run-dev.sh stop",
    "dev:restart": "./run-dev.sh restart",
    "dev:status": "./run-dev.sh status",
    "dev:clean": "./run-dev.sh clean",
    "dev:logs": "./run-dev.sh logs",
    "dev:test": "./run-dev.sh test",
    "dev:api": "cd apps/web-api && tsx watch src/server.ts",
    "dev:web": "cd apps/web && vite --port 2901 --host",
    "dev:mobile": "cd apps/mobile && expo start --port 2902",
    "test": "node scripts/test-runner.js all",
    "test:unit": "node scripts/test-runner.js unit",
    "test:integration": "node scripts/test-runner.js integration",
    "test:e2e": "node scripts/test-runner.js e2e",
    "test:performance": "node scripts/test-runner.js performance",
    "test:watch": "node scripts/test-runner.js all --watch",
    "test:coverage": "node scripts/test-runner.js all --coverage",
    "test:no-coverage": "node scripts/test-runner.js all --no-coverage",
    "test:silent": "node scripts/test-runner.js all --silent",
    "test:bail": "node scripts/test-runner.js all --bail",
    "test:leaks": "node scripts/test-runner.js all --detectLeaks",
    "test:update-snapshots": "node scripts/test-runner.js all --updateSnapshot",
    "test:ci": "node scripts/test-runner.js all --no-coverage --silent --bail",
    "test:specific": "jest",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:performance-only": "jest --testPathPattern=performance --testTimeout=300000",
    "test:ai-services": "jest --testPathPattern=ai-analytics-services.test.ts",
    "test:collaboration": "jest --testPathPattern=collaboration-realtime-services.test.ts",
    "test:privacy-security": "jest --testPathPattern=privacy-security-services.test.ts",
    "test:load-performance": "jest --testPathPattern=performance-services.test.ts",
    "setup:test-db": "DATABASE_URL=$TEST_DATABASE_URL npx prisma db push --force-reset",
    "teardown:test-db": "DATABASE_URL=$TEST_DATABASE_URL npx prisma db push --force-reset",
    "clean:test-cache": "rm -rf .jest-cache coverage test-reports",
    "lint:tests": "eslint tests/ --ext .ts",
    "format:tests": "prettier --write tests/**/*.ts",
    "validate:tests": "npm run lint:tests && npm run format:tests",
    "report:open": "open test-reports/test-report.html",
    "report:coverage": "open coverage/lcov-report/index.html",
    "benchmark": "node scripts/benchmark-runner.js",
    "stress-test": "node scripts/stress-test-runner.js",
    "pre-commit-tests": "npm run test:unit && npm run test:integration",
    "pre-push-tests": "npm run test:ci",
    "quality-gate": "npm run validate:tests && npm run test:coverage && npm run security-check",
    "demo:seed": "cd scripts/demo-data && pnpm install && pnpm seed",
    "demo:seed:small": "cd scripts/demo-data && pnpm install && pnpm seed:small",
    "demo:seed:medium": "cd scripts/demo-data && pnpm install && pnpm seed:medium",
    "demo:seed:large": "cd scripts/demo-data && pnpm install && pnpm seed:large",
    "demo:seed:minimal": "cd scripts/demo-data && pnpm install && pnpm seed:minimal",
    "demo:run": "cd scripts/demo-data && pnpm install && pnpm demo",
    "demo:onboarding": "cd scripts/demo-data && pnpm install && pnpm demo:onboarding",
    "demo:journal": "cd scripts/demo-data && pnpm install && pnpm demo:journal",
    "demo:search": "cd scripts/demo-data && pnpm install && pnpm demo:search",
    "demo:analytics": "cd scripts/demo-data && pnpm install && pnpm demo:analytics",
    "demo:crud": "cd scripts/demo-data && pnpm install && pnpm demo:crud",
    "demo:export:json": "cd scripts/demo-data && pnpm install && pnpm export:json",
    "demo:export:csv": "cd scripts/demo-data && pnpm install && pnpm export:csv",
    "demo:export:sql": "cd scripts/demo-data && pnpm install && pnpm export:sql",
    "demo:test-cycle": "cd scripts/demo-data && pnpm install && pnpm test:data",
    "security-check": "npm audit --audit-level moderate",
    "dependency-check": "npx npm-check-updates",
    "test:health": "node scripts/health-check.js",
    "health": "node scripts/health-check.js",
    "health:quick": "node scripts/health-check.js --quick",
    "audit:security": "tsx scripts/security-audit.ts",
    "audit:accessibility": "tsx scripts/accessibility-audit.ts",
    "audit:all": "npm run audit:security && npm run audit:accessibility"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/client": "^7.3.0",
    "bullmq": "^5.67.2",
    "ioredis": "^5.9.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.19.0",
    "axios": "^1.13.4",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "testing",
    "jest",
    "typescript",
    "integration-tests",
    "performance-tests",
    "e2e-tests",
    "flashit"
  ],
  "author": "Flashit Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flashit/flashit.git",
    "directory": "products/flashit"
  },
  "bugs": {
    "url": "https://github.com/flashit/flashit/issues"
  },
  "homepage": "https://github.com/flashit/flashit#readme"
}
