# Flashit Development Environment Configuration

# Application
NODE_ENV=development
APP_NAME=flashit
VERSION=1.0.0

# Database
DATABASE_URL=postgresql://ghatana:ghatana123@localhost:5432/flashit_dev
TEST_DATABASE_URL=postgresql://ghatana:ghatana123@localhost:5432/flashit_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Configuration
API_PORT=2900
API_BASE_URL=http://localhost:2900

# Web App
WEB_PORT=2901
WEB_BASE_URL=http://localhost:2901

# Mobile App (React Native)
MOBILE_PORT=2902

# Admin Portal
ADMIN_PORT=2903
ADMIN_BASE_URL=http://localhost:2903

# JWT Configuration
JWT_SECRET=dev_jwt_secret_key_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# OpenAI Configuration (for AI services)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS Configuration (for media storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=flashit-dev-media

# Email Configuration (for notifications)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@flashit.dev

# WebSocket Configuration
WS_PORT=8080

# File Upload Configuration
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=image/*,audio/*,video/*,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Development Settings
LOG_LEVEL=debug
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000
ENABLE_SWAGGER=true

# Testing Configuration
TEST_TIMEOUT=30000
MOCK_EXTERNAL_SERVICES=true

# Performance Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
