# Flashit Environment Configuration Template
# Copy this file to .env.development for development
# Copy this file to .env.production for production

# =================================
# APPLICATION CONFIGURATION
# =================================

# Environment
NODE_ENV=development
APP_NAME=flashit
VERSION=1.0.0
DEBUG=flashit:*

# Server Configuration
API_PORT=8000
WEB_PORT=3000
MOBILE_PORT=8081
WS_PORT=8080

# Base URLs
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# =================================
# DATABASE CONFIGURATION
# =================================

# PostgreSQL Database URLs
# Development Database
DATABASE_URL=postgresql://${DB_USER:-ghatana}:${DB_PASSWORD:-ghatana123}@${DB_HOST:-localhost}:${DB_PORT:-5432}/${DB_NAME:-ghatana}

# Test Database
TEST_DATABASE_URL=postgresql://${DB_USER:-ghatana}:${DB_PASSWORD:-ghatana123}@${DB_HOST:-localhost}:${DB_PORT:-5432}/${DB_NAME:-ghatana}

# Production Database (use strong passwords in production)
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# =================================
# REDIS CONFIGURATION
# =================================

REDIS_HOST=${REDIS_HOST:-localhost}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_PASSWORD=${REDIS_PASSWORD:-redis123}
REDIS_DB=0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2

# Redis URLs (alternative format)
# REDIS_URL=redis://localhost:6379
# REDIS_SESSION_URL=redis://localhost:6379/1

# =================================
# AUTHENTICATION & SECURITY
# =================================

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=flashit-app

# Session Configuration
SESSION_SECRET=your_super_secret_session_key_change_in_production
SESSION_NAME=flashit_session
SESSION_MAX_AGE=86400000

# Password Configuration
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# =================================
# AI SERVICES CONFIGURATION
# =================================

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# AI Service Configuration
AI_SERVICE_TIMEOUT=30000
AI_MAX_CONCURRENT_REQUESTS=5
AI_RATE_LIMIT_PER_MINUTE=60

# =================================
# MEDIA & FILE STORAGE
# =================================

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=flashit-media-bucket
S3_PUBLIC_BUCKET=flashit-public-assets

# MinIO Configuration (for development)
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=flashit-dev-media

# CloudFront Configuration (for production)
CLOUDFRONT_DISTRIBUTION_ID=your_cloudfront_distribution_id
CDN_DOMAIN=cdn.flashit.app

# File Upload Configuration
MAX_FILE_SIZE=100MB
MAX_FILES_PER_UPLOAD=10
ALLOWED_FILE_TYPES=image/*,audio/*,video/*,application/pdf
UPLOAD_TIMEOUT=300000

# =================================
# EMAIL CONFIGURATION
# =================================

# SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@flashit.app
SMTP_FROM_NAME=Flashit

# Production Email Services (choose one)
# SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# Amazon SES
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY_ID=your_ses_access_key
# AWS_SES_SECRET_ACCESS_KEY=your_ses_secret_key

# Mailgun
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.yourdomain.com

# =================================
# NOTIFICATION CONFIGURATION
# =================================

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Apple Push Notifications
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id
APNS_BUNDLE_ID=com.flashit.app

# Web Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@flashit.app

# =================================
# REAL-TIME FEATURES
# =================================

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_IP=10
WS_MAX_ROOMS_PER_USER=50
WS_MESSAGE_RATE_LIMIT=100

# Socket.IO Configuration
SOCKETIO_ADAPTER=redis
SOCKETIO_STICKY_SESSIONS=true
SOCKETIO_CORS_ORIGIN=http://localhost:3000

# =================================
# ANALYTICS & MONITORING
# =================================

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=10000

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Error Tracking (Sentry)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# =================================
# PERFORMANCE & CACHING
# =================================

# Cache Configuration
CACHE_TTL_DEFAULT=3600
CACHE_TTL_USER=7200
CACHE_TTL_STATIC=86400
CACHE_MAX_ITEMS=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STORE=redis

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_THRESHOLD=1024
COMPRESSION_LEVEL=6

# =================================
# DEVELOPMENT CONFIGURATION
# =================================

# Development Settings
ENABLE_SWAGGER=true
SWAGGER_PATH=/docs
ENABLE_CORS=true
TRUST_PROXY=true

# Hot Reload
HOT_RELOAD=true
WATCH_FILES=true

# Mock Services (for development/testing)
MOCK_AI_SERVICES=false
MOCK_EMAIL_SERVICES=true
MOCK_PUSH_NOTIFICATIONS=true
MOCK_PAYMENT_SERVICES=true

# Debug Configuration
DEBUG_SQL=false
DEBUG_REDIS=false
DEBUG_WEBSOCKET=false

# =================================
# TESTING CONFIGURATION
# =================================

# Test Configuration
TEST_TIMEOUT=30000
TEST_PARALLEL=true
TEST_COVERAGE_THRESHOLD=85

# Test Database Configuration
TEST_DB_RESET=true
TEST_DB_SEED=true

# Test Service Mocking
MOCK_EXTERNAL_SERVICES=true
MOCK_OPENAI_API=true
MOCK_AWS_SERVICES=true

# =================================
# PRODUCTION CONFIGURATION
# =================================

# Security Headers
HELMET_ENABLED=true
HSTS_ENABLED=true
CSP_ENABLED=true

# SSL Configuration
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30000

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30000

# =================================
# FEATURE FLAGS
# =================================

# Core Features
FEATURE_USER_REGISTRATION=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_EMAIL_VERIFICATION=true

# AI Features
FEATURE_AI_TRANSCRIPTION=true
FEATURE_AI_EMBEDDINGS=true
FEATURE_AI_REFLECTIONS=true
FEATURE_SEMANTIC_SEARCH=true

# Collaboration Features
FEATURE_SPHERE_SHARING=true
FEATURE_REAL_TIME_COLLABORATION=true
FEATURE_COMMENTS_REACTIONS=true
FEATURE_USER_FOLLOWING=true

# Advanced Features
FEATURE_ANALYTICS_DASHBOARD=true
FEATURE_EXPORT_DATA=true
FEATURE_MOBILE_APP=true
FEATURE_PROGRESSIVE_UPLOAD=true

# Beta Features
FEATURE_AI_INSIGHTS=false
FEATURE_VOICE_NOTES=false
FEATURE_VIDEO_TRANSCRIPTION=false

# =================================
# MOBILE APP CONFIGURATION
# =================================

# React Native Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8080

# Deep Linking
DEEP_LINK_SCHEME=flashit
DEEP_LINK_HOST=app.flashit.com

# App Store Configuration
IOS_BUNDLE_ID=com.flashit.app
ANDROID_PACKAGE=com.flashit.app

# =================================
# BACKUP & MAINTENANCE
# =================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=flashit-backups

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please try again later.

# =================================
# LOCALIZATION
# =================================

# Language Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,zh,ja,ko

# Timezone Configuration
DEFAULT_TIMEZONE=UTC
DETECT_USER_TIMEZONE=true

# =================================
# COMPLIANCE & PRIVACY
# =================================

# GDPR Compliance
GDPR_ENABLED=true
GDPR_RETENTION_PERIOD=2555
GDPR_DELETION_SCHEDULE=0 3 * * *

# Privacy Configuration
PRIVACY_MODE=standard
ANONYMIZE_IPS=true
COLLECT_ANALYTICS=true

# Cookie Configuration
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_HTTP_ONLY=true

# =================================
# CUSTOM CONFIGURATION
# =================================

# Add your custom environment variables here
# CUSTOM_FEATURE_FLAG=true
# CUSTOM_API_ENDPOINT=https://api.example.com
# CUSTOM_TIMEOUT=5000
