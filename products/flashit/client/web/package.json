{
  "name": "@flashit/web",
  "version": "0.1.0",
  "description": "Flashit web application for capturing and reflecting on Moments",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test": "playwright test",
    "test:coverage": "playwright test --reporter=line",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ghatana/design-system": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/theme": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@flashit/shared": "workspace:*",
    "@tanstack/query-core": "^5.100.10",
    "@tanstack/react-query": "catalog:",
    "date-fns": "catalog:",
    "jotai": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "scheduler": "^0.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "author": "Ghatana FlashIt Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samujjwal/ghatana.git",
    "directory": "products/flashit/client/web"
  },
  "bugs": {
    "url": "https://github.com/samujjwal/ghatana/issues"
  },
  "homepage": "https://github.com/samujjwal/ghatana/tree/main/products/flashit/client/web#readme"
}
