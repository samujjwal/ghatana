{
  "name": "@ghatana/flashit-mobile",
  "version": "0.1.0",
  "description": "Flashit mobile app for iOS and Android",
  "main": "index.js",
  "browser": "index.web.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:e2e": "detox test",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:ios:release": "detox test --configuration ios.sim.release",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:android:release": "detox test --configuration android.emu.release",
    "build:e2e:ios": "detox build --configuration ios.sim.debug",
    "build:e2e:android": "detox build --configuration android.emu.debug",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@ghatana/flashit-shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "@tanstack/react-query": "^5.90.12",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "date-fns": "^4.1.0",
    "expo": "^54.0.30",
    "expo-audio": "^1.1.1",
    "expo-av": "~16.0.8",
    "expo-background-fetch": "^14.0.9",
    "expo-camera": "^17.0.10",
    "expo-file-system": "^19.0.21",
    "expo-image-manipulator": "^14.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-modules-core": "^3.0.29",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "^14.0.9",
    "expo-updates": "^29.0.15",
    "expo-video": "^3.0.15",
    "jotai": "^2.16.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@types/react": "^19.1.17",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "detox": "^20.46.1",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "react-native": "0.81",
    "typescript": "^5.9.3"
  },
  "private": true
}