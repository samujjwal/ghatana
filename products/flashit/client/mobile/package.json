{
  "name": "@flashit/mobile",
  "version": "0.1.0",
  "description": "Flashit mobile app for iOS and Android",
  "main": "index.js",
  "browser": "index.web.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:e2e": "detox test",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:ios:release": "detox test --configuration ios.sim.release",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:android:release": "detox test --configuration android.emu.release",
    "build:e2e:ios": "detox build --configuration ios.sim.debug",
    "build:e2e:android": "detox build --configuration android.emu.debug",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@babel/runtime": "^7.29.2",
    "@flashit/shared": "workspace:*",
    "@ghatana/product-shell": "workspace:*",
    "@ghatana/tokens": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@tanstack/react-query": "^5.100.14",
    "@types/react-dom": "~19.2.3",
    "date-fns": "^4.1.0",
    "expo": "^55.0.14",
    "expo-application": "^55.0.14",
    "expo-audio": "^55.0.13",
    "expo-av": "~16.0.8",
    "expo-battery": "^55.0.13",
    "expo-background-fetch": "^55.0.14",
    "expo-camera": "^55.0.15",
    "expo-constants": "^55.0.13",
    "expo-device": "^55.0.14",
    "expo-file-system": "^55.0.16",
    "expo-haptics": "^55.0.14",
    "expo-image-manipulator": "^55.0.15",
    "expo-image-picker": "^55.0.18",
    "expo-linking": "^55.0.12",
    "expo-local-authentication": "^55.0.13",
    "expo-modules-core": "^55.0.22",
    "expo-network": "^55.0.13",
    "expo-notifications": "^55.0.18",
    "expo-router": "^55.0.12",
    "expo-secure-store": "^55.0.13",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-task-manager": "^55.0.14",
    "expo-updates": "^55.0.20",
    "expo-video": "^55.0.15",
    "jotai": "^2.19.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "0.85.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "detox": "^20.50.1",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "typescript": "^6.0.2"
  },
  "private": true,
  "author": "Ghatana FlashIt Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samujjwal/ghatana.git",
