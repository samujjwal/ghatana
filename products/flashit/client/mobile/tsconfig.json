{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node", "react", "react-native"],
    "paths": {
      "@/*": ["./src/*"],
      "@ghatana/platform-utils": ["../../../../platform/typescript/platform-utils/src/index.ts"],
      "@ghatana/product-shell": ["../../../../platform/typescript/product-shell/src/index.ts"],
      "@ghatana/tokens": ["../../../../platform/typescript/tokens/src/index.ts"]
    }
  },
  "include": ["src", "App.tsx"],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/__tests__"
  ],
  "extends": "expo/tsconfig.base"
}
