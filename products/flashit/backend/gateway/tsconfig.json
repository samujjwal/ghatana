{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"],
    "typeRoots": [
      "../../types",
      "../../../node_modules/@types",
      "../../../../node_modules/@types"
    ]
  },
  "typeAcquisition": {
    "enable": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/__tests__/**"]
}
