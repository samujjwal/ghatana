# Flashit Web API Environment Variables
# Copy this to .env and fill in the values

NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://flashit:flashit@localhost:5432/flashit_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRY_DAYS=30

# Context Service (Java/ActiveJ backend)
CONTEXT_SERVICE_URL=http://localhost:8080

# AWS S3 Configuration (required for Week 3 - Voice & Video Capture)
S3_BUCKET=flashit-media-dev
S3_REGION=us-east-1
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Email Configuration
EMAIL_PROVIDER=stub # Options: stub, smtp, ses
EMAIL_FROM=noreply@flashit.app

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Java Agent Service
JAVA_AGENT_SERVICE_URL=http://localhost:8090
USE_JAVA_AGENT_CLASSIFICATION=true

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_TEAMS_MONTHLY=price_teams_monthly_id
STRIPE_PRICE_TEAMS_ANNUAL=price_teams_annual_id

# Application URLs
APP_URL=http://localhost:2900

