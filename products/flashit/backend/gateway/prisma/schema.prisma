model TopicNode {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String   @db.VarChar(255)
  normalizedName String @map("normalized_name") @db.VarChar(255)
  description  String?  @db.Text
  momentCount  Int      @default(0) @map("moment_count")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations — edges are tracked via GraphEdge
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId])
  @@index([normalizedName])
  @@index([momentCount(sort: Desc)])
  @@index([userId, lastSeenAt])
  @@map("topic_nodes")
}

model EntityNode {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(255)
  normalizedName String   @map("normalized_name") @db.VarChar(255)
  entityType     String   @map("entity_type") @db.VarChar(50) // person, place, org, concept
  wikidataId     String?  @map("wikidata_id") @db.VarChar(50)
  mentionCount   Int      @default(0) @map("mention_count")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations — edges are tracked via GraphEdge
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName, entityType])
  @@index([userId])
  @@index([normalizedName])
  @@index([entityType])
  @@index([mentionCount(sort: Desc)])
  @@index([userId, lastSeenAt])
  @@map("entity_nodes")
}

model GraphEdge {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  sourceType  String   @map("source_type") @db.VarChar(50) // topic, entity, moment, sphere
  sourceId    String   @map("source_id") @db.Uuid
  targetType  String   @map("target_type") @db.VarChar(50)
  targetId    String   @map("target_id") @db.Uuid
  edgeType    String   @map("edge_type") @db.VarChar(100) // related_to, mentioned_in, co_occurs, part_of
  weight      Decimal  @default(1.0) @db.Decimal(5, 4)
  occurrences Int      @default(1)
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId, targetType, targetId, edgeType])
  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([edgeType])
  @@index([weight(sort: Desc)])
  @@map("graph_edges")
}

