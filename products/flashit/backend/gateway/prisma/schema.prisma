// ==========================================================================
// Recommendation Engine (P0 Remediation)
// ==========================================================================

enum RecommendationType {
  REVISIT
  CONNECT
  HABIT
  WELLBEING
  EXPLORE
}

enum RecommendationStatus {
  ACTIVE
  DISMISSED
  ACTED
  EXPIRED
}

model Recommendation {
  id                String               @id @default(uuid()) @db.Uuid
  userId            String               @map("user_id") @db.Uuid
  type              RecommendationType
  strategy          String               @db.VarChar(100)
  title             String               @db.VarChar(500)
  content           String               @db.Text
  score             Decimal              @db.Decimal(5, 4)
  status            RecommendationStatus @default(ACTIVE)
  relatedMomentIds  String[]             @map("related_moment_ids")
  relatedSphereIds  String[]             @map("related_sphere_ids")
  metadata          Json?                @db.JsonB
  expiresAt         DateTime?            @map("expires_at") @db.Timestamptz
  actedAt           DateTime?            @map("acted_at") @db.Timestamptz
  dismissedAt       DateTime?            @map("dismissed_at") @db.Timestamptz
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback RecommendationFeedback[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([userId, status])
  @@index([score(sort: Desc)])
  @@index([expiresAt])
  @@index([createdAt(sort: Desc)])
  @@map("recommendations")
}

model RecommendationFeedback {
  id               String   @id @default(uuid()) @db.Uuid
  recommendationId String   @map("recommendation_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  action           String   @db.VarChar(50) // clicked, dismissed, helpful, not_helpful
  rating           Int?     // 1-5 star rating
  comment          String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
  @@index([recommendationId])
  @@index([userId])
  @@index([action])
  @@map("recommendation_feedback")
}

