{
  "name": "@ghatana/flashit-web-api",
  "version": "0.1.0",
  "description": "Flashit Fastify API for capture, search, and reflection",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "npm run db:generate || true",
    "dev": "npm run db:generate && tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json || true",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:clean": "rm -rf generated/prisma",
    "db:generate": "npm run db:clean && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/client-ses": "^3.962.0",
    "@aws-sdk/s3-request-presigner": "^3.962.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.4.2",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.2",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.2",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^6.15.0",
    "otplib": "^12.0.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "stripe": "^20.1.2",
    "ua-parser-js": "^1.0.39",
    "undici": "^7.18.0",
    "zod": "^4.2.1",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.8",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "@testing-library/react": "^16.2.0",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
