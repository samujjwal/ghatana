{
  "name": "@flashit/web-api",
  "version": "0.1.0",
  "description": "Flashit Fastify API for capture, search, and reflection",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "npm run db:generate || true",
    "dev": "npm run db:generate && tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json || true",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:clean": "rm -rf generated/prisma",
    "db:generate": "npm run db:clean && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/client-ses": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.4",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "stripe": "^22.0.1",
    "ua-parser-js": "^2.0.9",
    "undici": "^8.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "@testing-library/react": "^16.3.2",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
