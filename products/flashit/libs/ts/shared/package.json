{
    "name": "@ghatana/flashit-shared",
    "version": "0.1.0",
    "description": "Shared types, utilities, and API client for Flashit applications",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "test": "vitest"
    },
    "dependencies": {
        "date-fns": "^4.1.0",
        "jotai": "^2.17.0",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/node": "^25.0.3",
        "@vitest/coverage-v8": "^2.1.9",
        "typescript": "^5.9.3",
        "vitest": "^2.1.9"
    }
}