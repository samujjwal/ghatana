{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bootstrap Evidence Schema",
  "description": "Schema for validating bootstrap evidence files across products",
  "type": "object",
  "required": ["schemaVersion", "productId", "environment", "targetEnv", "generatedAt", "commitSha", "bootstrap"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "productId": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["local", "dev", "staging", "prod"]
    },
    "targetEnv": {
      "type": "string",
      "enum": ["local", "dev", "staging", "prod"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "bootstrap": {
      "type": "object",
      "required": ["validated", "validatedAt"],
      "properties": {
        "validated": {
          "type": "boolean"
        },
        "validatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "failClosed": {
          "type": "boolean"
        },
        "postgres": {
          "type": "object",
          "required": ["status", "host", "port", "database", "evidence"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "host": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "database": {
              "type": "string"
            },
            "rlsEnabled": {
              "type": "boolean"
            },
            "tenantIsolation": {
              "type": "string"
            },
            "connectionPoolMax": {
              "type": "integer",
              "minimum": 1
            },
            "sslMode": {
              "type": "string"
            },
            "evidence": {
              "type": "string"
            },
            "migrationStatus": {
              "type": "string"
            },
            "multiAz": {
              "type": "boolean"
            },
            "replicationEnabled": {
              "type": "boolean"
            }
          }
        },
        "migrations": {
          "type": "object",
          "required": ["status", "tool", "appliedCount", "pendingCount"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "tool": {
              "type": "string"
            },
            "appliedCount": {
              "type": "integer",
              "minimum": 0
            },
            "pendingCount": {
              "type": "integer",
              "minimum": 0
            },
            "lastApplied": {
              "type": "string"
            },
            "migrationPath": {
              "type": "string"
            },
            "checksumVerified": {
              "type": "boolean"
            },
            "backupBeforeMigration": {
              "type": "boolean"
            }
          }
        },
        "secrets": {
          "type": "object",
          "required": ["status", "provider", "secretsPath", "requiredSecrets", "allSecretsPresent"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "provider": {
              "type": "string"
            },
            "secretsPath": {
              "type": "string"
            },
            "requiredSecrets": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allSecretsPresent": {
              "type": "boolean"
            },
            "rotationPolicy": {
              "type": "string"
            },
            "kmsEnabled": {
              "type": "boolean"
            }
          }
        },
        "storage": {
          "type": "object",
          "required": ["status", "type", "bucket", "region"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "type": {
              "type": "string"
            },
            "bucket": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "encryption": {
              "type": "string"
            },
            "versioning": {
              "type": "boolean"
            },
            "retentionPolicy": {
              "type": "string"
            },
            "crossRegionReplication": {
              "type": "boolean"
            },
            "objectLock": {
              "type": "boolean"
            }
          }
        },
        "distributedCache": {
          "type": "object",
          "required": ["status", "type", "host", "port"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "type": {
              "type": "string"
            },
            "host": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "clusterMode": {
              "type": "boolean"
            },
            "replicationFactor": {
              "type": "integer",
              "minimum": 1
            },
            "maxMemoryPolicy": {
              "type": "string"
            },
            "tlsEnabled": {
              "type": "boolean"
            },
            "consentCacheTtlSeconds": {
              "type": "integer",
              "minimum": 0
            },
            "invalidationSupported": {
              "type": "boolean"
            },
            "persistenceEnabled": {
              "type": "boolean"
            }
          }
        },
        "dataCloud": {
          "type": "object",
          "required": ["status", "endpoint", "tenantId"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "endpoint": {
              "type": "string",
              "format": "uri"
            },
            "tenantId": {
              "type": "string"
            },
            "runtimeTruthEnabled": {
              "type": "boolean"
            },
            "collections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "rlsEnforced": {
              "type": "boolean"
            },
            "durableWritesEnabled": {
              "type": "boolean"
            },
            "writeProofPath": {
              "type": "string"
            }
          }
        },
        "kernel": {
          "type": "object",
          "required": ["status", "lifecycleEnabled"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "lifecycleEnabled": {
              "type": "boolean"
            },
            "kernelProductConfig": {
              "type": "string"
            },
            "lifecyclePhases": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "gatesActive": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "failClosedOnGateFailure": {
              "type": "boolean"
            }
          }
        },
        "healthChecks": {
          "type": "object",
          "required": ["status", "endpoints", "allPassed"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "expectedStatus", "timeout"],
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "expectedStatus": {
                    "type": "integer"
                  },
                  "timeout": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            },
            "allPassed": {
              "type": "boolean"
            },
            "loadBalancerHealthCheckPath": {
              "type": "string"
            }
          }
        },
        "fhir": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "r4Enabled": {
              "type": "boolean"
            },
            "validationGate": {
              "type": "string"
            },
            "goldenFixtures": {
              "type": "string"
            },
            "supportedResources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "strictValidationMode": {
              "type": "boolean"
            }
          }
        },
        "featureFlags": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "provider": {
              "type": "string"
            },
            "configPath": {
              "type": "string"
            },
            "allRequiredFlagsPresent": {
              "type": "boolean"
            },
            "stagingOverridesApplied": {
              "type": "boolean"
            }
          }
        },
        "googleAdsConnector": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "oauthConfigured": {
              "type": "boolean"
            },
            "tokenRefreshEnabled": {
              "type": "boolean"
            },
            "retryPolicyEnabled": {
              "type": "boolean"
            },
            "dlqConfigured": {
              "type": "boolean"
            },
            "idempotencyKeysEnabled": {
              "type": "boolean"
            },
            "connectorModule": {
              "type": "string"
            },
            "testAccountId": {
              "type": "string"
            },
            "sandboxMode": {
              "type": "boolean"
            }
          }
        },
        "otlp": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "endpoint": {
              "type": "string"
            },
            "tracingEnabled": {
              "type": "boolean"
            },
            "metricsEnabled": {
              "type": "boolean"
            },
            "logsEnabled": {
              "type": "boolean"
            },
            "samplingRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "kernelBridge": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "not-ready"]
            },
            "adapterClass": {
              "type": "string"
            },
            "consentPluginActive": {
              "type": "boolean"
            },
            "approvalPluginActive": {
              "type": "boolean"
            },
            "auditTrailPluginActive": {
              "type": "boolean"
            },
            "riskManagementPluginActive": {
              "type": "boolean"
            },
            "notificationPluginActive": {
              "type": "boolean"
            },
            "featureFlagPluginActive": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "configStatus": {
      "type": "object",
      "required": ["validated", "configSource"],
      "properties": {
        "validated": {
          "type": "boolean"
        },
        "configSource": {
          "type": "string"
        },
        "allRequiredConfigPresent": {
          "type": "boolean"
        },
        "failClosedOnMissingConfig": {
          "type": "boolean"
        },
        "ephemeralAdaptersBlocked": {
          "type": "boolean"
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
