{
  "schemaVersion": "1.0.0",
  "productId": "yappc",
  "generatedAt": "2026-05-24T08:35:00.000Z",
  "commitSha": "7f84bc08e9e4e6d7e209cb49a855f199f7c90347",
  "evidenceFreshnessValidation": {
    "status": "configured",
    "description": "Evidence freshness validation during ingestion to prevent stale data in YAPPC cockpit"
  },
  "freshnessPolicies": {
    "maxAgeSeconds": {
      "bootstrapEvidence": 86400,
      "rollbackEvidence": 86400,
      "releaseReadiness": 3600,
      "runtimeProfile": 3600,
      "platformProviderReadiness": 3600
    },
    "staleThreshold": {
      "warning": 43200,
      "critical": 86400
    }
  },
  "validationRules": {
    "requiredFields": [
      "generatedAt",
      "commitSha",
      "schemaVersion"
    ],
    "timestampValidation": {
      "enabled": true,
      "check": "generatedAt must be within maxAgeSeconds of current time"
    },
    "commitShaValidation": {
      "enabled": true,
      "check": "commitSha must match current deployment commit"
    },
    "schemaVersionValidation": {
      "enabled": true,
      "check": "schemaVersion must be supported by current YAPPC version"
    }
  },
  "ingestionFlow": {
    "steps": [
      "Receive evidence from kernel",
      "Validate required fields present",
      "Validate timestamp freshness",
      "Validate commit SHA matches deployment",
      "Validate schema version compatibility",
      "Reject stale or invalid evidence",
      "Store valid evidence in Data Cloud",
      "Update cockpit with freshness indicators"
    ]
  },
  "freshnessIndicators": {
    "fresh": {
      "status": "fresh",
      "color": "green",
      "maxAge": 3600
    },
    "warning": {
      "status": "stale-warning",
      "color": "yellow",
      "maxAge": 43200
    },
    "critical": {
      "status": "stale-critical",
      "color": "red",
      "maxAge": 86400
    },
    "rejected": {
      "status": "rejected",
      "color": "gray",
      "reason": "evidence exceeds max age or validation failed"
    }
  },
  "integrationPoints": {
    "kernelEvidence": {
      "source": ".kernel/evidence",
      "ingestionEndpoint": "/api/v1/evidence/ingest",
      "validationService": "EvidenceFreshnessValidator"
    },
    "dataCloud": {
      "collection": "yappc-evidence",
      "index": "generatedAt",
      "ttl": 90
    }
  },
  "evidenceRefs": [
    ".kernel/evidence/phr/staging-bootstrap-evidence.json",
    ".kernel/evidence/phr/prod-bootstrap-evidence.json",
    ".kernel/evidence/digital-marketing/staging-bootstrap-evidence.json",
    ".kernel/evidence/digital-marketing/prod-bootstrap-evidence.json",
    ".kernel/evidence/data-cloud/staging-release-readiness.json",
    ".kernel/evidence/data-cloud/prod-release-readiness.json"
  ]
}
