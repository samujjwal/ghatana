{
  "name": "@ghatana/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ghatana Platform Monorepo",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter './platform/typescript/**' --filter './products/*/ui' build",
    "build:platform": "pnpm -r --filter './platform/typescript/**' build",
    "dev": "pnpm -r --parallel --filter './products/*/ui' dev",
    "test": "pnpm -r test",
    "test:ui": "pnpm -r --filter './platform/typescript/**' --filter './products/*/ui' test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r --parallel exec rm -rf node_modules dist build .turbo",
    "typecheck": "pnpm -r --parallel --filter './platform/typescript/**' --filter './products/*/ui' exec tsc --noEmit",
    "typecheck:workspace": "node ./scripts/run-typescript-workspace-typecheck.js",
    "check:deprecated-ui": "./scripts/check-deprecated-ui.sh",
    "check:duplicate-packages": "./scripts/check-duplicate-package-names.sh",
    "check:platform-package-governance": "node ./scripts/check-platform-package-governance.js",
    "check:truth-surfaces": "node ./scripts/check-truth-surfaces.mjs",
    "check:data-cloud-ui-contracts": "pnpm --dir ./products/data-cloud/delivery/ui exec vitest run src/__tests__/pages/ContractBacked.test.tsx src/__tests__/api/capabilities.service.test.ts",
    "check:data-cloud-sdk-drift": "./gradlew :products:data-cloud:delivery:sdk:check --no-build-cache --rerun-tasks",
    "check:data-cloud-runbook-smoke": "./gradlew :products:data-cloud:integration-tests:runbookSmoke --no-build-cache --rerun-tasks",
    "check:tsconfig-strict": "node ./scripts/check-typescript-strict.js",
    "check:production-readiness": "node ./scripts/check-production-readiness.mjs",
    "check:audit-todo-burndown": "node ./scripts/generate-audit-todo-burndown.mjs",
    "check:jwt-policy": "./scripts/check-jwt-dependency-policy.sh",
    "check:license-policy": "./scripts/check-license-policy.sh",
    "check:cross-workspace-deps": "node ./scripts/check-cross-workspace-deps.mjs",
    "check:capability-schema-drift": "node ./scripts/check-capability-schema-drift.mjs",
    "check:data-cloud-feature-gates": "node ./scripts/generate-data-cloud-feature-gates.mjs --check",
    "generate:data-cloud-feature-gates": "node ./scripts/generate-data-cloud-feature-gates.mjs",
    "check:data-cloud-architecture-scorecard": "node ./scripts/generate-data-cloud-architecture-scorecard.mjs --check",
    "generate:data-cloud-architecture-scorecard": "node ./scripts/generate-data-cloud-architecture-scorecard.mjs",
    "check:openapi-canonical": "node ./scripts/check-openapi-contract-canonical.mjs",
    "check:production-stubs": "node ./scripts/check-production-stubs.mjs --report --allowlist=config/production-stub-allowlist.json",
    "check:doc-truth": "node ./scripts/check-doc-truth.mjs",
    "check:doc-claims-evidence": "node ./scripts/check-doc-claims-evidence.mjs",
    "check:circular-deps": "node ./scripts/check-circular-deps.mjs",
    "check:product-ui-contracts": "node ./scripts/check-product-ui-contracts.mjs",
    "check:product-doc-taxonomy": "node ./scripts/check-product-doc-taxonomy.mjs",
    "check:product-manifest-contracts": "node ./scripts/check-product-manifest-contracts.mjs",
    "check:product-ci-matrices": "node ./scripts/check-product-ci-matrices.mjs",
    "check:product-workspace-registration": "node ./scripts/check-product-workspace-registration.mjs",
    "check:product-scaffolder": "node ./scripts/check-product-scaffolder.mjs",
    "check:product-kernel-audit-progress": "node ./scripts/generate-product-kernel-audit-progress.mjs --check",
    "generate:product-kernel-audit-progress": "node ./scripts/generate-product-kernel-audit-progress.mjs",
    "check:security-workflow-coverage": "node ./scripts/check-security-workflow-coverage.mjs",
    "check:digital-marketing-root-docs": "node ./scripts/check-digital-marketing-root-docs.mjs",
    "check:bridge-compliance": "node ./scripts/check-bridge-compliance.mjs",
    "check:data-access-contract": "node ./scripts/check-data-access-contract.mjs",
    "check:observability-conformance": "node ./scripts/check-observability-conformance.mjs",
    "check:finance-transaction-workflow-proof": "node ./scripts/check-finance-transaction-workflow-proof.mjs",
    "check:dmos-boundary-workflow-coverage": "node ./scripts/check-dmos-boundary-workflow-coverage.mjs",
    "check:inmemory-policy-store-usage": "node ./scripts/check-inmemory-policy-store-usage.mjs",
    "check:secret-default-credentials": "node ./scripts/check-secret-default-credentials.mjs",
    "check:route-entitlement-contracts": "node ./scripts/check-route-entitlement-contracts.mjs",
    "check:flashit-client-conformance": "node ./scripts/check-flashit-client-conformance.mjs",
    "check:local-dev-port-allocations": "node ./scripts/check-local-dev-port-allocations.mjs",
    "check:runtime-template-conformance": "node ./scripts/check-runtime-template-conformance.mjs",
    "check:flashit-doc-content": "node ./scripts/check-flashit-doc-content.mjs",
    "check:audited-ui-workflows": "node ./scripts/check-audited-ui-workflows.mjs",
    "check:audited-e2e-workflow": "node ./scripts/check-audited-e2e-workflow.mjs",
    "check:audited-performance-workflows": "node ./scripts/check-audited-performance-workflows.mjs",
    "check:design-system-conformance": "node ./scripts/check-design-system-conformance.mjs",
    "check:shared-product-shells": "node ./scripts/check-shared-product-shells.mjs",
    "check:shared-layout-primitives": "node ./scripts/check-shared-layout-primitives.mjs",
    "check:shared-ui-state-coverage": "node ./scripts/check-shared-ui-state-coverage.mjs",
    "check:workspace-source-aliases": "node ./scripts/check-workspace-source-aliases.mjs",
    "check:router-strategy": "node ./scripts/check-router-strategy.mjs",
    "check:product-package-metadata": "node ./scripts/check-product-package-metadata.mjs",
    "check:flashit-package-manager": "node ./scripts/check-flashit-package-manager.mjs",
    "check:kernel-product-boundary-audit": "pnpm check:bridge-compliance && pnpm check:data-access-contract && pnpm check:production-stubs && pnpm check:product-manifest-contracts && pnpm check:observability-conformance && pnpm check:production-readiness",
    "scaffold:product": "node ./scripts/scaffold-product.mjs",
    "test:eslint-rules": "node ./eslint-rules/ghatana-architecture-rules.test.js",
    "prepare": "husky",
    "build:phr-gateway": "pnpm --dir products/phr build",
    "dev:phr-gateway": "pnpm --dir products/phr dev",
    "test:phr-gateway": "pnpm --dir products/phr test",
    "build:phr-web": "pnpm --dir products/phr/apps/web build",
    "dev:phr-web": "pnpm --dir products/phr/apps/web dev",
    "test:phr-web": "pnpm --dir products/phr/apps/web test",
    "build:phr": "pnpm --filter './products/phr/**' build",
    "build:finance-gateway": "pnpm --dir products/finance build",
    "dev:finance-gateway": "pnpm --dir products/finance dev",
    "test:finance-gateway": "pnpm --dir products/finance test",
    "build:digital-marketing-gateway": "pnpm --dir products/digital-marketing/dm-api build",
    "dev:digital-marketing-gateway": "pnpm --dir products/digital-marketing/dm-api dev",
    "test:digital-marketing-gateway": "pnpm --dir products/digital-marketing/dm-api test",
    "build:digital-marketing-web": "pnpm --dir products/digital-marketing/ui build",
    "dev:digital-marketing-web": "pnpm --dir products/digital-marketing/ui dev",
    "test:digital-marketing-web": "pnpm --dir products/digital-marketing/ui test",
    "build:digital-marketing": "pnpm --filter './products/digital/marketing/**' build",
    "build:flashit-gateway": "pnpm --dir products/flashit/backend/gateway build",
    "dev:flashit-gateway": "pnpm --dir products/flashit/backend/gateway dev",
    "test:flashit-gateway": "pnpm --dir products/flashit/backend/gateway test",
    "build:flashit-web": "pnpm --dir products/flashit/client/web build",
    "dev:flashit-web": "pnpm --dir products/flashit/client/web dev",
    "test:flashit-web": "pnpm --dir products/flashit/client/web test",
    "build:flashit-mobile": "pnpm --dir products/flashit/client/mobile build",
    "dev:flashit-mobile": "pnpm --dir products/flashit/client/mobile dev",
    "test:flashit-mobile": "pnpm --dir products/flashit/client/mobile test",
    "build:flashit": "pnpm --filter './products/flashit/**' build",
    "build:data-cloud-gateway": "pnpm --dir products/data-cloud/delivery/api build",
    "dev:data-cloud-gateway": "pnpm --dir products/data-cloud/delivery/api dev",
    "test:data-cloud-gateway": "pnpm --dir products/data-cloud/delivery/api test",
    "build:data-cloud-web": "pnpm --dir products/data-cloud/delivery/ui build",
    "dev:data-cloud-web": "pnpm --dir products/data-cloud/delivery/ui dev",
    "test:data-cloud-web": "pnpm --dir products/data-cloud/delivery/ui test",
    "build:data-cloud": "pnpm --filter './products/data/cloud/**' build",
    "build:yappc-gateway": "pnpm --dir products/yappc/core/yappc-api build",
    "dev:yappc-gateway": "pnpm --dir products/yappc/core/yappc-api dev",
    "test:yappc-gateway": "pnpm --dir products/yappc/core/yappc-api test",
    "build:yappc-web": "pnpm --dir products/yappc/frontend build",
    "dev:yappc-web": "pnpm --dir products/yappc/frontend dev",
    "test:yappc-web": "pnpm --dir products/yappc/frontend test",
    "build:yappc": "pnpm --filter './products/yappc/**' build",
    "build:audio-video-gateway": "pnpm --dir products/audio-video build",
    "dev:audio-video-gateway": "pnpm --dir products/audio-video dev",
    "test:audio-video-gateway": "pnpm --dir products/audio-video test",
    "build:audio-video": "pnpm --filter './products/audio/video/**' build",
    "build:dcmaar-gateway": "pnpm --dir products/dcmaar build",
    "dev:dcmaar-gateway": "pnpm --dir products/dcmaar dev",
    "test:dcmaar-gateway": "pnpm --dir products/dcmaar test",
    "build:dcmaar-web": "pnpm --dir products/dcmaar/apps build",
    "dev:dcmaar-web": "pnpm --dir products/dcmaar/apps dev",
    "test:dcmaar-web": "pnpm --dir products/dcmaar/apps test",
    "build:dcmaar": "pnpm --filter './products/dcmaar/**' build",
    "build:tutorputor-gateway": "pnpm --dir products/tutorputor build",
    "dev:tutorputor-gateway": "pnpm --dir products/tutorputor dev",
    "test:tutorputor-gateway": "pnpm --dir products/tutorputor test",
    "build:tutorputor-web": "pnpm --dir products/tutorputor/apps build",
    "dev:tutorputor-web": "pnpm --dir products/tutorputor/apps dev",
    "test:tutorputor-web": "pnpm --dir products/tutorputor/apps test",
    "build:tutorputor": "pnpm --filter './products/tutorputor/**' build",
    "build:aura-gateway": "pnpm --dir products/aura/platform/api build",
    "dev:aura-gateway": "pnpm --dir products/aura/platform/api dev",
    "test:aura-gateway": "pnpm --dir products/aura/platform/api test",
    "build:software-org-gateway": "pnpm --dir products/software-org build",
    "dev:software-org-gateway": "pnpm --dir products/software-org dev",
    "test:software-org-gateway": "pnpm --dir products/software-org test",
    "build:virtual-org-gateway": "pnpm --dir products/virtual-org build",
    "dev:virtual-org-gateway": "pnpm --dir products/virtual-org dev",
    "test:virtual-org-gateway": "pnpm --dir products/virtual-org test",
    "build:security-gateway-gateway": "pnpm --dir products/security-gateway build",
    "dev:security-gateway-gateway": "pnpm --dir products/security-gateway dev",
    "test:security-gateway-gateway": "pnpm --dir products/security-gateway test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "@tanstack/react-query": "^5.90.20",
      "jotai": "^2.17.0",
      "zod": "^4.3.6",
      "typescript": "^6.0.2",
      "vite": "^8.0.3",
      "vitest": "^4.1.4",
      "tailwindcss": "^4.1.18",
      "eslint": "^9.39.2",
      "prettier": "^3.8.2",
      "date-fns": "^4.1.0",
      "axios": "^1.13.1",
      "bullmq>uuid": "11.1.0",
      "uuid": "npm:nanoid@5"
    },
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "detox",
      "esbuild",
      "fastify-socket.io",
      "msw",
      "prisma"
    ]
  }
}
