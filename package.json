{
  "name": "@ghatana/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Ghatana Platform Monorepo",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter './platform/typescript/**' --filter './products/*/ui' build",
    "build:platform": "pnpm -r --filter './platform/typescript/**' build",
    "build:data-cloud-ui": "pnpm --filter '@data-cloud/ui' build",
    "build:yappc": "pnpm --filter './products/yappc/**' build",
    "dev": "pnpm -r --parallel --filter './products/*/ui' dev",
    "dev:data-cloud": "pnpm --filter '@data-cloud/ui' dev",
    "test": "pnpm -r test",
    "test:ui": "pnpm -r --filter './platform/typescript/**' --filter './products/*/ui' test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r --parallel exec rm -rf node_modules dist build .turbo",
    "typecheck": "pnpm -r --parallel --filter './platform/typescript/**' --filter './products/*/ui' exec tsc --noEmit",
    "typecheck:workspace": "node ./scripts/run-typescript-workspace-typecheck.js",
    "check:deprecated-ui": "./scripts/check-deprecated-ui.sh",
    "check:duplicate-packages": "./scripts/check-duplicate-package-names.sh",
    "check:platform-package-governance": "node ./scripts/check-platform-package-governance.js",
    "check:truth-surfaces": "node ./scripts/check-truth-surfaces.mjs",
    "check:data-cloud-ui-contracts": "pnpm --dir ./products/data-cloud/ui exec vitest run src/__tests__/pages/ContractBacked.test.tsx src/__tests__/api/capabilities.service.test.ts",
    "check:tsconfig-strict": "node ./scripts/check-typescript-strict.js",
    "check:production-readiness": "node ./scripts/check-production-readiness.mjs",
    "check:audit-todo-burndown": "node ./scripts/generate-audit-todo-burndown.mjs",
    "check:jwt-policy": "./scripts/check-jwt-dependency-policy.sh",
    "check:license-policy": "./scripts/check-license-policy.sh",
    "check:cross-workspace-deps": "node ./scripts/check-cross-workspace-deps.mjs",
    "check:capability-schema-drift": "node ./scripts/check-capability-schema-drift.mjs",
    "check:data-cloud-feature-gates": "node ./scripts/generate-data-cloud-feature-gates.mjs --check",
    "generate:data-cloud-feature-gates": "node ./scripts/generate-data-cloud-feature-gates.mjs",
    "check:openapi-canonical": "node ./scripts/check-openapi-contract-canonical.mjs",
    "check:production-stubs": "node ./scripts/check-production-stubs.mjs --report --allowlist=config/production-stub-allowlist.json",
    "check:doc-truth": "node ./scripts/check-doc-truth.mjs",
    "check:circular-deps": "node ./scripts/check-circular-deps.mjs",
    "test:eslint-rules": "node ./eslint-rules/ghatana-architecture-rules.test.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "@tanstack/react-query": "^5.90.20",
      "jotai": "^2.17.0",
      "zod": "^4.3.6",
      "typescript": "^6.0.2",
      "vite": "^8.0.3",
      "vitest": "^4.1.4",
      "tailwindcss": "^4.1.18",
      "eslint": "^9.39.2",
      "prettier": "^3.8.2",
      "date-fns": "^4.1.0",
      "axios": "^1.13.1",
      "bullmq>uuid": "11.1.0",
      "uuid": "npm:nanoid@5"
    },
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "detox",
      "esbuild",
      "fastify-socket.io",
      "msw",
      "prisma"
    ]
  }
}
